          "summary": "\u062e\u0628\u0631\u06af\u0632\u0627\u0631\u06cc \u0628\u0644\u0648\u0645\u0628\u0631\u06af \u0627\u0632 \u0639\u0628\u0648\u0631 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u06a9\u0627\u0646\u062a\u06cc\u0646\u0631\u06cc \u0641\u0631\u0627\u0646\u0633\u0648\u06cc \u0627\u0632 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u062e\u0628\u0631 \u062f\u0627\u062f. \u0627\u06cc\u0646 \u0627\u0648\u0644\u06cc\u0646 \u06a9\u0634\u062a\u06cc \u063a\u0631\u0628\u06cc \u0627\u0633\u062a \u06a9\u0647 \u0627\u0632 \u0632\u0645\u0627\u0646 \u0627\u062e\u0644\u0627\u0644 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0627\u0632 \u0627\u06cc\u0646 \u0622\u0628\u0631\u0627\u0647 \u062d\u06cc\u0627\u062a\u06cc \u0639\u0628\u0648\u0631 \u0645\u06cc\u200c\u06a9\u0646\u062f. \u0647\u0645\u0632\u0645\u0627\u0646 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u06cc\u0634 \u0627\u0632 \u06f8\u06f1\u06f6 \u0633\u0627\u0639\u062a \u0627\u0633\u062a \u06a9\u0647 \u06a9\u0627\u0631\u0628\u0631\u0627\u0646\u2026",
