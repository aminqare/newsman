        {
          "title": "\u0646\u0638\u0627\u0645\u06cc \u06a9\u0647 \u062d\u0627\u06a9\u0645\u0627\u0646 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0631\u0627\u06cc \u0645\u0627\u0646\u062f\u06af\u0627\u0631\u06cc \u062f\u0631 \u0642\u062f\u0631\u062a \u0628\u0646\u0627 \u06a9\u0631\u062f\u0646\u062f",
