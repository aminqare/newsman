          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u062a\u063a\u06cc\u06cc\u0631 \u0631\u0698\u06cc\u0645 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0639\u0645\u0644\u0627 \u0627\u062a\u0641\u0627\u0642 \u0627\u0641\u062a\u0627\u062f\u0647 \u0627\u0633\u062a\u061b \u0647\u06cc\u0686\u200c\u06a9\u0633 \u062f\u0644\u0634 \u0646\u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u062f \u0631\u0647\u0628\u0631 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0634\u0648\u062f",
