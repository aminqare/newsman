        {
          "title": "\u00ab\u0628\u0627 \u0647\u0631 \u0627\u0646\u0641\u062c\u0627\u0631\u060c \u0645\u0631\u06cc\u0636 \u0645\u06cc\u200c\u0634\u0648\u0645\u00bb\u061b \u062f\u0648\u0645\u06cc\u0646 \u0645\u0627\u0647 \u062c\u0646\u06af \u0648 \u0642\u0644\u0628\u200c\u0647\u0627\u06cc\u06cc \u06a9\u0647 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u0628\u06cc\u0645 \u0648 \u0627\u0645\u06cc\u062f \u0645\u06cc\u200c\u062a\u067e\u0646\u062f",
