        {
          "title": "\u0622\u062a\u0634\u200c\u0628\u0633 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u06cc\u0631\u0627\u0646\u061b \u0622\u06cc\u0627 \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648 \u0628\u0647 \u0627\u0647\u062f\u0627\u0641\u0634 \u0631\u0633\u06cc\u062f\u061f",
