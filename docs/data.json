          "title": "\u0645\u062c\u062a\u0628\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc \u062f\u0631 \u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u063a\u0631\u0628\u06cc\u061b \u00ab\u0628\u0627\u0632\u06af\u0634\u062a \u0628\u0647 \u0646\u0638\u0627\u0645 \u0633\u0644\u0637\u0646\u062a\u06cc \u0628\u062f\u0648\u0646 \u062a\u063a\u06cc\u06cc\u0631 \u0631\u0698\u06cc\u0645\u00bb",
