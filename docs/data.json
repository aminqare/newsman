          "title": "\u062f\u0631 \u0645\u0648\u0631\u062f \u0645\u062d\u062a\u0648\u0627\u06cc \u062a\u0648\u0627\u0641\u0642 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0686\u0647 \u0645\u06cc\u200c\u062f\u0627\u0646\u06cc\u0645\u061f",
