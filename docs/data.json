        {
          "title": "\u062a\u0631\u0627\u0645\u067e \u0627\u0632 \u0634\u0645\u0627\u0631\u06cc \u0627\u0632 \u06a9\u0634\u0648\u0631\u0647\u0627 \u062e\u0648\u0627\u0633\u062a \u0628\u0631\u0627\u06cc \u06a9\u0645\u06a9 \u0628\u0647 \u062a\u0627\u0645\u06cc\u0646 \u0627\u0645\u0646\u06cc\u062a \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u06a9\u0634\u062a\u06cc \u0627\u0639\u0632\u0627\u0645 \u06a9\u0646\u0646\u062f",
          "link": "https://www.bbc.co.uk/persian/live/cly2kk66pp2t?at_medium=RSS&at_campaign=rss",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u06af\u0641\u062a\u0647 \u0627\u0633\u062a \u06a9\u0647 \u00ab\u0628\u0647 \u0647\u0631 \u0637\u0631\u06cc\u0642\u06cc \u06a9\u0647 \u0634\u062f\u0647\u060c \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0628\u0627\u0632\u060c\u200c \u0627\u0645\u0646 \u0648 \u0622\u0632\u0627\u062f \u062e\u0648\u0627\u0647\u06cc\u0645 \u06a9\u0631\u062f.\u00bb \u0622\u0642\u0627\u06cc \u062a\u0631\u0627\u0645\u067e \u062f\u0631 \u067e\u0633\u062a\u06cc \u062f\u0631 \u0634\u0628\u06a9\u0647 \u0627\u062c\u062a\u0645\u0627\u0639\u06cc \u062a\u0631\u0648\u062b \u0633\u0648\u0634\u0627\u0644 \u06af\u0641\u062a \u06a9\u0647 \u0627\u0645\u06cc\u062f\u0648\u0627\u0631 \u0627\u0633\u062a \u0686\u06cc\u0646\u060c \u0641\u0631\u0627\u0646\u0633\u0647\u060c \u0698\u0627\u067e\u0646\u060c \u06a9\u0631\u0647 \u062c\u0646\u0648\u0628\u06cc \u0648 \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u06a9\u0634\u062a\u06cc\u200c\u0647\u2026",
