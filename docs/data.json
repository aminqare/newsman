          "title": "\u0647\u0645\u0632\u0645\u0627\u0646 \u0628\u0627 \u0648\u0631\u0648\u062f \u0645\u06cc\u0627\u0646\u062c\u06cc\u200c\u0647\u0627\u06cc \u067e\u0627\u06a9\u0633\u062a\u0627\u0646\u06cc \u0628\u0647 \u062a\u0647\u0631\u0627\u0646\u060c \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631\u0628\u0627\u0631\u0647 \u062f\u0648\u0631 \u0628\u0639\u062f\u06cc \u06af\u0641\u062a\u200c\u0648\u06af\u0648\u0647\u0627\u06cc \u0635\u0644\u062d \u0631\u0627\u06cc\u0632\u0646\u06cc \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f",
