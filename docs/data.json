          "title": "\u062a\u0631\u0627\u0645\u067e: \u062e\u0644\u0628\u0627\u0646 \u062f\u0648\u0645 \u0627\u0641 \u06f1\u06f5 \u0633\u0631\u0646\u06af\u0648\u0646\u200c\u0634\u062f\u0647 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u0646\u062c\u0627\u062a \u062f\u0627\u062f\u06cc\u0645",
