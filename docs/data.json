          "title": "\u062f\u0631\u06af\u06cc\u0631\u06cc\u200c\u0647\u0627\u06cc \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0648 \u0627\u0641\u063a\u0627\u0646\u0633\u062a\u0627\u0646\u061b \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f: \u0622\u0645\u0627\u062f\u0647 \u0633\u0631\u06a9\u0648\u0628 \u0637\u0627\u0644\u0628\u0627\u0646 \u0647\u0633\u062a\u06cc\u0645",
          "link": "https://www.bbc.com/persian/articles/cvgjd9011jxo?at_medium=RSS&at_campaign=rss",
          "summary": "\u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u062a\u0623\u06cc\u06cc\u062f \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a \u06a9\u0647 \u0645\u0646\u0627\u0637\u0642\u06cc \u062f\u0631 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u0645\u0648\u0631\u062f \u062d\u0645\u0644\u0647 \u067e\u0647\u067e\u0627\u062f\u06cc \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0646\u062f\u060c \u0627\u0645\u0627 \u06af\u0631\u0648\u0647 \u062a\u062d\u0631\u06cc\u06a9 \u0637\u0627\u0644\u0628\u0627\u0646 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 (\u062a\u06cc\u200c\u062a\u06cc\u200c\u067e\u06cc) \u0631\u0627 \u0645\u0633\u0626\u0648\u0644 \u0627\u06cc\u0646 \u062d\u0645\u0644\u0627\u062a \u062f\u0627\u0646\u0633\u062a\u0647 \u0627\u0633\u062a. \u0639\u0637\u0627\u0621\u0627\u0644\u0644\u0647 \u0637\u0631\u0627\u0631\u060c \u0648\u0632\u06cc\u0631 \u0627\u0637\u0644\u0627\u0639\u0627\u062a \u0631\u0633\u0627\u0646\u06cc \u067e\u0627\u06a9\u0633\u062a\u0627\u0646\u060c \u062f\u0631\u067e\u06cc\u0627\u0645\u06cc \u062f\u0631 \u0634\u0628\u06a9\u0647 \u0627\u06cc\u06a9\u0633 \u0646\u0648\u0634\u062a\u0647 \u0627\u0633\u2026",
