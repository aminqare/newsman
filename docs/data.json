          "title": "\u0642\u0627\u0644\u06cc\u0628\u0627\u0641: \u0628\u0627\u0632\u06af\u0634\u0627\u06cc\u06cc \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0628\u0627 \u0646\u0642\u0636 \u0641\u0627\u062d\u0634 \u0622\u062a\u0634\u200c\u0628\u0633 \u0645\u0645\u06a9\u0646 \u0646\u06cc\u0633\u062a",
