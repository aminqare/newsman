        {
          "title": "\u067e\u06cc\u0627\u0645 \u06a9\u062a\u0628\u06cc \u0645\u0646\u062a\u0633\u0628 \u0628\u0647 \u0645\u062c\u062a\u0628\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc \u0628\u0647 \u062c\u0627\u06cc \u0633\u062e\u0646\u0631\u0627\u0646\u06cc \u0647\u0631 \u0633\u0627\u0644\u0647 \u067e\u062f\u0631\u0634 \u062f\u0631 \u0633\u0627\u0644\u0645\u0631\u06af \u062e\u0645\u06cc\u0646\u06cc",
