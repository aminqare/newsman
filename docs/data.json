          "title": "\u0647\u06cc\u0626\u062a \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0628\u0647 \u0627\u0633\u0644\u0627\u0645 \u0622\u0628\u0627\u062f \u0631\u0633\u06cc\u062f",
