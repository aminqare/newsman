          "title": "\u0648\u0632\u06cc\u0631 \u062f\u0641\u0627\u0639 \u0622\u0645\u0631\u06cc\u06a9\u0627: \u067e\u06cc\u0631\u0648\u0632\u06cc \u0642\u0627\u0637\u0639 \u0646\u0632\u062f\u06cc\u06a9 \u0627\u0633\u062a\u061b \u0627\u06cc\u0631\u0627\u0646: \u0627\u0632 \u0627\u0645\u0631\u0648\u0632 \u0642\u0627\u0639\u062f\u0647 \u00ab\u0686\u0634\u0645 \u062f\u0631 \u0645\u0642\u0627\u0628\u0644 \u0686\u0634\u0645\u00bb \u0631\u0627 \u0627\u062c\u0631\u0627 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u0645",
