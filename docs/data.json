          "title": "\u0647\u0645\u0632\u0645\u0627\u0646 \u0628\u0627 \u0627\u062f\u0627\u0645\u0647 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f\u060c \u0627\u06cc\u0631\u0627\u0646 \u0639\u0628\u0648\u0631 \u062f\u0648 \u06a9\u0634\u062a\u06cc \u062c\u0646\u06af\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0627\u0632 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0628\u0631\u0627\u06cc \u067e\u0627\u06a9\u0633\u0627\u0632\u06cc \u0645\u06cc\u0646\u200c\u0647\u0627 \u0631\u0627 \u0631\u062f \u06a9\u0631\u062f",
