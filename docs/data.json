        {
          "title": "\ud83d\udd34\u0647\u0634\u062f\u0627\u0631 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0627\u0639\u0636\u0627\u06cc \u062e\u0628\u0631\u06af\u0627\u0646\u061b \u062a\u0631\u0627\u0645\u067e: \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u06a9\u0633\u06cc \u062f\u0631 \u06a9\u0627\u062f\u0631 \u0631\u0647\u0628\u0631\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0646\u0645\u0627\u0646\u062f \u06a9\u0647 \u0628\u06af\u0648\u06cc\u062f \u0645\u0627 \u062a\u0633\u0644\u06cc\u0645 \u0634\u062f\u06cc\u0645",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0627\u06cc\u0646 \u0627\u062d\u062a\u0645\u0627\u0644 \u0631\u0627 \u0645\u0637\u0631\u062d \u06a9\u0631\u062f \u06a9\u0647 \u062c\u0646\u06af \u0628\u0627 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0632\u0645\u0627\u0646\u06cc \u067e\u0627\u06cc\u0627\u0646 \u06cc\u0627\u0628\u062f \u06a9\u0647 \u062a\u0647\u0631\u0627\u0646 \u062f\u06cc\u06af\u0631 \u0627\u0631\u062a\u0634 \u06a9\u0627\u0631\u0622\u0645\u062f \u06cc\u0627 \u0631\u0647\u0628\u0631\u06cc \u062f\u0631 \u0642\u062f\u0631\u062a \u0646\u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u062f. \u0647\u0645\u0632\u0645\u0627\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0627\u0639\u0636\u0627\u06cc \u062e\u0628\u0631\u06af\u0627\u0646 \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f \u06a9\u0647 \u062f\u0631 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u062f\u0627\u062f\u0646\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
