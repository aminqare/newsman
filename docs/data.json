        {
          "title": "\u0627\u0631\u062a\u0634 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0627\u0632 \u0622\u063a\u0627\u0632 \u00ab\u0639\u0645\u0644\u06cc\u0627\u062a \u0645\u062a\u0646\u0627\u0633\u0628\u00bb \u062f\u0631 \u0648\u0627\u06a9\u0646\u0634 \u0628\u0647 \u0633\u0642\u0648\u0637 \u0628\u0627\u0644\u06af\u0631\u062f \u0622\u067e\u0627\u0686\u06cc \u062e\u0628\u0631 \u062f\u0627\u062f",
