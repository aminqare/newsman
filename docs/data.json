        {
          "title": "\u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0639\u0644\u06cc\u0647 \u0627\u06cc\u0631\u0627\u0646\u061b \u0686\u0647 \u06a9\u0633\u06cc \u0628\u06cc\u0634\u062a\u0631 \u0636\u0631\u0631 \u0645\u06cc\u200c\u06a9\u0646\u062f\u061f",
          "link": "https://www.bbc.com/persian/articles/c36r2nz9gwro?at_medium=RSS&at_campaign=rss",
          "summary": "\u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0686\u0646\u062f \u06af\u0632\u06cc\u0646\u0647 \u0628\u0631\u0627\u06cc \u0648\u0627\u06a9\u0646\u0634 \u0628\u0647 \u0645\u0633\u062f\u0648\u062f \u0634\u062f\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0627\u0632 \u0633\u0648\u06cc \u0627\u06cc\u0631\u0627\u0646 \u062f\u0627\u0634\u062a. \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u067e\u0627\u0633\u062e\u06cc \u0645\u062a\u0642\u0627\u0628\u0644 \u0631\u0627 \u0628\u0631\u06af\u0632\u06cc\u062f \u0648 \u062f\u0633\u062a\u0648\u0631 \u062f\u0627\u062f \u0628\u0646\u0627\u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0645\u0633\u062f\u0648\u062f \u0634\u0648\u0646\u062f. \u0646\u062a\u06cc\u062c\u0647 \u0627\u06cc\u0646 \u0627\u0642\u062f\u0627\u0645 \u0686\u0647 \u062e\u0648\u0627\u0647\u062f \u0628\u0648\u062f\u061f",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0631\u0648\u0633\u0644\u0627\u0646 \u0633\u0644\u06cc\u0645\u0627\u0646\u0648\u0641\u060c \u0634\u0631\u0642\u200c\u0634\u0646\u0627\u0633 \u0631\u0648\u0633: \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631 \u062d\u0627\u0644 \u062f\u06af\u0631\u06af\u0648\u0646 \u06a9\u0631\u062f\u0646 \u0646\u0638\u0627\u0645 \u0648 \u0645\u0639\u0645\u0627\u0631\u06cc \u0627\u0645\u0646\u06cc\u062a\u06cc \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0627\u0633\u062a",
          "link": "https://www.bbc.com/persian/articles/c5y75ykexleo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0622\u062a\u0634\u200c\u0628\u0633 \u0645\u06cc\u0627\u0646 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0648 \u0627\u06cc\u0631\u0627\u0646 \u0634\u06a9\u0646\u0646\u062f\u0647 \u0627\u0633\u062a. \u0645\u0642\u0627\u0645\u200c\u0647\u0627\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0647\u0645\u0686\u0646\u0627\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0645\u0633\u062f\u0648\u062f \u0646\u06af\u0647 \u062f\u0627\u0634\u062a\u0647\u200c\u0627\u0646\u062f. \u0627\u0632\u0633\u0631\u06af\u06cc\u0631\u06cc \u0631\u0641\u062a\u200c\u0648\u200c\u0622\u0645\u062f \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627 \u06cc\u06a9\u06cc \u0627\u0632 \u0634\u0631\u0637\u200c\u0647\u0627\u06cc \u062a\u0648\u0642\u0641 \u062f\u0631\u06af\u06cc\u0631\u06cc \u0628\u0648\u062f\u060c \u0627\u0645\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u062f\u0644\u06cc\u0644 \u0627\u062f\u0627\u0645\u0647 \u062d\u0645\u0644\u0627\u062a \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0644\u0628\u0646\u0627\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0644\u0628\u0646\u0627\u0646 \u062f\u0631 \u062c\u0633\u062a\u200c\u0648\u062c\u0648\u06cc \u0635\u0644\u062d\u061b \u0622\u06cc\u0627 \u062d\u0632\u0628\u200c\u0627\u0644\u0644\u0647 \u0645\u062a\u0642\u0627\u0639\u062f \u0645\u06cc\u200c\u0634\u0648\u062f\u061f",
