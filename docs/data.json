        {
          "title": "\u062a\u06cc\u0631\u0627\u0646\u062f\u0627\u0632\u06cc \u0645\u0631\u06af\u0628\u0627\u0631 \u062f\u0631 \u062a\u06af\u0632\u0627\u0633\u061b \u0645\u0638\u0646\u0648\u0646 \u0632\u06cc\u0631 \u0647\u0648\u062f\u06cc \u062e\u0648\u062f \u067e\u06cc\u0631\u0627\u0647\u0646\u06cc \u0628\u0627 \u0637\u0631\u062d \u067e\u0631\u0686\u0645 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0647 \u062a\u0646 \u062f\u0627\u0634\u062a",
