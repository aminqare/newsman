        {
          "title": "\u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u067e\u0631\u0648\u061b \u0627\u062d\u0633\u0627\u0633\u0627\u062a \u0645\u062a\u0646\u0627\u0642\u0636 \u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0648 \u062c\u0627 \u062e\u0627\u0644\u06cc \u062f\u0627\u062f\u0646 \u0645\u0633\u0626\u0648\u0644\u0627\u0646",
