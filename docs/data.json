        {
          "title": "\u0686\u0631\u0627 \u0645\u0637\u0627\u0644\u0628\u0647 \u0639\u062f\u0627\u0644\u062a \u0648 \u00ab\u0628\u0627\u0632\u06af\u0634\u062a\u00bb \u0686\u0647\u0631\u0647\u200c\u0647\u0627\u06cc \u0646\u0638\u0627\u0645 \u0628\u0634\u0627\u0631 \u0627\u0633\u062f \u062a\u0646\u0634\u200c\u0647\u0627 \u0631\u0627 \u062f\u0631 \u0633\u0648\u0631\u06cc\u0647 \u0627\u0641\u0632\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0627\u0633\u062a\u061f",
