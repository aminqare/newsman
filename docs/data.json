          "title": "\u0639\u0631\u0627\u0642\u0686\u06cc: \u062a\u0648\u0627\u0641\u0642 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0628\u0627 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0647\u06cc\u0686\u06af\u0627\u0647 \u062a\u0627 \u0627\u06cc\u0646 \u062d\u062f \u0628\u0647 \u0646\u0647\u0627\u06cc\u06cc \u0634\u062f\u0646 \u0646\u0632\u062f\u06cc\u06a9 \u0646\u0628\u0648\u062f\u0647 \u0627\u0633\u062a",
