          "summary": "\u0639\u0645\u0627\u0646 \u0628\u0631\u062e\u0644\u0627\u0641 \u062f\u06cc\u06af\u0631 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u0634\u0648\u0631\u0627\u06cc \u0647\u0645\u06a9\u0627\u0631\u06cc \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633\u060c \u0628\u0627 \u062d\u0641\u0638 \u0633\u06cc\u0627\u0633\u062a \u00ab\u0628\u06cc\u200c\u0637\u0631\u0641\u06cc \u0641\u0639\u0627\u0644\u00bb \u0627\u0632 \u062a\u0634\u062f\u06cc\u062f \u062a\u0646\u0634 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u067e\u0631\u0647\u06cc\u0632 \u06a9\u0631\u062f \u0648 \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0631\u0627 \u00ab\u063a\u06cc\u0631\u0642\u0627\u0646\u0648\u0646\u06cc\u00bb \u062f\u0627\u0646\u0633\u062a. \u0645\u0633\u0642\u0637 \u06a9\u0647 \u0646\u0642\u0634 \u0645\u06cc\u0627\u0646\u062c\u06cc \u0645\u06cc\u0627\u0646 \u062a\u0647\u0631\u0627\u0646 \u0648 \u0648\u0627\u0634\u0646\u06af\u062a\u0646 \u0631\u0627 \u062f\u0627\u0631\u062f\u060c \u062d\u062a\u06cc \u067e\u0633 \u0627\u0632 \u062d\u0645\u0644\u0647 \u0628\u2026",
