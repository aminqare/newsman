        {
          "title": "\u0686\u06af\u0648\u0646\u0647 \u062c\u0646\u06af \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646\u060c \u0627\u0631\u0648\u067e\u0627 \u0631\u0627 \u0628\u0627 \u06cc\u06a9 \u0628\u062d\u0631\u0627\u0646 \u0627\u0646\u0631\u0698\u06cc \u062f\u06cc\u06af\u0631 \u0631\u0648\u0628\u0647\u200c\u0631\u0648 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a\u061f",
