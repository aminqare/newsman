        {
          "title": "\u0627\u0641\u0634\u0627 \u06cc\u0627 \u0628\u0627\u0632\u06cc \u0631\u0633\u0627\u0646\u0647\u200c\u0627\u06cc\u061f \u067e\u0634\u062a \u067e\u0631\u062f\u0647 \u0627\u0633\u0646\u0627\u062f \u062a\u0627\u0632\u0647 \u0628\u0634\u0642\u0627\u0628\u200c\u067e\u0631\u0646\u062f\u0647\u200c\u0647\u0627",
