          "summary": "\u062f\u0631 \u0645\u0639\u0627\u0645\u0644\u0627\u062a \u0635\u0628\u062d \u0627\u0645\u0631\u0648\u0632 \u0628\u0627\u0632\u0627\u0631 \u0622\u0633\u06cc\u0627 \u0648 \u062f\u0631 \u0648\u0627\u06a9\u0646\u0634 \u0628\u0647 \u0633\u062e\u0646\u0631\u0627\u0646\u06cc \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u06a9\u0647 \u0646\u062a\u0648\u0627\u0646\u0633\u062a \u0628\u0647 \u0628\u0627\u0632\u0627\u0631\u0647\u0627\u06cc \u062c\u0647\u0627\u0646\u06cc \u0627\u0637\u0645\u06cc\u0646\u0627\u0646 \u062f\u0647\u062f \u06a9\u0647 \u062c\u0646\u06af \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u062e\u0648\u062f \u0646\u0632\u062f\u06cc\u06a9\u200c\u062a\u0631 \u0634\u062f\u0647 \u0648 \u06a9\u0634\u062a\u06cc\u0631\u0627\u0646\u06cc \u0627\u0632 \u0637\u0631\u06cc\u0642 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0628\u0647 \u062d\u0627\u0644\u062a \u0639\u0627\u062f\u06cc \u0628\u0627\u0632 \u062e\u0648\u0627\u0647\u062f \u06af\u0634\u062a\u060c \u0642\u2026",
