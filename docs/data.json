        {
          "title": "\u0628\u0631\u0622\u0648\u0631\u062f\u0647\u0627 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u062d\u0645\u0644\u0627\u062a \u0627\u06cc\u0631\u0627\u0646 \u06f8\u06f0\u06f0 \u0645\u06cc\u0644\u06cc\u0648\u0646 \u062f\u0644\u0627\u0631 \u0628\u0647 \u067e\u0627\u06cc\u06af\u0627\u0647\u200c\u0647\u0627\u06cc \u0645\u0648\u0631\u062f \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062e\u0633\u0627\u0631\u062a \u0648\u0627\u0631\u062f \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a",
