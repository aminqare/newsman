        {
          "title": "\u062d\u0645\u0644\u0647 \u0628\u0647 \u067e\u0627\u0631\u0633 \u062c\u0646\u0648\u0628\u06cc \u0648 \u0648\u0627\u06a9\u0646\u0634 \u0627\u06cc\u0631\u0627\u0646\u061b \u0686\u0647 \u0645\u0639\u0627\u062f\u0644\u0647\u200c\u0627\u06cc \u062f\u0631 \u062c\u0646\u06af \u062a\u063a\u06cc\u06cc\u0631 \u06a9\u0631\u062f\u061f",
