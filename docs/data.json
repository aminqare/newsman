        {
          "title": "\u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646\u061b \u062a\u0644\u0627\u0634\u200c\u0647\u0627 \u0628\u0631\u0627\u06cc \u0628\u0627\u0632 \u06a9\u0631\u062f\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0648 \u062a\u0648\u0642\u0641 \u062d\u0645\u0644\u0627\u062a \u0628\u0647 \u062a\u0627\u0633\u06cc\u0633\u0627\u062a \u0646\u0641\u062a \u0648 \u06af\u0627\u0632",
