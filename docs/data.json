        {
          "title": "\u067e\u0648\u062a\u06cc\u0646 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0628\u0647 \u0627\u0639\u062a\u0642\u0627\u062f \u0627\u0648 \u062c\u0646\u06af \u0627\u0648\u06a9\u0631\u0627\u06cc\u0646 \u00ab\u0631\u0648 \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u0627\u0633\u062a\u00bb",
