          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u0645\u0642\u0627\u0645\u200c\u0647\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646 \u062f\u06cc\u06af\u0631 \u0642\u0627\u062f\u0631 \u0628\u0647 \u00ab\u0633\u0627\u0645\u0627\u0646\u062f\u0647\u06cc \u0627\u0648\u0636\u0627\u0639\u00bb \u0646\u06cc\u0633\u062a\u0646\u062f \u0648 \u0646\u0645\u06cc\u200c\u062f\u0627\u0646\u0646\u062f \u06a9\u0647 \u0628\u0647 \u06af\u0641\u062a\u0647 \u0627\u0648 \u0686\u06af\u0648\u0646\u0647 \u00ab\u06cc\u06a9 \u062a\u0648\u0627\u0641\u0642 \u063a\u06cc\u0631\u0647\u0633\u062a\u0647\u200c\u0627\u06cc \u0631\u0627 \u0627\u0645\u0636\u0627\u0621 \u06a9\u0646\u0646\u062f.\u00bb \u0627\u0648 \u0627\u0632 \u0633\u0631\u0627\u0646 \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u062e\u0648\u0627\u0633\u062a \u06a9\u0647 \u00ab\u0628\u0647\u062a\u0631 \u0627\u0633\u062a \u0647\u0631\u0686\u0647 \u0632\u0648\u062a\u0631 \u0633\u0631 \u0639\u0642\u0644 \u0628\u06cc\u0627\u06cc\u0646\u062f.\u00bb \u067e\u06cc\u0634\u062a\u0631\u2026",
