          "title": "\u062d\u0645\u0644\u0647 \u0628\u0647 \u062f\u0648 \u0646\u0641\u062a\u06a9\u0634 \u062f\u0631 \u0622\u0628\u0647\u0627\u06cc \u0639\u0631\u0627\u0642 \u06cc\u06a9 \u06a9\u0634\u062a\u0647 \u0648 \u0686\u0646\u062f \u0632\u062e\u0645\u06cc \u0628\u0631\u062c\u0627\u06cc \u06af\u0630\u0627\u0634\u062a",
