          "summary": "\u0633\u0631\u0641\u0631\u0645\u0627\u0646\u062f\u0647\u06cc \u0645\u0631\u06a9\u0632\u06cc \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 (\u0633\u0646\u062a\u06a9\u0627\u0645) \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0645\u0633\u062f\u0648\u062f \u06a9\u0631\u062f\u0646 \u0628\u0646\u0627\u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u00ab\u0628\u0637\u0648\u0631 \u06a9\u0627\u0645\u0644\u00bb \u0627\u062c\u0631\u0627 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0627\u06cc\u0646 \u0646\u0647\u0627\u062f \u062f\u0631 \u0627\u0637\u0644\u0627\u0639\u06cc\u0647\u200c\u0627\u06cc \u06af\u0641\u062a\u0647 \u0627\u0633\u062a \u06a9\u0647 \u0637\u06cc \u0633\u0627\u0639\u0627\u062a\u06cc \u06a9\u0647 \u0627\u0632 \u0627\u06cc\u0646 \u0627\u0642\u062f\u0627\u0645 \u06af\u0630\u0634\u062a\u0647\u060c \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0628\u0637\u0648\u0631 \u06a9\u0627\u0645\u0644 \u0631\u0648\u0646\u062f \u062a\u062c\u0627\u0631\u062a \u0627\u0642\u062a\u0635\u0627\u062f\u06cc \u0628\u0647 \u0645\u0642\u0635\u062f \u0648\u2026",
