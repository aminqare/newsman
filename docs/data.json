          "title": "\ud83d\udd34 \u0627\u0634\u0627\u0631\u0647 \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u062a\u062d\u0644\u06cc\u0644\u06cc \u06a9\u0647 \u00ab\u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc\u00bb \u0631\u0627 \u0627\u0628\u0632\u0627\u0631 \u0627\u0648 \u062f\u0631 \u0645\u0642\u0627\u0628\u0644 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0645\u06cc\u200c\u062f\u0627\u0646\u062f\u061b \u0647\u06cc\u0626\u062a \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0647\u0645\u06af\u06cc \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u0631\u0627 \u062a\u0631\u06a9 \u06a9\u0631\u062f\u0646\u062f",
