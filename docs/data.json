          "summary": "\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627 \u0645\u06cc\u200c\u06af\u0648\u06cc\u0646\u062f \u067e\u0646\u062a\u0627\u06af\u0648\u0646 \u062f\u0631 \u062d\u0627\u0644 \u0627\u0639\u0632\u0627\u0645 \u0646\u0627\u0648\u0647\u0627\u06cc \u062c\u0646\u06af\u06cc\u060c \u06cc\u06a9 \u00ab\u06af\u0631\u0648\u0647 \u0622\u0645\u0627\u062f\u0647 \u0622\u0628\u06cc-\u062e\u0627\u06a9\u06cc\u00bb \u0648 \u062a\u0641\u0646\u06af\u062f\u0627\u0631\u0627\u0646 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0628\u06cc\u0634\u062a\u0631 \u0628\u0647 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0627\u0633\u062a. \u0627\u0631\u062a\u0634 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u062f\u0631 \u062d\u0645\u0644\u0627\u062a\u06cc \u0628\u0627 \u0628\u06cc\u0634 \u0627\u0632 \u06f9\u06f0 \u0641\u0631\u0648\u0646\u062f \u062c\u0646\u06af\u0646\u062f\u0647 \u0628\u0647 \u0632\u06cc\u0631\u0633\u0627\u062e\u062a\u200c\u0647\u0627\u06cc \u0627\u0645\u0646\u06cc\u062a\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u062a\u2026",
