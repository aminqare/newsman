        {
          "title": "\u06a9\u0645\u06cc\u062a\u0647 \u062d\u0641\u0627\u0638\u062a \u0627\u0632 \u062e\u0628\u0631\u0646\u06af\u0627\u0631\u0627\u0646: \u0635\u062f\u0647\u0627 \u0646\u0641\u0631 \u062f\u0631 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u0639\u0631\u0628\u06cc \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u0628\u0631\u0627\u06cc \u0627\u0646\u062a\u0634\u0627\u0631 \u0648\u06cc\u062f\u06cc\u0648\u0647\u0627\u06cc \u062d\u0645\u0644\u0627\u062a \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627\u0632\u062f\u0627\u0634\u062a \u0634\u062f\u0647\u200c\u0627\u0646\u062f",
