          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0627 \u0647\u0645\u0647\u200c\u0686\u06cc\u0632 \u0645\u0648\u0627\u0641\u0642\u062a \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a\u061b \u0647\u06cc\u0686 \u06af\u0648\u0646\u0647 \u062a\u0628\u0627\u062f\u0644 \u0645\u0627\u0644\u06cc \u062f\u0631 \u06a9\u0627\u0631 \u0646\u06cc\u0633\u062a",
