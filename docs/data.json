        {
          "title": "\u062a\u062c\u0645\u0639 \u0645\u062e\u0627\u0644\u0641\u0627\u0646 \u062a\u0648\u0627\u0641\u0642 \u0628\u0627 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u062a\u0647\u0631\u0627\u0646 \u0648 \u0645\u0634\u0647\u062f\u061b\u200c \u00ab\u0642\u0627\u0644\u06cc\u0628\u0627\u0641\u060c \u0639\u0631\u0627\u0642\u0686\u06cc\u060c \u067e\u0633 \u062e\u0648\u0646 \u0631\u0647\u0628\u0631\u0645 \u0686\u06cc\u061f\u00bb",
