          "title": "\ud83d\udd34 \u06cc\u06a9 \u0645\u0639\u062a\u0631\u0636 \u062c\u0648\u0627\u0646 \u062f\u06cc\u06af\u0631 \u0627\u0639\u062f\u0627\u0645 \u0634\u062f: \u0633\u0627\u0633\u0627\u0646 \u0622\u0632\u0627\u062f\u0648\u0627\u0631\u060c \u06f2\u06f1 \u0633\u0627\u0644\u0647 \u0648 \u0627\u0647\u0644 \u0627\u0635\u0641\u0647\u0627\u0646\u061b \u0642\u0637\u0639 \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0648\u0627\u0631\u062f \u0634\u0635\u062a\u200c\u0648\u062f\u0648\u0645\u06cc\u0646 \u0631\u0648\u0632 \u0645\u062a\u0648\u0627\u0644\u06cc \u062e\u0648\u062f \u0634\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u06af\u0632\u0627\u0631\u0634 \u0633\u0627\u0632\u0645\u0627\u0646 \u06af\u0632\u0627\u0631\u0634\u06af\u0631\u0627\u0646 \u0628\u062f\u0648\u0646 \u0645\u0631\u0632\u060c \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u0631\u062f\u0647\u200c\u0628\u0646\u062f\u06cc \u0622\u0632\u0627\u062f\u06cc \u0645\u0637\u0628\u0648\u0639\u0627\u062a \u06f2\u06f0\u06f2\u06f6\u060c \u06cc\u06a9 \u067e\u0644\u0647 \u0633\u0642\u0648\u0637 \u06a9\u0631\u062f\u0647 \u0648 \u0647\u0645\u0686\u0646\u0627\u0646 \u062f\u0631 \u0642\u0639\u0631 \u0631\u062f\u0647\u200c\u0628\u0646\u062f\u06cc \u062c\u0647\u0627\u0646\u06cc \u0622\u0632\u0627\u062f\u06cc \u0645\u0637\u0628\u0648\u0639\u0627\u062a \u0627\u0633\u062a. \u0647\u0645\u0632\u0645\u0627\u0646 \u0642\u0637\u0639 \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062c\u0647\u0627\u0646\u06cc \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0648\u0627\u0631\u062f \u0634\u0635\u062a \u0648 \u062f\u0648\u0645\u06cc\u0646 \u0631\u0648\u0632 \u0645\u062a\u0648\u0627\u0644\u06cc\u2026",
