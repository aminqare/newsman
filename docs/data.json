          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647\u060c \u0631\u0648\u0632 \u0634\u0646\u0628\u0647 \u0628\u0627 \u0627\u0646\u062a\u0634\u0627\u0631 \u067e\u06cc\u0627\u0645\u06cc \u0628\u0631 \u0639\u0632\u0645 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0628\u0631\u0627\u06cc \u0628\u0627\u0632 \u0648 \u0627\u06cc\u0645\u0646 \u0646\u06af\u0647 \u062f\u0627\u0634\u062a\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u062a\u0627\u06a9\u06cc\u062f \u06a9\u0631\u062f. \u0627\u0648 \u067e\u06cc\u0634\u062a\u0631 \u062f\u0631 \u0645\u0648\u0631\u062f \u0632\u0645\u0627\u0646 \u067e\u0627\u06cc\u0627\u0646 \u0639\u0645\u0644\u06cc\u0627\u062a \u0646\u0638\u0627\u0645\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u062a\u0635\u0631\u06cc\u062d \u06a9\u0631\u062f \u06a9\u0647 \u062c\u0646\u06af \u0628\u0627 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u2026",
