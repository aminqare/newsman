          "title": "\u062a\u0631\u0627\u0645\u067e: \u06af\u0631\u0641\u062a\u0646 \u0627\u0648\u0631\u0627\u0646\u06cc\u0648\u0645 \u063a\u0646\u06cc\u200c\u0634\u062f\u0647 \u0627\u0632 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0647\u0645\u06cc\u062a \u0631\u0648\u0627\u0646\u0634\u0646\u0627\u062e\u062a\u06cc \u062f\u0627\u0631\u062f",
