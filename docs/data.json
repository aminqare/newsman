          "summary": "\u06a9\u0645\u06cc\u062a\u0647 \u062d\u0641\u0627\u0638\u062a \u0627\u0632 \u062e\u0628\u0631\u0646\u06af\u0627\u0631\u0627\u0646 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u0635\u062f\u0647\u0627 \u0646\u0641\u0631 \u062f\u0631 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u0639\u0631\u0628\u06cc \u062d\u0627\u0634\u06cc\u0647 \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633\u060c \u0628\u0647 \u062f\u0644\u06cc\u0644 \u0627\u0646\u062a\u0634\u0627\u0631 \u0645\u062d\u062a\u0648\u0627\u06cc \u0645\u0631\u062a\u0628\u0637 \u0628\u0627 \u062d\u0645\u0644\u0627\u062a \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627\u0632\u062f\u0627\u0634\u062a \u06a9\u0631\u062f\u0647\u200c\u0627\u0646\u062f. \u0627\u06cc\u0646 \u0646\u0647\u0627\u062f \u0647\u0645\u0686\u0646\u06cc\u0646 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u06a9\u0647 \u0627\u062d\u0645\u062f \u0634\u0647\u0627\u0628\u200c\u0627\u0644\u062f\u06cc\u0646\u060c \u0631\u0648\u0632\u0646\u0627\u0645\u0647\u200c\u0646\u06af\u0627\u0631 \u0634\u0646\u0627\u062e\u062a\u0647\u200c\u0634\u062f\u0647 \u0634\u0634 \u0647\u0641\u062a\u0647\u200c \u0627\u2026",
