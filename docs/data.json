          "title": "\u0627\u0628\u0631\u0627\u0632 \u0646\u06af\u0631\u0627\u0646\u06cc \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u0632\u0648\u062c \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627\u06cc\u06cc \u0632\u0646\u062f\u0627\u0646\u06cc \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0646\u0633\u0628\u062a \u0628\u0647 \u0633\u0644\u0627\u0645\u062a \u0622\u0646\u0647\u0627",
