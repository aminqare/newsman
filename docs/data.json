        {
          "title": "\u0646\u0648\u0633\u0627\u0646 \u0634\u062f\u06cc\u062f \u0642\u06cc\u0645\u062a \u0646\u0641\u062a \u0646\u0627\u0634\u06cc \u0627\u0632 \u0627\u0644\u062a\u0647\u0627\u0628 \u0648 \u0633\u0631\u062f\u0631\u06af\u0645\u06cc \u0628\u0627\u0632\u0627\u0631\u0647\u0627",
          "link": "https://www.bbc.com/persian/articles/c9qdl14z5njo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0641\u0642\u0637 \u0638\u0631\u0641 \u062f\u0648 \u0633\u0627\u0639\u062a\u060c \u0642\u06cc\u0645\u062a \u0647\u0631 \u0628\u0634\u06a9\u0647 \u0646\u0641\u062a \u062e\u0627\u0645 \u0628\u0631\u0646\u062a \u0627\u0632 \u06f1\u06f1\u06f3 \u062f\u0644\u0627\u0631 \u0628\u0647 \u06f9\u06f7 \u062f\u0644\u0627\u0631 \u06a9\u0627\u0647\u0634 \u06cc\u0627\u0641\u062a\u060c \u0633\u067e\u0633 \u062a\u0627 \u06f1\u06f0\u06f6 \u062f\u0644\u0627\u0631 \u0628\u0627\u0644\u0627 \u0631\u0641\u062a\u060c \u062f\u0648\u0628\u0627\u0631\u0647 \u062a\u0627 \u06f1\u06f0\u06f0 \u062f\u0644\u0627\u0631 \u067e\u0627\u06cc\u06cc\u0646 \u0622\u0645\u062f \u0648 \u0627\u06cc\u0646 \u0628\u0627\u0644\u0627 \u0648 \u067e\u0627\u06cc\u06cc\u0646 \u0634\u062f\u0646 \u0642\u06cc\u0645\u062a \u062f\u0631 \u0633\u0627\u0639\u062a\u200c\u0647\u0627\u06cc \u0628\u0639\u062f \u0647\u0645 \u0627\u062f\u0627\u0645\u0647 \u06cc\u0627\u0641\u062a. \u0627\u06cc\u0646 \u0633\u0637\u062d \u0646\u0648\u0633\u0627\u0646 \u0628\u0647 \u0647\u06cc\u0686 \u0648\u062c\u0647 \u0645\u0639\u0645\u2026",
