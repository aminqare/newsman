        {
          "title": "\u0622\u062a\u0634\u200c\u0628\u0633 \u0644\u0628\u0646\u0627\u0646 \u06a9\u0647 \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u062f\u0646\u0628\u0627\u0644\u0634 \u0628\u0648\u062f\u060c \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0631\u0627 \u063a\u0627\u0641\u0644\u06af\u06cc\u0631 \u06a9\u0631\u062f",
