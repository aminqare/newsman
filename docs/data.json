        {
          "title": "\u0628\u062d\u0631\u0627\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u061b\u200c \u0642\u0627\u0644\u06cc\u0628\u0627\u0641: \u062a\u0635\u0645\u06cc\u0645 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0631\u0627\u06cc \u0627\u062f\u0627\u0645\u0647 \u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0628\u0646\u0627\u062f\u0631 \u0627\u06cc\u0631\u0627\u0646\u060c \u0646\u0627\u062f\u0631\u0633\u062a \u0648 \u0646\u0633\u0646\u062c\u06cc\u062f\u0647 \u0627\u0633\u062a",
