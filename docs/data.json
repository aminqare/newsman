        {
          "title": "\u0686\u0631\u0627 \u0631\u0648\u0627\u0628\u0637 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0627\u0645\u0627\u0631\u0627\u062a \u0628\u0647 \u0645\u0631\u0632 \u0628\u062d\u0631\u0627\u0646 \u0631\u0633\u06cc\u062f\u0647 \u0627\u0633\u062a\u061f",
