        {
          "title": "\ud83d\udd34 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0645\u062c\u0628\u0648\u0631 \u0628\u0647 \u06a9\u0627\u0647\u0634 \u062a\u0648\u0644\u06cc\u062f \u0646\u0641\u062a \u0634\u062f\u061b \u062f\u0648 \u0646\u0641\u0631 \u062f\u06cc\u06af\u0631 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u0627\u062a\u0647\u0627\u0645 \u00ab\u062c\u0627\u0633\u0648\u0633\u06cc\u00bb \u0627\u0639\u062f\u0627\u0645 \u0634\u062f\u0646\u062f\u061b \u0642\u0637\u0639 \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u06f1\u06f5\u06f0\u06f0 \u0633\u0627\u0639\u062a\u0647 \u0634\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0628\u0627 \u0627\u062f\u0627\u0645\u0647 \u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0639\u0644\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u06cc\u0631\u0627\u0646\u060c \u0635\u0627\u062f\u0631\u0627\u062a \u0646\u0641\u062a \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u0628\u0647\u200c\u0634\u062f\u062a \u06a9\u0627\u0647\u0634 \u06cc\u0627\u0641\u062a\u0647 \u0648 \u0638\u0631\u0641\u06cc\u062a\u200c\u0647\u0627\u06cc \u0630\u062e\u06cc\u0631\u0647\u200c\u0633\u0627\u0632\u06cc \u0646\u0641\u062a \u0622\u0646 \u0646\u06cc\u0632 \u0628\u0647\u200c\u0633\u0631\u0639\u062a \u062f\u0631 \u062d\u0627\u0644 \u067e\u0631 \u0634\u062f\u0646 \u0627\u0633\u062a. \u0642\u0648\u0647 \u0642\u0636\u0627\u0626\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u06af\u0641\u062a \u062f\u0648 \u0646\u0641\u0631\u060c \u06cc\u0639\u0642\u0648\u0628 \u06a9\u0631\u06cc\u0645\u200c\u067e\u0648\u0631 \u0648 \u0646\u0627\u0635\u0631 \u0628\u06a9\u0631\u0632\u0627\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
