        {
          "title": "\u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u061b \u0686\u06af\u0648\u0646\u0647 \u06cc\u06a9 \u0645\u0644\u0648\u0627\u0646 \u062f\u0631 \u062a\u062e\u062a\u0634 \u06a9\u0634\u062a\u0647 \u0634\u062f \u0648 \u062f\u06cc\u06af\u0631\u06cc \u06f2\u06f4 \u0633\u0627\u0639\u062a \u062f\u0631 \u062f\u0631\u06cc\u0627 \u0632\u0646\u062f\u0647 \u0645\u0627\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/cx2r93y9y8lo?at_medium=RSS&at_campaign=rss",
          "summary": "\u062f\u0631 \u067e\u06cc \u062d\u0645\u0644\u0627\u062a \u0628\u0647 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u060c \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627\u06cc \u062a\u062c\u0627\u0631\u06cc \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0646\u062f \u0648 \u0633\u0631\u0646\u0648\u0634\u062a \u0645\u0644\u0648\u0627\u0646\u0627\u0646 \u0628\u0647 \u062a\u0631\u0627\u0698\u062f\u06cc \u06af\u0631\u0647 \u062e\u0648\u0631\u062f. \u062d\u0633\u0646 \u067e\u0633 \u0627\u0632 \u063a\u0631\u0642 \u0634\u062f\u0646 \u06a9\u0634\u062a\u06cc\u060c \u06f2\u06f4 \u0633\u0627\u0639\u062a \u062f\u0631 \u062f\u0631\u06cc\u0627\u06cc \u0637\u0648\u0641\u0627\u0646\u06cc \u062f\u0648\u0627\u0645 \u0622\u0648\u0631\u062f \u0648 \u0646\u062c\u0627\u062a \u06cc\u0627\u0641\u062a\u060c \u0627\u0645\u0627 \u06cc\u0627\u0633\u0631 \u062f\u0631 \u062e\u0648\u0627\u0628 \u0648 \u067e\u0633 \u0627\u0632 \u0627\u0635\u0627\u0628\u062a \u0645\u0648\u0634\u06a9 \u062c\u0627\u0646 \u0628\u0627\u062e\u062a. \u0627\u06cc\u0646 \u0631\u0648\u0627\u06cc\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
