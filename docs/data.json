          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u062d\u06a9\u0648\u0645\u062a\u06cc \u06a9\u0647 \u06f4\u06f2 \u0647\u0632\u0627\u0631 \u0645\u0639\u062a\u0631\u0636 \u0631\u0627 \u06a9\u064f\u0634\u062a\u0647\u060c \u0646\u0628\u0627\u06cc\u062f \u0633\u0644\u0627\u062d \u0647\u0633\u062a\u0647\u200c\u0627\u06cc \u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u062f\u061b \u0647\u0634\u062f\u0627\u0631 \u0648\u0632\u06cc\u0631 \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc",
