        {
          "title": "\u0622\u0698\u0627\u0646\u0633 \u0628\u06cc\u0646\u200c\u0627\u0644\u0645\u0644\u0644\u06cc \u0627\u0646\u0631\u0698\u06cc: \u0627\u0641\u0632\u0627\u06cc\u0634 \u0634\u062f\u06cc\u062f \u0642\u06cc\u0645\u062a \u0646\u0641\u062a\u060c \u062c\u0647\u0627\u0646 \u0631\u0627 \u0628\u0627 \u0686\u0627\u0644\u0634\u06cc \u0628\u0632\u0631\u06af \u0631\u0648\u0628\u0631\u0648 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a",
