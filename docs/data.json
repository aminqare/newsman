        {
          "title": "\u0648\u0627\u06a9\u0646\u0634\u200c\u0647\u0627 \u0628\u0647 \u0627\u0639\u062f\u0627\u0645 \u0632\u0646\u062f\u0627\u0646\u06cc\u0627\u0646 \u062f\u0631 \u0645\u06cc\u0627\u0646\u0647 \u062c\u0646\u06af\u061b \u0627\u0632 \u00ab\u0633\u0631\u06a9\u0648\u0628 \u0633\u06cc\u0627\u0633\u06cc\u00bb \u062a\u0627 \u00ab\u0627\u0646\u062a\u0642\u0627\u0645 \u062d\u06a9\u0648\u0645\u062a \u0627\u0632 \u0645\u0631\u062f\u0645 \u0627\u06cc\u0631\u0627\u0646\u00bb",
