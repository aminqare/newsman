      "items": [
        {
          "title": "\ud83d\udd34 \u062e\u0627\u0645\u0648\u0634\u06cc \u062f\u06cc\u062c\u06cc\u062a\u0627\u0644 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u06f1\u06f7\u06f0\u06f0 \u0633\u0627\u0639\u062a \u06af\u0630\u0634\u062a\u061b \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u0641\u06a9\u0631 \u0645\u06cc\u200c\u06a9\u0646\u0645 \u00ab\u062e\u06cc\u0644\u06cc \u0632\u0648\u062f\u00bb \u0627\u0632 \u0631\u0698\u06cc\u0645 \u0627\u06cc\u0631\u0627\u0646 \u062e\u0628\u0631\u06cc \u0628\u0634\u0646\u0648\u06cc\u0645",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0642\u0637\u0639 \u0633\u0631\u0627\u0633\u0631\u06cc \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u06a9\u0646\u0648\u0646 \u0648\u0627\u0631\u062f \u0647\u0641\u062a\u0627\u062f \u0648 \u062f\u0648\u0645\u06cc\u0646 \u0631\u0648\u0632 \u062e\u0648\u062f \u0634\u062f\u0647\u060c \u0648 \u0627\u0632 \u0647\u0632\u0627\u0631 \u0648 \u06f7\u06f0\u06f0 \u0633\u0627\u0639\u062a \u06af\u0630\u0634\u062a\u0647 \u0627\u0633\u062a. \u062f\u0631 \u062a\u062d\u0648\u0644\u06cc \u062f\u06cc\u06af\u0631\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0631\u0648\u0632 \u0634\u0646\u0628\u0647 \u06f1\u06f9 \u0627\u0631\u062f\u06cc\u0628\u0647\u0634\u062a \u062f\u0631 \u0645\u0635\u0627\u062d\u0628\u0647 \u0628\u0627 \u06cc\u06a9 \u0634\u0628\u06a9\u0647 \u062e\u0628\u0631\u06cc \u0641\u0631\u0627\u0646\u0633\u0648\u06cc \u062f\u0631\u0628\u0627\u0631\u0647 \u062a\u0627\u0632\u0647\u200c\u062a\u0631\u06cc\u0646 \u062a\u062d\u0648\u0644\u0627\u062a \u062f\u0631 \u0632\u0645\u06cc\u0646\u0647\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
          "source_url": "https://ir.voanews.com/api/zbtpil-vomx-tpeqiyp"
        },
        {
          "title": "\u0648\u0646\u0633: \u0647\u06cc\u0686 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0645\u0628\u0646\u06cc \u0628\u0631 \u0627\u06cc\u0646 \u0648\u062c\u0648\u062f \u0646\u062f\u0627\u0631\u062f \u06a9\u0647 \u0627\u0642\u062f\u0627\u0645 \u0646\u0638\u0627\u0645\u06cc \u0639\u0644\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0647 \u062c\u0646\u06af\u06cc \u0637\u0648\u0644\u0627\u0646\u06cc \u062f\u0631 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0645\u0646\u062c\u0631 \u0634\u0648\u062f",
