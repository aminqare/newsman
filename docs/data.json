          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e: \u0627\u06af\u0631 \u062a\u0627 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u062a\u0648\u0627\u0641\u0642 \u0646\u0634\u0648\u062f\u060c \u0645\u062c\u0628\u0648\u0631\u06cc\u0645 \u0628\u0645\u0628\u0627\u0631\u0627\u0646 \u0631\u0627 \u0627\u0632 \u0633\u0631 \u0628\u06af\u06cc\u0631\u06cc\u0645\u061b \u06a9\u0627\u0647\u0634 \u06f9 \u062f\u0631\u0635\u062f\u06cc \u0628\u0647\u0627\u06cc \u0646\u0641\u062a \u062f\u0631 \u0633\u0627\u06cc\u0647 \u06af\u0634\u0627\u06cc\u0634 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647\u060c \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u06a9\u0647 \u0627\u06af\u0631 \u062a\u0627 \u0631\u0648\u0632 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u062a\u0648\u0627\u0641\u0642\u06cc \u0628\u0644\u0646\u062f\u0645\u062f\u062a \u062d\u0627\u0635\u0644 \u0646\u0634\u0648\u062f\u060c \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u0628\u0647 \u0622\u062a\u0634\u200c\u0628\u0633 \u0628\u0627 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u067e\u0627\u06cc\u0627\u0646 \u062f\u0647\u062f. \u0647\u0645\u0632\u0645\u0627\u0646 \u067e\u0633 \u0627\u0632 \u0622\u0646\u06a9\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u0639\u0628\u0648\u0631 \u0647\u0645\u0647 \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627\u06cc \u062a\u062c\u0627\u0631\u06cc \u0627\u0632 \u062a\u0646\u06af\u0647\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
