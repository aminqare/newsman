          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631\u0628\u0627\u0631\u0647 \u0627\u0639\u0632\u0627\u0645 \u062c\u0631\u062f \u06a9\u0648\u0634\u0646\u0631\u060c \u0645\u0634\u0627\u0648\u0631 \u0627\u0631\u0634\u062f\u0634\u060c \u0648 \u0627\u0633\u062a\u06cc\u0648 \u0648\u06cc\u062a\u06a9\u0627\u0641\u060c \u0641\u0631\u0633\u062a\u0627\u062f\u0647 \u0627\u0634 \u062f\u0631 \u0627\u0645\u0648\u0631 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647\u060c \u0628\u0631\u0627\u06cc \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0645\u0633\u062a\u0642\u06cc\u0645 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u06af\u0641\u062a\u0647 \u0627\u0633\u062a \u06a9\u0647 \u0622\u0646\u0647\u0627 \u00ab\u0647\u0645\u06cc\u0646 \u062d\u0627\u0644\u0627\u00bb \u062f\u0631 \u062d\u0627\u0644 \u0645\u0630\u0627\u06a9\u0631\u0647 \u0647\u0633\u062a\u0646\u062f \u0648 \u0627\u062f\u0627\u0645\u0647 \u062f\u0627\u062f \u06a9\u0647 \u062c\u06cc\u200c\u062f\u06cc \u0648\u0646\u0633\u060c\u2026",
