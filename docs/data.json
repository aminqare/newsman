        {
          "title": "\u062f\u0631\u0628\u0627\u0631\u0647 \u062d\u0645\u0644\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u06f2\u06f0 \u067e\u0627\u06cc\u06af\u0627\u0647\u200c \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0686\u0647 \u0645\u06cc\u200c\u062f\u0627\u0646\u06cc\u0645\u061f",
