          "title": "\u062a\u0631\u0627\u0645\u067e: \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0627\u0648\u0631\u0627\u0646\u06cc\u0648\u0645 \u063a\u0646\u06cc\u200c\u0634\u062f\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u062a\u062d\u0648\u06cc\u0644 \u0645\u06cc\u200c\u06af\u06cc\u0631\u062f\u061b \u0642\u0627\u0644\u06cc\u0628\u0627\u0641: \u0647\u0645\u0647 \u0627\u062f\u0639\u0627\u0647\u0627\u06cc \u0627\u0648 \u06a9\u0630\u0628 \u0627\u0633\u062a",
