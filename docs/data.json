        {
          "title": "\u0637\u0627\u0644\u0628\u0627\u0646: \u062f\u0631 \u062d\u0645\u0644\u0647 \u0647\u0648\u0627\u06cc\u06cc \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u063a\u06cc\u0631\u0646\u0638\u0627\u0645\u06cc\u0627\u0646 \u06a9\u0634\u062a\u0647 \u0634\u062f\u0646\u062f\u061b \u067e\u0627\u06a9\u0633\u062a\u0627\u0646: \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0645\u0648\u0631\u062f \u062d\u0645\u0627\u06cc\u062a \u0647\u0646\u062f \u0647\u062f\u0641 \u0628\u0648\u062f\u0646\u062f",
