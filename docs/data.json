          "summary": "\u062e\u0628\u0631\u06af\u0632\u0627\u0631\u06cc \u0631\u0648\u06cc\u062a\u0631\u0632 \u06af\u0632\u0627\u0631\u0634 \u062f\u0627\u062f \u06a9\u0647 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0648 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0637\u0631\u062d\u06cc \u0628\u0631\u0627\u06cc \u067e\u0627\u06cc\u0627\u0646 \u062f\u0627\u062f\u0646 \u0628\u0647 \u062f\u0631\u06af\u06cc\u0631\u06cc\u200c\u0647\u0627 \u062f\u0631\u06cc\u0627\u0641\u062a \u06a9\u0631\u062f\u0647\u200c\u0627\u0646\u062f \u06a9\u0647 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u0627\u0632 \u0631\u0648\u0632 \u062f\u0648\u0634\u0646\u0628\u0647 \u06f1\u06f7 \u0641\u0631\u0648\u0631\u062f\u06cc\u0646 \u0627\u062c\u0631\u0627\u06cc\u06cc \u0634\u0648\u062f \u0648 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0628\u0627\u0632\u06af\u0634\u0627\u06cc\u06cc \u06a9\u0646\u062f. \u062f\u0631 \u062a\u062d\u0648\u0644\u06cc \u062f\u06cc\u06af\u0631\u060c \u0642\u0648\u0647 \u0642\u0636\u0627\u0626\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u2026",
