          "summary": "\u062f\u0631 \u0627\u062b\u0631 \u062a\u06cc\u0631\u0627\u0646\u062f\u0627\u0632\u06cc \u062f\u0631 \u0628\u0632\u0631\u06af\u062a\u0631\u06cc\u0646 \u0645\u0633\u062c\u062f \u0634\u0647\u0631 \u0633\u0646 \u062f\u06cc\u06af\u0648 - \u062f\u0631 \u062c\u0646\u0648\u0628 \u06a9\u0627\u0644\u06cc\u0641\u0631\u0646\u06cc\u0627 - \u062f\u0633\u062a\u200c\u06a9\u0645 \u0633\u0647 \u0646\u0641\u0631 \u06a9\u0634\u062a\u0647 \u0634\u062f\u0646\u062f \u0648 \u067e\u0644\u06cc\u0633 \u06af\u0641\u062a\u0647 \u062f\u0648 \u0639\u0627\u0645\u0644 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0627\u06cc\u0646 \u062a\u06cc\u0631\u0627\u0646\u062f\u0627\u0632\u06cc \u0646\u06cc\u0632 \u00ab\u0628\u0631 \u0627\u062b\u0631 \u0634\u0644\u06cc\u06a9 \u0628\u0647 \u062e\u0648\u062f\u00bb \u06a9\u0634\u062a\u0647 \u0634\u062f\u0647\u200c\u0627\u0646\u062f. \u0628\u0647 \u06af\u0641\u062a\u0647 \u067e\u0644\u06cc\u0633 \u062d\u0627\u062f\u062b\u0647 \u0631\u062e\u200c\u062f\u0627\u062f\u0647 \u062f\u0631 \u0645\u0631\u06a9\u0632 \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u062d\u2026",
