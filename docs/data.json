        {
          "title": "\ud83d\udd34 \u0647\u06cc\u0626\u062a \u0645\u0630\u0627\u06a9\u0631\u0647\u200c\u06a9\u0646\u0646\u062f\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0628\u0647 \u0633\u0631\u067e\u0631\u0633\u062a\u06cc \u0648\u0646\u0633 \u0648\u0627\u0631\u062f \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u0634\u062f\u061b \u0642\u0637\u0639\u06cc \u0645\u062a\u0648\u0627\u0644\u06cc \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u0647\u0632\u0627\u0631 \u0633\u0627\u0639\u062a \u06af\u0630\u0634\u062a",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0648 \u0645\u0646\u0628\u0639 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646\u06cc \u0628\u0647 \u0631\u0648\u06cc\u062a\u0631\u0632 \u06af\u0641\u062a\u0646\u062f \u06a9\u0647 \u0647\u0648\u0627\u067e\u06cc\u0645\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u062d\u0627\u0645\u0644 \u062a\u06cc\u0645 \u0645\u0630\u0627\u06a9\u0631\u0647\u200c\u06a9\u0646\u0646\u062f\u0647 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0628\u0647 \u0631\u0647\u0628\u0631\u06cc \u062c\u06cc\u200c\u062f\u06cc. \u0648\u0646\u0633\u060c \u0645\u0639\u0627\u0648\u0646 \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u0635\u0628\u062d \u0634\u0646\u0628\u0647 \u062f\u0631 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u0641\u0631\u0648\u062f \u0622\u0645\u062f. \u0648\u0631\u0648\u062f \u0627\u06cc\u0646 \u0647\u06cc\u0626\u062a \u0633\u0627\u0639\u0627\u062a\u06cc \u067e\u0633 \u0627\u0632 \u0648\u0631\u0648\u062f \u0647\u06cc\u0626\u062a \u0645\u0630\u0627\u06a9\u0631\u0647\u200c\u06a9\u0646\u0646\u062f\u0647\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
