        {
          "title": "\u062a\u0631\u0627\u0645\u067e \u0627\u0632 \u0645\u0648\u0627\u0641\u0642\u062a \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627 \u062a\u062d\u0648\u06cc\u0644 \u0627\u0648\u0631\u0627\u0646\u06cc\u0648\u0645 \u062e\u0648\u062f \u062e\u0628\u0631 \u062f\u0627\u062f\u060c \u0622\u062a\u0634\u200c\u0628\u0633 \u0645\u06cc\u0627\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648 \u0644\u0628\u0646\u0627\u0646 \u0622\u063a\u0627\u0632 \u0634\u062f",
          "link": "https://www.bbc.co.uk/persian/live/cq6jpr6d1mvt?at_medium=RSS&at_campaign=rss",
          "summary": "\u0622\u062a\u0634 \u0628\u0633 \u06f1\u06f0 \u0631\u0648\u0632\u0647 \u0645\u06cc\u0627\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648 \u0644\u0628\u0646\u0627\u0646 \u0631\u0633\u0645\u0627 \u0622\u063a\u0627\u0632 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u0627\u06cc\u0646 \u0622\u062a\u0634\u200c\u0628\u0633 \u0627\u0633\u062a\u0642\u0628\u0627\u0644 \u06a9\u0631\u062f\u0647 \u0648 \u0645\u062d\u0645\u0628\u0627\u0642\u0631 \u0642\u0627\u0644\u06cc\u0628\u0627\u0641 \u062a\u0627\u06a9\u06cc\u062f \u06a9\u0631\u062f\u0647 \u06a9\u0647 \u0628\u0631\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0622\u062a\u0634\u200c\u0628\u0633 \u062f\u0631 \u0644\u0628\u0646\u0627\u0646 \u0647\u0645\u0633\u0627\u0646 \u0622\u062a\u0634 \u0628\u0633 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0633\u062a. \u0628\u0646\u06cc\u0627\u0645\u06cc\u0646 \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648 \u062f\u0631 \u0622\u0633\u062a\u0627\u0646\u0647 \u0622\u063a\u0627\u0632 \u0622\u062a\u0634 \u0628\u0633 \u0627\u0632 \u0627\u062d\u062a\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
