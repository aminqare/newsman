        {
          "title": "\u062d\u0645\u0644\u0627\u062a \u0645\u0648\u0634\u06a9\u06cc \u0648 \u067e\u0647\u067e\u0627\u062f\u06cc \u0633\u067e\u0627\u0647 \u067e\u0627\u0633\u062f\u0627\u0631\u0627\u0646 \u0648 \u0627\u0631\u062a\u0634 \u0628\u0647 \u067e\u0627\u06cc\u06af\u0627\u0647\u200c\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u0628\u062d\u0631\u06cc\u0646\u060c \u06a9\u0648\u06cc\u062a \u0648 \u0627\u0631\u062f\u0646",
