        {
          "title": "\u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u061b \u0686\u0647 \u0622\u06cc\u0646\u062f\u0647\u200c\u0627\u06cc \u062f\u0631 \u0627\u0646\u062a\u0638\u0627\u0631 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u0639\u0631\u0628 \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u0627\u0633\u062a\u061f",
          "link": "https://www.bbc.com/persian/articles/c62jw8vvllvo?at_medium=RSS&at_campaign=rss",
          "summary": "\u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u062a\u0635\u0648\u06cc\u0631 \u062b\u0628\u0627\u062a \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u0631\u0627 \u062e\u062f\u0634\u0647\u200c\u062f\u0627\u0631 \u06a9\u0631\u062f\u0647 \u0648 \u0622\u0646\u200c\u0647\u0627 \u0631\u0627 \u0628\u0627 \u062a\u0647\u062f\u06cc\u062f\u0627\u062a \u0627\u0645\u0646\u06cc\u062a\u06cc \u0648 \u0627\u0642\u062a\u0635\u0627\u062f\u06cc \u0631\u0648\u0628\u0647\u200c\u0631\u0648 \u0633\u0627\u062e\u062a\u0647 \u0627\u0633\u062a. \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631\u0647\u0627 \u062f\u0631 \u062a\u0644\u0627\u0634 \u0628\u0631\u0627\u06cc \u0627\u06cc\u062c\u0627\u062f \u062a\u0648\u0627\u0632\u0646 \u0645\u06cc\u0627\u0646 \u0646\u0632\u062f\u06cc\u06a9\u06cc \u0628\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0645\u062f\u06cc\u0631\u06cc\u062a \u0631\u0648\u0627\u0628\u0637 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0647\u0633\u062a\u0646\u062f\u060c \u062f\u0631 \u062d\u0627\u0644\u06cc \u06a9\u0647 \u0639\u0645\u062f\u062a\u0627\u2026",
