          "title": "\u062a\u0631\u0627\u0645\u067e \u0627\u0632 \u0633\u0631\u0627\u0646 \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u062e\u0648\u0627\u0633\u062a \u06a9\u0647 \u00ab\u0647\u0631\u0686\u0647 \u0632\u0648\u062f\u062a\u0631 \u0633\u0631 \u0639\u0642\u0644 \u0628\u06cc\u0627\u06cc\u0646\u062f\u00bb",
