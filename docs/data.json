          "title": "\ud83d\udd34 \u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627: \u067e\u0646\u062a\u0627\u06af\u0648\u0646 \u062f\u0631 \u062d\u0627\u0644 \u0627\u0639\u0632\u0627\u0645 \u0646\u0627\u0648\u0647\u0627\u06cc \u062c\u0646\u06af\u06cc \u0648 \u062a\u0641\u0646\u06af\u062f\u0627\u0631\u0627\u0646 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0628\u06cc\u0634\u062a\u0631 \u0628\u0647 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0627\u0633\u062a\u061b\n\u062d\u0645\u0644\u0627\u062a \u06af\u0633\u062a\u0631\u062f\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0632\u06cc\u0631\u0633\u0627\u062e\u062a\u200c\u0647\u0627\u06cc \u0627\u0645\u0646\u06cc\u062a\u06cc \u062f\u0631 \u062a\u0647\u0631\u0627\u0646",
