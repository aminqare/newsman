          "title": "\u200c\ud83d\udd34 \u0627\u0631\u062a\u0634 \u0627\u0633\u0631\u0627\u0626\u064a\u0644 \u0627\u0632 \u062d\u0645\u0644\u0647 \u0645\u0648\u0634\u06a9\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062e\u0628\u0631 \u062f\u0627\u062f\u061b \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e: \u0631\u0698\u06cc\u0645 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627\u06cc\u062f \u062c\u0627\u0647\u200c\u0637\u0644\u0628\u06cc\u200c\u0647\u0627\u06cc \u0647\u0633\u062a\u0647\u200c\u0627\u06cc \u062e\u0648\u062f \u0631\u0627 \u06a9\u0646\u0627\u0631 \u0628\u06af\u0630\u0627\u0631\u062f",
