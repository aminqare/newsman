        {
          "title": "\u0622\u06cc\u0627 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u0627\u0647\u062f\u0627\u0641 \u062e\u0648\u062f \u062f\u0631 \u062c\u0646\u06af \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0633\u06cc\u062f\u061f",
