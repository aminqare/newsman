        {
          "title": "\u0686\u0631\u06cc\u06a9\u200c\u0647\u0627\u06cc \u06a9\u0631\u062f\u061b \u062f\u0631\u0648\u0646 \u06cc\u06a9 \u06af\u0631\u062f\u0627\u0646 \u0646\u0638\u0627\u0645\u06cc \u0645\u062e\u0641\u06cc \u06a9\u0627\u0645\u0644\u0627 \u0632\u0646\u0627\u0646\u0647",
