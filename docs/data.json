        {
          "title": "\u0686\u0647 \u06a9\u0633\u0627\u0646\u06cc \u0628\u06cc\u0634\u062a\u0631 \u0627\u0632 \u062a\u0632\u0631\u06cc\u0642\u200c\u0647\u0627\u06cc \u0644\u0627\u063a\u0631\u06cc \u0633\u0648\u062f \u0645\u06cc\u200c\u0628\u0631\u0646\u062f\u061f",
          "link": "https://www.bbc.com/persian/articles/cvgkzjnv7lko?at_medium=RSS&at_campaign=rss",
          "summary": "\u067e\u0698\u0648\u0647\u0634 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u0627\u0641\u0631\u0627\u062f\u06cc \u06a9\u0647 \u062f\u0627\u0631\u0627\u06cc \u062f\u0648 \u06af\u0648\u0646\u0647 \u0698\u0646\u062a\u06cc\u06a9\u06cc \u0645\u0631\u062a\u0628\u0637 \u0628\u0627 \u0627\u0634\u062a\u0647\u0627 \u0648 \u06af\u0648\u0627\u0631\u0634 \u0647\u0633\u062a\u0646\u062f \u0628\u0627 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0627\u0632 \u062f\u0627\u0631\u0648\u200c\u200c\u0647\u0627\u06cc \u062a\u0632\u0631\u06cc\u0642\u06cc \u0628\u0631\u0627\u06cc \u062f\u0631\u0645\u0627\u0646 \u0686\u0627\u0642\u06cc \u0645\u0627\u0646\u0646\u062f \u0648\u06cc\u06af\u0648\u0648\u06cc \u0648 \u0645\u0627\u0646\u062c\u0627\u0631\u0648 \u06a9\u0627\u0647\u0634 \u0648\u0632\u0646 \u0628\u06cc\u0634\u062a\u0631\u06cc \u067e\u06cc\u062f\u0627 \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f. \u06cc\u0627\u0641\u062a\u0647\u200c\u0647\u0627\u06cc \u0645\u0646\u062a\u0634\u0631\u200c\u0634\u062f\u0647 \u062f\u0631 \u0645\u062c\u0644\u0647 \u0646\u06cc\u0686\u0631 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0631\u0647\u0628\u0631 \u0627\u0631\u0634\u062f \u062d\u0632\u0628\u200c\u0627\u0644\u0644\u0647 \u0644\u0628\u0646\u0627\u0646: \u062e\u0644\u0639 \u0633\u0644\u0627\u062d \u0631\u0627 \u0647\u0631\u06af\u0632 \u0646\u0645\u06cc\u200c\u067e\u0630\u06cc\u0631\u06cc\u0645",
