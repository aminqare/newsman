        {
          "title": "\u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u06cc\u0631\u0627\u0646\u061b \u0645\u0627\u062c\u0631\u0627\u06cc \u062f\u0644\u0641\u06cc\u0646\u200c\u0647\u0627\u06cc \u0627\u0646\u062a\u062d\u0627\u0631\u06cc \u0686\u06cc\u0633\u062a\u061f",
          "link": "https://www.bbc.com/persian/articles/c8xwq9expevo?at_medium=RSS&at_campaign=rss",
          "summary": "\u062f\u0631 \u0646\u0634\u0633\u062a \u062e\u0628\u0631\u06cc \u0631\u0648\u0632 \u0633\u0647\u200c\u0634\u0646\u0628\u0647 (\u06f5 \u0645\u0647/\u06f1\u06f5 \u0627\u0631\u062f\u06cc\u0628\u0647\u0634\u062a) \u067e\u0646\u062a\u0627\u06af\u0648\u0646 \u062f\u0631 \u06a9\u0646\u0627\u0631 \u0633\u0626\u0648\u0627\u0644\u200c\u0647\u0627\u06cc \u0639\u0627\u062f\u06cc \u0645\u0631\u0628\u0648\u0637 \u0628\u0647 \u062f\u0631\u06af\u06cc\u0631\u06cc\u200c\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u06cc\u0631\u0627\u0646 \u0646\u06a9\u062a\u0647\u200c\u0627\u06cc \u0645\u0637\u0631\u062d \u0634\u062f \u06a9\u0647 \u062a\u0639\u062c\u0628 \u0628\u0633\u06cc\u0627\u0631\u06cc \u0628\u0631\u0627\u0646\u06af\u06cc\u062e\u062a: \u00ab\u0622\u06cc\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u062f\u0644\u0641\u06cc\u0646\u200c\u0647\u0627\u06cc \u0627\u0646\u062a\u062d\u0627\u0631\u06cc \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0645\u06cc\u200c\u06a9\u0646\u062f\u061f\u00bb",
