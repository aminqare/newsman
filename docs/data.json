          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e: \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0628\u0627 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0627\u0632 \u0632\u0648\u0631 \u06a9\u0646\u062a\u0631\u0644 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u0628\u0627\u0631\u06cc \u0628\u0627 \u067e\u0631\u0686\u0645 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0631\u0627 \u062f\u0631 \u0627\u062e\u062a\u06cc\u0627\u0631 \u06af\u0631\u0641\u062a\u0646\u062f",
