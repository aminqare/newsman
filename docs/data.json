          "title": "\u0686\u06af\u0648\u0646\u0647 \u067e\u0647\u067e\u0627\u062f\u0647\u0627\u06cc \u0627\u0631\u0632\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646 \u0645\u0639\u0627\u062f\u0644\u0627\u062a \u0627\u0645\u0646\u06cc\u062a\u06cc \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0631\u0627 \u0628\u0647\u0645 \u0632\u062f\u0647 \u0627\u0633\u062a",
