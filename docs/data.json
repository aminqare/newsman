        {
          "title": "\u0627\u0646\u062a\u0634\u0627\u0631 \u06af\u0632\u0627\u0631\u0634 \u0645\u0631\u0628\u0648\u0637 \u0628\u0647 \u0628\u0631\u0646\u0627\u0645\u0647 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u062c\u0646\u06af \u0639\u0644\u06cc\u0647 \u0627\u06cc\u0631\u0627\u0646\u061b \u0642\u06cc\u0645\u062a \u0646\u0641\u062a \u0628\u0647 \u0628\u0627\u0644\u0627\u062a\u0631\u06cc\u0646 \u062d\u062f \u062e\u0648\u062f \u0627\u0632 \u0633\u0627\u0644 \u06f2\u06f0\u06f2\u06f2 \u0631\u0633\u06cc\u062f",
