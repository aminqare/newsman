          "summary": "\u0645\u0631\u06cc\u0645 \u0627\u06a9\u0628\u0631\u06cc \u0645\u0646\u0641\u0631\u062f\u060c \u0632\u0646\u062f\u0627\u0646 \u0633\u06cc\u0627\u0633\u06cc \u06a9\u0647 \u06f1\u06f7 \u0633\u0627\u0644 \u0628\u062f\u0648\u0646 \u06cc\u06a9 \u0631\u0648\u0632 \u0645\u0631\u062e\u0635\u06cc \u062f\u0631 \u0632\u0646\u062f\u0627\u0646 \u0645\u0627\u0646\u062f\u060c \u0622\u0632\u0627\u062f \u0634\u062f\u0647 \u0627\u0633\u062a. \u0639\u06a9\u0633\u06cc \u0627\u0632 \u0627\u0648 \u062f\u0631 \u06a9\u0646\u0627\u0631 \u0627\u0639\u0636\u0627\u06cc \u062e\u0627\u0646\u0648\u0627\u062f\u0647\u200c\u0627\u0634 \u0631\u0648\u0632 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u06f1\u06f9 \u0641\u0631\u0648\u0631\u062f\u06cc\u0646 \u0645\u0646\u062a\u0634\u0631 \u0634\u062f\u0647 \u06a9\u0647 \u062e\u0627\u0646\u0645 \u0627\u06a9\u0628\u0631\u06cc \u0645\u0646\u0641\u0631\u062f \u0631\u0627 \u0628\u0631\u0627\u06cc \u0646\u062e\u0633\u062a\u06cc\u0646 \u0628\u0627\u0631 \u0628\u06cc\u0631\u0648\u0646 \u062f\u06cc\u0648\u0627\u0631\u0647\u0627\u06cc \u0632\u0646\u062f\u0627\u0646 \u0646\u0634\u2026",
