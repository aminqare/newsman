          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0647 \u0637\u0648\u0631 \u062c\u062f\u06cc \u0622\u062a\u0634\u200c\u0628\u0633 \u0631\u0627 \u0646\u0642\u0636 \u06a9\u0631\u062f\u0647 \u0648 \u0648\u0642\u062a \u0622\u0646 \u0631\u0633\u06cc\u062f\u0647 \u00ab\u0645\u0627\u0634\u06cc\u0646 \u06a9\u0634\u062a\u0627\u0631\u00bb \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0645\u062a\u0648\u0642\u0641 \u0634\u0648\u062f",
