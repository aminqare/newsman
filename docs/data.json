          "summary": "\u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0631\u0648\u0632 \u0634\u0646\u0628\u0647 \u06f2\u06f9 \u0641\u0631\u0648\u0631\u062f\u06cc\u0646 \u062f\u0631 \u06a9\u0627\u062e \u0633\u0641\u06cc\u062f\u060c \u0636\u0645\u0646 \u0627\u0646\u062a\u0642\u0627\u062f \u0627\u0632 \u0631\u0648\u06cc\u06a9\u0631\u062f \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u062c\u0627\u0631\u06cc \u0628\u0627 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u06af\u0641\u062a: \u00ab\u0622\u0646\u200c\u0647\u0627 \u0645\u06cc\u200c\u062e\u0648\u0627\u0633\u062a\u0646\u062f \u062f\u0648\u0628\u0627\u0631\u0647 \u062a\u0646\u06af\u0647 \u0631\u0627 \u0628\u0628\u0646\u062f\u0646\u062f\u060c \u0627\u0645\u0627 \u062f\u06cc\u06af\u0631 \u0646\u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u0646\u062f \u0627\u0632 \u0645\u0627 \u0628\u0627\u062c\u200c\u06af\u06cc\u0631\u06cc \u06a9\u0646\u0646\u062f.\u00bb",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
