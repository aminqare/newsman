          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u064a\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0631\u0648\u0632 \u06cc\u06a9\u0634\u0646\u0628\u0647 \u06af\u0641\u062a \u067e\u0627\u0633\u062e \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0631\u0627 \u062f\u0631\u06cc\u0627\u0641\u062a \u06a9\u0631\u062f\u0647 \u0648 \u0627\u0632 \u0622\u0646 \u0646\u0627\u0631\u0627\u0636\u06cc \u0627\u0633\u062a. \u0627\u0648 \u062f\u0631 \u067e\u06cc\u0627\u0645\u06cc \u06af\u0641\u062a \u06f4\u06f7 \u0633\u0627\u0644 \u0627\u0633\u062a \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0646\u06cc\u0627 \u0631\u0627 \u0645\u0639\u0637\u0644 \u0646\u06af\u0647 \u062f\u0627\u0634\u062a\u0647 \u0648 \u0627\u062e\u06cc\u0631\u0627\u064b \u06f4\u06f2 \u0647\u0632\u0627\u0631 \u0645\u0639\u062a\u0631\u0636 \u0628\u06cc\u200c\u06af\u0646\u0627\u0647 \u0648 \u063a\u06cc\u0631\u0645\u0633\u0644\u062d \u0631\u0627 \u06a9\u0634\u062a\u0647 \u0627\u0633\u062a\u2026",
