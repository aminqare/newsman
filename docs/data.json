          "title": "\u0686\u0631\u0627 \u0642\u06cc\u0645\u062a \u0646\u0641\u062a \u0628\u06cc\u0634 \u0627\u0632 \u0622\u0646\u0686\u0647 \u0641\u06a9\u0631 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u062f \u0627\u0647\u0645\u06cc\u062a \u062f\u0627\u0631\u062f\u061f",
