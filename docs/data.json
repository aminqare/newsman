        {
          "title": "\u0627\u0626\u062a\u0644\u0627\u0641 \u062c\u062f\u06cc\u062f \u0627\u062d\u0632\u0627\u0628 \u0645\u062e\u0627\u0644\u0641 \u06a9\u0631\u062f \u0627\u06cc\u0631\u0627\u0646\u06cc \u0634\u0627\u0645\u0644 \u0686\u0647 \u06af\u0631\u0648\u0647\u200c\u0647\u0627\u06cc\u06cc \u0627\u0633\u062a\u061f",
          "link": "https://www.bbc.com/persian/articles/c8xywll70wgo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0686\u0646\u062f\u06cc\u0646 \u06af\u0631\u0648\u0647 \u0645\u062e\u0627\u0644\u0641 \u06a9\u0631\u062f \u0627\u06cc\u0631\u0627\u0646\u06cc \u06a9\u0647 \u062f\u0631 \u0645\u0646\u0637\u0642\u0647 \u0646\u06cc\u0645\u0647\u200c\u062e\u0648\u062f\u0645\u062e\u062a\u0627\u0631 \u0627\u0642\u0644\u06cc\u0645 \u06a9\u0631\u062f\u0633\u062a\u0627\u0646 \u0639\u0631\u0627\u0642 \u0645\u0633\u062a\u0642\u0631 \u0647\u0633\u062a\u0646\u062f\u060c \u0631\u0648\u0632 \u06f2\u06f2 \u0641\u0648\u0631\u06cc\u0647 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f\u0646\u062f \u0627\u0626\u062a\u0644\u0627\u0641\u06cc \u062a\u0627\u0632\u0647 \u0628\u0647 \u0646\u0627\u0645 \u00ab\u0627\u0626\u062a\u0644\u0627\u0641 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0633\u06cc\u0627\u0633\u06cc \u06a9\u0631\u062f\u0633\u062a\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u00bb \u062a\u0634\u06a9\u06cc\u0644 \u062f\u0627\u062f\u0647\u200c\u0627\u0646\u062f. \u0647\u062f\u0641 \u0627\u06cc\u0646 \u0627\u0626\u062a\u0644\u0627\u0641 \u0647\u0645\u0627\u0647\u0646\u06af \u06a9\u0631\u062f\u0646 \u0641\u0639\u0627\u0644\u06cc\u062a\u200c\u0647\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0648\u0646\u0632\u0648\u0626\u0644\u0627 \u0627\u0632 \u00ab\u0645\u062a\u062d\u062f \u0631\u0627\u0647\u0628\u0631\u062f\u06cc\u00bb \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u00ab\u0634\u0631\u06cc\u06a9\u00bb \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062a\u063a\u06cc\u06cc\u0631 \u062c\u0647\u062a \u0645\u06cc\u200c\u062f\u0647\u062f",
