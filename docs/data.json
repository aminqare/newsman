        {
          "title": "\u0631\u0645\u0632\u06af\u0634\u0627\u06cc\u06cc \u0627\u0632 \u067e\u06cc\u0627\u0645 \u062a\u0631\u0627\u0645\u067e \u067e\u0633 \u0627\u0632 \u062d\u0645\u0644\u0647 \u0628\u0647 \u0645\u06cc\u062f\u0627\u0646 \u06af\u0627\u0632\u06cc \u0627\u06cc\u0631\u0627\u0646\u061b \u0622\u06cc\u0627 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0647\u0645\u0627\u0647\u0646\u06af \u0639\u0645\u0644 \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f\u061f",
