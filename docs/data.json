        {
          "title": "\u0627\u0648\u0644\u06cc\u0627\u0646\u0648\u0641: \u0631\u0648\u0633\u06cc\u0647 \u0622\u0645\u0627\u062f\u0647 \u0645\u06cc\u0627\u0646\u062c\u06cc\u200c\u06af\u0631\u06cc \u0627\u0633\u062a\u060c \u0627\u06cc\u0631\u0627\u0646 \u0645\u0648\u0627\u0641\u0642 \u0627\u0633\u062a\u060c \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0646\u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u062f",
