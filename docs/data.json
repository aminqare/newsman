        {
          "title": "\u0641\u0631\u062f\u06cc \u06a9\u0647 \u0628\u0647 \u062a\u06cc\u0631\u0627\u0646\u062f\u0627\u0632\u06cc \u062f\u0631 \u0636\u06cc\u0627\u0641\u062a \u0634\u0627\u0645 \u062a\u0631\u0627\u0645\u067e \u0645\u062a\u0647\u0645 \u0634\u062f\u0647 \u0627\u0639\u0644\u0627\u0645 \u0628\u06cc\u200c\u06af\u0646\u0627\u0647\u06cc \u06a9\u0631\u062f",
