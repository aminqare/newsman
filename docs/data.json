        {
          "title": "\u062a\u0647\u062f\u06cc\u062f \u0631\u0648\u0633\u06cc\u0647 \u0628\u0631\u0627\u06cc \u062d\u0645\u0644\u0627\u062a \u0628\u06cc\u0634\u062a\u0631 \u0628\u0647 \u06a9\u06cc\u200c\u06cc\u0641 \u0648 \u0647\u0634\u062f\u0627\u0631 \u0628\u0647 \u0627\u062a\u0628\u0627\u0639 \u062e\u0627\u0631\u062c\u06cc \u0628\u0631\u0627\u06cc \u062a\u0631\u06a9 \u0627\u06cc\u0646 \u0634\u0647\u0631",
