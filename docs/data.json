        {
          "title": "\u0628\u062d\u0631\u0627\u0646 \u0646\u0641\u062a\u06cc \u062f\u0647\u0647 \u06f1\u06f9\u06f7\u06f0 \u0686\u0647 \u0628\u0648\u062f \u0648 \u0622\u06cc\u0627 \u062c\u0647\u0627\u0646 \u0627\u06a9\u0646\u0648\u0646 \u0628\u0647 \u0633\u0648\u06cc \u0648\u0636\u0639\u06cc\u062a\u06cc \u0648\u062e\u06cc\u0645\u200c\u062a\u0631 \u0645\u06cc\u200c\u0631\u0648\u062f\u061f",
          "link": "https://www.bbc.com/persian/articles/cgrl5111enpo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0628\u0633\u062a\u0647 \u0634\u062f\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u062f\u0631 \u067e\u06cc \u062c\u0646\u06af\u060c \u0646\u06af\u0631\u0627\u0646\u06cc\u200c\u0647\u0627 \u0627\u0632 \u0627\u062e\u062a\u0644\u0627\u0644 \u0634\u062f\u06cc\u062f \u062f\u0631 \u062a\u0627\u0645\u06cc\u0646 \u0627\u0646\u0631\u0698\u06cc \u0631\u0627 \u0627\u0641\u0632\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0648 \u0628\u0631\u062e\u06cc \u0622\u0646 \u0631\u0627 \u0641\u0631\u0627\u062a\u0631 \u0627\u0632 \u0634\u0648\u06a9 \u062f\u0647\u0647 \u06f1\u06f9\u06f7\u06f0 \u0645\u06cc\u200c\u062f\u0627\u0646\u0646\u062f. \u0622\u0646 \u0628\u062d\u0631\u0627\u0646 \u0628\u0627 \u062a\u062d\u0631\u06cc\u0645 \u0646\u0641\u062a\u06cc \u0648 \u062c\u0647\u0634 \u0642\u06cc\u0645\u062a\u200c\u0647\u0627 \u0631\u06a9\u0648\u062f\u060c \u062a\u0648\u0631\u0645 \u0648 \u0628\u06cc\u06a9\u0627\u0631\u06cc \u06af\u0633\u062a\u0631\u062f\u0647 \u0627\u06cc\u062c\u0627\u062f \u06a9\u0631\u062f. \u0627\u0645\u0631\u0648\u0632 \u0646\u06cc\u0632 \u06a9\u0645\u0628\u0648\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u06af\u0632\u0627\u0631\u0634 \u0628\u06cc\u200c\u0628\u06cc\u200c\u0633\u06cc \u0627\u0632 \u06a9\u0627\u0628\u06cc\u0646 \u0647\u0648\u0627\u067e\u06cc\u0645\u0627\u06cc \u0633\u0648\u062e\u062a\u200c\u0631\u0633\u0627\u0646 \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u062f\u0631 \u0639\u0645\u0644\u06cc\u0627\u062a \u0645\u0642\u0627\u0628\u0644\u0647 \u0628\u0627 \u067e\u0647\u067e\u0627\u062f\u0647\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646",
