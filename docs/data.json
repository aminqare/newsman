        {
          "title": "\u067e\u06cc\u0627\u0645 \u0648\u0632\u06cc\u0631 \u062e\u0627\u0631\u062c\u0647 \u062a\u0631\u06a9\u06cc\u0647 \u062f\u0631 \u0633\u0641\u0631 \u0628\u0647 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u062d\u0627\u0634\u06cc\u0647 \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u0686\u0647 \u0628\u0648\u062f\u061f",
