        {
          "title": "\u0644\u063a\u0648 \u06a9\u0646\u0633\u0631\u062a \u06a9\u0627\u0646\u06cc\u0647 \u0648\u0633\u062a \u062f\u0631 \u0644\u0647\u0633\u062a\u0627\u0646 \u0628\u0647 \u062f\u0644\u06cc\u0644 \u0627\u0638\u0647\u0627\u0631\u0627\u062a \u06cc\u0647\u0648\u062f\u0633\u062a\u06cc\u0632\u0627\u0646\u0647",
