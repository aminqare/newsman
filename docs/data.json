          "title": "\u062a\u0645\u062f\u06cc\u062f \u06f4\u06f5 \u0631\u0648\u0632\u0647 \u0622\u062a\u0634\u200c\u0628\u0633 \u0644\u0628\u0646\u0627\u0646\u061b \u0627\u0633\u0631\u0627\u0626\u06cc\u0644:\u200c \u0639\u0632\u0627\u0644\u062f\u06cc\u0646 \u062d\u062f\u0627\u062f\u060c \u0641\u0631\u0645\u0627\u0646\u062f\u0647 \u0634\u0627\u062e\u0647 \u0646\u0638\u0627\u0645\u06cc \u062d\u0645\u0627\u0633 \u062f\u0631 \u063a\u0632\u0647 \u06a9\u0634\u062a\u0647 \u0634\u062f",
