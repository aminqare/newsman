        {
          "title": "\u00ab\u0632\u0645\u0633\u062a\u0627\u0646 \u0633\u0631\u062e\u00bb\u061b \u0647\u0631\u0627\u0646\u0627 \u0622\u0645\u0627\u0631 \u0628\u06cc\u0634 \u0627\u0632 \u0647\u0641\u062a \u0647\u0632\u0627\u0631 \u06a9\u0634\u062a\u0647\u200c\u0634\u062f\u0647 \u0627\u0639\u062a\u0631\u0627\u0636\u0627\u062a \u062f\u06cc \u06f1\u06f4\u06f0\u06f4 \u0631\u0627 \u0645\u0646\u062a\u0634\u0631 \u06a9\u0631\u062f",
