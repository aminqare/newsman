        {
          "title": "\u062f\u0633\u062a\u0648\u0631 \u062f\u0627\u062f\u0633\u062a\u0627\u0646 \u062a\u0647\u0631\u0627\u0646 \u0628\u0631\u0627\u06cc \u062a\u0648\u0642\u06cc\u0641 \u0627\u0645\u0648\u0627\u0644 \u00ab\u0628\u06cc\u0634 \u0627\u0632 \u06f1\u06f0\u06f0 \u0686\u0647\u0631\u0647\u00bb \u0631\u0633\u0627\u0646\u0647\u200c\u0627\u06cc \u0648 \u062d\u0627\u0645\u06cc \u062c\u0646\u06af",
