        {
          "title": "\u0639\u0631\u0627\u0642\u0686\u06cc: \u0627\u0637\u0644\u0627\u0639 \u062f\u0627\u0634\u062a\u0646 \u0627\u0632 \u062c\u0644\u0633\u0647\u200c\u0647\u0627\u06cc \u0633\u0631\u0627\u0646\u060c \u06cc\u06a9 \u062d\u0641\u0631\u0647 \u0627\u0645\u0646\u06cc\u062a\u06cc \u0627\u0633\u062a \u06a9\u0647 \u0627\u062d\u062a\u0645\u0627\u0644\u0627 \u0647\u0646\u0648\u0632 \u0648\u062c\u0648\u062f \u062f\u0627\u0631\u062f",
