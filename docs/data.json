        {
          "title": "\u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u060c \u0686\u06cc\u0646 \u0648 \u062c\u0627\u0647\u200c\u0637\u0644\u0628\u06cc\u200c\u0647\u0627\u06cc\u0634 \u0631\u0627 \u0628\u0627 \u0645\u0634\u06a9\u0644 \u0631\u0648\u0628\u0647\u200c\u0631\u0648 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a",
