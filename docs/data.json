        {
          "title": "\u062a\u06cc\u0631\u0627\u0646\u062f\u0627\u0632\u06cc \u0645\u0631\u06af\u0628\u0627\u0631 \u062f\u0631 \u0645\u062f\u0627\u0631\u0633 \u062a\u0631\u06a9\u06cc\u0647\u061b \u06f1\u06f6\u06f2 \u0646\u0641\u0631 \u0628\u0647 \u0627\u062a\u0647\u0627\u0645 \u062a\u0645\u062c\u06cc\u062f \u0627\u0632 \u062c\u0631\u0645 \u0648 \u062c\u0646\u0627\u06cc\u062a \u062f\u0631 \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u0628\u0627\u0632\u062f\u0627\u0634\u062a \u0634\u062f\u0646\u062f",
