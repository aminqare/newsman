        {
          "title": "\u067e\u0634\u062a \u067e\u0631\u062f\u0647 \u00ab\u062d\u0631\u0627\u0633\u062a\u00bb \u062f\u0631 \u062a\u06cc\u0645\u200c\u0647\u0627\u06cc \u0648\u0631\u0632\u0634\u06cc \u0627\u06cc\u0631\u0627\u0646\u061b \u0641\u0634\u0627\u0631 \u0631\u0648\u0627\u0646\u06cc\u060c \u0627\u0632 \u062e\u0648\u0627\u0628\u06af\u0627\u0647 \u062a\u0627 \u0632\u0645\u06cc\u0646 \u0628\u0627\u0632\u06cc \u0648 \u0636\u0628\u0637 \u06af\u0630\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627",
