        {
          "title": "\u0646\u0648\u0631\u0648\u0632 \u062f\u0631 \u0633\u0627\u06cc\u0647 \u062c\u0646\u06af\u061b \u00ab\u0645\u06af\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f \u0633\u0627\u0644 \u0646\u0648 \u0628\u062f\u0648\u0646 \u0645\u0648\u0633\u06cc\u0642\u06cc \u0648 \u0622\u0648\u0627\u0632 \u0628\u0627\u0634\u062f\u061f\u00bb",
          "link": "https://www.bbc.com/persian/articles/clyd2rnmp1jo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0628\u06cc\u200c\u0628\u06cc\u200c\u0633\u06cc \u0641\u0627\u0631\u0633\u06cc \u0645\u06cc\u200c\u06a9\u0648\u0634\u062f \u0628\u0627 \u062a\u06a9\u06cc\u0647 \u0628\u0631 \u0631\u0648\u0627\u06cc\u062a \u0627\u0641\u0631\u0627\u062f\u06cc \u062f\u0631 \u062f\u0627\u062e\u0644 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0647\u0645\u0686\u0646\u06cc\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc\u0627\u0646 \u062f\u0631 \u06af\u0648\u0634\u0647\u200c\u0648\u06a9\u0646\u0627\u0631 \u062c\u0647\u0627\u0646\u060c \u062a\u062c\u0631\u0628\u0647 \u0646\u0648\u0631\u0648\u0632 \u062f\u0631 \u0634\u0631\u0627\u06cc\u0637 \u062c\u0646\u06af\u06cc \u0631\u0627 \u0628\u0627\u0632\u062a\u0627\u0628 \u062f\u0647\u062f. \u0627\u0644\u0628\u062a\u0647 \u0627\u06cc\u0646 \u0631\u0648\u0627\u06cc\u062a\u200c\u0647\u0627 \u062a\u0646\u0647\u0627 \u0628\u0627\u0632\u062a\u0627\u0628\u200c\u062f\u0647\u0646\u062f\u0647 \u062a\u062c\u0631\u0628\u0647 \u0628\u062e\u0634 \u06a9\u0648\u0686\u06a9\u06cc \u0627\u0632 \u062c\u0627\u0645\u0639\u0647 \u06af\u0633\u062a\u0631\u062f\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0633\u062a.",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u06cc\u06a9 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0648 \u06cc\u06a9 \u0631\u0648\u0645\u0627\u0646\u06cc\u0627\u06cc\u06cc \u067e\u0633 \u0627\u0632 \u062a\u0644\u0627\u0634 \u0628\u0631\u0627\u06cc \u0648\u0631\u0648\u062f \u0628\u0647 \u0645\u062d\u0644 \u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0632\u06cc\u0631\u062f\u0631\u06cc\u0627\u06cc\u06cc\u200c\u0647\u0627\u06cc \u0647\u0633\u062a\u0647\u200c\u0627\u06cc \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u0628\u0627\u0632\u062f\u0627\u0634\u062a \u0648 \u0631\u0633\u0645\u0627 \u0645\u062a\u0647\u0645 \u0634\u062f\u0646\u062f",
