          "title": "\u062a\u0631\u0627\u0645\u067e \u067e\u06cc\u0634 \u0627\u0632 \u0639\u0632\u06cc\u0645\u062a \u0628\u0647 \u0686\u06cc\u0646: \u06cc\u0627 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u062a\u0648\u0627\u0641\u0642 \u0645\u06cc \u0631\u0633\u06cc\u0645 \u06cc\u0627 \u0646\u0627\u0628\u0648\u062f \u0645\u06cc\u200c\u0634\u0648\u0646\u062f",
