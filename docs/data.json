          "summary": "\u0631\u0626\u06cc\u0633 \u06cc\u06a9\u06cc \u0627\u0632 \u0628\u0632\u0631\u06af\u062a\u0631\u06cc\u0646 \u062a\u0648\u0644\u06cc\u062f\u200c\u06a9\u0646\u0646\u062f\u06af\u0627\u0646 \u06a9\u0648\u062f \u0634\u06cc\u0645\u06cc\u0627\u06cc\u06cc \u062f\u0631 \u062c\u0647\u0627\u0646 \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f\u0647 \u0627\u0633\u062a \u06a9\u0647 \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646\u060c \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u0628\u0631\u0627\u06cc \u062c\u0647\u0627\u0646 \u0647\u0641\u062a\u0647\u200c\u0627\u06cc \u06f1\u06f0 \u0645\u06cc\u0644\u06cc\u0627\u0631\u062f \u0648\u0639\u062f\u0647 \u063a\u0630\u0627 \u0647\u0632\u06cc\u0646\u0647 \u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u062f \u0648 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u0641\u0642\u06cc\u0631 \u0628\u06cc\u0634\u062a\u0631\u06cc\u0646 \u0622\u0633\u06cc\u0628 \u0631\u0627 \u062e\u0648\u0627\u0647\u0646\u062f \u062e\u0648\u0627\u0647\u0646\u062f \u062f\u06cc\u062f.",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0633\u0631\u0646\u0648\u0634\u062a \u062f\u0644\u0627\u0631 \u062f\u0631 \u067e\u06cc \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646\u061b \u0627\u0641\u0648\u0644 \u067e\u062a\u0631\u0648\u062f\u0644\u0627\u0631\u060c \u0637\u0644\u0648\u0639 \u067e\u062a\u0631\u0648 \u06cc\u0648\u0622\u0646\u061f",
          "link": "https://www.bbc.com/persian/articles/c78r8g4pe30o?at_medium=RSS&at_campaign=rss",
          "summary": "\u062d\u0645\u0644\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627\u0631 \u062f\u06cc\u06af\u0631 \u0628\u062d\u062b\u200c\u0647\u0627 \u062f\u0631\u0628\u0627\u0631\u0647 \u0627\u0641\u0648\u0644 \u0642\u0631\u06cc\u0628\u200c\u0627\u0644\u0648\u0642\u0648\u0639 \u062f\u0644\u0627\u0631 \u0628\u0647\u200c\u0639\u0646\u0648\u0627\u0646 \u0627\u0631\u0632 \u0630\u062e\u06cc\u0631\u0647 \u0648 \u0645\u0628\u0627\u062f\u0644\u0627\u062a\u06cc \u062c\u0647\u0627\u0646 \u0631\u0627 \u0632\u0646\u062f\u0647 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0627\u06cc\u0631\u0627\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0645\u0633\u062f\u0648\u062f \u06a9\u0631\u062f\u0647 \u0648 \u0627\u0632 \u0646\u0641\u062a\u06a9\u0634\u200c\u0647\u0627 \u0628\u0627 \u06cc\u0648\u0622\u0646 \u0686\u06cc\u0646 \u0648 \u0627\u0633\u062a\u06cc\u0628\u0644\u200c\u06a9\u0648\u06cc\u0646\u200c\u0647\u0627 \u0639\u0648\u0627\u0631\u0636 \u062f\u0631\u06cc\u0627\u0641\u062a \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u062a\u0647\u062f\u06cc\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u062f\u0631\u062e\u0648\u0627\u0633\u062a \u0627\u0632 \u0645\u062a\u062e\u0635\u0635\u0627\u0646 \u0627\u0648\u06a9\u0631\u0627\u06cc\u0646\u06cc \u0628\u0631\u0627\u06cc \u06a9\u0645\u06a9 \u0628\u0647 \u0639\u0628\u0648\u0631 \u06a9\u0634\u062a\u06cc \u0627\u0632 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u061b \u0622\u06cc\u0627 \u06a9\u06cc\u200c\u06cc\u0641 \u0627\u062c\u0627\u0632\u0647 \u0645\u06cc\u200c\u062f\u0647\u062f\u061f",
