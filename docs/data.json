        {
          "title": "\u062c\u0627\u0645\u0639\u0647 \u062c\u0647\u0627\u0646\u06cc \u0628\u0647\u0627\u0626\u06cc: \u067e\u06cc\u0648\u0646\u062f \u0646\u0639\u06cc\u0645\u06cc \u0628\u0639\u062f \u0627\u0632 \u062f\u0648 \u0628\u0627\u0631 \u0627\u0639\u062f\u0627\u0645 \u0646\u0645\u0627\u06cc\u0634\u06cc \u062f\u0631 \u0632\u0646\u062f\u0627\u0646 \u06a9\u0631\u0645\u0627\u0646 \u062f\u0631 \u0645\u0639\u0631\u0636 \u062e\u0637\u0631 \u062c\u062f\u06cc \u0627\u0633\u062a",
