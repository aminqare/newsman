        {
          "title": "\u0646\u0627\u067e\u062f\u06cc\u062f \u0634\u062f\u0646 \u06f2\u06f5\u06f0 \u0645\u0633\u0627\u0641\u0631 \u0642\u0627\u06cc\u0642 \u0645\u0647\u0627\u062c\u0631\u0627\u0646 \u062f\u0631 \u0627\u0642\u06cc\u0627\u0646\u0648\u0633 \u0647\u0646\u062f",
