        {
          "title": "\u0634\u06cc\u0648\u0647 \u0628\u0631\u06af\u0632\u0627\u0631\u06cc \u0646\u0634\u0633\u062a\u200c\u0647\u0627\u06cc \u062e\u0628\u0631\u06cc\u200c \u0648\u0632\u06cc\u0631 \u062f\u0641\u0627\u0639 \u0622\u0645\u0631\u06cc\u06a9\u0627\u061b  \u00ab\u0628\u0647\u200c\u0634\u062f\u062a \u062a\u0646\u0638\u06cc\u0645 \u0648 \u06a9\u0646\u062a\u0631\u0644\u200c\u0634\u062f\u0647\u00bb",
