          "title": "\u062a\u0631\u0627\u0645\u067e: \u062a\u0648\u0627\u0641\u0642 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u06cc\u06a9\u0634\u0646\u0628\u0647 \u0627\u0645\u0636\u0627 \u0648 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0641\u0648\u0631\u06cc \u0628\u0627\u0632 \u0645\u06cc\u200c\u0634\u0648\u062f",
          "link": "https://www.bbc.co.uk/persian/live/c932grgrw12t?at_medium=RSS&at_campaign=rss",
          "summary": "\u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u0645\u0648\u0631\u062f \u0632\u0645\u0627\u0646 \u0627\u0645\u0636\u0627\u06cc \u062a\u0641\u0627\u0647\u0645\u200c\u0646\u0627\u0645\u0647 \u0635\u0644\u062d \u0627\u0638\u0647\u0627\u0631\u0627\u062a \u0636\u062f\u200c\u0648\u200c\u0646\u0642\u06cc\u0636\u06cc \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f. \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u062a\u0641\u0627\u0647\u0645\u200c\u0646\u0627\u0645\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0642\u0631\u0627\u0631 \u0627\u0633\u062a \u06cc\u06a9\u0634\u0646\u0628\u0647 \u0627\u0645\u0636\u0627 \u0634\u0648\u062f \u0648 \u0633\u067e\u0633 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0641\u0648\u0631\u06cc \u0628\u0627\u0632 \u0645\u06cc\u200c\u0634\u0648\u062f. \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0647\u0645 \u067e\u06cc\u0634\u062a\u0631 \u06af\u0641\u062a\u0647 \u0628\u0648\u062f \u06a9\u0647 \u0627\u06cc\u0646 \u062a\u2026",
