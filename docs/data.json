        {
          "title": "\ud83d\udd34 \u0645\u0631\u06a9\u0632 \u0622\u0645\u0627\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u062a\u0648\u0631\u0645 \u06f1\u06f1\u06f5 \u062f\u0631\u0635\u062f\u06cc \u0645\u0648\u0627\u062f \u063a\u0630\u0627\u06cc\u06cc \u062e\u0628\u0631 \u062f\u0627\u062f\u061b \u062e\u0627\u0645\u0648\u0634\u06cc \u062f\u06cc\u062c\u06cc\u062a\u0627\u0644 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u0645\u0631\u0632 \u0647\u0632\u0627\u0631 \u0648 \u06f5\u06f0\u06f0 \u0633\u0627\u0639\u062a \u0631\u0633\u06cc\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0645\u0631\u06a9\u0632 \u0622\u0645\u0627\u0631 \u0627\u06cc\u0631\u0627\u0646 \u062a\u0648\u0631\u0645 \u0645\u0648\u0627\u062f \u063a\u0630\u0627\u06cc\u06cc \u062f\u0631 \u0641\u0631\u0648\u0631\u062f\u06cc\u0646 \u0627\u0645\u0633\u0627\u0644 \u0646\u0633\u0628\u062a \u0628\u0647 \u0645\u0627\u0647 \u0645\u0634\u0627\u0628\u0647 \u067e\u0627\u0631\u0633\u0627\u0644 (\u062a\u0648\u0631\u0645 \u0646\u0642\u0637\u0647 \u0628\u0647 \u0646\u0642\u0637\u0647) \u0631\u0627 \u06f1\u06f1\u06f5 \u062f\u0631\u0635\u062f \u0628\u0631\u0622\u0648\u0631\u062f \u06a9\u0631\u062f. \u062f\u0631 \u062a\u062d\u0648\u0644\u06cc \u062f\u06cc\u06af\u0631\u060c\u200c \u062e\u0627\u0645\u0648\u0634\u06cc \u062f\u06cc\u062c\u06cc\u062a\u0627\u0644 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0648\u0627\u0631\u062f \u0634\u0635\u062a \u0648 \u0633\u0648\u0645\u06cc\u0646 \u0631\u0648\u0632 \u062e\u0648\u062f \u0634\u062f \u0648 \u0634\u0647\u0631\u0648\u0646\u062f\u0627\u0646 \u0646\u0632\u062f\u06cc\u06a9 \u0628\u0647 \u0647\u0632\u0627\u0631 \u0648 \u06f5\u06f0\u06f0 \u0633\u0627\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
