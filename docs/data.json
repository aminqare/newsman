        {
          "title": "\u0628\u062d\u0631\u0627\u0646 \u0633\u0648\u062e\u062a\u061b \u06a9\u0627\u0631\u0648\u0627\u0646 \u0622\u0647\u0633\u062a\u0647\u200c\u0631\u0648 \u062a\u0631\u0627\u06a9\u062a\u0648\u0631 \u062a\u0631\u062f\u062f \u0631\u0627 \u062f\u0631 \u0628\u0644\u0641\u0627\u0633\u062a \u0645\u062e\u062a\u0644 \u06a9\u0631\u062f",
