          "summary": "\u06cc\u06a9 \u0631\u0648\u0632 \u0628\u0639\u062f \u0627\u0632 \u0627\u0645\u0636\u0627\u06cc \u062a\u0641\u0627\u0647\u0645\u0646\u0627\u0645\u0647 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646\u060c \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u06af\u0641\u062a\u0647 \u0627\u0646\u062a\u0638\u0627\u0631 \u062f\u0627\u0631\u062f \u0622\u062a\u0634\u200c\u0628\u0633 \u062f\u0631 \u0647\u0645\u0647 \u062c\u0628\u0647\u0647\u200c\u0647\u0627 \u0627\u0632 \u062c\u0645\u0644\u0647 \u0644\u0628\u0646\u0627\u0646 \u0631\u0639\u0627\u06cc\u062a \u0634\u0648\u062f. \u062f\u0631 \u062d\u0627\u0644\u06cc \u06a9\u0647 \u062f\u0631 \u062f\u0627\u062e\u0644 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648\u0627\u06a9\u0646\u0634\u200c\u0647\u0627 \u0627\u063a\u0644\u0628 \u0628\u0647 \u0645\u0641\u0627\u062f \u0627\u0645\u062a\u06cc\u0627\u0632\u0627\u062a \u0627\u0642\u062a\u0635\u0627\u062f\u06cc \u0648 \u0628\u0631\u0646\u0627\u0645\u0647 \u0647\u0633\u062a\u0647\u200c\u0627\u06cc \u062f\u0631 \u062a\u0641\u0627\u0647\u0645\u0646\u0627\u0645\u0647 \u0628\u0627 \u0627\u06cc\u0631\u0627\u2026",
