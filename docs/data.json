          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u00ab\u0644\u062d\u0638\u0627\u062a\u06cc \u067e\u06cc\u0634 \u0648 \u0628\u0647 \u062f\u0633\u062a\u0648\u0631 \u0645\u0646\u060c \u0641\u0631\u0645\u0627\u0646\u062f\u0647\u06cc \u0645\u0631\u06a9\u0632\u06cc \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u06cc\u06a9\u06cc \u0627\u0632 \u0642\u062f\u0631\u062a\u0645\u0646\u062f\u062a\u0631\u06cc\u0646 \u062d\u0645\u0644\u0627\u062a \u0647\u0648\u0627\u06cc\u06cc \u062f\u0631 \u062a\u0627\u0631\u06cc\u062e \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0631\u0627 \u0627\u062c\u0631\u0627 \u06a9\u0631\u062f \u0648 \u062a\u0645\u0627\u0645\u06cc \u0627\u0647\u062f\u0627\u0641 \u0646\u0638\u0627\u0645\u06cc \u062f\u0631 \u062c\u0632\u06cc\u0631\u0647 \u062e\u0627\u0631\u06a9\u060c \u06a9\u0647 \u0628\u0647\u200c\u0646\u0648\u0639\u06cc \u0645\u0647\u0645\u200c\u062a\u0631\u06cc\u0646 \u062f\u0627\u0631\u0627\u2026",
