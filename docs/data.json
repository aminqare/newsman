        {
          "title": "\u0686\u0631\u0627 \u062a\u0631\u06a9\u06cc\u0647 \u0646\u06af\u0631\u0627\u0646 \u0622\u0634\u0648\u0628 \u062f\u0631 \u0645\u0631\u0632\u0647\u0627\u06cc\u0634 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0633\u062a\u061f",
