        {
          "title": "\u062a\u0631\u0627\u0645\u067e: \u0645\u0630\u0627\u06a9\u0631\u0647 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u062f\u0631 \u062f\u0648 \u0631\u0648\u0632 \u0622\u06cc\u0646\u062f\u0647 \u0634\u0631\u0648\u0639 \u0634\u0648\u062f\u061b \u0648\u0646\u0633: \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u062f\u0646\u0628\u0627\u0644 \u00ab\u062a\u0648\u0627\u0641\u0642 \u0628\u0632\u0631\u06af\u00bb \u0628\u0627 \u062a\u0647\u0631\u0627\u0646 \u0627\u0633\u062a",
