        {
          "title": "\u06af\u0631\u0648\u0647 \u0627\u06cc\u060c \u0628\u06cc\u060c \u0633\u06cc \u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc: \u0645\u06a9\u0632\u06cc\u06a9 \u0628\u0647 \u062f\u0646\u0628\u0627\u0644 \u0628\u0627\u0632\u06af\u0634\u062a \u0628\u0647 \u0627\u0648\u062c\u060c \u0642\u0637\u0631 \u062f\u0631 \u062a\u0644\u0627\u0634 \u0628\u0631\u0627\u06cc \u0641\u0631\u0627\u0645\u0648\u0634 \u06a9\u0631\u062f\u0646 \u062c\u0627\u0645 \u0642\u0628\u0644\u06cc \u0648 \u0645\u0647\u0627\u062c\u0645 \u0627\u0633\u062a\u0642\u0644\u0627\u0644 \u062a\u0647\u0631\u0627\u0646 \u0645\u0642\u0627\u0628\u0644 \u0633\u062a\u0627\u0631\u0647\u200c\u0647\u0627\u06cc \u0628\u0631\u0632\u06cc\u0644",
