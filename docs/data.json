          "summary": "\u0627\u06cc\u0631\u0627\u0646 \u06af\u0641\u062a \u06a9\u0647 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u062a\u0627 \u067e\u0627\u06cc\u0627\u0646 \u0622\u062a\u0634\u200c\u0628\u0633 \u0644\u0628\u0646\u0627\u0646 \u0628\u0631\u0627\u06cc \u062a\u0645\u0627\u0645 \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627\u06cc \u062a\u062c\u0627\u0631\u06cc \u0628\u0627\u0632 \u0645\u06cc\u200c\u06a9\u0646\u062f. \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u0628\u0627 \u062a\u0634\u06a9\u0631 \u0627\u0632 \u0627\u06cc\u0631\u0627\u0646\u060c\u200c \u0627\u0632 \u0627\u062f\u0627\u0645\u0647 \u0645\u0630\u0627\u06a9\u0631\u0647 \u0648 \u0627\u062d\u062a\u0645\u0627\u0644 \u062a\u0648\u0627\u0641\u0642 \u0628\u0627 \u062a\u0647\u0631\u0627\u0646 \u06af\u0641\u062a \u0627\u0645\u0627 \u062a\u0627\u06a9\u06cc\u062f \u06a9\u0631\u062f \u06a9\u0647 \u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0628\u0646\u0627\u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u062a\u0627 \u062f\u0633\u062a\u06cc\u0627\u0628\u06cc \u0628\u0647 \u062a\u2026",
