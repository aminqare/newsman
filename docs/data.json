        {
          "title": "\u062d\u0645\u0644\u0647 \u0647\u0648\u0627\u06cc\u06cc \u0628\u0647 \u0641\u0631\u0648\u062f\u06af\u0627\u0647 \u0645\u0647\u0631\u0622\u0628\u0627\u062f \u0648 \u062d\u0645\u0644\u0647 \u067e\u0647\u067e\u0627\u062f\u06cc \u0628\u0647 \u0646\u0632\u062f\u06cc\u06a9\u06cc \u0641\u0631\u0648\u062f\u06af\u0627\u0647 \u062f\u0648\u0628\u06cc",
          "link": "https://www.bbc.co.uk/persian/live/cy03r0r3p5lt?at_medium=RSS&at_campaign=rss",
          "summary": "\u0628\u0627\u0645\u062f\u0627\u062f \u0647\u0641\u062f\u0647\u0645\u06cc\u0646 \u0631\u0648\u0632 \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0647\u0645 \u0628\u0627 \u062d\u0645\u0644\u0627\u062a \u0633\u0646\u06af\u06cc\u0646 \u0647\u0648\u0627\u06cc\u06cc \u0628\u0647 \u062a\u0647\u0631\u0627\u0646 \u0622\u063a\u0627\u0632 \u0634\u062f \u0648 \u0647\u0645\u0632\u0645\u0627\u0646 \u062f\u0631 \u0639\u0631\u0628\u0633\u062a\u0627\u0646 \u0648 \u0642\u0637\u0631 \u062f\u0648 \u0631\u0648\u06cc\u062f\u0627\u062f \u0628\u0632\u0631\u06af \u0648\u0631\u0632\u0634\u06cc \u0628\u0647 \u0639\u0644\u062a \u0646\u0627\u0627\u0645\u0646\u06cc \u062f\u0631 \u0645\u0646\u0637\u0642\u0647 \u0644\u063a\u0648 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0633\u0627\u0639\u062a\u06cc \u0628\u0639\u062f \u0627\u0632 \u0627\u0646\u062a\u0634\u0627\u0631 \u062a\u0635\u0627\u0648\u06cc\u0631\u06cc \u0645\u0646\u062a\u0633\u0628 \u0628\u0647 \u062d\u0645\u0644\u0647 \u0647\u0648\u0627\u06cc\u2026",
