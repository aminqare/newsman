        {
          "title": "\u0646\u0631\u06af\u0633 \u0645\u062d\u0645\u062f\u06cc \u0627\u0632 \u0632\u0646\u062f\u0627\u0646 \u0632\u0646\u062c\u0627\u0646 \u0628\u0647 \u0628\u06cc\u0645\u0627\u0631\u0633\u062a\u0627\u0646 \u0627\u0639\u0632\u0627\u0645 \u0634\u062f",
          "link": "https://www.bbc.com/persian/articles/cdxpvk7p42po?at_medium=RSS&at_campaign=rss",
          "summary": "\u0646\u0631\u06af\u0633 \u0645\u062d\u0645\u062f\u06cc\u060c \u0628\u0631\u0646\u062f\u0647 \u062c\u0627\u06cc\u0632\u0647 \u0635\u0644\u062d \u0646\u0648\u0628\u0644\u060c \u0627\u0632 \u0632\u0646\u062f\u0627\u0646 \u0632\u0646\u062c\u0627\u0646 \u0628\u0647 \u0628\u06cc\u0645\u0627\u0631\u0633\u062a\u0627\u0646 \u0627\u0639\u0632\u0627\u0645 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0645\u0635\u0637\u0641\u06cc \u0646\u06cc\u0644\u06cc\u060c \u0648\u06a9\u06cc\u0644 \u062e\u0627\u0646\u0645 \u0645\u062d\u0645\u062f\u06cc\u060c \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u062f\u0644\u06cc\u0644 \u0627\u06cc\u0646 \u0627\u0639\u0632\u0627\u0645 \u00ab\u0646\u0648\u0633\u0627\u0646\u0627\u062a \u0634\u062f\u06cc\u062f \u0641\u0634\u0627\u0631 \u062e\u0648\u0646 \u0648 \u0627\u0641\u062a \u0646\u0627\u06af\u0647\u0627\u0646\u06cc \u0622\u0646\u00bb \u0628\u0648\u062f\u0647 \u0627\u0633\u062a.",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
