        {
          "title": "\u062a\u0631\u0627\u0645\u067e: \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062a\u0627 \u0632\u0645\u0627\u0646 \u0627\u062c\u0631\u0627\u06cc \u062a\u0648\u0627\u0641\u0642 \u00ab\u0648\u0627\u0642\u0639\u06cc\u00bb \u062d\u0627\u0635\u0644 \u0634\u062f\u0647\u060c \u062f\u0631 \u0627\u0637\u0631\u0627\u0641 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627\u0642\u06cc \u0645\u06cc\u200c\u0645\u0627\u0646\u0646\u062f",
          "link": "https://www.bbc.co.uk/persian/live/cd7jr7w139dt?at_medium=RSS&at_campaign=rss",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u062a\u0627 \u0632\u0645\u0627\u0646 \u0639\u0645\u0644 \u06a9\u0631\u062f\u0646 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u00ab\u062a\u0648\u0627\u0641\u0642 \u0648\u0627\u0642\u0639\u06cc \u062d\u0627\u0635\u0644 \u0634\u062f\u0647\u00bb\u060c \u062a\u0645\u0627\u0645 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0646\u0638\u0627\u0645\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u0645\u0646\u0637\u0642\u0647 \u0628\u0627\u0642\u06cc \u0645\u06cc\u200c\u0645\u0627\u0646\u0646\u062f. \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u06af\u0641\u062a \u06a9\u0647 \u00ab\u0628\u0633\u06cc\u0627\u0631 \u0628\u0639\u06cc\u062f \u0627\u0633\u062a\u00bb \u06a9\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u0686\u0646\u06cc\u0646 \u062a\u0648\u0627\u0641\u0642\u06cc \u0639\u0645\u0644 \u0646\u06a9\u0646\u062f \u0627\u0645\u0627 \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f \u06a9\u0647 \u0627\u06af\u0631\u2026",
