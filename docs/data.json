        {
          "title": "\u0642\u0627\u0644\u06cc\u0628\u0627\u0641 \u062f\u0631 \u0648\u0627\u06a9\u0646\u0634 \u0628\u0647 \u0627\u062f\u0639\u0627\u06cc \u062a\u0631\u0627\u0645\u067e \u062f\u0631\u0628\u0627\u0631\u0647 \u0645\u0630\u0627\u06a9\u0631\u0647\u061b \u0622\u0631\u0632\u0648\u0647\u0627\u06cc \u062e\u0648\u062f \u0631\u0627 \u062f\u0631 \u0642\u0627\u0644\u0628 \u062e\u0628\u0631 \u0637\u0631\u062d \u0645\u06cc\u200c\u06a9\u0646\u062f",
          "link": "https://www.bbc.co.uk/persian/live/c1l9mn8lejrt?at_medium=RSS&at_campaign=rss",
          "summary": "\u062f\u0631 \u062d\u0627\u0644\u06cc \u06a9\u0647 \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u0648 \u06a9\u0627\u062e\u200c\u0633\u0641\u06cc\u062f \u062a\u0627\u06a9\u06cc\u062f \u062f\u0627\u0631\u0646\u062f \u06a9\u0647 \u062f\u0631 \u062d\u0627\u0644 \u00ab\u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u062c\u062f\u06cc \u0648 \u0645\u0646\u0637\u0642\u06cc\u00bb \u0628\u0627 \u062d\u0627\u06a9\u0645\u06cc\u062a \u062c\u062f\u06cc\u062f \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0647\u0633\u062a\u0646\u062f\u060c \u0645\u062d\u0645\u062f\u0628\u0627\u0642\u0631 \u0642\u0627\u0644\u06cc\u0628\u0627\u0641\u060c \u0631\u0626\u06cc\u0633 \u0645\u062c\u0644\u0633 \u0634\u0648\u0631\u0627\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062a\u0644\u0648\u06cc\u062d\u0627 \u06af\u0641\u062a\u0647 \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u00ab\u0622\u0631\u0632\u0648\u0647\u0627\u06cc \u062e\u0648\u062f \u0631\u0627 \u062f\u0631 \u0642\u0627\u0644\u0628 \u062e\u0628\u0631 \u0645\u0637\u0631\u062d \u0645\u06cc\u200c\u06a9\u0646\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u06a9\u0627\u0631\u0634\u0646\u0627\u0633\u0627\u0646 \u0627\u062d\u062a\u0645\u0627\u0644 \u0645\u06cc\u200c\u062f\u0647\u0646\u062f \u06cc\u06a9 \u0645\u0648\u0634\u06a9 \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u062f\u0631 \u062d\u0645\u0644\u0647 \u0645\u0631\u06af\u0628\u0627\u0631 \u0628\u0647 \u0644\u0627\u0645\u0631\u062f \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u06a9\u0627\u0631 \u0631\u0641\u062a\u0647 \u0627\u0633\u062a",
          "link": "https://www.bbc.com/persian/articles/c75kdq4995eo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0627\u06cc\u0646 \u06af\u0632\u0627\u0631\u0634 \u0628\u0647 \u062d\u0645\u0644\u0647\u200c\u0627\u06cc \u0645\u0631\u06af\u0628\u0627\u0631 \u0628\u0647 \u0634\u0647\u0631 \u0644\u0627\u0645\u0631\u062f \u0645\u06cc\u200c\u067e\u0631\u062f\u0627\u0632\u062f \u06a9\u0647 \u0628\u0647 \u06af\u0641\u062a\u0647 \u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u062f\u0648\u0644\u062a\u06cc \u0627\u06cc\u0631\u0627\u0646 \u062f\u0633\u062a\u200c\u06a9\u0645 \u06f2\u06f1 \u06a9\u0634\u062a\u0647 \u0628\u0631\u062c\u0627\u06cc \u06af\u0630\u0627\u0634\u062a. \u062a\u062d\u0644\u06cc\u0644 \u062a\u0635\u0627\u0648\u06cc\u0631 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u0627\u062d\u062a\u0645\u0627\u0644\u0627\u0627 \u0627\u0632 \u0645\u0648\u0634\u06a9 \u062a\u0647\u0627\u062c\u0645\u06cc \u062f\u0642\u06cc\u0642 (\u067e\u06cc\u200c\u0622\u0631\u200c\u0627\u0633\u200c\u0627\u0645)\u060c \u06cc\u06a9 \u0633\u0644\u0627\u062d \u062f\u0648\u0631\u0628\u0631\u062f \u062c\u062f\u06cc\u062f \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc\u060c \u062f\u0631 \u0627\u06cc\u0646 \u062d\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u00ab\u0627\u06cc\u0631\u0627\u0646 \u0627\u0635\u0644\u0627 \u0628\u0631\u0627\u06cc \u0622\u0646\u200c\u0647\u0627 \u0627\u0647\u0645\u06cc\u062a\u06cc \u0646\u062f\u0627\u0631\u062f\u00bb\u061b \u062f\u0648\u06af\u0627\u0646\u06af\u06cc \u0646\u06af\u0627\u0647\u200c\u0647\u0627 \u0628\u0647 \u062c\u0646\u06af \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646",
          "link": "https://www.bbc.com/persian/articles/cx2w6eelzedo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0648\u0627\u06cc\u062a\u200c\u0647\u0627\u06cc \u0631\u0633\u06cc\u062f\u0647 \u0627\u0632 \u062f\u0627\u062e\u0644 \u0627\u06cc\u0631\u0627\u0646 \u0646\u0634\u0627\u0646\u200c\u062f\u0647\u0646\u062f\u0647 \u0637\u06cc\u0641\u06cc \u0627\u0632 \u0627\u062d\u0633\u0627\u0633\u0627\u062a \u0645\u062a\u0646\u0627\u0642\u0636 \u062f\u0631\u0628\u0627\u0631\u0647 \u062c\u0646\u06af \u0627\u0633\u062a\u061b \u0627\u0632 \u062a\u0631\u0633 \u0648 \u0627\u0636\u0637\u0631\u0627\u0628 \u0639\u0645\u06cc\u0642 \u0646\u0633\u0628\u062a \u0628\u0647 \u0622\u06cc\u0646\u062f\u0647 \u0648 \u0641\u0634\u0627\u0631\u0647\u0627\u06cc \u0627\u0642\u062a\u0635\u0627\u062f\u06cc \u0648 \u0627\u0645\u0646\u06cc\u062a\u06cc\u060c \u062a\u0627 \u062e\u0634\u0645\u060c \u0646\u0627\u0627\u0645\u06cc\u062f\u06cc \u0648 \u062d\u062a\u06cc \u062d\u0645\u0627\u06cc\u062a \u0628\u0631\u062e\u06cc \u0627\u0632 \u0627\u062f\u0627\u0645\u0647 \u062f\u0631\u06af\u06cc\u0631\u06cc. \u062f\u0631 \u0647\u0645\u06cc\u0646 \u062d\u0627\u0644 \u0627\u062e\u062a\u0644\u0627\u0644 \u0634\u062f\u06cc\u062f \u0627\u06cc\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u062c\u0631\u0645\u06cc \u0628\u0648\u0626\u0646: \u062a\u0631\u0627\u0645\u067e \u0628\u0631 \u0627\u0633\u0627\u0633 \u063a\u0631\u06cc\u0632\u0647 \u062c\u0646\u06af \u0631\u0627 \u067e\u06cc\u0634 \u0645\u06cc\u200c\u0628\u0631\u062f \u0648 \u0627\u06cc\u0646 \u0631\u0648\u0634 \u062c\u0648\u0627\u0628 \u0646\u062f\u0627\u062f\u0647 \u0627\u0633\u062a",
          "link": "https://www.bbc.com/persian/articles/c05dm320gdgo?at_medium=RSS&at_campaign=rss",
          "summary": "\u062c\u0631\u0645\u06cc \u0628\u0648\u0626\u0646\u060c \u0633\u0631\u062f\u0628\u06cc\u0631 \u0628\u06cc\u0646\u200c\u0627\u0644\u0645\u0644\u0644 \u0628\u06cc\u200c\u0628\u06cc\u200c\u0633\u06cc\u060c \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u062c\u0646\u06af \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u0628\u06cc\u0634\u062a\u0631 \u0628\u0631 \u0627\u0633\u0627\u0633 \u063a\u0631\u06cc\u0632\u0647 \u067e\u06cc\u0634 \u0645\u06cc\u200c\u0628\u0631\u062f \u062a\u0627 \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0631\u06cc\u0632\u06cc \u0631\u0627\u0647\u0628\u0631\u062f\u06cc\u060c \u0648 \u0627\u06cc\u0646 \u0631\u0648\u06cc\u06a9\u0631\u062f \u0628\u0627 \u0648\u0627\u0642\u0639\u06cc\u062a\u200c\u0647\u0627\u06cc \u0645\u06cc\u062f\u0627\u0646 \u062c\u0646\u06af \u0647\u0645\u062e\u0648\u0627\u0646\u06cc \u0646\u062f\u0627\u0631\u062f. \u0628\u0647 \u06af\u0641\u062a\u0647 \u0627\u0648\u060c \u0628\u0631\u062e\u0644\u0627\u0641 \u0627\u0646\u062a\u0638\u0627\u0631\u060c \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0627\u0632 \u062a\u0646\u0634 \u0628\u0627 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0631 \u0633\u0631 \u0627\u06cc\u0631\u0627\u0646 \u062e\u0628\u0631 \u0645\u06cc\u200c\u062f\u0647\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/cx2d858dg58o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u06cc \u0645\u06cc\u200c\u06af\u0648\u06cc\u0646\u062f \u062f\u0631 \u062d\u0627\u0644\u06cc\u200c \u06a9\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u062e\u0648\u0627\u0647\u0627\u0646 \u062d\u0645\u0644\u0647 \u0628\u0647 \u0632\u06cc\u0631\u0633\u0627\u062e\u062a\u200c\u0647\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0627\u0633\u062a\u060c \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0647\u0645\u0686\u0646\u0627\u0646 \u0628\u0631 \u062f\u0627\u062f\u0646 \u0641\u0631\u0635\u062a \u0628\u0647 \u0645\u0633\u06cc\u0631 \u062f\u06cc\u067e\u0644\u0645\u0627\u062a\u06cc\u06a9 \u062a\u0627\u06a9\u06cc\u062f \u062f\u0627\u0631\u062f. \u0647\u0645\u200c\u0632\u0645\u0627\u0646\u060c \u06af\u0632\u0627\u0631\u0634\u200c\u0647\u0627\u06cc\u06cc \u0627\u0632 \u0631\u0627\u06cc\u0632\u0646\u06cc\u200c\u0647\u0627\u06cc \u0641\u0634\u0631\u062f\u0647 \u0628\u0631\u0627\u06cc \u0647\u0645\u0627\u0647\u0646\u06af\u06cc \u062f\u0631 \u0635\u0648\u0631\u062a \u0634\u06a9\u0633\u062a \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0645\u0646\u2026",
