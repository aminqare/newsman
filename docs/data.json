          "title": "\u0633\u0641\u0631 \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u0686\u06cc\u0646\u061b \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0634\u0627\u06cc\u062f \u062d\u062a\u06cc \u0645\u0647\u0645\u062a\u0631 \u0627\u0632 \u062c\u0646\u06af \u062a\u062c\u0627\u0631\u06cc",
