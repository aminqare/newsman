        {
          "title": "\u062c\u0646\u06af \u0633\u0627\u06cc\u0628\u0631\u06cc \u0686\u0647 \u0646\u0642\u0634\u06cc \u062f\u0631 \u062f\u0631\u06af\u06cc\u0631\u06cc \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0627\u0634\u062a\u0647 \u0627\u0633\u062a\u061f",
