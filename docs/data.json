        {
          "title": "\u062d\u0645\u0644\u0647 \u0628\u0647 \u06a9\u0634\u062a\u06cc \u062a\u0627\u06cc\u0644\u0646\u062f\u06cc\u061b \u0628\u0627\u0646\u06a9\u0648\u06a9 \u0633\u0641\u06cc\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u0627\u062d\u0636\u0627\u0631 \u06a9\u0631\u062f",
          "link": "https://www.bbc.co.uk/persian/live/cev7mk7g7n7t?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u062a\u0627\u06cc\u0644\u0646\u062f \u06af\u0632\u0627\u0631\u0634 \u06a9\u0631\u062f\u0647\u200c\u0627\u0646\u062f \u06a9\u0647 \u062f\u0631 \u067e\u06cc \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0646 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u0628\u0627\u0631\u06cc \u062a\u0627\u06cc\u0644\u0646\u062f\u06cc\u060c \u0648\u0632\u0627\u0631\u062a \u062e\u0627\u0631\u062c\u0647 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631\u060c \u0633\u0641\u06cc\u0631 \u062a\u0647\u0631\u0627\u0646 \u062f\u0631 \u0628\u0627\u0646\u06a9\u0648\u06a9 \u0631\u0627 \u0627\u062d\u0636\u0627\u0631 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0631\u0648\u0632 \u06af\u0630\u0634\u062a\u0647 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u0628\u0627 \u067e\u0631\u0686\u0645 \u062a\u0627\u06cc\u0644\u0646\u062f \u0647\u0646\u06af\u0627\u0645 \u0639\u0628\u0648\u0631 \u0627\u0632 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a \u0648 \u0646\u06cc\u0631\u0648\u06cc\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0631\u0648\u0633\u06cc\u0647 \u0628\u0647\u200c\u062f\u0646\u0628\u0627\u0644 \u06a9\u0633\u0628 \u0627\u0645\u062a\u06cc\u0627\u0632\u0647\u0627\u06cc \u062f\u06cc\u067e\u0644\u0645\u0627\u062a\u06cc\u06a9 \u0648 \u0627\u0642\u062a\u0635\u0627\u062f\u06cc \u0627\u0632 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0627\u0633\u062a",
          "link": "https://www.bbc.com/persian/articles/ce8wl0nj047o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0627\u06cc\u0646 \u0627\u062a\u0641\u0627\u0642 \u062d\u0627\u0644\u0627 \u062f\u0631 \u0637\u0648\u0644 \u06cc\u06a9 \u0647\u0641\u062a\u0647 \u062f\u0648 \u0628\u0627\u0631 \u0631\u062e \u062f\u0627\u062f\u0647 \u0627\u0633\u062a. \u06cc\u06a9 \u06af\u0641\u062a\u200c\u0648\u06af\u0648\u06cc \u062a\u0644\u0641\u0646\u06cc \u0645\u06cc\u0627\u0646 \u0631\u0648\u0633\u0627\u06cc \u062c\u0645\u0647\u0648\u0631 \u0631\u0648\u0633\u06cc\u0647 \u0648 \u0627\u06cc\u0631\u0627\u0646. \u062f\u0631 \u062d\u0627\u0644\u06cc \u06a9\u0647 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u062d\u0645\u0644\u0627\u062a \u062e\u0648\u062f \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0627\u062f\u0627\u0645\u0647 \u0645\u06cc\u200c\u062f\u0647\u0646\u062f\u060c \u0648\u0644\u0627\u062f\u06cc\u0645\u06cc\u0631 \u067e\u0648\u062a\u06cc\u0646\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0631\u0648\u0633\u06cc\u0647\u060c \u062f\u0631 \u062d\u0627\u0644 \u0627\u0631\u0627\u0626\u0647 \u062a\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0627\u062d\u062a\u06cc\u0627\u0637 \u0686\u06cc\u0646 \u062f\u0631 \u0642\u0628\u0627\u0644 \u062c\u0627\u0646\u0634\u06cc\u0646\u06cc \u0645\u062c\u062a\u0628\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc \u0648 \u062d\u0645\u0627\u06cc\u062a \u0627\u0632 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u0639\u0631\u0628 \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633",
          "link": "https://www.bbc.com/persian/articles/cq5768nyy5do?at_medium=RSS&at_campaign=rss",
          "summary": "\u0648\u0627\u06a9\u0646\u0634 \u0686\u06cc\u0646 \u0628\u0647 \u062c\u0627\u0646\u0634\u06cc\u0646\u06cc \u0645\u062c\u062a\u0628\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc \u067e\u0633 \u0627\u0632 \u06a9\u0634\u062a\u0647 \u0634\u062f\u0646 \u067e\u062f\u0631\u0634\u060c \u0628\u0647 \u0639\u0646\u0648\u0627\u0646 \u0631\u0647\u0628\u0631 \u062c\u062f\u06cc\u062f \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0645\u062d\u062a\u0627\u0637\u0627\u0646\u0647 \u0628\u0648\u062f\u0647 \u0627\u0633\u062a. \u067e\u06a9\u0646 \u0647\u0645\u0686\u0646\u06cc\u0646 \u062f\u0631 \u0627\u0648\u062c \u062d\u0645\u0644\u0627\u062a \u0627\u06cc\u0631\u0627\u0646\u060c \u0627\u0632 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u062d\u0648\u0632\u0647 \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u062f\u0631 \u0686\u0627\u0631\u0686\u0648\u0628 \u062d\u0641\u0638 \u0627\u0645\u0646\u06cc\u062a\u0634\u0627\u0646 \u062d\u0645\u0627\u06cc\u062a \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a.",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u060c \u0686\u06cc\u0646 \u0648 \u062c\u0627\u0647\u200c\u0637\u0644\u0628\u06cc\u200c\u0647\u0627\u06cc\u0634 \u0631\u0627 \u0628\u0627 \u0645\u0634\u06a9\u0644 \u0631\u0648\u0628\u0647\u200c\u0631\u0648 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a",
          "link": "https://www.bbc.com/persian/articles/cn5g3q13g27o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0686\u06cc\u0646\u060c \u062f\u0633\u062a\u200c\u06a9\u0645 \u0641\u0639\u0644\u0627\u060c \u0634\u0648\u06a9 \u0645\u0633\u062a\u0642\u06cc\u0645 \u062c\u0646\u06af \u062f\u0631 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0631\u0627 \u0627\u062d\u0633\u0627\u0633 \u0646\u0645\u06cc\u200c\u06a9\u0646\u062f. \u0627\u0645\u0627 \u0645\u0648\u062c\u200c\u0647\u0627\u06cc \u0646\u0627\u0634\u06cc \u0627\u0632 \u0622\u0646 \u0631\u0627 \u062d\u0633 \u0645\u06cc\u200c\u06a9\u0646\u062f. \u062f\u0631 \u06a9\u0648\u062a\u0627\u0647\u200c\u0645\u062f\u062a\u060c \u0686\u06cc\u0646 \u0630\u062e\u0627\u06cc\u0631 \u0646\u0641\u062a\u06cc \u06a9\u0627\u0641\u06cc \u0628\u0631\u0627\u06cc \u0686\u0646\u062f \u0645\u0627\u0647 \u062f\u0631 \u0627\u062e\u062a\u06cc\u0627\u0631 \u062f\u0627\u0631\u062f \u0648 \u067e\u0633 \u0627\u0632 \u0622\u0646 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u0628\u0631\u0627\u06cc \u062a\u0627\u0645\u06cc\u0646 \u0627\u0646\u0631\u0698\u06cc \u0628\u0647 \u0647\u0645\u0633\u0627\u06cc\u0647 \u062e\u0648\u062f\u060c \u0631\u0648\u0633\u06cc\u2026",
