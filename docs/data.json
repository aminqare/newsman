        {
          "title": "\u0633\u0646\u062a\u06a9\u0627\u0645: \u062f\u0631 \u0648\u0627\u06a9\u0646\u0634 \u0628\u0647 \u062d\u0645\u0644\u0647 \u0628\u0647 \u06a9\u0634\u062a\u06cc \u062a\u062c\u0627\u0631\u06cc\u060c \u0645\u0648\u0627\u0636\u0639\u06cc \u0631\u0627 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u062f\u0627\u062f\u06cc\u0645",
