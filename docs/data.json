        {
          "title": "\u00ab\u0628\u0627\u0631 \u062f\u06cc\u06af\u0631 \u0627\u06cc\u0646 \u0645\u0631\u062f\u0645 \u0628\u0648\u062f\u0646\u062f \u06a9\u0647 \u0628\u0647\u0627\u06cc \u0648\u0627\u0642\u0639\u06cc \u062c\u0646\u06af \u0631\u0627 \u067e\u0631\u062f\u0627\u062e\u062a\u0646\u062f\u00bb\u061b \u0631\u0648\u0627\u06cc\u062a\u200c\u0647\u0627\u06cc \u0645\u062a\u0641\u0627\u0648\u062a \u0627\u0632 \u0622\u062a\u0634\u200c\u0628\u0633 \u062f\u0648\u0647\u0641\u062a\u0647\u200c\u0627\u06cc",
