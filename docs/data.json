        {
          "title": "\u0627\u0648\u0644\u06cc\u0646 \u06a9\u0646\u0641\u0631\u0627\u0646\u0633 \u062e\u0628\u0631\u06cc \u067e\u0646\u062a\u0627\u06af\u0648\u0646\u061b \u00ab\u0645\u0631\u06af\u0628\u0627\u0631\u062a\u0631\u06cc\u0646 \u0639\u0645\u0644\u06cc\u0627\u062a \u0647\u0648\u0627\u06cc\u06cc \u062a\u0627\u0631\u06cc\u062e \u0622\u0645\u0631\u06cc\u06a9\u0627\u00bb \u0648 \u0627\u0628\u0647\u0627\u0645 \u062f\u0631\u0628\u0627\u0631\u0647 \u062f\u0627\u0645\u0646\u0647 \u0648 \u0647\u0632\u06cc\u0646\u0647 \u062c\u0646\u06af \u067e\u06cc\u0634 \u0631\u0648",
