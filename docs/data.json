          "title": "\u0646\u06af\u0631\u0627\u0646\u06cc \u0627\u0632 \u0646\u0634\u062a \u0645\u0648\u0627\u062f \u0633\u0645\u06cc \u067e\u0633 \u0627\u0632 \u062d\u0645\u0644\u0647 \u0645\u0648\u0634\u06a9\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u062a\u0627\u0633\u06cc\u0633\u0627\u062a \u0635\u0646\u0639\u062a\u06cc \u062f\u0631 \u062c\u0646\u0648\u0628 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644",
