          "title": "\u062f\u0631 \u062d\u0645\u0644\u0627\u062a \u062f\u06cc\u0631\u0648\u0632 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0648 \u0639\u0636\u0648 \u067e\u062f\u0627\u0641\u0646\u062f \u0627\u0631\u062a\u0634 \u06a9\u0634\u062a\u0647 \u0634\u062f\u0647\u200c\u0627\u0646\u062f",
