          "title": "\u062f\u06cc\u062f\u0627\u0631 \u0645\u0633\u0639\u0648\u062f \u067e\u0632\u0634\u06a9\u06cc\u0627\u0646 \u0628\u0627 \u0631\u0648\u062d\u0627\u0646\u06cc\u0648\u0646 \u0628\u0631\u062c\u0633\u062a\u0647 \u0642\u0645 \u0628\u0627 \u0647\u062f\u0641 \u00ab\u062d\u0641\u0638 \u0627\u0646\u0633\u062c\u0627\u0645 \u0645\u0644\u06cc\u00bb",
