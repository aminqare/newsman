        {
          "title": "\u0633\u0646\u0646\u062f\u062c \u0632\u06cc\u0631 \u0622\u062a\u0634\u061b \u0646\u0627\u0628\u0648\u062f\u06cc \u06af\u0633\u062a\u0631\u062f\u0647 \u067e\u0627\u06cc\u06af\u0627\u0647\u200c\u0647\u0627\u06cc \u0646\u0638\u0627\u0645\u06cc \u0648 \u0627\u0645\u0646\u06cc\u062a\u06cc \u062f\u0631 \u062d\u0645\u0644\u0627\u062a \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644",
