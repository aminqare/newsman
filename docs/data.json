        {
          "title": "\u200c\ud83d\udd34 \u06a9\u0627\u062a\u0632: \u0648\u0639\u062f\u0647 \u0627\u0645\u0646\u06cc\u062a \u062f\u0631 \u0634\u0645\u0627\u0644 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0631\u0627 \u0645\u062d\u0642\u0642 \u06a9\u0631\u062f\u06cc\u0645\u061b \u06af\u0631\u0648\u0633\u06cc \u0627\u0632 \u00ab\u062f\u06cc\u062f\u0627\u0631 \u0645\u0647\u0645\u00bb \u062f\u0631 \u0639\u0631\u0628\u0633\u062a\u0627\u0646 \u0648 \u06af\u0641\u062a\u200c\u0648\u06af\u0648 \u062f\u0631\u0628\u0627\u0631\u0647 \u0648\u0636\u0639\u06cc\u062a \u0627\u06cc\u0631\u0627\u0646 \u062e\u0628\u0631 \u062f\u0627\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u06a9\u0627\u062a\u0632\u060c \u0648\u0632\u06cc\u0631 \u062f\u0641\u0627\u0639 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631\u060c \u0627\u0632 \u0622\u062a\u0634\u200c\u0628\u0633 \u062f\u0631 \u0644\u0628\u0646\u0627\u0646 \u06a9\u0647 \u0645\u06cc\u0627\u0646\u062c\u06cc\u200c\u06af\u0631\u06cc\u200c \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u062f\u0633\u062a \u0622\u0645\u062f\u0647\u060c \u062a\u0645\u062c\u06cc\u062f \u0648 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u062f\u0648\u0644\u062a \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648\u0639\u062f\u0647 \u062e\u0648\u062f \u0628\u0631\u0627\u06cc \u0628\u0631\u0642\u0631\u0627\u0631\u06cc \u0627\u0645\u0646\u06cc\u062a \u062f\u0631 \u0634\u0645\u0627\u0644 \u06a9\u0634\u0648\u0631 \u0631\u0627 \u0645\u062d\u0642\u0642 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u062f\u0631 \u062e\u0628\u0631\u06cc \u062f\u06cc\u06af\u0631\u060c \u0645\u062f\u06cc\u0631\u06a9\u0644 \u0622\u0698\u0627\u0646\u0633 \u0628\u06cc\u0646\u200c\u0627\u0644\u0645\u0644\u0644\u06cc \u0627\u0646\u0631\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
          "source_url": "https://ir.voanews.com/api/zbtpil-vomx-tpeqiyp"
        },
        {
          "title": "\u0648\u0646\u0633: \u0647\u06cc\u0686 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0645\u0628\u0646\u06cc \u0628\u0631 \u0627\u06cc\u0646 \u0648\u062c\u0648\u062f \u0646\u062f\u0627\u0631\u062f \u06a9\u0647 \u0627\u0642\u062f\u0627\u0645 \u0646\u0638\u0627\u0645\u06cc \u0639\u0644\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0647 \u062c\u0646\u06af\u06cc \u0637\u0648\u0644\u0627\u0646\u06cc \u062f\u0631 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0645\u0646\u062c\u0631 \u0634\u0648\u062f",
          "link": "https://ir.voanews.com/a/8118179.html",
