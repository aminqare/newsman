        {
          "title": "\u0633\u0646\u062a\u06a9\u0627\u0645\u061b \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u067e\u06cc \u062d\u0645\u0644\u0647 \u0628\u0647 \u0646\u0641\u062a\u06a9\u0634\u200c\u0647\u0627 \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062d\u0645\u0644\u0647 \u06a9\u0631\u062f",
