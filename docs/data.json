          "title": "\u0633\u067e\u0627\u0647: \u067e\u0627\u06cc\u06af\u0627\u0647\u200c\u0647\u0627\u06cc \u0645\u0648\u0631\u062f \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0631\u0627 \u062f\u0631 \u06a9\u0648\u06cc\u062a \u0648 \u0627\u0645\u0627\u0631\u0627\u062a \u062f\u0631\u0647\u0645 \u06a9\u0648\u0628\u06cc\u062f\u06cc\u0645\u061b \u0627\u0633\u0631\u0627\u0626\u06cc\u0644: \u062f\u0631 \u0647\u0641\u062a\u0647 \u062c\u062f\u06cc\u062f \u062d\u0645\u0644\u0627\u062a\u0645\u0627\u0646 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062a\u0634\u062f\u06cc\u062f \u0645\u06cc\u200c\u0634\u0648\u062f",
