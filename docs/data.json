          "summary": "\u06af\u06cc\u062f\u0626\u0648\u0646 \u0633\u0627\u0639\u0631\u060c \u0648\u0632\u06cc\u0631 \u062e\u0627\u0631\u062c\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u060c \u0645\u0639\u062a\u0642\u062f \u0627\u0633\u062a \u06a9\u0647 \u0645\u0631\u062f\u0645 \u0627\u06cc\u0631\u0627\u0646 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u0646\u062f \u00ab\u0631\u0698\u06cc\u0645 \u062a\u0647\u0631\u0627\u0646\u00bb \u0631\u0627 \u0633\u0631\u0646\u06af\u0648\u0646 \u06a9\u0646\u0646\u062f\u060c \u00ab\u0627\u0645\u0627 \u0628\u0647 \u062d\u0645\u0627\u06cc\u062a \u062e\u0627\u0631\u062c\u06cc \u0646\u06cc\u0627\u0632 \u062f\u0627\u0631\u0646\u062f.\u00bb \u0647\u0645\u0632\u0645\u0627\u0646 \u0627\u0631\u062a\u0634 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u06a9\u0647 \u0645\u0648\u062c \u062c\u062f\u06cc\u062f\u06cc \u0627\u0632 \u062d\u0645\u0644\u0627\u062a \u0631\u0627 \u0639\u0644\u06cc\u0647 \u0627\u0647\u062f\u0627\u0641\u06cc \u062f\u0631 \u0633\u0631\u0627\u0633\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0622\u063a\u0627\u0632 \u06a9\u0631\u062f\u2026",
