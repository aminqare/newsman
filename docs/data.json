        {
          "title": "\u0645\u0646\u0627\u0628\u0639 \u062e\u0628\u0631\u06cc \u0627\u0632 \u0634\u0631\u0648\u0639 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u062e\u0628\u0631 \u062f\u0627\u062f\u0646\u062f",
          "link": "https://www.bbc.co.uk/persian/live/clye5k5pwylt?at_medium=RSS&at_campaign=rss",
          "summary": "\u0645\u0646\u0627\u0628\u0639 \u0645\u062d\u0644\u06cc \u062f\u0631 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0628\u0647 \u0628\u06cc\u200c\u0628\u06cc\u200c\u0633\u06cc \u06af\u0641\u062a\u0647\u200c\u0627\u0646\u062f \u06a9\u0647 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0628\u06cc\u0646 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u06cc\u0631\u0627\u0646 \u0622\u063a\u0627\u0632 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0627\u06af\u0631\u0686\u0647 \u0647\u0646\u0648\u0632 \u0627\u06cc\u0646 \u06af\u0641\u062a\u06af\u0648\u0647\u0627 \u0628\u0647 \u0637\u0648\u0631 \u063a\u06cc\u0631\u0645\u0633\u062a\u0642\u06cc\u0645 \u0648 \u0627\u0632 \u0637\u0631\u06cc\u0642 \u0645\u06cc\u0627\u0646\u062c\u06cc\u06af\u0631\u0627\u0646 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646\u06cc \u062f\u0631 \u062c\u0631\u06cc\u0627\u0646 \u0627\u0633\u062a. \u067e\u06cc\u0634\u200c\u062a\u0631 \u0647\u06cc\u0626\u062a\u200c\u0647\u0627\u06cc \u0646\u0645\u0627\u06cc\u0646\u062f\u06af\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0648 \u067e\u0627\u06a9\u0633\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u062f\u0631 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f\u061b \u0686\u0647 \u06a9\u0633\u0627\u0646\u06cc \u0633\u0631\u0646\u0648\u0634\u062a \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0642\u0645 \u0645\u06cc\u200c\u0632\u0646\u0646\u062f\u061f",
