        {
          "title": "\u0642\u0627\u0644\u06cc\u0628\u0627\u0641: \u0622\u0646\u0647\u0627 \u0642\u0648\u06cc\u200c\u062a\u0631 \u0647\u0633\u062a\u0646\u062f \u0627\u0645\u0627 \u0645\u0627 \u062f\u0631 \u06cc\u06a9 \u062c\u0646\u06af \u0646\u0627\u0645\u062a\u0642\u0627\u0631\u0646 \u0637\u0648\u0631\u06cc \u062c\u0646\u06af\u06cc\u062f\u06cc\u0645 \u06a9\u0647 \u0628\u0631\u0646\u062f\u0647 \u0645\u06cc\u062f\u0627\u0646 \u0634\u062f\u06cc\u0645",
