          "title": "\ud83d\udd34 \u0628\u0631\u0627\u06cc \u0627\u0648\u0644\u06cc\u0646 \u0628\u0627\u0631 \u0627\u0632 \u0632\u0645\u0627\u0646 \u062f\u0631\u06af\u06cc\u0631\u06cc\u200c\u0647\u0627 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u063a\u0631\u0628\u06cc \u0627\u0632 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u06af\u0630\u0634\u062a\u061b \u0642\u0637\u0639 \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u0645\u0631\u0632 \u06f8\u06f1\u06f6 \u0633\u0627\u0639\u062a \u06af\u0630\u0634\u062a",
