        {
          "title": "\u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u0648 \u0641\u0631\u0627\u0646\u0633\u0647 \u06cc\u06a9 \u0645\u0627\u0645\u0648\u0631\u06cc\u062a \u062f\u0641\u0627\u0639\u06cc \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0631\u0647\u0628\u0631\u06cc \u062e\u0648\u0627\u0647\u0646\u062f \u06a9\u0631\u062f",
