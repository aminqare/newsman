          "title": "\u062a\u0631\u0627\u0645\u067e: \u0648\u0646\u0633 \u0648 \u0631\u0648\u0628\u06cc\u0648 \u062f\u0631 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u062f\u062e\u06cc\u0644 \u0647\u0633\u062a\u0646\u062f",
