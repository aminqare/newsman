        {
          "title": "\u0622\u0645\u0627\u062f\u06af\u06cc \u0628\u0631\u0627\u06cc \u00ab\u0631\u0648\u0632 \u0648\u0627\u0642\u0639\u0647\u00bb\u061b \u0627\u0631\u062f\u0648\u06af\u0627\u0647 \u0631\u0636\u0627 \u067e\u0647\u0644\u0648\u06cc \u0686\u0647 \u062a\u0635\u0648\u06cc\u0631\u06cc \u0627\u0632 \u0641\u0631\u062f\u0627\u06cc \u062d\u0645\u0644\u0647 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0627\u0631\u062f\u061f",
          "link": "https://www.bbc.com/persian/articles/c7vj17llng3o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0634\u0627\u0647\u0632\u0627\u062f\u0647 \u0631\u0636\u0627 \u067e\u0647\u0644\u0648\u06cc \u062f\u0631 \u06cc\u06a9\u06cc \u0627\u0632 \u067e\u06cc\u0627\u0645\u200c\u0647\u0627\u06cc \u0627\u062e\u06cc\u0631 \u062e\u0648\u062f \u0628\u0631\u0627\u06cc \u0628\u0627\u0631 \u0686\u0646\u062f\u0645 \u06af\u0641\u062a\u0647 \u0627\u0633\u062a \u06a9\u0647 \u06a9\u0647 \u062d\u0645\u0644\u0647 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u0627\u06cc\u0646 \u062c\u0647\u062a \u0636\u0631\u0648\u0631\u06cc \u0627\u0633\u062a \u06a9\u0647 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u0645\u06cc\u0627\u0646 \u0645\u062e\u0627\u0644\u0641\u0627\u0646 \u0648 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0645\u0633\u0644\u062d \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u00ab\u062a\u0648\u0627\u0632\u0646 \u0642\u0648\u0627\u00bb \u0628\u0631\u0642\u0631\u0627\u0631 \u06a9\u0646\u062f. \u0645\u0639\u0646\u06cc \u0627\u06cc\u0646 \u062d\u0631\u0641 \u0686\u06cc\u0633\u062a \u0648 \u0627\u0631\u062f\u0648\u06af\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0633\u0641\u0631 \u0645\u0648\u062f\u06cc \u0628\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u061b \u062a\u0639\u0631\u06cc\u0641 \u062c\u062f\u06cc\u062f \u0645\u0639\u0627\u062f\u0644\u0627\u062a \u0645\u0646\u0637\u0642\u0647\u200c\u0627\u06cc \u062f\u0631 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0648 \u063a\u0631\u0628 \u0622\u0633\u06cc\u0627",
          "link": "https://www.bbc.com/persian/articles/cgk2ndl2e0po?at_medium=RSS&at_campaign=rss",
          "summary": "\u0646\u062e\u0633\u062a\u200c\u0648\u0632\u06cc\u0631 \u0647\u0646\u062f\u060c \u0646\u0627\u0631\u0646\u062f\u0631\u0627 \u0645\u0648\u062f\u06cc\u060c \u0628\u0631\u0627\u06cc \u0633\u0641\u0631\u06cc \u062f\u0648 \u0631\u0648\u0632\u0647 \u0648\u0627\u0631\u062f \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0634\u062f\u0647 \u0627\u0633\u062a\u061b \u0627\u06cc\u0646 \u0646\u062e\u0633\u062a\u06cc\u0646 \u0633\u0641\u0631 \u0627\u0648 \u0627\u0632 \u0632\u0645\u0627\u0646 \u0622\u063a\u0627\u0632 \u062c\u0646\u06af \u062f\u0631 \u063a\u0632\u0647 \u0628\u0647 \u0634\u0645\u0627\u0631 \u0645\u06cc\u200c\u0631\u0648\u062f. \u0646\u062e\u0633\u062a \u0648\u0632\u06cc\u0631 \u0647\u0646\u062f \u0628\u0627 \u0627\u0633\u062a\u0642\u0628\u0627\u0644 \u0628\u0646\u06cc\u0627\u0645\u06cc\u0646 \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648\u060c \u0646\u062e\u0633\u062a\u200c\u0648\u0632\u06cc\u0631 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u060c \u0648\u0627\u0631\u062f \u062a\u0644 \u0622\u0648\u06cc\u0648 \u0634\u062f. \u0627\u0648 \u062f\u0631 \u06a9\u0646\u0633\u062a\u060c \u067e\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
