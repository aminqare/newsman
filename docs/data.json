    {
      "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
      "source_url": "https://ir.voanews.com/api/zbtpil-vomx-tpeqiyp",
      "items": [
        {
          "title": "\ud83d\udd34 \u0627\u062f\u0627\u0645\u0647 \u062d\u0645\u0644\u0627\u062a \u0633\u0646\u06af\u06cc\u0646 \u0647\u0648\u0627\u06cc\u06cc \u0634\u0628\u0627\u0646\u0647 \u062f\u0631 \u062a\u0647\u0631\u0627\u0646 \u0648 \u0634\u0647\u0631\u0647\u0627\u06cc \u062f\u06cc\u06af\u0631\u061b \u0647\u0634\u062f\u0627\u0631 \u0646\u0647\u0627\u06cc\u06cc \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc\u061b \u06a9\u0627\u062e \u0633\u0641\u06cc\u062f: \u0627\u06cc\u0646 \u00ab\u0641\u0631\u0635\u062a \u0637\u0644\u0627\u06cc\u06cc\u00bb \u0631\u0627 \u0627\u0632 \u062f\u0633\u062a \u0646\u062f\u0647\u06cc\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0637\u0628\u0642 \u06af\u0632\u0627\u0631\u0634\u200c\u0647\u0627 \u0627\u0632 \u0645\u0646\u0627\u0628\u0639 \u062f\u0627\u062e\u0644 \u0627\u06cc\u0631\u0627\u0646 \u062d\u062f\u0648\u062f \u0633\u0627\u0639\u062a \u06f2\u06f1 \u0645\u0646\u0627\u0637\u0642 \u0645\u062e\u062a\u0644\u0641\u06cc \u062f\u0631 \u062a\u0647\u0631\u0627\u0646 \u0647\u062f\u0641 \u062d\u0645\u0644\u0627\u062a \u0647\u0648\u0627\u06cc\u06cc \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0646\u062f \u0648 \u0627\u0646\u0641\u062c\u0627\u0631\u0647\u0627\u06cc \u0633\u0646\u06af\u06cc\u0646\u06cc \u062f\u0631 \u063a\u0631\u0628 \u062a\u0647\u0631\u0627\u0646 \u06af\u0632\u0627\u0631\u0634 \u0634\u062f. \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0628\u0627\u0631 \u062f\u06cc\u06af\u0631 \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f \u06a9\u0647 \u0627\u06af\u0631 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0641\u0648\u0631\u0627 \u0628\u0627\u0632 \u0646\u06a9\u0646\u062f\u060c\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
          "source_url": "https://ir.voanews.com/api/zbtpil-vomx-tpeqiyp"
        },
