          "title": "\u0631\u0648\u0632 \u0633\u06cc\u200c\u0627\u0645 \u062c\u0646\u06af: \u0633\u067e\u0627\u0647 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u062d\u0645\u0644\u0647 \u0628\u0647 \u062f\u0627\u0646\u0634\u06af\u0627\u0647 \u0639\u0644\u0645 \u0648 \u0635\u0646\u0639\u062a \u0631\u0627 \u062a\u0644\u0627\u0641\u06cc \u0645\u06cc\u200c\u06a9\u0646\u062f\u060c \u06af\u0632\u0627\u0631\u0634\u200c\u0647\u0627 \u0627\u0632 \u0622\u0645\u0627\u062f\u0647\u200c \u0634\u062f\u0646 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0631\u0627\u06cc \u0639\u0645\u0644\u06cc\u0627\u062a \u0632\u0645\u06cc\u0646\u06cc",
