          "title": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u0648 \u0634\u0647\u0628\u0627\u0632 \u0634\u0631\u06cc\u0641 \u0627\u0632 \u062d\u0635\u0648\u0644 \u062a\u0641\u0627\u0647\u0645\u200c\u0646\u0627\u0645\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062e\u0628\u0631 \u062f\u0627\u062f\u0646\u062f",
