        {
          "title": "\u0628\u062d\u0631\u0627\u0646 \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u061b \u0648\u0632\u06cc\u0631 \u062f\u0641\u0627\u0639 \u0622\u0645\u0631\u06cc\u06a9\u0627: \u0622\u062a\u0634\u200c\u0628\u0633 \u0647\u0646\u0648\u0632 \u0628\u0631\u0642\u0631\u0627\u0631 \u0627\u0633\u062a",
