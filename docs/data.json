          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e \u0627\u0638\u0647\u0627\u0631\u0627\u062a \u0648\u0632\u06cc\u0631 \u062e\u0627\u0631\u062c\u0647 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u062f\u0631\u0628\u0627\u0631\u0647 \u0639\u0628\u0648\u0631 \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627 \u0627\u0632 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0628\u0627\u0632\u0646\u0634\u0631 \u06a9\u0631\u062f\u061b \u062d\u0645\u0644\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u00ab\u06f7\u06f0 \u062f\u0631\u0635\u062f \u0632\u06cc\u0631\u0633\u0627\u062e\u062a\u200c\u0647\u0627\u06cc \u0646\u0638\u0627\u0645\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc\u00bb",
