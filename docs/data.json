          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0631\u0648\u0632 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u062f\u0631 \u062c\u0645\u0639 \u0634\u0645\u0627\u0631\u06cc \u0627\u0632 \u0645\u0631\u062f\u0645 \u06a9\u0646\u062a\u0627\u06a9\u06cc \u0628\u0627 \u0627\u0634\u0627\u0631\u0647 \u0628\u0647 \u0639\u0645\u0644\u06cc\u0627\u062a \u0646\u0638\u0627\u0645\u06cc \u0639\u0644\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u06af\u0641\u062a: \u00ab\u0646\u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u06cc\u0645 \u0632\u0648\u062f \u0628\u0631\u0648\u06cc\u0645.. \u0628\u0627\u06cc\u062f \u06a9\u0627\u0631 \u0631\u0627 \u062a\u0645\u0627\u0645 \u06a9\u0646\u06cc\u0645.\u00bb \u062f\u0631 \u0647\u0645\u06cc\u0646 \u062e\u0628\u0631\u06af\u0632\u0627\u0631\u06cc \u062d\u06a9\u0648\u0645\u062a\u06cc \u0641\u0627\u0631\u0633 \u062a\u0627\u06cc\u06cc\u062f \u06a9\u0631\u062f \u06a9\u0647 \u062d\u0645\u0644\u0627\u062a\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
