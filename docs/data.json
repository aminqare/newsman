          "title": "\ud83d\udd34 \u0646\u0645\u0627\u06cc\u0646\u062f\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u0633\u0627\u0632\u0645\u0627\u0646 \u0645\u0644\u0644 \u0628\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc: \u06a9\u0634\u062a\u06cc\u0631\u0627\u0646\u06cc \u0628\u06cc\u0646\u200c\u0627\u0644\u0645\u0644\u0644\u06cc \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u062a\u0647\u062f\u06cc\u062f \u0646\u06a9\u0646\u06cc\u062f\u061b \u06af\u0632\u0627\u0631\u0634\u200c\u0647\u0627 \u0627\u0632 \u0627\u062d\u062a\u0645\u0627\u0644 \u0627\u062f\u0627\u0645\u0647 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u062f\u0631 \u0642\u0637\u0631",
