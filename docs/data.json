          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e \u0628\u0627 \u0627\u0634\u0627\u0631\u0647 \u0628\u0647 \u062a\u0644\u0627\u0634 \u062f\u0648\u0628\u0627\u0631\u0647 \u0631\u0698\u06cc\u0645 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0631\u0627\u06cc \u0628\u0633\u062a\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632: \u0646\u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u0646\u062f \u0627\u0632 \u0645\u0627 \u0628\u0627\u062c\u200c\u06af\u06cc\u0631\u06cc \u06a9\u0646\u0646\u062f",
