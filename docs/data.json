          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e: \u0628\u0647 \u067e\u0627\u067e \u0628\u06af\u0648\u06cc\u06cc\u062f \u062d\u06a9\u0648\u0645\u062a \u0645\u0633\u0626\u0648\u0644 \u06a9\u0634\u062a\u0627\u0631 \u0647\u0632\u0627\u0631\u0627\u0646 \u0645\u0639\u062a\u0631\u0636 \u0627\u06cc\u0631\u0627\u0646\u06cc\u060c \u0646\u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u0633\u0644\u0627\u062d \u0647\u0633\u062a\u0647\u200c\u0627\u06cc \u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u062f\u061b \u0628\u06cc\u0634 \u0627\u0632 \u06f1\u06f1\u06f0\u06f0 \u0633\u0627\u0639\u062a \u0627\u0646\u0632\u0648\u0627\u06cc \u062f\u06cc\u062c\u06cc\u062a\u0627\u0644 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646",
