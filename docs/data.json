        {
          "title": "\u067e\u0644\u06cc\u0633 \u06a9\u0627\u0646\u0627\u062f\u0627 \u06cc\u06a9 \u0632\u0646 \u0648 \u0645\u0631\u062f \u0627\u06cc\u0631\u0627\u0646\u06cc\u200c\u062a\u0628\u0627\u0631 \u0631\u0627 \u0628\u0647 \u0627\u062a\u0647\u0627\u0645 \u0642\u062a\u0644 \u0645\u0633\u0639\u0648\u062f \u0645\u0633\u062c\u0648\u062f\u06cc \u0628\u0627\u0632\u062f\u0627\u0634\u062a \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a",
