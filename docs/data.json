        {
          "title": "\u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0686\u0647 \u0645\u0639\u0646\u0627\u06cc\u06cc \u0628\u0631\u0627\u06cc \u0622\u062a\u0634\u200c\u0628\u0633 \u0634\u06a9\u0646\u0646\u062f\u0647 \u063a\u0632\u0647 \u062f\u0627\u0631\u062f\u061f",
