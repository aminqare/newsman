        {
          "title": "\u0635\u0641\u060c \u0633\u0647\u0645\u06cc\u0647\u060c \u0635\u0631\u0641\u0647\u200c\u062c\u0648\u06cc\u06cc\u061b \u062c\u0647\u0627\u0646 \u0686\u06af\u0648\u0646\u0647 \u0628\u0627 \u0634\u0648\u06a9 \u0646\u0641\u062a\u06cc \u06a9\u0646\u0627\u0631 \u0645\u06cc\u200c\u0622\u06cc\u062f\u061f",
