        {
          "title": "\u00ab\u062f\u06cc\u06af\u0631 \u0646\u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u0645 \u0631\u0648\u06cc\u0627\u06cc\u06cc \u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u0645\u00bb\u061b \u0627\u06cc\u0631\u0627\u0646\u06cc\u0627\u0646 \u0633\u0627\u06a9\u0646 \u062a\u0631\u06a9\u06cc\u0647 \u062f\u0631\u0628\u0627\u0631\u0647 \u062c\u0646\u06af \u0686\u0647 \u0645\u06cc\u200c\u06af\u0648\u06cc\u0646\u062f\u061f",
