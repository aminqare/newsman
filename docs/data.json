          "summary": "\u062f\u0633\u062a\u06af\u0627\u0647 \u0642\u0636\u0627\u06cc\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0631\u0648\u0632 \u062f\u0648\u0634\u0646\u0628\u0647 \u06f1\u06f1 \u062e\u0631\u062f\u0627\u062f \u0627\u0632 \u0627\u0639\u062f\u0627\u0645 \u062f\u0648 \u0646\u0641\u0631 \u062f\u06cc\u06af\u0631 \u0627\u0632 \u0645\u0639\u062a\u0631\u0636\u0627\u0646 \u062f\u06cc \u0645\u0627\u0647 \u06f1\u06f4\u06f0\u06f4\u060c \u0628\u0647 \u0646\u0627\u0645 \u0645\u0647\u0631\u062f\u0627\u062f \u0645\u062d\u0645\u062f\u06cc\u200c\u0646\u06cc\u0627 \u0648 \u0627\u0634\u06a9\u0627\u0646 \u0645\u0627\u0644\u06a9\u06cc \u062e\u0628\u0631 \u062f\u0627\u062f. \u0647\u0645\u0686\u0646\u06cc\u0646 \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u06af\u0641\u062a \u06a9\u0647 \u062f\u0631 \u062c\u0631\u06cc\u0627\u0646 \u062a\u0635\u0645\u06cc\u0645 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0631\u0627\u06cc \u062a\u0648\u0642\u0641 \u06af\u0641\u062a\u06af\u0648\u0647\u0627\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
