          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062a\u0627\u0632\u0647 \u00ab\u0635\u062d\u0628\u062a\u06cc\u00bb \u062f\u0627\u0634\u062a\u0647\u200c\u0627\u0646\u062f \u0627\u0645\u0627 \u0627\u0648 \u0627\u0632 \u0622\u0646\u0686\u0647 \u0627\u06cc\u0631\u0627\u0646 \u067e\u06cc\u0634\u0646\u0647\u0627\u062f \u0645\u06cc\u200c\u06a9\u0646\u062f \u0631\u0627\u0636\u06cc \u0646\u06cc\u0633\u062a. \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u06af\u0641\u062a \u06a9\u0647 \u0631\u0647\u0628\u0631\u06cc \u0627\u06cc\u0631\u0627\u0646 \u062f\u0686\u0627\u0631 \u0634\u06a9\u0627\u0641 \u0634\u062f\u0647 \u0627\u0633\u062a: \u00ab\u0628\u0627 \u0647\u0645 \u0628\u062d\u062b \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f \u0648 \u0628\u0639\u062f \u0628\u0631\u200c\u0645\u06cc\u200c\u06af\u0631\u062f\u0646\u062f \u0648 \u0647\u0631 \u06a9\u062f\u0627\u0645\u0634\u0627\u0646 \u0686\u06cc\u0632\u06cc\u2026",
