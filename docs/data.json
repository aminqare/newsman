        {
          "title": "\u0686\u0631\u0627 \u067e\u0648\u062a\u06cc\u0646 \u062f\u0631 \u0622\u0633\u062a\u0627\u0646\u0647 \u0627\u0646\u062a\u062e\u0627\u0628\u0627\u062a \u0627\u0631\u0645\u0646\u0633\u062a\u0627\u0646\u060c \u067e\u0627\u0634\u06cc\u0646\u06cc\u0627\u0646 \u0631\u0627 \u062a\u0647\u062f\u06cc\u062f \u0645\u06cc\u200c\u06a9\u0646\u062f\u061f",
