        {
          "title": "\u0633\u0647 \u06a9\u0634\u0648\u0631 \u0627\u0631\u0648\u067e\u0627\u06cc\u06cc \u0647\u0645\u0631\u0627\u0647 \u0628\u0627 \u06a9\u0627\u0646\u0627\u062f\u0627\u060c \u0627\u0633\u062a\u0631\u0627\u0644\u06cc\u0627 \u0648 \u0646\u06cc\u0648\u0632\u06cc\u0644\u0646\u062f   \u0646\u0647\u0627\u062f\u0647\u0627\u06cc \u00ab\u0645\u0633\u0626\u0648\u0644 \u062a\u0634\u062f\u06cc\u062f \u0634\u0647\u0631\u06a9\u200c\u0633\u0627\u0632\u06cc\u00bb \u0631\u0627 \u062a\u062d\u0631\u06cc\u0645 \u06a9\u0631\u062f\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/cx2jk039eygo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0641\u0631\u0627\u0646\u0633\u0647\u060c \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627\u060c \u06a9\u0627\u0646\u0627\u062f\u0627\u060c \u0627\u0633\u062a\u0631\u0627\u0644\u06cc\u0627\u060c \u0646\u06cc\u0648\u0632\u06cc\u0644\u0646\u062f \u0648 \u0646\u0631\u0648\u0698 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f\u0646\u062f \u06a9\u0647 \u0628\u0647 \u062f\u0644\u06cc\u0644 \u062a\u062f\u0627\u0648\u0645 \u062e\u0634\u0648\u0646\u062a\u200c\u0647\u0627 \u062f\u0631 \u06a9\u0631\u0627\u0646\u0647 \u0628\u0627\u062e\u062a\u0631\u06cc \u062a\u062d\u0631\u06cc\u0645\u200c\u0647\u0627\u06cc\u06cc \u0631\u0627 \u0639\u0644\u06cc\u0647 \u00ab\u0646\u0647\u0627\u062f\u0647\u0627\u06cc \u0645\u0633\u0626\u0648\u0644 \u0634\u0647\u0631\u06a9\u200c\u0633\u0627\u0632\u06cc\u00bb \u062f\u0631 \u0627\u06cc\u0646 \u0645\u0646\u0637\u0642\u0647 \u0627\u0639\u0645\u0627\u0644 \u06a9\u0631\u062f\u0646\u062f. \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u062f\u0631 \u0648\u0627\u06a9\u0646\u0634 \u0627\u06cc\u0646 \u0631\u0627 \u00ab\u0634\u0631\u0645 \u0622\u0648\u0631\u00bb \u062e\u0648\u0627\u0646\u062f\u0647 \u0648\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0647\u0634\u062f\u0627\u0631 \u062f\u0631\u0628\u0627\u0631\u0647 \u0627\u0641\u0632\u0627\u06cc\u0634 \u0628\u06cc\u200c\u0633\u0627\u0628\u0642\u0647 \u0628\u0648\u062f\u062c\u0647 \u062a\u0633\u0644\u06cc\u062d\u0627\u062a \u0627\u062a\u0645\u06cc \u062f\u0631 \u0645\u06cc\u0627\u0646 \u0642\u062f\u0631\u062a\u200c\u0647\u0627\u06cc \u0647\u0633\u062a\u0647\u200c\u0627\u06cc",
