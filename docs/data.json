        {
          "title": "\u0686\u0631\u0627 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u062d\u0645\u0644\u0627\u062a \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u062a\u0644\u0627\u0641\u06cc \u0646\u0645\u06cc\u200c\u06a9\u0646\u0646\u062f\u061f",
