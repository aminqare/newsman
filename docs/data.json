        {
          "title": "\u00ab\u0686\u0646\u062f \u0631\u0648\u0632 \u0627\u0633\u062a \u0646\u062e\u0648\u0627\u0628\u06cc\u062f\u0647\u200c\u0627\u0645\u00bb\u061b \u0631\u0648\u0627\u06cc\u062a \u0627\u06cc\u0631\u0627\u0646\u06cc\u0627\u0646 \u0627\u0632 \u0627\u0641\u0632\u0627\u06cc\u0634 \u0641\u0634\u0627\u0631 \u0648 \u0646\u0627\u0627\u0645\u06cc\u062f\u06cc \u067e\u0633 \u0627\u0632 \u06cc\u06a9 \u0645\u0627\u0647 \u062c\u0646\u06af",
