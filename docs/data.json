        {
          "title": "\u067e\u0631\u0648\u0646\u062f\u0647 \u0646\u0627\u067e\u062f\u06cc\u062f \u0634\u062f\u0646 \u0631\u0627\u0646\u064a\u0627 \u0639\u0628\u0627\u0633\u06cc \u0648 \u0634\u0634 \u0641\u0631\u0632\u0646\u062f\u0634\u061b \u067e\u0627\u06cc\u0627\u0646\u06cc \u062a\u0644\u062e \u0628\u0631\u0627\u06cc \u06cc\u06a9\u06cc \u0627\u0632 \u062f\u0631\u062f\u0646\u0627\u06a9\u200c\u062a\u0631\u06cc\u0646 \u0645\u0639\u0645\u0627\u0647\u0627\u06cc \u0633\u0648\u0631\u06cc\u0647",
