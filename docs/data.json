          "title": "\u062a\u0631\u0627\u0645\u067e \u0627\u0632 \u0644\u063a\u0648 \u062f\u0633\u062a\u0648\u0631 \u062d\u0645\u0644\u0647 \u0646\u0638\u0627\u0645\u06cc \u0628\u0647 \u0639\u0644\u062a \u00ab\u0646\u0632\u062f\u06cc\u06a9 \u0634\u062f\u0646\u00bb \u0628\u0647 \u062a\u0648\u0627\u0641\u0642 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u062e\u0628\u0631 \u062f\u0627\u062f",
