          "title": "\u062c\u0646\u06af \u0628\u0627\u0644\u0627\u062a\u0631 \u0627\u0632 \u0645\u0644\u0627\u062d\u0638\u0627\u062a \u062f\u06cc\u067e\u0644\u0645\u0627\u062a\u06cc\u06a9\u061b \u0686\u0631\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u0642\u0637\u0631 \u062d\u0645\u0644\u0647 \u06a9\u0631\u062f\u061f",
