        {
          "title": "\u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u067e\u0627\u06a9\u0633\u062a\u0627\u0646\u06cc \u062f\u0631 \u0639\u0631\u0628\u0633\u062a\u0627\u0646\u061b \u0645\u0648\u0627\u0632\u0646\u0647\u200c\u0633\u0627\u0632\u06cc \u0627\u0645\u0646\u06cc\u062a\u06cc \u06cc\u0627 \u0648\u0631\u0648\u062f \u0628\u0647 \u0645\u0639\u0627\u062f\u0644\u0647 \u062c\u0646\u06af\u061f",
          "link": "https://www.bbc.com/persian/articles/cx2d1lm4j1ro?at_medium=RSS&at_campaign=rss",
          "summary": "\u0686\u0646\u062f \u0631\u0648\u0632 \u067e\u06cc\u0634\u060c \u062c\u0646\u06af\u0646\u062f\u0647\u200c\u0647\u0627 \u0648 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0646\u0638\u0627\u0645\u06cc \u067e\u0627\u06a9\u0633\u062a\u0627\u0646\u06cc \u062f\u0631 \u0686\u0627\u0631\u0686\u0648\u0628 \u0627\u062c\u0631\u0627\u06cc \u062a\u0648\u0627\u0641\u0642\u06cc \u062f\u0641\u0627\u0639\u06cc \u06a9\u0647 \u0633\u0627\u0644 \u06af\u0630\u0634\u062a\u0647 \u0645\u06cc\u0627\u0646 \u062f\u0648 \u06a9\u0634\u0648\u0631 \u0627\u0645\u0636\u0627 \u0634\u062f\u0647 \u0628\u0648\u062f\u060c \u0648\u0627\u0631\u062f \u0639\u0631\u0628\u0633\u062a\u0627\u0646 \u0633\u0639\u0648\u062f\u06cc \u0634\u062f\u0646\u062f. \u0627\u06cc\u0646 \u062a\u062d\u0631\u06a9 \u0647\u0645\u0632\u0645\u0627\u0646 \u0628\u0627 \u0645\u06cc\u0632\u0628\u0627\u0646\u06cc \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u0627\u0632 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0645\u06cc\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0628\u0627\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
