          "title": "\u062a\u0631\u0627\u0645\u067e: \u0628\u0627 \u0645\u0642\u0627\u0645 \u0628\u0644\u0646\u062f\u067e\u0627\u06cc\u0647\u200c\u0627\u06cc \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631 \u062a\u0645\u0627\u0633\u06cc\u0645\u061b \u0642\u0627\u0644\u06cc\u0628\u0627\u0641: \u062a\u0627 \u062a\u0646\u0628\u06cc\u0647 \u06a9\u0627\u0645\u0644 \u0645\u062a\u062c\u0627\u0648\u0632\u0627\u0646 \u067e\u0634\u062a \u0633\u0631 \u0631\u0647\u0628\u0631 \u0627\u06cc\u0633\u062a\u0627\u062f\u0647\u200c\u0627\u06cc\u0645",
