          "title": "\ud83d\udd34 \u06af\u0632\u0627\u0631\u0634\u200c\u0647\u0627 \u0627\u0632 \u0627\u0639\u0632\u0627\u0645 \u0647\u0632\u0627\u0631\u0627\u0646 \u0646\u06cc\u0631\u0648\u06cc \u0648\u06cc\u0698\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0628\u0647 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647\u061b \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u0645\u0634\u062a\u0627\u0642 \u062a\u0648\u0627\u0641\u0642 \u0627\u0633\u062a",
