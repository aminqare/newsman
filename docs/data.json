        {
          "title": "\u0627\u0633\u0631\u0627\u0626\u06cc\u0644: \u0639\u0645\u0644\u06cc\u0627\u062a \u0632\u0645\u06cc\u0646\u06cc \u062f\u0631 \u0644\u0628\u0646\u0627\u0646 \u0628\u0627 \u0648\u062c\u0648\u062f \u0622\u062a\u0634\u200c\u0628\u0633 \u062c\u062f\u06cc\u062f \u0627\u062f\u0627\u0645\u0647 \u062e\u0648\u0627\u0647\u062f \u06cc\u0627\u0641\u062a",
