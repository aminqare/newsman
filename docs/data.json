        {
          "title": "\u0636\u0631\u0628\u0647 \u0633\u0646\u06af\u06cc\u0646 \u0627\u0646\u062a\u062e\u0627\u0628\u0627\u062a\u06cc \u062d\u0632\u0628 \u06a9\u0627\u0631\u06af\u0631\u061b \u0627\u0633\u062a\u0627\u0631\u0645\u0631: \u06a9\u0646\u0627\u0631\u0647\u200c\u06af\u06cc\u0631\u06cc \u0646\u0645\u06cc\u200c\u06a9\u0646\u0645",
