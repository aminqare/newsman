          "title": "\u062a\u0631\u0627\u0645\u067e \u062e\u0637\u0627\u0628 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646: \u06f4\u06f8 \u0633\u0627\u0639\u062a \u0641\u0631\u0635\u062a \u062f\u0627\u0631\u06cc\u062f \u062a\u0627 \u0628\u0647 \u062a\u0648\u0627\u0641\u0642 \u0628\u0631\u0633\u06cc\u062f \u06cc\u0627 \u062c\u0647\u0646\u0645 \u0628\u0631 \u0633\u0631 \u0634\u0645\u0627 \u0641\u0631\u0648 \u062e\u0648\u0627\u0647\u062f \u0631\u06cc\u062e\u062a\u061b \u0631\u0648\u0633\u06cc\u0647 \u06a9\u0627\u0631\u06a9\u0646\u0627\u0646\u0634 \u0631\u0627 \u0627\u0632 \u0646\u06cc\u0631\u0648\u06af\u0627\u0647 \u0627\u062a\u0645\u06cc \u0628\u0648\u0634\u0647\u0631 \u062e\u0627\u0631\u062c \u06a9\u0631\u062f",
