          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0627\u0632 \u0634\u0644\u06cc\u06a9 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0646\u0638\u0627\u0645\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u0628\u0627\u0631\u06cc \u062f\u0631 \u062d\u0627\u0644 \u062d\u0631\u06a9\u062a \u0628\u0627 \u067e\u0631\u0686\u0645 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u06a9\u0647 \u0628\u0647 \u062a\u0630\u06a9\u0631 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0628\u06cc\u200c\u062a\u0648\u062c\u0647\u06cc \u06a9\u0631\u062f \u062e\u0628\u0631 \u062f\u0627\u062f \u0648 \u06af\u0641\u062a \u0645\u0644\u0648\u0627\u0646\u0627\u0646 \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u06a9\u0646\u062a\u0631\u0644 \u0627\u06cc\u0646 \u06a9\u0634\u062a\u06cc \u0631\u0627 \u062f\u0631 \u0627\u062e\u062a\u06cc\u0627\u0631 \u062f\u0627\u0631\u0646\u062f.\u2026",
