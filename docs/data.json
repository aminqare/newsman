          "title": "\u0627\u062f\u0627\u0645\u0647 \u062d\u0645\u0644\u0627\u062a \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0634\u0647\u0631\u0647\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646\u061b \u0642\u06cc\u0645\u062a \u0647\u0631 \u0628\u0634\u06a9\u0647 \u0646\u0641\u062a \u0628\u0647 \u0628\u0627\u0644\u0627\u06cc \u06f1\u06f0\u06f0 \u062f\u0644\u0627\u0631 \u0628\u0631\u06af\u0634\u062a",
