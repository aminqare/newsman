          "title": "\u0633\u0627\u0632\u0645\u0627\u0646 \u0645\u0644\u0644 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648 \u0631\u0648\u0633\u06cc\u0647 \u0631\u0627 \u0628\u0647 \u00ab\u0641\u0647\u0631\u0633\u062a \u0633\u06cc\u0627\u0647\u00bb \u0627\u0631\u062a\u06a9\u0627\u0628 \u062e\u0634\u0648\u0646\u062a \u062c\u0646\u0633\u06cc \u062f\u0631 \u0632\u0645\u0627\u0646 \u062c\u0646\u06af \u0627\u0636\u0627\u0641\u0647 \u06a9\u0631\u062f",
