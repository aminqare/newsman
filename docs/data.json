          "summary": "\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u0645\u062d\u0644\u06cc \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0628\u0647\u200c\u0637\u0648\u0631 \u06af\u0633\u062a\u0631\u062f\u0647 \u06af\u0632\u0627\u0631\u0634 \u062f\u0627\u062f\u0647\u200c\u0627\u0646\u062f \u06a9\u0647 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u0628\u0627 \u0648\u062c\u0648\u062f \u0641\u0634\u0627\u0631\u0647\u0627\u06cc \u0627\u0642\u062a\u0635\u0627\u062f\u06cc \u062a\u0635\u0645\u06cc\u0645 \u06af\u0631\u0641\u062a\u0647 \u0648\u0627\u0645 \u062e\u0648\u062f \u0628\u0647 \u0627\u0645\u0627\u0631\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0639\u0631\u0628\u06cc \u0631\u0627 \u0628\u0627\u0632\u067e\u0631\u062f\u0627\u062e\u062a \u06a9\u0646\u062f. \u0631\u0648\u0627\u0628\u0637 \u0645\u06cc\u0627\u0646 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0648 \u0627\u0645\u0627\u0631\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0639\u0631\u0628\u06cc \u0627\u062e\u06cc\u0631\u0627\u064b \u0645\u0648\u0631\u062f \u062a\u0648\u062c\u0647 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0647 \u0648 \u0628\u0631\u062e\u2026",
