          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e: \u0627\u0633\u0631\u0627\u0626\u064a\u0644 \u0645\u062a\u062d\u062f \u0628\u0632\u0631\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0627\u0633\u062a\u061b \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648\u06cc\u062f\u0648\u06cc\u06cc \u0627\u0632 \u062f\u0631\u062e\u0648\u0627\u0633\u062a \u06a9\u0645\u06a9 \u0627\u06cc\u0631\u0627\u0646\u06cc\u0627\u0646 \u0645\u0639\u062a\u0631\u0636 \u0627\u0632 \u0627\u0648 \u0631\u0627 \u0645\u0646\u062a\u0634\u0631 \u06a9\u0631\u062f",
