          "title": "\u062a\u0631\u0627\u0645\u067e: \u0627\u0645\u0631\u0648\u0632 \u0647\u0645 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062d\u0645\u0644\u0647 \u062e\u0648\u0627\u0647\u06cc\u0645 \u06a9\u0631\u062f\u061b \u067e\u0632\u0634\u06a9\u06cc\u0627\u0646: \u062d\u0645\u0644\u0647 \u0628\u0647 \u0632\u06cc\u0631\u0633\u0627\u062e\u062a\u200c\u0647\u0627 \u0646\u0634\u0627\u0646\u0647 \u0627\u0633\u062a\u06cc\u0635\u0627\u0644 \u0627\u0633\u062a",
