          "summary": "\u0628\u0631\u0631\u0633\u06cc\u200c\u0647\u0627\u06cc \u0628\u062e\u0634 \u0631\u0627\u0633\u062a\u06cc\u200c\u0622\u0632\u0645\u0627\u06cc\u06cc \u0628\u0631 \u0627\u0633\u0627\u0633 \u062a\u0635\u0627\u0648\u06cc\u0631 \u0645\u0627\u0647\u0648\u0627\u0631\u0647\u200c\u0627\u06cc \u0634\u0631\u06a9\u062a \u067e\u0644\u0646\u062a \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u06a9\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0633\u062a\u200c\u06a9\u0645 \u0628\u0647 \u06f1\u06f0 \u067e\u0627\u06cc\u06af\u0627\u0647\u200c\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u06cc\u0627 \u067e\u0627\u06cc\u06af\u0627\u0647\u200c\u0647\u0627\u06cc\u06cc \u06a9\u0647 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u062f\u0631 \u0622\u0646\u0647\u0627 \u0645\u0633\u062a\u0642\u0631 \u0647\u0633\u062a\u0646\u062f\u060c \u062f\u0631 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u0627\u0631\u062f\u0646\u060c \u0639\u0631\u0628\u0633\u062a\u0627\u0646 \u0633\u0639\u0648\u062f\u06cc\u060c \u0628\u062d\u0631\u06cc\u0646\u060c \u0627\u0645\u0627\u0631\u0627\u062a \u0645\u2026",
