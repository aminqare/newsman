          "title": "\u0686\u0647\u0627\u0631 \u0622\u0645\u0628\u0648\u0644\u0627\u0646\u0633 \u062c\u0627\u0645\u0639\u0647 \u06cc\u0647\u0648\u062f\u06cc\u0627\u0646 \u062f\u0631 \u0644\u0646\u062f\u0646 \u0628\u0647 \u0622\u062a\u0634 \u06a9\u0634\u06cc\u062f\u0647 \u0634\u062f\u0646\u062f",
