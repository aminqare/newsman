        {
          "title": "\u0648\u0631\u0632\u0634\u06cc \u06a9\u0647 \u0642\u0647\u0631\u0645\u0627\u0646\u0627\u0646\u0634 \u0645\u06cc\u0644\u06cc\u0648\u0646\u200c\u0647\u0627 \u062f\u0644\u0627\u0631 \u062f\u0631\u0622\u0645\u062f \u062f\u0627\u0631\u0646\u062f\u061b \u0686\u06af\u0648\u0646\u0647 \u0648\u0627\u0644\u062f\u06cc\u0646 \u062e\u0648\u0628\u06cc \u0628\u0631\u0627\u06cc \u06cc\u06a9 \u062a\u0646\u06cc\u0633\u200c\u0628\u0627\u0632 \u0628\u0627\u0634\u06cc\u0645\u061f",
