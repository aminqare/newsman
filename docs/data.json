          "title": "\ud83d\udd34 \u06a9\u0627\u062e \u0633\u0641\u06cc\u062f: \u0646\u0634\u0633\u062a \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u00ab\u0633\u0647\u200c\u062c\u0627\u0646\u0628\u0647 \u0648 \u0631\u0648\u062f\u0631\u0631\u0648\u00bb \u0627\u0633\u062a\u061b \u067e\u0633\u0631 \u0645\u0639\u0635\u0648\u0645\u0647 \u0627\u0628\u062a\u06a9\u0627\u0631 \u0648 \u062e\u0627\u0646\u0648\u0627\u062f\u0647\u200c\u0627\u0634 \u062f\u0631 \u0635\u0641 \u0627\u062e\u0631\u0627\u062c \u0627\u0632 \u0622\u0645\u0631\u06cc\u06a9\u0627",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062c\u06cc\u200c\u062f\u06cc. \u0648\u0646\u0633\u060c \u0645\u0639\u0627\u0648\u0646 \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0633\u0627\u0639\u062a\u06cc \u067e\u0633 \u0627\u0632 \u0648\u0631\u0648\u062f \u0628\u0647 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u0628\u0627 \u0646\u062e\u0633\u062a\u200c\u0648\u0632\u06cc\u0631 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u062f\u06cc\u062f\u0627\u0631 \u06a9\u0631\u062f. \u0627\u0646\u062a\u0638\u0627\u0631 \u0645\u06cc\u200c\u0631\u0648\u062f \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0639\u0635\u0631 \u0631\u0648\u0632 \u0634\u0646\u0628\u0647 \u0628\u0647 \u0648\u0642\u062a \u0645\u062d\u0644\u06cc \u0628\u0631\u06af\u0632\u0627\u0631 \u0634\u0648\u062f. \u062f\u0631 \u0627\u06cc\u0646 \u0645\u06cc\u0627\u0646 \u06cc\u06a9 \u0645\u0642\u0627\u0645 \u06a9\u0627\u062e \u0633\u0641\u06cc\u062f \u06af\u0632\u0627\u0631\u0634\u200c\u0647\u0627 \u062f\u0631 \u0645\u0648\u0631\u062f \u0645\u0648\u0627\u0641\u0642\u062a \u0622\u0645\u0631\u06cc\u06a9\u0627\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
