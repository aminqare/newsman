        {
          "title": "\u0631\u0628\u0648\u062f\u0647 \u0634\u062f\u0646 \u06cc\u06a9 \u0646\u0641\u062a\u06a9\u0634 \u062f\u0631 \u0646\u0632\u062f\u06cc\u06a9\u06cc \u0633\u0648\u0627\u062d\u0644 \u06cc\u0645\u0646",
          "link": "https://www.bbc.co.uk/persian/live/c70v478gjyqt?at_medium=RSS&at_campaign=rss",
          "summary": "\u06af\u0627\u0631\u062f \u0633\u0627\u062d\u0644\u06cc \u06cc\u0645\u0646 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u0627\u0641\u0631\u0627\u062f \u0645\u0633\u0644\u062d \u0646\u0627\u0634\u0646\u0627\u0633 \u06cc\u06a9 \u0646\u0641\u062a\u06a9\u0634 \u0631\u0627 \u062f\u0631 \u0646\u0632\u062f\u06cc\u06a9\u06cc \u0633\u0648\u0627\u062d\u0644 \u0622\u0646 \u06a9\u0634\u0648\u0631 \u0631\u0628\u0648\u062f\u0647\u200c\u0627\u0646\u062f. \u0627\u06cc\u0646 \u0627\u0641\u0631\u0627\u062f \u067e\u0633 \u0627\u0632 \u06a9\u0646\u062a\u0631\u0644 \u06a9\u0634\u062a\u06cc \u0622\u0646 \u0631\u0627 \u0628\u0647 \u0633\u0645\u062a \u0633\u0648\u0627\u062d\u0644 \u0633\u0648\u0645\u0627\u0644\u06cc \u0647\u062f\u0627\u06cc\u062a \u06a9\u0631\u062f\u0647\u200c\u0627\u0646\u062f. \u0628\u0647 \u06af\u0641\u062a\u0647 \u0645\u0642\u0627\u0645\u200c\u0647\u0627\u06cc \u06af\u0627\u0631\u062f \u0633\u0627\u062d\u0644\u06cc \u06cc\u0645\u0646\u060c \u0686\u0646\u062f \u0642\u0627\u06cc\u0642 \u06af\u0634\u062a\u06cc \u0628\u0631\u0627\u06cc \u0645\u062a\u0648\u0642\u0641 \u06a9\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0622\u0645\u0631\u06cc\u06a9\u0627 \u0634\u0631\u06a9\u062a\u200c\u0647\u0627\u06cc \u06a9\u0634\u062a\u06cc\u0631\u0627\u0646\u06cc \u0631\u0627 \u062a\u0647\u062f\u06cc\u062f \u06a9\u0631\u062f \u06a9\u0647 \u062f\u0631 \u0635\u0648\u0631\u062a \u067e\u0631\u062f\u0627\u062e\u062a \u0639\u0648\u0627\u0631\u0636 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062a\u062d\u0631\u06cc\u0645 \u0645\u06cc\u200c\u0634\u0648\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/c1e2757w7zpo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u0634\u0631\u06a9\u062a\u200c\u0647\u0627\u06cc \u06a9\u0634\u062a\u06cc\u0631\u0627\u0646\u06cc \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f\u0647 \u0627\u0633\u062a \u06a9\u0647 \u062f\u0631 \u0635\u0648\u0631\u062a \u067e\u0631\u062f\u0627\u062e\u062a \u0639\u0648\u0627\u0631\u0636 \u0628\u0631\u0627\u06cc \u0639\u0628\u0648\u0631 \u0627\u06cc\u0645\u0646 \u0627\u0632 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0647\u0631\u0645\u0632 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646\u060c \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u0628\u0627 \u062a\u062d\u0631\u06cc\u0645 \u0645\u0648\u0627\u062c\u0647 \u0634\u0648\u0646\u062f. \u062f\u0631 \u0647\u0634\u062f\u0627\u0631\u06cc \u06a9\u0647 \u0631\u0648\u0632 \u062c\u0645\u0639\u0647 \u062a\u0648\u0633\u0637 \u062f\u0641\u062a\u0631 \u06a9\u0646\u062a\u0631\u0644 \u062f\u0627\u0631\u0627\u06cc\u06cc\u200c\u0647\u0627\u06cc \u062e\u0627\u0631\u062c\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 (OFAC) \u0645\u0646\u062a\u0634\u0631 \u0634\u062f\u060c\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u062a\u0646\u0634 \u0644\u0641\u0638\u06cc \u062a\u0631\u0627\u0645\u067e \u0648 \u0645\u0631\u062a\u0633 \u062f\u0631\u0628\u0627\u0631\u0647 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u061b \u0622\u0645\u0631\u06cc\u06a9\u0627 \u067e\u0646\u062c \u0647\u0632\u0627\u0631 \u0646\u06cc\u0631\u0648\u06cc \u062e\u0648\u062f \u0631\u0627 \u0627\u0632 \u0622\u0644\u0645\u0627\u0646 \u062e\u0627\u0631\u062c \u0645\u06cc\u200c\u06a9\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/crrp9p18k9zo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0648\u0632\u0627\u0631\u062a \u062f\u0641\u0627\u0639 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0642\u0635\u062f \u062f\u0627\u0631\u062f \u06f5 \u0647\u0632\u0627\u0631 \u0646\u06cc\u0631\u0648\u06cc \u062e\u0648\u062f \u0631\u0627 \u0627\u0632 \u0622\u0644\u0645\u0627\u0646 \u062e\u0627\u0631\u062c \u06a9\u0646\u062f. \u0627\u06cc\u0646 \u0627\u0642\u062f\u0627\u0645 \u062f\u0631 \u0628\u062d\u0628\u0648\u062d\u0647 \u062a\u0646\u0634 \u0645\u06cc\u0627\u0646 \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0641\u0631\u06cc\u062f\u0631\u06cc\u0634 \u0645\u0631\u062a\u0633\u060c \u0635\u062f\u0631\u0627\u0639\u0638\u0645 \u0622\u0644\u0645\u0627\u0646 \u0628\u0631 \u0633\u0631 \u062c\u0646\u06af \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u0635\u0648\u0631\u062a \u0645\u06cc\u200c\u06af\u06cc\u0631\u062f.",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u06af\u0632\u0627\u0631\u0634\u200c\u0647\u0627 \u0627\u0632 \u0648\u062e\u0627\u0645\u062a \u0628\u0627\u0632\u0627\u0631 \u06a9\u0627\u0631 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646\u061b \u00ab\u0628\u06cc\u0634 \u0627\u0632 \u06cc\u06a9\u200c \u0645\u06cc\u0644\u06cc\u0648\u0646 \u0634\u063a\u0644 \u0627\u0632 \u062f\u0633\u062a \u0631\u0641\u062a\u0647 \u0627\u0633\u062a\u00bb",
          "link": "https://www.bbc.com/persian/articles/c8r8l8y3mg8o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0648\u0632\u0646\u0627\u0645\u0647 \u062f\u0646\u06cc\u0627\u06cc \u0627\u0642\u062a\u0635\u0627\u062f \u062f\u0631 \u06af\u0632\u0627\u0631\u0634\u06cc \u0628\u0647 \u0648\u062e\u0627\u0645\u062a \u0628\u0627\u0632\u0627\u0631 \u06a9\u0627\u0631 \u0627\u06cc\u0631\u0627\u0646 \u067e\u0631\u062f\u0627\u062e\u062a\u0647 \u0627\u0633\u062a. \u062f\u0631 \u0627\u06cc\u0646 \u06af\u0632\u0627\u0631\u0634 \u0622\u0645\u062f\u0647 \u0627\u0633\u062a \u06a9\u0647 \u062f\u0631 \u0628\u0627\u0632\u0627\u0631 \u0622\u0646\u0644\u0627\u06cc\u0646 \u06a9\u0627\u0631\u06cc\u0627\u0628\u06cc \u00ab\u062a\u0642\u0631\u06cc\u0628\u0627\u06f8\u06f0 \u062f\u0631\u0635\u062f\u00bb \u0627\u0632 \u0641\u0631\u0635\u062a\u200c\u0647\u0627\u06cc \u0634\u063a\u0644\u06cc \u062f\u0631 \u0628\u0647\u0627\u0631 \u0627\u0645\u0633\u0627\u0644 \u0627\u0632 \u062f\u0633\u062a \u0631\u0641\u062a\u0647 \u0627\u0633\u062a\u061b \u0628\u0647 \u062a\u0639\u0628\u06cc\u0631\u06cc \u0627\u0632 \u0647\u0631 \u067e\u0646\u062c \u0641\u0631\u0635\u062a \u0634\u063a\u0644\u06cc \u06a9\u0647 \u0633\u0627\u0644\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0627\u06cc\u0631\u0627\u0646 \u062f\u0648 \u0632\u0646\u062f\u0627\u0646\u06cc \u0628\u0647 \u0646\u0627\u0645 \u06cc\u0639\u0642\u0648\u0628 \u06a9\u0631\u06cc\u0645\u200c\u067e\u0648\u0631 \u0648 \u0646\u0627\u0635\u0631 \u0628\u06a9\u0631\u0632\u0627\u062f\u0647 \u0631\u0627 \u0628\u0647 \u0627\u062a\u0647\u0627\u0645 \u00ab\u062c\u0627\u0633\u0648\u0633\u06cc \u0628\u0631\u0627\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u00bb \u0627\u0639\u062f\u0627\u0645 \u06a9\u0631\u062f",
          "link": "https://www.bbc.com/persian/articles/cdxpvzqr08xo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0627\u0639\u062f\u0627\u0645 \u0647\u0627 \u067e\u0633 \u0627\u0632 \u0634\u0631\u0648\u0639 \u062c\u0646\u06af \u0628\u0627 \u0627\u0639\u062f\u0627\u0645 \u06cc\u06a9 \u0634\u0647\u0631\u0648\u0646\u062f \u062f\u0648\u062a\u0627\u0628\u0639\u06cc\u062a\u06cc \u0627\u06cc\u0631\u0627\u0646\u06cc-\u0633\u0648\u0626\u062f\u06cc \u0628\u0647 \u0646\u0627\u0645 \u06a9\u0648\u0631\u0648\u0634 \u06a9\u06cc\u0648\u0627\u0646\u06cc \u0628\u0647 \u00ab\u062c\u0631\u0645 \u062c\u0627\u0633\u0648\u0633\u06cc\u00bb \u0622\u063a\u0627\u0632 \u0634\u062f \u0648 \u062a\u0646\u0647\u0627 \u06cc\u06a9 \u0631\u0648\u0632 \u0628\u0639\u062f \u0628\u0627 \u0627\u0639\u062f\u0627\u0645 \u0633\u0647 \u0645\u0639\u062a\u0631\u0636 \u062f\u06cc \u0645\u0627\u0647 \u062f\u0631 \u0642\u0645 \u0628\u0647 \u0646\u0627\u0645\u200c\u0647\u0627\u06cc \u0635\u0627\u0644\u062d \u0645\u062d\u0645\u062f\u06cc \u0648 \u0633\u0639\u06cc\u062f \u062f\u0627\u0648\u062f\u06cc \u0648 \u0645\u0647\u062f\u06cc \u0642\u0627\u0633\u0645\u06cc \u0628\u0627 \u0627\u062a\u0647\u0627\u0645\u0627\u062a \u0633\u2026",
