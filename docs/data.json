          "title": "\u0647\u0634\u062f\u0627\u0631 \u0642\u0631\u0627\u0631\u06af\u0627\u0647 \u062e\u0627\u062a\u0645\u200c\u0627\u0644\u0627\u0646\u0628\u06cc\u0627 \u0628\u0647 \u0633\u0627\u06a9\u0646\u0627\u0646 \u0634\u0645\u0627\u0644 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u062f\u0631 \u0635\u0648\u0631\u062a \u062d\u0645\u0644\u0647 \u0628\u0647 \u0636\u0627\u062d\u06cc\u0647",
