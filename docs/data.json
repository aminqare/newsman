        {
          "title": "\u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648 \u0628\u0647 \u0627\u0631\u062a\u0634 \u062f\u0633\u062a\u0648\u0631 \u062f\u0627\u062f \u0627\u0647\u062f\u0627\u0641 \u062d\u0632\u0628\u200c\u0627\u0644\u0644\u0647 \u0644\u0628\u0646\u0627\u0646 \u0631\u0627 \u00ab\u0628\u0647\u200c\u0634\u062f\u062a \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u062f\u0647\u0646\u062f\u00bb\u061b \u062a\u0631\u0627\u0645\u067e \u0633\u0641\u0631 \u0646\u0645\u0627\u06cc\u0646\u062f\u06af\u0627\u0646\u0634 \u0628\u0647 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0631\u0627 \u0644\u063a\u0648 \u06a9\u0631\u062f",
