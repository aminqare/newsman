          "summary": "\u0628\u0632\u0631\u06af\u062a\u0631\u06cc\u0646 \u0646\u06af\u0631\u0627\u0646\u06cc \u062a\u0631\u06a9\u06cc\u0647 \u0641\u0631\u0648\u067e\u0627\u0634\u06cc \u062f\u0648\u0644\u062a \u062f\u0631 \u062a\u0647\u0631\u0627\u0646 \u0648 \u0648\u0631\u0648\u062f \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u062f\u0648\u0631\u0627\u0646\u06cc \u0627\u0632 \u062c\u0646\u06af \u062f\u0627\u062e\u0644\u06cc \u0648 \u0622\u0634\u0648\u0628 \u0633\u0631\u0632\u0645\u06cc\u0646\u06cc \u0627\u0633\u062a. \u0645\u0642\u0627\u0645\u200c\u0647\u0627\u06cc \u0622\u0646\u06a9\u0627\u0631\u0627 \u0628\u0647\u200c\u062e\u0635\u0648\u0635 \u0628\u0627 \u0627\u0634\u0627\u0631\u0647 \u0628\u0647 \u062a\u062c\u0631\u0628\u0647 \u0633\u0648\u0631\u06cc\u0647 \u0627\u0632 \u0627\u06cc\u0646 \u0645\u0648\u0636\u0648\u0639 \u0627\u0628\u0631\u0627\u0632 \u0646\u06af\u0631\u0627\u0646\u06cc \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f. \u0622\u0646\u0647\u0627 \u0647\u0645\u0686\u0646\u06cc\u0646 \u0646\u06af\u0631\u0627\u0646\u0646\u062f \u06a9\u0647 \u062f\u0631 \u0635\u0648\u0631\u062a \u0633\u0642\u0648\u0637\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0627\u062f\u0627\u0645\u0647 \u0645\u0627\u062c\u0631\u0627\u06cc \u0628\u0627\u0632\u06cc\u06a9\u0646\u0627\u0646 \u062a\u06cc\u0645 \u0641\u0648\u062a\u0628\u0627\u0644 \u0632\u0646\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u061b \u0627\u0632 \u00ab\u062a\u063a\u06cc\u06cc\u0631 \u0639\u0642\u06cc\u062f\u0647\u00bb \u0645\u0644\u06cc\u200c\u067e\u0648\u0634\u0627\u0646 \u0686\u0647 \u0645\u06cc\u200c\u062f\u0627\u0646\u06cc\u0645\u061f",
