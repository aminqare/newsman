        {
          "title": "\u0627\u0632 \u0698\u0627\u067e\u0646 \u062a\u0627 \u063a\u0632\u0647\u061b \u0645\u062d\u0627\u0635\u0631\u0647\u200c\u0647\u0627\u06cc \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0686\u0642\u062f\u0631 \u0645\u0648\u062b\u0631 \u0628\u0648\u062f\u0647\u200c\u0627\u0646\u062f\u061f",
