          "title": "\u0648\u0627\u06a9\u0646\u0634\u200c \u0628\u0627\u0632\u0627\u0631 \u0628\u0647 \u0633\u062e\u0646\u0631\u0627\u0646\u06cc \u062a\u0631\u0627\u0645\u067e\u061b \u0627\u0641\u0632\u0627\u06cc\u0634 \u0642\u06cc\u0645\u062a \u0646\u0641\u062a \u0648 \u0633\u0642\u0648\u0637 \u0633\u0647\u0627\u0645",
