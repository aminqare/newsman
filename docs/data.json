        {
          "title": "\u0644\u0628\u0646\u0627\u0646 \u062a\u0635\u0648\u0631 \u0645\u06cc\u200c\u06a9\u0631\u062f \u0622\u062a\u0634\u200c\u0628\u0633 \u0628\u0631\u0642\u0631\u0627\u0631 \u0634\u062f\u0647\u060c \u0627\u0645\u0627 \u0646\u0627\u06af\u0647\u0627\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u062d\u0645\u0644\u0647 \u0645\u0631\u06af\u0628\u0627\u0631 \u062e\u0648\u062f \u0631\u0627 \u0622\u063a\u0627\u0632 \u06a9\u0631\u062f",
