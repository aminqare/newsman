        {
          "title": "\ud83d\udd34 \u062a\u0648\u0642\u06cc\u0641 \u0628\u06cc\u0634 \u0627\u0632 \u06f2\u06f6\u06f0 \u0645\u0644\u06a9 \u0634\u0647\u0631\u0648\u0646\u062f\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0628\u0627 \u0627\u062a\u0647\u0627\u0645\u200c\u0647\u0627\u06cc \u0633\u06cc\u0627\u0633\u06cc\u061b \u062e\u0627\u0645\u0648\u0634\u06cc \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u0627\u06cc\u0631\u0627\u0646 \u0648\u0627\u0631\u062f \u0647\u0641\u062a\u0647 \u06cc\u0627\u0632\u062f\u0647\u0645 \u0648 \u0631\u0648\u0632 \u0647\u0641\u062a\u0627\u062f\u0648\u06cc\u06a9\u0645 \u0634\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0633\u062a\u06af\u0627\u0647 \u0642\u0636\u0627\u06cc\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u06a9\u0647 \u0646\u0642\u0634 \u0645\u0647\u0645\u06cc \u062f\u0631 \u0633\u0631\u06a9\u0648\u0628\u200c\u0647\u0627 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0627\u0631\u062f\u060c \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u062a\u0627\u06a9\u0646\u0648\u0646 \u06f2\u06f6\u06f2 \u0641\u0642\u0631\u0647 \u0645\u0644\u06a9 \u0634\u0647\u0631\u0648\u0646\u062f\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0631\u0627 \u0628\u0627 \u0627\u062a\u0647\u0627\u0645\u200c\u0647\u0627\u06cc \u0633\u06cc\u0627\u0633\u06cc \u062a\u0648\u0642\u06cc\u0641 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0647\u0645\u0632\u0645\u0627\u0646 \u0628\u0647 \u06af\u0632\u0627\u0631\u0634 \u0646\u062a\u200c\u0628\u0644\u0627\u06a9\u0633\u060c \u062e\u0627\u0645\u0648\u0634\u06cc \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0648\u0627\u0631\u062f \u0647\u0641\u062a\u0647 \u06cc\u0627\u0632\u062f\u0647\u0645 \u0648\u2026",
