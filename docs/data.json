        {
          "title": "\u0628\u0644\u06cc\u062a \u06cc\u0627\u0632\u062f\u0647 \u0647\u0632\u0627\u0631 \u062f\u0644\u0627\u0631\u06cc \u0641\u06cc\u0646\u0627\u0644\u061b \u0627\u0632 \u0627\u0648\u0644\u06cc\u0646 \u0641\u0631\u0648\u0634 \u0639\u0645\u0648\u0645\u06cc \u0628\u0644\u06cc\u062a\u200c\u0647\u0627\u06cc \u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc \u0686\u0647 \u0645\u06cc\u200c\u062f\u0627\u0646\u06cc\u0645\u061f",
