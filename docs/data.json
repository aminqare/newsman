        {
          "title": "\u0631\u0627\u0632\u0647\u0627\u06cc\u06cc \u06a9\u0647 \u06f4\u06f9 \u0645\u06cc\u0644\u06cc\u0648\u0646 \u0633\u0627\u0644 \u067e\u0646\u0647\u0627\u0646 \u0645\u0627\u0646\u062f\u0646\u062f\u061b \u063a\u0627\u0631\u06cc \u06a9\u0647 \u0646\u06af\u0627\u0647 \u0645\u0627 \u0628\u0647 \u062d\u06cc\u0627\u062a \u0641\u0631\u0627\u0632\u0645\u06cc\u0646\u06cc \u0631\u0627 \u062a\u063a\u06cc\u06cc\u0631 \u0645\u06cc\u200c\u062f\u0647\u062f",
