          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u062f\u0631\u06af\u06cc\u0631\u06cc \u0628\u0627 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u06a9\u0648\u0686\u06a9 \u0627\u0633\u062a\u060c \u0622\u0646\u0647\u0627 \u0628\u06cc\u0645\u0627\u0631 \u0648 \u062f\u06cc\u0648\u0627\u0646\u0647\u200c\u0627\u0646\u062f\u061b \u0647\u06af\u0633\u062a: \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u062e\u0627\u0630\u06cc \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0645\u06cc\u200c\u06a9\u0631\u062f \u0648 \u0645\u0627 \u0628\u0647 \u06a9\u0645\u06a9 \u062c\u0647\u0627\u0646 \u0631\u0641\u062a\u06cc\u0645",
