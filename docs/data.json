          "summary": "\u062f\u0631 \u0645\u06cc\u0627\u0646\u0647 \u06cc\u06a9\u06cc \u0627\u0632 \u067e\u06cc\u0686\u06cc\u062f\u0647\u200c\u062a\u0631\u06cc\u0646 \u0628\u062d\u0631\u0627\u0646\u200c\u0647\u0627\u06cc \u0698\u0626\u0648\u067e\u0644\u06cc\u062a\u06cc\u06a9\u06cc \u0633\u0627\u0644\u200c\u0647\u0627\u06cc \u0627\u062e\u06cc\u0631\u060c \u062c\u0627\u06cc\u06cc \u06a9\u0647 \u062a\u0646\u0634 \u0645\u06cc\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u0633\u062a \u0627\u0632 \u0633\u0637\u062d \u06a9\u0646\u0648\u0646\u06cc \u0646\u06cc\u0632 \u0641\u0631\u0627\u062a\u0631 \u0631\u0648\u062f\u060c \u0646\u0627\u0645\u06cc \u0628\u0647\u200c\u0639\u0646\u0648\u0627\u0646 \u0645\u06cc\u0627\u0646\u062c\u06cc \u0645\u0637\u0631\u062d \u0634\u062f \u06a9\u0647 \u0628\u0631\u0627\u06cc \u0628\u0633\u06cc\u0627\u0631\u06cc \u063a\u06cc\u0631\u0645\u0646\u062a\u0638\u0631\u0647 \u0628\u0648\u062f: \u067e\u0627\u06a9\u0633\u062a\u0627\u0646.",
