          "title": "\ud83d\udd34 \u0647\u0634\u062f\u0627\u0631 \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u200c\u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u0645\u0648\u0631\u062f \u0645\u06cc\u0646\u200c\u06af\u0630\u0627\u0631\u06cc\u200c \u062f\u0631 \u062f\u0631\u06cc\u0627\u061b \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648 \u0628\u0647 \u0645\u0631\u062f\u0645 \u0627\u06cc\u0631\u0627\u0646: \u062f\u0631 \u0631\u0648\u0632\u0647\u0627\u06cc \u0622\u06cc\u0646\u062f\u0647 \u0634\u0631\u0627\u06cc\u0637 \u0628\u062f\u0633\u062a \u06af\u0631\u0641\u062a\u0646 \u0633\u0631\u0646\u0648\u0634\u062a\u062a\u0627\u0646 \u0641\u0631\u0627\u0647\u0645 \u0645\u06cc\u200c\u0634\u0648\u062f",
