        {
          "title": "\u062d\u0632\u0628 \u0627\u0635\u0644\u06cc \u0645\u062e\u0627\u0644\u0641 \u062a\u0631\u06a9\u06cc\u0647 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u062d\u06a9\u0645 \u062f\u0627\u062f\u06af\u0627\u0647 \u0628\u0631\u06a9\u0646\u0627\u0631\u06cc \u0631\u0647\u0628\u0631\u0627\u0646\u0634 \u0631\u0627 \u0628\u0647 \u0686\u0627\u0644\u0634 \u0645\u06cc\u200c\u06a9\u0634\u062f",
