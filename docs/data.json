        {
          "title": "\u0646\u0627\u067e\u062f\u06cc\u062f\u0634\u062f\u06af\u0627\u0646 \u0645\u06a9\u0632\u06cc\u06a9 \u062f\u0631 \u0633\u0627\u06cc\u0647 \u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc\u061b \u00ab\u062a\u0628 \u0641\u0648\u062a\u0628\u0627\u0644 \u062f\u0648\u0628\u0627\u0631\u0647 \u0628\u0627\u0644\u0627 \u06af\u0631\u0641\u062a\u0647 \u0627\u0645\u0627 \u0628\u0686\u0647\u200c\u0647\u0627\u06cc \u0645\u0627 \u06a9\u062c\u0627 \u0647\u0633\u062a\u0646\u062f\u061f\u00bb",
