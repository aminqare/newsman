        {
          "title": "\u067e\u0634\u062a \u067e\u0631\u062f\u0647 \u062f\u06cc\u062f\u0627\u0631 \u0639\u0631\u0627\u0642\u0686\u06cc \u0648 \u067e\u0648\u062a\u06cc\u0646\u061b \u0622\u06cc\u0627 \u0631\u0648\u0633\u06cc\u0647 \u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u062f \u0627\u06cc\u0646 \u0628\u062d\u0631\u0627\u0646 \u062a\u0645\u0627\u0645 \u0634\u0648\u062f\u061f",
          "link": "https://www.bbc.com/persian/articles/cg5p66e66p5o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0639\u0628\u0627\u0633 \u0639\u0631\u0627\u0642\u0686\u06cc \u0631\u0648\u0632 \u062f\u0648\u0634\u0646\u0628\u0647 \u062f\u0631 \u0633\u0641\u0631\u06cc \u063a\u06cc\u0631\u0645\u0646\u062a\u0638\u0631\u0647 \u0628\u0647 \u0633\u0646\u200c\u067e\u062a\u0631\u0632\u0628\u0648\u0631\u06af \u0631\u0641\u062a \u0648 \u0628\u0627 \u0648\u0644\u0627\u062f\u06cc\u0645\u06cc\u0631 \u067e\u0648\u062a\u06cc\u0646 \u062f\u06cc\u062f\u0627\u0631 \u06a9\u0631\u062f. \u0646\u06cc\u06a9\u06cc\u062a\u0627 \u0627\u0633\u0645\u0627\u06af\u06cc\u0646\u060c \u06a9\u0627\u0631\u0634\u0646\u0627\u0633 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631 \u0645\u0635\u0627\u062d\u0628\u0647 \u0628\u0627 \u0628\u062e\u0634 \u0631\u0648\u0633\u06cc \u0628\u06cc\u200c\u0628\u06cc\u200c\u0633\u06cc\u060c \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0627\u0637\u0644\u0627\u0639\u0627\u062a \u0632\u06cc\u0627\u062f\u06cc \u062f\u0631\u0628\u0627\u0631\u0647 \u062c\u0632\u0626\u06cc\u0627\u062a \u062f\u06cc\u062f\u0627\u0631 \u062f\u0631 \u062f\u0633\u062a \u0646\u06cc\u0633\u062a\u060c \u0627\u0645\u0627 \u0645\u062d\u0648\u0631 \u0645\u0647\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
