          "summary": "\u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0633\u0641\u0631 \u062c\u0631\u062f \u06a9\u0648\u0634\u0646\u0631 \u0648 \u0627\u0633\u062a\u06cc\u0648 \u0648\u06cc\u062a\u06a9\u0627\u0641\u060c \u0645\u0630\u0627\u06a9\u0631\u0647\u200c\u06a9\u0646\u0646\u062f\u06af\u0627\u0646 \u0627\u0631\u0634\u062f \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647\u060c \u0628\u0647 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0628\u0631\u0627\u06cc \u06af\u0641\u062a\u200c\u0648\u200c\u06af\u0648 \u0628\u0627 \u0646\u0645\u0627\u06cc\u0646\u062f\u06af\u0627\u0646 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0631\u0627 \u0644\u063a\u0648 \u06a9\u0631\u062f. \u0627\u0648 \u062a\u0627\u06a9\u06cc\u062f \u06a9\u0631\u062f: \u00ab\u0627\u062e\u062a\u0644\u0627\u0641\u0627\u062a \u0648 \u0633\u0631\u062f\u0631\u06af\u0645\u06cc \u0634\u062f\u06cc\u062f\u06cc \u0645\u06cc\u0627\u0646 \u0631\u0647\u0628\u0631\u0627\u0646 [\u0631\u0698\u06cc\u2026",
