          "title": "\u0633\u0647 \u06a9\u0634\u062a\u0647 \u062f\u0631 \u062d\u0645\u0644\u0647 \u0645\u0631\u06af\u0628\u0627\u0631 \u0628\u0647 \u0645\u0633\u062c\u062f \u062c\u0627\u0645\u0639 \u0633\u0646\u200c\u062f\u06cc\u06af\u0648\u060c \u062c\u0633\u062f \u062f\u0648 \u0646\u0648\u062c\u0648\u0627\u0646 \u0645\u0638\u0646\u0648\u0646 \u0628\u0647 \u062a\u06cc\u0631\u0627\u0646\u062f\u0627\u0632\u06cc \u062f\u0631 \u062e\u0648\u062f\u0631\u0648 \u067e\u06cc\u062f\u0627 \u0634\u062f",
