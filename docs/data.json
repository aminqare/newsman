        {
          "title": "\u06cc\u06a9 \u0645\u0627\u0647 \u0632\u06cc\u0631 \u0622\u062a\u0634\u061b \u063a\u06cc\u0631\u0646\u0638\u0627\u0645\u06cc\u0627\u0646 \u062f\u0631 \u062a\u0647\u0631\u0627\u0646 \u0686\u06af\u0648\u0646\u0647 \u062a\u062d\u062a \u062a\u0627\u062b\u06cc\u0631 \u062d\u0645\u0644\u0627\u062a \u0646\u0638\u0627\u0645\u06cc \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0647\u200c\u0627\u0646\u062f\u061f",
