        {
          "title": "\u062d\u0645\u0644\u0647 \u067e\u0647\u067e\u0627\u062f\u06cc \u0648 \u0645\u0648\u0634\u06a9\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u06a9\u0648\u06cc\u062a\u061b \u062a\u0635\u0627\u0648\u06cc\u0631 \u0645\u0627\u0647\u0648\u0627\u0631\u0647\u200c\u0627\u06cc \u0627\u0632 \u067e\u0627\u06cc\u06af\u0627\u0647 \u0647\u0648\u0627\u06cc\u06cc \u0639\u0644\u06cc\u200c\u0627\u0644\u0633\u0627\u0644\u0645",
          "link": "https://www.bbc.com/persian/articles/cx212l799n5o?at_medium=RSS&at_campaign=rss",
          "summary": "\u062a\u0635\u0627\u0648\u06cc\u0631 \u0645\u0627\u0647\u0648\u0627\u0631\u0647\u200c\u0627\u06cc \u0634\u0631\u06a9\u062a \u0627\u06cc\u0631\u0628\u0627\u0633 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u06a9\u0647 \u062f\u0631 \u067e\u06cc \u062d\u0645\u0644\u0647 \u067e\u0647\u067e\u0627\u062f\u06cc \u0648 \u0645\u0648\u0634\u06a9\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u06a9\u0648\u06cc\u062a \u062f\u0631 \u06f1\u06f3 \u062e\u0631\u062f\u0627\u062f\u060c \u06cc\u06a9 \u0633\u0627\u062e\u062a\u0645\u0627\u0646 \u062f\u0631 \u067e\u0627\u06cc\u06af\u0627\u0647 \u0647\u0648\u0627\u06cc\u06cc \u0639\u0644\u06cc\u200c\u0627\u0644\u0633\u0627\u0644\u0645 \u0622\u0633\u06cc\u0628 \u062f\u06cc\u062f\u0647 \u0648 \u0628\u0647\u200c\u0646\u0638\u0631 \u0645\u06cc\u200c\u0631\u0633\u062f \u0628\u0647\u200c\u0637\u0648\u0631 \u06a9\u0627\u0645\u0644 \u062a\u062e\u0631\u06cc\u0628 \u0634\u062f\u0647 \u0627\u0633\u062a.",
