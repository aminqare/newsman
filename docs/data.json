          "title": "\u0628\u062d\u0631\u0627\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u061b \u0633\u067e\u0627\u0647 \u067e\u0627\u0633\u062f\u0627\u0631\u0627\u0646 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0634\u0646\u0627\u0648\u0631\u0647\u0627\u06cc\u06cc \u06a9\u0647 \u0628\u0647 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0646\u0632\u062f\u06cc\u06a9 \u0634\u0648\u0646\u062f\u00ab\u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u062e\u0648\u0627\u0647\u0646\u062f \u06af\u0631\u0641\u062a\u00bb",
