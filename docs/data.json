          "title": "\u0645\u062c\u062a\u0628\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc\u061b \u0628\u0627\u0632\u06cc\u06af\u0631 \u067e\u0646\u0647\u0627\u0646\u200c\u06a9\u0627\u0631 \u00ab\u0646\u0638\u0627\u0645\u00bb",
