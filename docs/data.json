          "summary": "\u0642\u0631\u0627\u0631\u06af\u0627\u0647 \u0645\u0631\u06a9\u0632\u06cc \u062e\u0627\u062a\u0645\u200c\u0627\u0644\u0646\u0628\u06cc\u0627 \u0628\u0647 \u0633\u0627\u06a9\u0646\u0627\u0646 \u00ab\u0628\u062e\u0634\u200c\u0647\u0627\u06cc \u0634\u0645\u0627\u0644\u06cc \u0648 \u0634\u0647\u0631\u06a9\u200c\u0647\u0627\u06cc \u0646\u0638\u0627\u0645\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u00bb \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f \u06a9\u0647 \u062f\u0631 \u0635\u0648\u0631\u062a \u0628\u0645\u0628\u0627\u0631\u0627\u0646 \u0636\u0627\u062d\u06cc\u0647 \u0648 \u0628\u06cc\u0631\u0648\u062a \u00ab\u0627\u06af\u0631 \u0646\u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u0646\u062f \u0622\u0633\u06cc\u0628 \u0628\u0628\u06cc\u0646\u0646\u062f \u0645\u0646\u0637\u0642\u0647 \u0631\u0627 \u062a\u0631\u06a9 \u0646\u0645\u0627\u06cc\u0646\u062f.\u00bb \u0628\u0646\u06cc\u0627\u0645\u06cc\u0646 \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648 \u0627\u0645\u0631\u0648\u0632 \u062f\u0633\u062a\u0648\u0631 \u062d\u0645\u0644\u0647 \u0628\u0647 \u0627\u0647\u062f\u0627\u0641\u06cc \u062f\u0631 \u0636\u0627\u2026",
