          "title": "\u062a\u0631\u0627\u0645\u067e: \u0645\u0646\u062a\u0638\u0631 \u067e\u0627\u0633\u062e \u0627\u06cc\u0631\u0627\u0646 \u0647\u0633\u062a\u06cc\u0645\u061b \u0627\u0631\u062a\u0634 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0631\u0627\u06cc \u0686\u0646\u062f \u0631\u0648\u0633\u062a\u0627 \u062f\u0631 \u062c\u0646\u0648\u0628 \u0644\u0628\u0646\u0627\u0646 \u0647\u0634\u062f\u0627\u0631 \u062a\u062e\u0644\u06cc\u0647 \u0635\u0627\u062f\u0631 \u06a9\u0631\u062f",
