        {
          "title": "\u0622\u06cc\u0627 \u062c\u0647\u0627\u0646 \u0628\u0647 \u0633\u0645\u062a \u062c\u0646\u06af \u062c\u0647\u0627\u0646\u06cc \u0633\u0648\u0645 \u0645\u06cc\u200c\u0631\u0648\u062f \u06cc\u0627 \u0627\u06cc\u0646 \u0646\u06af\u0631\u0627\u0646\u06cc \u0627\u063a\u0631\u0627\u0642\u200c\u0622\u0645\u06cc\u0632 \u0627\u0633\u062a\u061f",
          "link": "https://www.bbc.com/persian/articles/c3exn233x30o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0628\u0627 \u06af\u0630\u0634\u062a \u0628\u06cc\u0634 \u0627\u0632 \u06cc\u06a9 \u0645\u0627\u0647 \u0627\u0632 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u060c \u0646\u06af\u0631\u0627\u0646\u06cc\u200c\u0647\u0627 \u062f\u0631\u0628\u0627\u0631\u0647 \u06af\u0633\u062a\u0631\u0634 \u0622\u0646 \u0627\u0641\u0632\u0627\u06cc\u0634 \u06cc\u0627\u0641\u062a\u0647\u060c \u0627\u0645\u0627 \u0628\u0633\u06cc\u0627\u0631\u06cc \u0622\u0646 \u0631\u0627 \u0647\u0645\u0686\u0646\u0627\u0646 \u062f\u0631 \u0633\u0637\u062d \u0645\u0646\u0637\u0642\u0647\u200c\u0627\u06cc \u0627\u0631\u0632\u06cc\u0627\u0628\u06cc \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f. \u06a9\u0627\u0631\u0634\u0646\u0627\u0633\u0627\u0646 \u0645\u06cc\u200c\u06af\u0648\u06cc\u0646\u062f \u062c\u0646\u06af\u200c\u0647\u0627\u06cc \u0628\u0632\u0631\u06af \u0627\u063a\u0644\u0628 \u0627\u0632 \u0633\u0648\u0621\u0645\u062d\u0627\u0633\u0628\u0647 \u0622\u063a\u0627\u0632 \u0645\u06cc\u200c\u0634\u0648\u0646\u062f\u060c \u0627\u0645\u0627 \u0646\u0634\u0627\u0646\u0647\u200c\u0627\u06cc \u0627\u0632 \u062a\u0645\u0627\u06cc\u0644\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0645\u062d\u0645\u062f\u0627\u0645\u06cc\u0646 \u0628\u06cc\u06af\u0644\u0631\u06cc \u0648 \u0634\u0627\u0647\u06cc\u0646 \u0648\u0627\u062d\u062f\u067e\u0631\u0633\u062a\u060c \u0627\u0632 \u0645\u0639\u062a\u0631\u0636\u0627\u0646 \u062f\u06cc\u060c \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0639\u062f\u0627\u0645 \u0634\u062f\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/cr41evz24rko?at_medium=RSS&at_campaign=rss",
          "summary": "\u0642\u0648\u0647 \u0642\u0636\u0627\u0626\u06cc\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0645\u062d\u0645\u062f\u0627\u0645\u06cc\u0646 \u0628\u06cc\u06af\u0644\u0631\u06cc \u0648 \u0634\u0627\u0647\u06cc\u0646 \u0648\u0627\u062d\u062f\u067e\u0631\u0633\u062a \u0631\u0627 \u06a9\u0647 \u062f\u0631 \u0627\u0639\u062a\u0631\u0627\u0636\u0627\u062a \u062f\u06cc \u0645\u0627\u0647 \u0628\u0627\u0632\u062f\u0627\u0634\u062a \u0634\u062f\u0646\u062f\u060c \u0627\u0639\u062f\u0627\u0645 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0627\u0645\u06cc\u0631\u062d\u0633\u06cc\u0646 \u062d\u0627\u062a\u0645\u06cc\u060c \u06cc\u06a9\u06cc \u062f\u06cc\u06af\u0631 \u0627\u0632 \u0645\u0639\u062a\u0631\u0636\u0627\u0646 \u062f\u06cc \u0645\u0627\u0647\u060c \u0647\u0645 \u0633\u0647 \u0631\u0648\u0632 \u067e\u06cc\u0634 \u0628\u0627 \u0627\u062a\u0647\u0627\u0645\u0627\u062a \u0645\u0634\u0627\u0628\u0647\u06cc \u0627\u0639\u062f\u0627\u0645 \u0634\u062f. \u0627\u06cc\u0646 \u062f\u0647\u0645\u06cc\u0646 \u0627\u0639\u062f\u0627\u0645 \u0632\u0646\u062f\u0627\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
