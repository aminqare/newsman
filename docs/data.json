          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u067e\u0627\u0633\u062e \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u06a9\u0627\u0645\u0644\u0627 \u063a\u06cc\u0631\u0642\u0627\u0628\u0644 \u0642\u0628\u0648\u0644 \u0627\u0633\u062a\u061b \u0622\u0646\u200c\u0647\u0627 \u067e\u0633 \u0627\u0632 \u06f4\u06f7 \u0633\u0627\u0644 \u0628\u0627\u0632\u06cc \u06af\u0631\u0641\u062a\u0646 \u062f\u0646\u06cc\u0627 \u062f\u06cc\u06af\u0631 \u0628\u0647 \u0645\u0627 \u0646\u062e\u0648\u0627\u0647\u0646\u062f \u062e\u0646\u062f\u06cc\u062f",
