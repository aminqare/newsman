          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e \u0633\u0641\u0631 \u06a9\u0648\u0634\u0646\u0631 \u0648 \u0648\u06cc\u062a\u06a9\u0627\u0641 \u0628\u0647 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0631\u0627 \u0644\u063a\u0648 \u06a9\u0631\u062f",
