        {
          "title": "\u0648\u0627\u06a9\u0646\u0634\u200c\u0647\u0627 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u062a\u0641\u0627\u0647\u0645\u200c\u0646\u0627\u0645\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627\u061b \u0627\u0632 \u062d\u0645\u0627\u06cc\u062a \u062f\u0648 \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631 \u0633\u0627\u0628\u0642 \u062a\u0627 \u00ab\u0633\u06a9\u0648\u062a \u0622\u0646 \u06cc\u06a9 \u0646\u0641\u0631\u00bb",
