          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u06af\u0641\u062a \u0642\u0635\u062f \u062f\u0627\u0631\u062f \u0645\u06cc\u0632\u0628\u0627\u0646 \u0631\u0647\u0628\u0631\u0627\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648 \u0644\u0628\u0646\u0627\u0646 \u062f\u0631 \u06a9\u0627\u062e \u0633\u0641\u06cc\u062f \u0628\u0627\u0634\u062f\u061b \u062a\u0631\u0627\u0645\u067e: \u0631\u0647\u0628\u0631\u0627\u0646 \u0631\u0698\u06cc\u0645 \u0634\u06cc\u0637\u0627\u0646\u06cc \u0628\u0648\u062f\u0646\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062a\u0631\u0627\u0645\u067e \u0639\u0635\u0631 \u062c\u0645\u0639\u0647 \u06af\u0641\u062a \u00ab\u062f\u0627\u0631\u06cc\u0645 [\u0628\u0627 \u0631\u0698\u06cc\u0645] \u0635\u062d\u0628\u062a \u0645\u06cc\u200c\u06a9\u0646\u06cc\u0645...\u06a9\u0645\u06cc \u0633\u062e\u062a \u0627\u0633\u062a \u06a9\u0647 \u0628\u0641\u0647\u0645\u06cc\u0645 \u0631\u0647\u0628\u0631\u0627\u0646\u0634\u0627\u0646 \u0686\u0647 \u06a9\u0633\u0627\u0646\u06cc \u0647\u0633\u062a\u0646\u062f. \u0645\u06cc\u200c\u062f\u0627\u0646\u06cc\u062f\u060c \u0631\u0647\u0628\u0631\u0627\u0646\u0634\u0627\u0646 \u0627\u0632 \u0628\u06cc\u0646 \u0631\u0641\u062a\u0647\u200c\u0627\u0646\u062f...\u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc \u0627\u0632 \u0628\u06cc\u0646 \u0631\u0641\u062a.\u00bb \u0627\u0648 \u06af\u0641\u062a \u0622\u0646 \u0631\u0647\u0628\u0631\u0627\u0646 \u00ab\u0634\u06cc\u0637\u0627\u0646\u06cc\u00bb \u0628\u0648\u062f\u0646\u062f \u0648 \u0637\u06cc \u062f\u0648 \u0647\u0641\u062a\u0647\u060c \u06f4\u06f2 \u0647\u0632\u0627\u0631 \u0645\u0639\u062a\u0631\u0636\u2026",
