        {
          "title": "\u0622\u06cc\u0627 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u060c \u0628\u062d\u0631\u0627\u0646 \u0633\u0648\u0626\u0632 \u062a\u0631\u0627\u0645\u067e \u0627\u0633\u062a\u061f",
