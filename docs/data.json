        {
          "title": "\u067e\u0627\u0633\u062e \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u00ab\u0628\u0647\u062a\u0631\u06cc\u0646 \u0648 \u0622\u062e\u0631\u06cc\u0646\u00bb \u067e\u06cc\u0634\u0646\u0647\u0627\u062f \u0622\u0645\u0631\u06cc\u06a9\u0627: \u062d\u0633\u0646 \u0646\u06cc\u062a \u062f\u0627\u0634\u062a\u06cc\u0645 \u0627\u0645\u0627 \u0627\u0639\u062a\u0645\u0627\u062f\u0645\u0627\u0646 \u0631\u0627 \u0646\u062a\u0648\u0627\u0646\u0633\u062a\u0646\u062f \u062c\u0644\u0628 \u06a9\u0646\u0646\u062f",
          "link": "https://www.bbc.co.uk/persian/live/cvg0pzy07vjt?at_medium=RSS&at_campaign=rss",
          "summary": "\u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u067e\u0633 \u0627\u0632 \u06f2\u06f1 \u0633\u0627\u0639\u062a \u06af\u0641\u062a\u200c\u0648\u06af\u0648\u06cc \u0641\u0634\u0631\u062f\u0647 \u062f\u0631 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u067e\u0627\u06a9\u0633\u062a\u0627\u0646\u060c \u0628\u062f\u0648\u0646 \u062a\u0648\u0627\u0641\u0642 \u067e\u0627\u06cc\u0627\u0646 \u06cc\u0627\u0641\u062a. \u0628\u0639\u062f \u0627\u0632 \u067e\u0627\u06cc\u0627\u0646 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a\u060c \u062c\u06cc\u200c\u062f\u06cc\u200c\u0648\u0646\u0633\u060c \u0645\u0639\u0627\u0648\u0646 \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f \u06a9\u0647 \u00ab\u0628\u0647\u062a\u0631\u06cc\u0646 \u0648 \u0622\u062e\u0631\u06cc\u0646\u00bb \u067e\u06cc\u0634\u0646\u0647\u0627\u062f \u062e\u0648\u062f \u0631\u0627 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0627\u062f\u0647 \u0627\u0633\u062a:\u2026",
