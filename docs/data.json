        {
          "title": "\u0622\u0645\u0631\u06cc\u06a9\u0627 \u0641\u0631\u0648\u0634 \u06f1\u06f4 \u0645\u06cc\u0644\u06cc\u0627\u0631\u062f \u062f\u0644\u0627\u0631 \u062a\u0633\u0644\u06cc\u062d\u0627\u062a \u0628\u0647 \u062a\u0627\u06cc\u0648\u0627\u0646 \u0631\u0627 \u00ab\u0628\u0647\u200c\u062f\u0644\u06cc\u0644 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u00bb \u0645\u062a\u0648\u0642\u0641 \u06a9\u0631\u062f",
