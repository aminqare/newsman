        {
          "title": "\u0627\u0633\u062a\u0642\u0628\u0627\u0644 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u0622\u062a\u0634\u200c\u0628\u0633 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648 \u0644\u0628\u0646\u0627\u0646\u061b \u062a\u0631\u0627\u0645\u067e \u0645\u062f\u0639\u06cc \u0645\u0648\u0627\u0641\u0642\u062a \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627 \u062a\u062d\u0648\u06cc\u0644 \u0627\u0648\u0631\u0627\u0646\u06cc\u0648\u0645 \u063a\u0646\u06cc\u200c\u0634\u062f\u0647 \u0634\u062f",
          "link": "https://www.bbc.co.uk/persian/live/c4gj0jq74jnt?at_medium=RSS&at_campaign=rss",
          "summary": "\u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u0622\u062a\u0634 \u0628\u0633 \u06f1\u06f0 \u0631\u0648\u0632\u0647 \u0645\u06cc\u0627\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648 \u0644\u0628\u0646\u0627\u0646 \u0627\u0633\u062a\u0642\u0628\u0627\u0644 \u06a9\u0631\u062f\u0647 \u0648 \u0622\u0646 \u0631\u0627 \u062d\u0627\u0635\u0644 \u00ab\u0645\u0642\u0627\u0648\u0645\u062a \u0645\u0631\u062f\u0645 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u062f\u0627\u0646\u0633\u062a\u0647 \u0627\u0633\u062a\u00bb. \u0647\u0645\u0632\u0645\u0627\u0646 \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u06af\u0641\u062a\u0647 \u0627\u0633\u062a \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627 \u062a\u062d\u0648\u06cc\u0644 \u0627\u0648\u0631\u0627\u0646\u06cc\u0648\u0645 \u063a\u0646\u06cc\u200c\u0634\u062f\u0647 \u062e\u0648\u062f \u0645\u0648\u0627\u0641\u0642\u062a \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u0627\u06cc\u0646 \u0627\u0638\u0647\u0627\u0631\u0627\u062a \u0647\u0646\u0648\u0632 \u0648\u0627\u06a9\u0646\u0634\u2026",
