          "title": "\u0647\u0645\u0627 \u0645\u06cc\u0631\u0627\u0641\u0634\u0627\u0631\u060c \u00ab\u0632\u0646 \u0647\u0632\u0627\u0631 \u062a\u0631\u0627\u0646\u0647\u00bb \u0645\u0648\u0633\u06cc\u0642\u06cc \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631\u06af\u0630\u0634\u062a",
