        {
          "title": "\u0628\u0627\u0632\u0645\u0627\u0646\u062f\u06af\u0627\u0646 \u0646\u0627\u0648\u0647\u0627\u06cc \u062f\u0646\u0627 \u0648 \u0628\u0648\u0634\u0647\u0631 \u067e\u0633 \u0627\u0632 \u0647\u0641\u062a\u0647\u200c\u0647\u0627 \u0633\u0631\u06af\u0631\u062f\u0627\u0646\u06cc \u062f\u0631 \u0633\u0631\u06cc\u0644\u0627\u0646\u06a9\u0627 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0631\u06af\u0634\u062a\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/cew77qvgx0no?at_medium=RSS&at_campaign=rss",
          "summary": "\u0628\u06cc\u0634 \u0627\u0632 \u06f2\u06f0\u06f0 \u0645\u0644\u0648\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0628\u0627\u0632\u0645\u0627\u0646\u062f\u0647 \u0627\u0632 \u0646\u0627\u0648\u0686\u0647 \u063a\u0631\u0642 \u0634\u062f\u0647 \u062f\u0646\u0627 \u0648 \u06a9\u0634\u062a\u06cc \u0628\u0648\u0634\u0647\u0631 \u06a9\u0647 \u062f\u0631 \u0633\u0631\u06cc\u0644\u0627\u0646\u06a9\u0627 \u0633\u0631\u06af\u0631\u062f\u0627\u0646 \u0645\u0627\u0646\u062f\u0647 \u0628\u0648\u062f\u0646\u062f\u060c \u0627\u06a9\u0646\u0648\u0646 \u062f\u0631 \u062d\u0627\u0644 \u0628\u0627\u0632\u06af\u0634\u062a \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0647\u0633\u062a\u0646\u062f. \u0646\u0627\u0648\u0686\u0647 \u062f\u0646\u0627 \u0627\u0648\u0627\u0633\u0637 \u0627\u0633\u0641\u0646\u062f \u0633\u0627\u0644 \u06af\u0630\u0634\u062a\u0647 \u062e\u0648\u0631\u0634\u06cc\u062f\u06cc \u0647\u062f\u0641 \u0627\u0698\u062f\u0631 \u06cc\u06a9 \u0632\u06cc\u0631\u062f\u0631\u06cc\u0627\u06cc\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
