        {
          "title": "\u062c\u0646\u06af \u0645\u062c\u0627\u0632\u06cc \u062f\u0631 \u0627\u06cc\u06a9\u0633\u061b \u0633\u0641\u0627\u0631\u062a\u200c\u062e\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631 \u0628\u0631\u0627\u0628\u0631 \u062a\u0631\u0627\u0645\u067e",
