          "title": "\u062a\u0646\u0634 \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0648 \u062a\u0647\u062f\u06cc\u062f \u062a\u0631\u0627\u0645\u067e \u0639\u0644\u06cc\u0647 \u0639\u0645\u0627\u0646\u061b \u0628\u0627\u0632\u06cc \u0642\u062f\u0631\u062a \u0645\u06cc\u0627\u0646 \u062a\u0647\u0631\u0627\u0646\u060c \u0645\u0633\u0642\u0637 \u0648 \u0648\u0627\u0634\u0646\u06af\u062a\u0646",
