        {
          "title": "\ud83d\udd34 \u0647\u0634\u062f\u0627\u0631 \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u0645\u0648\u0631\u062f \u0646\u0642\u0636 \u0627\u062d\u062a\u0645\u0627\u0644\u06cc \u0622\u062a\u0634\u200c\u0628\u0633\u061b \u062c\u06cc\u200c\u062f\u06cc \u0648\u0646\u0633: \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0647\u0631 \u0686\u0647 \u0628\u06cc\u0634\u062a\u0631 \u0627\u0645\u062a\u06cc\u0627\u0632 \u062f\u0647\u062f\u060c \u0628\u06cc\u0634\u062a\u0631 \u0628\u0647\u0631\u0647 \u0645\u06cc\u200c\u0628\u0631\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0646\u0642\u0636 \u0622\u062a\u0634\u200c\u0628\u0633 \u0627\u0632 \u0633\u0648\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0631\u0627 \u00ab\u0628\u0633\u06cc\u0627\u0631 \u0628\u0639\u06cc\u062f\u00bb \u062e\u0648\u0627\u0646\u062f \u0648\u0644\u06cc \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f \u06a9\u0647 \u0627\u06af\u0631 \u0628\u0647 \u062a\u0648\u0627\u0641\u0642 \u0622\u062a\u0634\u200c\u0628\u0633 \u0628\u0647 \u0637\u0648\u0631 \u06a9\u0627\u0645\u0644 \u0639\u0645\u0644 \u0646\u0634\u0648\u062f\u060c \u00ab\u0634\u0644\u06cc\u06a9\u200c\u0647\u0627 \u0634\u0631\u0648\u0639 \u0645\u06cc\u200c\u0634\u0648\u062f.\u00bb \u062f\u0631 \u062a\u062d\u0648\u0644\u06cc \u062f\u06cc\u06af\u0631 \u062c\u06cc\u200c\u062f\u06cc \u0648\u0646\u0633 \u06af\u0641\u062a \u06a9\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0645\u0648\u0627\u0631\u062f \u0645\u0634\u062e\u0635\u06cc\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
          "source_url": "https://ir.voanews.com/api/zbtpil-vomx-tpeqiyp"
        },
