          "title": "\u200c\ud83d\udd34 \u0648\u0627\u06a9\u0646\u0634 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u0627\u062d\u062a\u0645\u0627\u0644 \u062a\u0648\u0642\u0641 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a: \u0645\u0634\u06a9\u0644\u06cc \u0646\u06cc\u0633\u062a\u060c \u0632\u06cc\u0627\u062f \u062d\u0631\u0641 \u0632\u062f\u0647\u200c\u0627\u06cc\u0645\u061b \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0648 \u0645\u0639\u062a\u0631\u0636 \u062f\u06cc\u06af\u0631 \u062f\u06cc\u200c\u0645\u0627\u0647 \u06f1\u06f4\u06f0\u06f4 \u0631\u0627 \u0627\u0639\u062f\u0627\u0645 \u06a9\u0631\u062f",
