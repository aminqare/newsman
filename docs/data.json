        {
          "title": "\u00ab\u0632\u0646\u062f\u06af\u06cc \u0634\u06cc\u0631\u06cc\u0646\u00bb\u061b \u0627\u06cc\u062a\u0627\u0644\u06cc\u0627\u060c \u0645\u0642\u0635\u062f \u062a\u0627\u0632\u0647 \u0633\u0631\u0645\u0627\u06cc\u0647\u200c\u062f\u0627\u0631\u0627\u0646 \u0628\u0632\u0631\u06af \u062c\u0647\u0627\u0646\u061f",
