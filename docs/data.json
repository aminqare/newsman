          "summary": "\u0641\u0631\u0645\u0627\u0646\u062f\u0647\u06cc \u0645\u0631\u06a9\u0632\u06cc \u0627\u0631\u062a\u0634 \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0633\u0646\u062a\u06a9\u0627\u0645\u060c \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u06a9\u0647 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0631\u0648\u0632 \u062c\u0645\u0639\u0647 \u062f\u0631 \u0648\u0627\u06a9\u0646\u0634 \u0628\u0647 \u062d\u0645\u0644\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u062a\u062c\u0627\u0631\u06cc \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u060c \u0645\u0648\u0627\u0636\u0639\u06cc \u0631\u0627 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u062f\u0627\u062f\u0646\u062f. \u0628\u0631 \u0627\u0633\u0627\u0633 \u0628\u06cc\u0627\u0646\u06cc\u0647 \u0633\u0646\u062a\u06a9\u0627\u0645\u060c \u0647\u0648\u0627\u067e\u06cc\u0645\u0627\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0627\u0646\u0628\u0627\u0631\u0647\u0627\u06cc \u0645\u0648\u0634\u2026",
