          "title": "\u06a9\u0648\u06cc\u062a \u0627\u0632 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0646 \u06cc\u06a9 \u0646\u0641\u062a\u06a9\u0634 \u0628\u0632\u0631\u06af \u062e\u0648\u062f \u062e\u0628\u0631 \u062f\u0627\u062f",
          "link": "https://www.bbc.co.uk/persian/live/c4g62yz7d33t?at_medium=RSS&at_campaign=rss",
          "summary": "\u06a9\u0648\u06cc\u062a \u0627\u0632 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0646 \u06cc\u06a9 \u0646\u0641\u062a\u06a9\u0634 \u0628\u0632\u0631\u06af \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u062f\u0631 \u0633\u0648\u0627\u062d\u0644 \u062f\u0648\u0628\u06cc \u062e\u0628\u0631 \u062f\u0627\u062f\u0647 \u0648 \u0622\u0646 \u0631\u0627 \u0628\u0647 \u062d\u0645\u0644\u0647 \u067e\u0647\u067e\u0627\u062f\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0646\u0633\u0628\u062a \u062f\u0627\u062f\u0647 \u0627\u0633\u062a. \u0628\u0646\u06cc\u0627\u0645\u06cc\u0646 \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648\u060c \u0646\u062e\u0633\u062a\u200c\u0648\u0632\u06cc\u0631 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u06af\u0641\u062a\u0647 \u0627\u0633\u062a \u0627\u06af\u0631 \u0686\u0647 \u0646\u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u062f \u0686\u0627\u0631\u0686\u0648\u0628 \u0632\u0645\u0627\u0646\u06cc \u0628\u0631\u0627\u06cc \u062c\u0646\u06af \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u062a\u0639\u06cc\u06cc\u0646 \u06a9\u0646\u062f \u0627\u0645\u0627\u2026",
