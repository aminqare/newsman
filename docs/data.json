        {
          "title": "\ud83d\udd34 \u0648\u0627\u06a9\u0646\u0634 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e \u0628\u0647 \u062a\u0627\u0632\u0647\u200c\u062a\u0631\u06cc\u0646 \u067e\u06cc\u0634\u0646\u0647\u0627\u062f \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc: \u0646\u0627\u0631\u0627\u0636\u06cc\u200c\u0627\u0645\u061b \u062a\u062d\u0631\u06cc\u0645 \u0635\u0631\u0627\u0641\u06cc\u200c\u0647\u0627\u06cc \u0645\u0631\u062a\u0628\u0637 \u0628\u0627 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u00ab\u062e\u0634\u0645 \u0627\u0642\u062a\u0635\u0627\u062f\u06cc\u00bb",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u06af\u0641\u062a \u06a9\u0647 \u0645\u0642\u0627\u0645\u0627\u062a \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062e\u0648\u0627\u0647\u0627\u0646 \u0631\u0633\u06cc\u062f\u0646 \u0628\u0647 \u062a\u0648\u0627\u0641\u0642 \u0647\u0633\u062a\u0646\u062f \u0627\u0645\u0627 \u0647\u0646\u0648\u0632 \u0646\u062a\u0648\u0627\u0646\u0633\u062a\u0647\u200c\u0627\u0646\u062f \u0631\u0636\u0627\u06cc\u062a \u0627\u0648 \u0631\u0627 \u062c\u0644\u0628 \u06a9\u0646\u0646\u062f\u060c \u0628\u0646\u0627\u0628\u0631\u0627\u06cc\u0646 \u0627\u0648 \u0645\u0637\u0645\u0626\u0646 \u0646\u06cc\u0633\u062a \u06a9\u0647 \u0628\u0647 \u062a\u0648\u0627\u0641\u0642 \u062e\u0648\u0627\u0647\u0646\u062f \u0631\u0633\u06cc\u062f \u06cc\u0627 \u0646\u0647. \u0627\u06cc\u0631\u0646\u0627 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u0645\u0642\u0627\u0645\u0627\u062a \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
