          "summary": "\u0627\u06cc\u0631\u0627\u0646\u06cc\u0627\u0646 \u0633\u0627\u06a9\u0646 \u062a\u0631\u06a9\u06cc\u0647 \u0627\u0632 \u0632\u0645\u0627\u0646 \u0622\u063a\u0627\u0632 \u062c\u0646\u06af\u060c \u0627\u062d\u0633\u0627\u0633\u0627\u062a \u0645\u062a\u0646\u0627\u0642\u0636\u06cc \u0631\u0627 \u0645\u06cc\u0627\u0646 \u0628\u06cc\u0645 \u0648 \u0627\u0645\u06cc\u062f \u062a\u062c\u0631\u0628\u0647 \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f. \u0632\u0646\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u06a9\u0647 \u0628\u0627 \u0628\u062e\u0634 \u062a\u0631\u06a9\u06cc \u0628\u06cc\u200c\u0628\u06cc\u200c\u0633\u06cc \u06af\u0641\u062a\u200c\u0648\u06af\u0648 \u06a9\u0631\u062f\u0647\u200c\u0627\u0646\u062f \u0645\u06cc\u200c\u06af\u0648\u06cc\u0646\u062f \u062f\u0634\u0648\u0627\u0631\u06cc\u200c\u0647\u0627\u06cc \u0641\u0631\u0627\u0648\u0627\u0646\u06cc \u0628\u0631\u0627\u06cc \u062a\u0645\u0627\u0633 \u0628\u0627 \u062e\u0627\u0646\u0648\u0627\u062f\u0647\u200c\u0647\u0627\u06cc \u062e\u0648\u062f \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0627\u0631\u0646\u062f \u0648 \u062f\u0686\u0627\u0631\u2026",
