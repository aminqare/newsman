          "title": "\u00ab\u062d\u0645\u0644\u0647 \u067e\u0647\u067e\u0627\u062f\u06cc\u00bb \u0628\u0647 \u0646\u0632\u062f\u06cc\u06a9\u06cc \u0646\u06cc\u0631\u0648\u06af\u0627\u0647 \u0647\u0633\u062a\u0647\u200c\u0627\u06cc \u0627\u0645\u0627\u0631\u0627\u062a\u061b \u0627\u0628\u0648\u0638\u0628\u06cc: \u0622\u062a\u0634\u200c\u0633\u0648\u0632\u06cc \u06a9\u0646\u062a\u0631\u0644 \u0634\u062f",
