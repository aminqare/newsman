        {
          "title": "\u062f\u0631\u06af\u06cc\u0631\u06cc\u200c\u0647\u0627\u06cc \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0648 \u0627\u0641\u063a\u0627\u0646\u0633\u062a\u0627\u0646\u061b \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f: \u067e\u0627\u0633\u062e \u0645\u0627 \u0628\u0647 \u0647\u0631 \u062a\u0647\u0627\u062c\u0645\u06cc \u06a9\u0648\u0628\u0646\u062f\u0647 \u0627\u0633\u062a",
