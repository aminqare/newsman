        {
          "title": "\u067e\u0631\u0648\u0627\u0632 \u062f\u0631 \u0633\u0627\u06cc\u0647 \u062c\u0646\u06af\u061b \u0622\u06cc\u0627 \u0639\u0635\u0631 \u0637\u0644\u0627\u06cc\u06cc \u0634\u0631\u06a9\u062a\u200c\u0647\u0627\u06cc \u0647\u0648\u0627\u06cc\u06cc \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u0631\u0648 \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u0627\u0633\u062a\u061f",
