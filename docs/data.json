        {
          "title": "\u0622\u06cc\u0627 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627\u0639\u062b \u0645\u06cc\u200c\u0634\u0648\u062f \u06a9\u06cc\u0645 \u062c\u0648\u0646\u06af \u0627\u0648\u0646 \u0628\u0631\u0627\u06cc \u0622\u06cc\u0646\u062f\u0647 \u06a9\u0631\u0647 \u0634\u0645\u0627\u0644\u06cc \u0627\u062d\u0633\u0627\u0633 \u0646\u06af\u0631\u0627\u0646\u06cc \u06a9\u0646\u062f\u061f",
