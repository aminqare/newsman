        {
          "title": "\u062a\u0631\u0627\u0645\u067e \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06af\u0641\u062a\u200c\u0648\u06af\u0648\u0647\u0627\u06cc \u00ab\u062e\u0648\u0628\u06cc\u00bb \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631 \u062c\u0631\u06cc\u0627\u0646 \u0627\u0633\u062a\u060c \u0627\u0645\u0627 \u062c\u0632\u0626\u06cc\u0627\u062a \u0632\u06cc\u0627\u062f\u06cc \u0627\u0631\u0627\u0626\u0647 \u0646\u0645\u06cc\u200c\u062f\u0647\u062f",
