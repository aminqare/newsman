        {
          "title": "\u067e\u0634\u062a\u200c\u067e\u0631\u062f\u0647 \u06cc\u06a9 \u0645\u06cc\u0627\u0646\u062c\u06cc\u200c\u06af\u0631\u06cc \u062d\u0633\u0627\u0633\u061b \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0686\u0637\u0648\u0631 \u0645\u06cc\u0632\u0628\u0627\u0646 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0635\u0644\u062d \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0634\u062f\u061f",
