        {
          "title": "\u062f\u06cc\u067e\u0644\u0645\u0627\u0633\u06cc \u0646\u06cc\u0645\u0647\u200c\u062c\u0627\u0646 \u0648 \u062a\u0646\u0634 \u0641\u0639\u0627\u0644 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u06a9\u062c\u0627 \u0645\u06cc\u200c\u0631\u0633\u062f\u061b \u0686\u0647\u0627\u0631 \u0633\u0646\u0627\u0631\u06cc\u0648\u06cc \u0645\u062d\u062a\u0645\u0644",
