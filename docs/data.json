          "summary": "\u0648\u0644\u0627\u062f\u06cc\u0645\u06cc\u0631 \u067e\u0648\u062a\u06cc\u0646\u060c \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631 \u0631\u0648\u0633\u06cc\u0647\u060c \u067e\u0633 \u0627\u0632 \u0631\u0698\u0647 \u0646\u0638\u0627\u0645\u06cc \u06a9\u0648\u0686\u06a9\u06cc \u06a9\u0647 \u062f\u0631 \u0645\u0633\u06a9\u0648 \u0628\u0647 \u0645\u0646\u0627\u0633\u0628\u062a \u067e\u06cc\u0631\u0648\u0632\u06cc \u0634\u0648\u0631\u0648\u06cc \u0633\u0627\u0628\u0642 \u062f\u0631 \u062c\u0646\u06af \u062c\u0647\u0627\u0646\u06cc \u062f\u0648\u0645 \u0627\u0646\u062c\u0627\u0645 \u0634\u062f\u060c \u062f\u0631 \u062c\u0645\u0639 \u062e\u0628\u0631\u0646\u06af\u0627\u0631\u0627\u0646 \u06af\u0641\u062a \u06a9\u0647 \u0627\u0648 \u0641\u06a9\u0631 \u0645\u06cc\u200c\u06a9\u0646\u062f \u062f\u0631\u06af\u06cc\u0631\u06cc \u0631\u0648\u0633\u06cc\u0647 \u0628\u0627 \u0627\u0648\u06a9\u0631\u0627\u06cc\u0646 \u0631\u0648 \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u0627\u0633\u062a.",
