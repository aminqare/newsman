          "title": "\u0633\u0642\u0648\u0637 \u06cc\u06a9 \u0647\u0644\u06cc\u200c\u06a9\u0648\u067e\u062a\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u062f\u0631 \u0646\u0632\u062f\u06cc\u06a9\u06cc \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u061b \u062a\u0631\u0627\u0645\u067e: \u062e\u0644\u0628\u0627\u0646\u0627\u0646 \u0633\u0627\u0644\u0645 \u0647\u0633\u062a\u0646\u062f",
