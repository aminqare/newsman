        },
        {
          "title": "\u0642\u0648\u0647 \u0642\u0636\u0627\u0626\u06cc\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0632 \u0627\u0639\u062f\u0627\u0645 \u0645\u0647\u0631\u062f\u0627\u062f \u0645\u062d\u0645\u062f\u06cc\u200c\u0646\u06cc\u0627 \u0648 \u0627\u0634\u06a9\u0627\u0646 \u0645\u0627\u0644\u06a9\u06cc\u060c \u062f\u0648 \u0646\u0641\u0631 \u0627\u0632 \u0645\u0639\u062a\u0631\u0636\u0627\u0646 \u062f\u06cc\u060c \u062e\u0628\u0631 \u062f\u0627\u062f",
