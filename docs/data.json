          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e \u062f\u0631 \u0645\u0648\u0631\u062f \u0627\u0642\u062f\u0627\u0645\u0627\u062a \u0631\u0698\u06cc\u0645 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632: \u0627\u06cc\u0646 \u062a\u0648\u0627\u0641\u0642\u06cc \u0646\u06cc\u0633\u062a \u06a9\u0647 \u0645\u0627 \u062f\u0627\u0631\u06cc\u0645! \u06af\u0631\u0641\u062a\u0646 \u0639\u0648\u0627\u0631\u0636\u06cc \u0627\u0632 \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627 \u0631\u0627 \u0645\u062a\u0648\u0642\u0641 \u06a9\u0646\u06cc\u062f\u061b\n\u06a9\u0645\u0627\u0644 \u062e\u0631\u0627\u0632\u06cc \u06a9\u0634\u062a\u0647 \u0634\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u062f\u0631 \u067e\u06cc\u0627\u0645\u06cc \u06a9\u0647 \u0639\u0635\u0631 \u067e\u0646\u062c\u200c\u0634\u0646\u0628\u0647 \u0645\u0646\u062a\u0634\u0631 \u06a9\u0631\u062f \u0628\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u0645\u0648\u0631\u062f \u06af\u0631\u0641\u062a\u0646 \u0639\u0648\u0627\u0631\u0636 \u0627\u0632 \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627 \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f. \u0628\u0646\u06cc\u0627\u0645\u06cc\u0646 \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648 \u06af\u0641\u062a \u062f\u0631 \u067e\u0627\u0633\u062e \u0628\u0647 \u00ab\u062f\u0631\u062e\u0648\u0627\u0633\u062a\u200c\u0647\u0627\u06cc \u0645\u06a9\u0631\u0631 \u0644\u0628\u0646\u0627\u0646\u06cc\u200c\u0647\u0627\u00bb \u062f\u0633\u062a\u0648\u0631 \u0628\u0631\u06af\u0632\u0627\u0631\u06cc \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0645\u0633\u062a\u0642\u06cc\u0645 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648\u2026",
