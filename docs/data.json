          "summary": "\u0631\u0647\u0628\u0631\u0649 \u06a9\u0647 \u0647\u0631\u06af\u0632 \u0628\u0647 \u200c\u0637\u0648\u0631 \u06a9\u0627\u0645\u0644 \u0622\u0632\u0645\u0648\u062f\u0647 \u0646\u0634\u062f\u0647 \u0627\u0633\u062a\u060c \u062f\u0631 \u0632\u0645\u0627\u0646\u06cc \u0633\u06a9\u0627\u0646 \u0642\u062f\u0631\u062a \u0631\u0627 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u062f\u0633\u062a \u0645\u06cc\u200c\u06af\u06cc\u0631\u062f \u06a9\u0647 \u062d\u06a9\u0648\u0645\u062a \u062f\u06cc\u0646\u06cc \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u0628\u0627 \u0628\u0632\u0631\u06af\u200c\u062a\u0631\u06cc\u0646 \u0622\u0632\u0645\u0648\u0646 \u062e\u0648\u062f \u062f\u0631 \u067e\u0646\u062c \u062f\u0647\u0647 \u06af\u0630\u0634\u062a\u0647 \u0631\u0648\u0628\u0647\u200c\u0631\u0648 \u0627\u0633\u062a. \u062a\u062f\u0627\u0648\u0645 \u0633\u0627\u062e\u062a\u0627\u0631 \u0642\u062f\u0631\u062a \u0648 \u0634\u0628\u06a9\u0647 \u0627\u0631\u062a\u0628\u0627\u0637\u0627\u062a\u060c \u0645\u062c\u062a\u0628\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc\u0650 \u06f5\u06f6\u2026",
