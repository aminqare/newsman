          "title": "\u062a\u0634\u062f\u06cc\u062f \u062a\u0644\u0627\u0634 \u062f\u06cc\u067e\u0644\u0645\u0627\u062a\u06cc\u06a9 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f\u061b \u0641\u0631\u0645\u0627\u0646\u062f\u0647 \u0627\u0631\u062a\u0634 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0648 \u0647\u06cc\u0626\u062a \u0642\u0637\u0631 \u062f\u0631 \u062a\u0647\u0631\u0627\u0646",
