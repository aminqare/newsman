        {
          "title": "\u0635\u062f\u0627\u0648\u0633\u06cc\u0645\u0627: \u0627\u06cc\u0631\u0627\u0646 \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0627\u06cc \u0628\u0631\u0627\u06cc \u0634\u0631\u06a9\u062a \u062f\u0631 \u062f\u0648\u0631 \u0628\u0639\u062f\u06cc \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0646\u062f\u0627\u0631\u062f",
          "link": "https://www.bbc.co.uk/persian/live/clyrexrxz72t?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0648\u0633\u0627\u06cc \u062f\u0648\u0644\u062a \u0627\u06cc\u0631\u0627\u0646 \u0648 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0648 \u0647\u0645\u0686\u0646\u06cc\u0646 \u0648\u0632\u0631\u0627\u06cc \u062e\u0627\u0631\u062c\u0647 \u062f\u0648 \u06a9\u0634\u0648\u0631 \u0627\u0645\u0631\u0648\u0632 \u062a\u0644\u0641\u0646\u06cc \u0628\u0627 \u06cc\u06a9\u062f\u06cc\u06af\u0631 \u06af\u0641\u062a\u200c\u0648\u06af\u0648 \u06a9\u0631\u062f\u0646\u062f. \u0633\u0647 \u0631\u0648\u0632 \u0645\u0627\u0646\u062f\u0647 \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u0622\u062a\u0634\u200c\u0628\u0633\u060c \u0635\u062f\u0627\u0648\u0633\u06cc\u0645\u0627 \u0628\u0647 \u0646\u0642\u0644 \u0627\u0632 \u0645\u0646\u0627\u0628\u0639 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0646\u0648\u0634\u062a \u06a9\u0647 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0627\u06cc \u0628\u0631\u0627\u06cc \u0634\u0631\u06a9\u062a \u062f\u0631 \u062f\u0648\u0631 \u0628\u0639\u062f\u06cc \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0646\u062f\u0627\u0631\u062f.\u0627\u2026",
