          "title": "\u0631\u0647\u0628\u0631 \u062c\u062f\u06cc\u062f \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u0622\u0632\u0645\u0648\u0646\u06cc \u0633\u0631\u0646\u0648\u0634\u062a\u200c\u0633\u0627\u0632\u061b \u0646\u0628\u0631\u062f\u06cc \u0628\u0631\u0627\u06cc \u0628\u0642\u0627",
