        {
          "title": "\u0627\u0632 \u0642\u0630\u0627\u0641\u06cc \u062a\u0627 \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc\u061b \u067e\u0648\u062a\u06cc\u0646 \u0628\u0639\u062f \u0627\u0632 \u0633\u0642\u0648\u0637 \u0645\u062a\u062d\u062f\u0627\u0646\u0634\u060c \u0686\u0647 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0648 \u0686\u0647 \u0646\u0645\u06cc\u200c\u06af\u0648\u06cc\u062f",
