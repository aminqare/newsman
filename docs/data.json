          "title": "\ud83d\udd34 \u0622\u063a\u0627\u0632 \u0645\u0648\u062c \u062c\u062f\u06cc\u062f \u062d\u0645\u0644\u0627\u062a \u0627\u0631\u062a\u0634 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646\n\u061b \u0648\u0632\u06cc\u0631 \u062e\u0627\u0631\u062c\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0627\u06cc\u0631\u0627\u0646\u06cc\u0627\u0646 \u0628\u0631\u0627\u06cc \u0633\u0631\u0646\u06af\u0648\u0646\u06cc \u0628\u0647 \u06a9\u0645\u06a9 \u062e\u0627\u0631\u062c\u06cc \u0646\u06cc\u0627\u0632 \u062f\u0627\u0631\u0646\u062f",
