          "title": "\u067e\u0634\u062a \u067e\u0631\u062f\u0647 \u06cc\u06a9 \u0628\u062d\u0631\u0627\u0646 \u062f\u0631\u06cc\u0627\u06cc\u06cc\u061b \u062c\u0647\u0627\u0646 \u067e\u0646\u0647\u0627\u0646 \u0646\u0641\u062a\u06a9\u0634\u200c\u0647\u0627\u06cc \u0631\u0647\u0627\u0634\u062f\u0647",
