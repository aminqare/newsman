        {
          "title": "\u0648\u0648 \u06cc\u06cc\u0632\u0647\u061b \u0641\u0648\u0642 \u0633\u062a\u0627\u0631\u0647\u200c \u0627\u0633\u0646\u0648\u06a9\u0631 \u0627\u0632 \u0622\u067e\u0627\u0631\u062a\u0645\u0627\u0646\u06cc \u0628\u062f\u0648\u0646 \u067e\u0646\u062c\u0631\u0647 \u062a\u0627 \u0642\u0647\u0631\u0645\u0627\u0646\u06cc \u062c\u0647\u0627\u0646",
