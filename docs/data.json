          "title": "\u0648\u0627\u0634\u0646\u06af\u062a\u0646 \u0627\u0638\u0647\u0627\u0631\u0627\u062a \u0639\u0631\u0627\u0642\u0686\u06cc \u062f\u0631 \u0645\u0648\u0631\u062f \u062d\u0645\u0644\u0627\u062a \u067e\u0647\u067e\u0627\u062f\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u0631\u0627 \u0631\u062f \u06a9\u0631\u062f",
