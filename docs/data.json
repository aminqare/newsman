        {
          "title": "\u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc \u06f2\u06f0\u06f2\u06f6\u061b \u0648\u0631\u0648\u062f \u0686\u0647 \u0686\u06cc\u0632\u0647\u0627\u06cc\u06cc \u0628\u0647 \u0648\u0631\u0632\u0634\u06af\u0627\u0647\u200c\u0647\u0627 \u0645\u0645\u0646\u0648\u0639 \u0627\u0633\u062a\u061f",
