        {
          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e: \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062a\u0646\u0647\u0627 \u067e\u06cc\u0631\u0648\u0632 \u0646\u0628\u0631\u062f\u0647\u0627\u06cc\u06cc \u0627\u0633\u062a \u06a9\u0647 \u0628\u0627 \u0647\u0648\u0634 \u0645\u0635\u0646\u0648\u0639\u06cc \u0633\u0627\u062e\u062a\u0647\u061b \u06af\u0632\u0627\u0631\u0634 \u0648\u0627\u0644\u200c\u0627\u0633\u062a\u0631\u06cc\u062a \u0698\u0648\u0631\u0646\u0627\u0644 \u062f\u0631\u0628\u0627\u0631\u0647 \u0647\u0648\u0627\u067e\u06cc\u0645\u0627\u0647\u0627\u06cc \u0633\u0648\u062e\u062a\u200c\u0631\u0633\u0627\u0646 \u0646\u0627\u062f\u0631\u0633\u062a \u0627\u0633\u062a",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u062f\u0631 \u0628\u06cc\u0627\u0646\u06cc\u0647\u200c\u0627\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0631\u0627 \u0627\u0633\u062a\u0627\u062f \u062f\u0633\u062a\u06a9\u0627\u0631\u06cc \u0631\u0633\u0627\u0646\u0647\u200c\u0627\u06cc \u062e\u0648\u0627\u0646\u062f \u06af\u0641\u062a \u0622\u0646\u200c\u0647\u0627 \u0627\u0632 \u0646\u0638\u0631 \u0646\u0638\u0627\u0645\u06cc \u0636\u0639\u06cc\u0641 \u0647\u0633\u062a\u0646\u062f \u0627\u0645\u0627 \u062f\u0631 \u0627\u0646\u062a\u0634\u0627\u0631 \u0627\u0637\u0644\u0627\u0639\u0627\u062a \u0646\u0627\u062f\u0631\u0633\u062a \u062f\u0631 \u00ab\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u062c\u0639\u0644\u06cc\u00bb \u0645\u0647\u0627\u0631\u062a \u0632\u06cc\u0627\u062f\u06cc \u062f\u0627\u0631\u0646\u062f. \u062a\u0627\u06cc\u0645\u0632 \u0627\u0633\u0631\u0627\u0626\u064a\u0644 \u0628\u0647 \u0646\u0642\u0644 \u0627\u0632 \u0645\u0642\u0627\u0645\u200c\u0647\u0627\u06cc \u0627\u0633\u0631\u0627\u0626\u064a\u0644\u06cc \u0646\u0648\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
