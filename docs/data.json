          "title": "\u0634\u0648\u0631\u0627\u06cc \u0639\u0627\u0644\u06cc \u0627\u0645\u0646\u06cc\u062a \u0645\u0644\u06cc \u0627\u06cc\u0631\u0627\u0646: \u062a\u0627 \u0632\u0645\u0627\u0646 \u067e\u0627\u06cc\u0627\u0646 \u0642\u0637\u0639\u06cc \u062c\u0646\u06af\u060c \u0646\u0638\u0627\u0631\u062a \u0648 \u06a9\u0646\u062a\u0631\u0644 \u0628\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0627\u0639\u0645\u0627\u0644 \u062e\u0648\u0627\u0647\u062f \u0634\u062f",
