          "title": "\ud83d\udd34 \u0645\u0648\u062c \u062c\u062f\u06cc\u062f \u062d\u0645\u0644\u0627\u062a \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0639\u0644\u06cc\u0647 \u0645\u0648\u0627\u0636\u0639 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u063a\u0631\u0628 \u0648 \u0645\u0631\u06a9\u0632 \u0627\u06cc\u0631\u0627\u0646\u061b \u0647\u0634\u062f\u0627\u0631 \u062f\u0631 \u0645\u0648\u0631\u062f \u0634\u0631\u0627\u06cc\u0637 \u00ab\u062e\u0637\u0631\u0646\u0627\u06a9\u00bb \u0632\u0646\u062f\u0627\u0646 \u062a\u0647\u0631\u0627\u0646 \u0628\u0632\u0631\u06af",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0627\u0631\u062a\u0634 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u06a9\u0647 \u0645\u0648\u062c\u06cc \u06af\u0633\u062a\u0631\u062f\u0647\u200c\u0627\u06cc \u0627\u0632 \u062d\u0645\u0644\u0627\u062a \u0631\u0627 \u0639\u0644\u06cc\u0647 \u0632\u06cc\u0631\u0633\u0627\u062e\u062a\u200c\u0647\u0627\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062f\u0631 \u063a\u0631\u0628 \u06a9\u0634\u0648\u0631 \u0622\u063a\u0627\u0632 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0631\u0648\u0632 \u06cc\u06a9\u0634\u0646\u0628\u0647 \u0647\u0645\u0686\u0646\u06cc\u0646 \u0642\u0637\u0639 \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0648\u0627\u0631\u062f \u0631\u0648\u0632 \u0634\u0627\u0646\u0632\u062f\u0647\u0645 \u0634\u062f \u0648 \u0645\u0633\u062f\u0648\u062f \u0628\u0648\u062f\u0646 \u0627\u0631\u062a\u0628\u0627\u0637\u0627\u062a \u0645\u0631\u062f\u0645 \u0628\u0627 \u0634\u0628\u06a9\u0647\u200c\u0647\u0627\u06cc \u0628\u06cc\u0646\u200c\u0627\u0644\u0645\u0644\u0644\u06cc\u2026",
