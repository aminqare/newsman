        {
          "title": "\u062c\u06cc\u200c\u062f\u06cc \u0648\u0646\u0633: \u06a9\u0627\u0628\u06cc\u0646\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647\u062a\u0631 \u0627\u0633\u062a \u0628\u062f\u0627\u0646\u062f \u06a9\u0647 \u062a\u0631\u0627\u0645\u067e \u062f\u0631 \u0634\u0631\u0627\u06cc\u0637 \u06a9\u0646\u0648\u0646\u06cc \u062a\u0646\u0647\u0627 \u0645\u062a\u062d\u062f \u0642\u062f\u0631\u062a\u0645\u0646\u062f \u0622\u0646\u0647\u0627\u0633\u062a",
