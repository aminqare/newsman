          "summary": "\u0647\u0645\u200c\u0632\u0645\u0627\u0646 \u0628\u0627 \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0639\u0644\u06cc\u0647 \u0627\u06cc\u0631\u0627\u0646 \u06a9\u0647 \u0628\u0647 \u0646\u0638\u0631 \u0645\u06cc\u200c\u0631\u0633\u062f \u062f\u0631 \u062d\u0627\u0644 \u062a\u063a\u06cc\u06cc\u0631 \u0646\u0642\u0634\u0647 \u0631\u0627\u0647\u0628\u0631\u062f\u06cc \u0645\u0646\u0637\u0642\u0647 \u0627\u0633\u062a \u0648 \u062a\u0648\u062c\u0647 \u062c\u0647\u0627\u0646 \u0631\u0627 \u0628\u06cc\u0634 \u0627\u0632 \u067e\u06cc\u0634 \u0628\u0647 \u062a\u0647\u0631\u0627\u0646 \u0645\u0639\u0637\u0648\u0641 \u06a9\u0631\u062f\u0647\u060c \u0622\u062a\u0634\u200c\u0628\u0633 \u0634\u06a9\u0646\u0646\u062f\u0647 \u063a\u0632\u0647 \u0628\u06cc\u0634 \u0627\u0632 \u0647\u0631 \u0632\u0645\u0627\u0646 \u062f\u06cc\u06af\u0631\u06cc \u062f\u0631 \u0645\u0639\u0631\u0636 \u062e\u0637\u0631 \u0648 \u062a\u0647\u062f\u06cc\u062f \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0647 \u0627\u0633\u062a.",
