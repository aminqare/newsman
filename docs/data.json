        {
          "title": "\u200c\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e: \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u0638\u0631\u0641 \u062f\u0648 \u0647\u0641\u062a\u0647 \u00ab\u067e\u06cc\u0631\u0648\u0632\u06cc \u06a9\u0627\u0645\u0644\u00bb \u062e\u0648\u062f \u0631\u0627 \u0628\u0631 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u0639\u0644\u0627\u0645 \u06a9\u0646\u062f\u061b \u0645\u0630\u0627\u06a9\u0631\u0647\u200c\u06a9\u0646\u0646\u062f\u06af\u0627\u0646 \u0631\u0698\u06cc\u0645 \u00ab\u062d\u0627\u0636\u0631\u0646\u062f \u0647\u0645\u0647\u200c \u0686\u06cc\u0632 \u0631\u0627 \u0628\u0647 \u0645\u0627 \u0628\u062f\u0647\u0646\u062f\u00bb",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0639\u0635\u0631 \u062f\u0648\u0634\u0646\u0628\u0647 \u06f1\u06f8 \u062e\u0631\u062f\u0627\u062f \u067e\u06cc\u0634\u200c\u0628\u06cc\u0646\u06cc \u06a9\u0631\u062f \u06a9\u0647 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u0638\u0631\u0641 \u062f\u0648 \u0647\u0641\u062a\u0647 \u0622\u06cc\u0646\u062f\u0647 \u00ab\u067e\u06cc\u0631\u0648\u0632\u06cc \u06a9\u0627\u0645\u0644\u00bb \u0628\u0631 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0646\u062f. \u0628\u0647 \u06af\u0632\u0627\u0631\u0634 \u0633\u06cc\u200c\u0628\u06cc\u200c\u0627\u0633\u060c \u0622\u0642\u0627\u06cc \u062a\u0631\u0627\u0645\u067e \u06af\u0641\u062a \u0645\u0630\u0627\u06a9\u0631\u0647\u200c\u06a9\u0646\u0646\u062f\u06af\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u00ab\u062d\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
