        {
          "title": "\u0631\u0647\u0628\u0631 \u062c\u062f\u06cc\u062f \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc\u061b \u062c\u0646\u06af\u060c \u0642\u062f\u0631\u062a \u0648 \u0646\u0628\u0631\u062f \u0628\u0631\u0627\u06cc \u0645\u0634\u0631\u0648\u0639\u06cc\u062a",
