          "title": "\u062d\u0645\u0644\u0627\u062a \u0647\u0648\u0627\u06cc\u06cc \u0633\u0646\u06af\u06cc\u0646 \u0628\u0647 \u062a\u0647\u0631\u0627\u0646\u061b \u062f\u0627\u0646\u0634\u06af\u0627\u0647 \u0635\u0646\u0639\u062a\u06cc \u0634\u0631\u06cc\u0641 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a",
          "link": "https://www.bbc.co.uk/persian/live/clyd9jddmprt?at_medium=RSS&at_campaign=rss",
          "summary": "\u0645\u0646\u0627\u0637\u0642 \u0645\u062e\u062a\u0644\u0641 \u062a\u0647\u0631\u0627\u0646 \u0627\u0632 \u0646\u062e\u0633\u062a\u06cc\u0646 \u0633\u0627\u0639\u0627\u062a \u0627\u0645\u0631\u0648\u0632 \u0634\u0627\u0647\u062f \u062d\u0645\u0644\u0627\u062a \u0647\u0648\u0627\u06cc\u06cc \u0633\u0646\u06af\u06cc\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0648\u062f. \u0628\u062e\u0634\u200c\u0647\u0627\u06cc\u06cc \u0627\u0632 \u062f\u0627\u0646\u0634\u06af\u0627\u0647 \u0635\u0646\u0639\u062a\u06cc \u0634\u0631\u06cc\u0641 \u0627\u0632 \u062c\u0645\u0644\u0647 \u067e\u0633\u062a \u06af\u0627\u0632 \u0622\u0646 \u0647\u062f\u0641 \u0627\u06cc\u0646 \u062d\u0645\u0644\u0627\u062a \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a \u06a9\u0647 \u062f\u0631 \u0646\u062a\u06cc\u062c\u0647 \u0622\u0646 \u06af\u0627\u0632 \u062f\u0631 \u0627\u06cc\u0646 \u0645\u0646\u0637\u0642\u0647 \u0642\u0637\u0639 \u0634\u062f\u0647 \u0627\u0633\u062a. \u062a\u0635\u0627\u0648\u06cc\u0631 \u0645\u0646\u062a\u0634\u0631 \u0634\u062f\u2026",
