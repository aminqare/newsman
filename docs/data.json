          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e \u062f\u0631 \u0645\u0648\u0631\u062f \u0639\u0645\u0644\u06cc\u0627\u062a \u0639\u0644\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc: \u0628\u0627\u06cc\u062f \u06a9\u0627\u0631 \u0631\u0627 \u06a9\u0627\u0645\u0644 \u0627\u0646\u062c\u0627\u0645 \u062f\u0627\u062f \u062a\u0627 \u0646\u06cc\u0627\u0632 \u0628\u0647 \u062a\u06a9\u0631\u0627\u0631\u0634 \u0646\u0628\u0627\u0634\u062f\u061b \u062d\u0645\u0644\u0627\u062a \u067e\u0647\u067e\u0627\u062f\u06cc \u0628\u0647 \u0627\u06cc\u0633\u062a\u200c\u0647\u0627\u06cc \u0628\u0627\u0632\u0631\u0633\u06cc \u062f\u0631 \u062a\u0647\u0631\u0627\u0646",
