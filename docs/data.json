        {
          "title": "\u0648\u0632\u06cc\u0631 \u062e\u0627\u0631\u062c\u0647 \u0639\u0645\u0627\u0646 \u062f\u0631\u0628\u0627\u0631\u0647 \u0645\u0630\u0627\u06a9\u0631\u0647 \u0628\u0627 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc\u060c \u062c\u0645\u0639\u0647 \u062f\u0631 \u0648\u0627\u0634\u0646\u06af\u062a\u0646 \u0628\u0627 \u062c\u06cc\u200c\u062f\u06cc \u0648\u0646\u0633 \u062f\u06cc\u062f\u0627\u0631 \u0645\u06cc\u200c\u06a9\u0646\u062f",
          "link": "https://ir.voanews.com/a/us-iran-oman-fm-in-white-house/8118187.html",
          "summary": "\u0642\u0631\u0627\u0631 \u0627\u0633\u062a \u0648\u0632\u06cc\u0631 \u0627\u0645\u0648\u0631 \u062e\u0627\u0631\u062c\u0647 \u0639\u0645\u0627\u0646\u060c \u0631\u0648\u0632 \u062c\u0645\u0639\u0647 \u062f\u0631 \u0648\u0627\u0634\u0646\u06af\u062a\u0646 \u0628\u0627 \u062c\u06cc\u200c\u062f\u06cc \u0648\u0646\u0633\u060c \u0645\u0639\u0627\u0648\u0646 \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0648 \u062f\u06cc\u06af\u0631 \u0645\u0642\u0627\u0645\u200c\u0647\u0627\u06cc \u0627\u0631\u0634\u062f \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u062f\u06cc\u062f\u0627\u0631 \u06a9\u0646\u062f. \u0627\u06cc\u0646 \u062f\u06cc\u062f\u0627\u0631 \u0627\u0632 \u0642\u0628\u0644 \u0628\u0631\u0646\u0627\u0645\u0647 \u0631\u06cc\u0632\u06cc \u0646\u0634\u062f\u0647 \u0628\u0648\u062f \u0648 \u0628\u0647 \u0646\u0638\u0631 \u0645\u06cc\u200c\u0631\u0633\u062f \u062c\u0632\u0626\u06cc\u0627\u062a \u0645\u0630\u0627\u06a9\u0631\u0647 \u0631\u0648\u0632 \u067e\u0646\u062c\u0634\u0646\u0628\u0647 \u062f\u0631 \u0698\u0646\u0648 \u0628\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
