          "summary": "\u067e\u06cc\u062a \u0647\u06af\u0633\u062a \u0648 \u0698\u0646\u0631\u0627\u0644 \u062f\u0646 \u06a9\u06cc\u0646\u060c \u0648\u0632\u06cc\u0631 \u062f\u0641\u0627\u0639 \u0648 \u0631\u0626\u06cc\u0633 \u0633\u062a\u0627\u062f \u0645\u0634\u062a\u0631\u06a9 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0645\u0633\u0644\u062d \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u062f\u0631 \u06a9\u0646\u0641\u0631\u0627\u0646\u0633 \u062e\u0628\u0631\u06cc \u062f\u0631\u0628\u0627\u0631\u0647 \u0622\u062e\u0631\u06cc\u0646 \u062a\u062d\u0648\u0644\u0627\u062a \u062f\u0631 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0634\u0631\u06a9\u062a \u06a9\u0631\u062f\u0646\u062f. \u0648\u0632\u06cc\u0631 \u062f\u0641\u0627\u0639 \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0642\u0631\u0627\u0631 \u0627\u0633\u062a \u062f\u0631 \u062d\u0627\u0644\u06cc \u0633\u062e\u0646\u0631\u0627\u0646\u06cc \u06a9\u0646\u062f \u06a9\u0647 \u062a\u0646\u0634\u200c\u0647\u0627 \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0628\u0647\u200c\u0634\u062f\u062a \u0627\u0641\u0632\u0627\u06cc\u0634\u2026",
