        {
          "title": "\u067e\u0631\u0627\u0641\u062a\u062e\u0627\u0631\u062a\u0631\u06cc\u0646 \u062a\u06cc\u0645 \u062c\u0647\u0627\u0646 \u062f\u0631 \u062d\u0633\u0631\u062a \u06af\u0630\u0634\u062a\u0647\u061b \u0622\u0646\u0686\u0644\u0648\u062a\u06cc \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u0637\u0644\u0633\u0645 \u0628\u0631\u0632\u06cc\u0644 \u0631\u0627 \u0628\u0634\u06a9\u0646\u062f\u061f",
