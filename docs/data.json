        {
          "title": "\u0627\u0632 \u00ab\u0644\u063a\u0648 \u0648\u06cc\u0632\u0627 \u0648 \u0627\u0642\u0627\u0645\u062a \u0627\u0645\u0627\u0631\u0627\u062a\u00bb \u0628\u0631\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646\u06cc\u0627\u0646 \u0686\u0647 \u0645\u06cc\u200c\u062f\u0627\u0646\u06cc\u0645\u061f",
