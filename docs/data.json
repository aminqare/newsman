        {
          "title": "\u0634\u0634 \u0645\u0627\u0647 \u067e\u0633 \u0627\u0632 \u0627\u0639\u062a\u0631\u0627\u0636\u0627\u062a \u062f\u06cc \u06f1\u06f4\u06f0\u06f4\u060c \u062c\u0633\u062a\u200c\u0648\u062c\u0648\u06cc \u062d\u0642\u06cc\u0642\u062a \u062f\u0631 \u0645\u06cc\u0627\u0646 \u0622\u0645\u0627\u0631\u0647\u0627\u06cc \u0645\u062a\u0646\u0627\u0642\u0636 \u06a9\u0634\u062a\u0647\u200c\u0634\u062f\u06af\u0627\u0646",
