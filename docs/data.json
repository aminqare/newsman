        {
          "title": "\u00ab\u0641\u0642\u0637 \u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u0645 \u0622\u0646\u0647\u0627 \u0628\u0631\u0648\u0646\u062f\u00bb\u061b \u0648\u0627\u06a9\u0646\u0634\u200c\u0647\u0627 \u062f\u0631\u0628\u0627\u0631\u0647 \u0627\u062d\u062a\u0645\u0627\u0644 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0645\u06cc\u0627\u0646 \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647",
