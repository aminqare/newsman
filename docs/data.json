          "title": "\u200c\ud83d\udd34 \u06f1\u06f4 \u0628\u0646\u062f \u062a\u0641\u0627\u0647\u0645\u200c\u0646\u0627\u0645\u0647 \u0645\u06cc\u0627\u0646 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u0639\u0644\u0627\u0645 \u0634\u062f\u061b \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u0647\u06cc\u0686 \u067e\u0648\u0644\u06cc \u0628\u0647 \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u0646\u0645\u06cc\u200c\u062f\u0647\u06cc\u0645\u061b \u0645\u062c\u0628\u0648\u0631 \u0634\u0648\u06cc\u0645\u060c \u0628\u0627\u0632 \u0628\u0645\u0628\u0627\u0631\u0627\u0646 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u0645",
