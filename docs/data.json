        {
          "title": "\u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u062f\u0631 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f\u061b \u0686\u0647 \u06a9\u0633\u0627\u0646\u06cc \u0633\u0631\u0646\u0648\u0634\u062a \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0642\u0645 \u0645\u06cc\u200c\u0632\u0646\u0646\u062f\u061f",
