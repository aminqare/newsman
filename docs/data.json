          "title": "\ud83d\udd34 \u0622\u063a\u0627\u0632 \u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc\u061b \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0631\u0627\u06cc \u0645\u0630\u0627\u06a9\u0631\u0647 \u067e\u06cc\u0627\u0645 \u062f\u0627\u062f\u0647 \u0627\u0633\u062a",
