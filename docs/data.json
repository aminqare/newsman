          "title": "\u062a\u0634\u062f\u06cc\u062f \u062c\u0646\u06af \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u061b \u062d\u0645\u0644\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u06f1\u06f6 \u0634\u0646\u0627\u0648\u0631 \u0645\u06cc\u0646\u200c\u06af\u0630\u0627\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0646 \u0633\u0647 \u06a9\u0634\u062a\u06cc \u062a\u062c\u0627\u0631\u06cc",
