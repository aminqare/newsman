        {
          "title": "\u062f\u0633\u062a\u06af\u06cc\u0631\u06cc \u0628\u06cc\u0634 \u0627\u0632 \u0647\u0632\u0627\u0631 \u0646\u0641\u0631 \u062f\u0631 \u06cc\u06a9 \u0639\u0645\u0644\u06cc\u0627\u062a \u062c\u0647\u0627\u0646\u06cc \u0645\u0642\u0627\u0628\u0644\u0647 \u0628\u0627 \u0642\u0627\u0686\u0627\u0642 \u0627\u0646\u0633\u0627\u0646",
