        {
          "title": "\u0646\u062a\u06cc\u062c\u0647 \u06cc\u06a9 \u0645\u0637\u0627\u0644\u0639\u0647: \u0645\u06cc\u0644\u06cc\u0648\u0646\u200c\u0647\u0627 \u0628\u06cc\u0645\u0627\u0631 \u0645\u0628\u062a\u0644\u0627 \u0628\u0647 \u0633\u0631\u0637\u0627\u0646 \u067e\u0633\u062a\u0627\u0646 \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u0628\u062a\u0648\u0627\u0646\u0646\u062f \u0628\u0627 \u062e\u06cc\u0627\u0644 \u0631\u0627\u062d\u062a \u0627\u0632 \u0634\u06cc\u0645\u06cc\u200c\u062f\u0631\u0645\u0627\u0646\u06cc \u0627\u062c\u062a\u0646\u0627\u0628 \u06a9\u0646\u0646\u062f",
