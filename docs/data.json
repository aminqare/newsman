        {
          "title": "\u0633\u0646\u0627\u062a\u0648\u0631\u0647\u0627\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc\u200c\u062e\u0648\u0627\u0647 \u0645\u0648\u0627\u0641\u0642 \u0648 \u0645\u062e\u0627\u0644\u0641 \u062a\u0641\u0627\u0647\u0645 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646\u061b \u0641\u0631\u0642\u200c\u0634\u0627\u0646 \u062f\u0631 \u0686\u06cc\u0633\u062a\u061f",
