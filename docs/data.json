        {
          "title": "\u0642\u0627\u0644\u06cc\u0628\u0627\u0641: \u062a\u0627 \u0627\u0632 \u06af\u0631\u0641\u062a\u0646 \u062d\u0642\u0648\u0642\u200c\u0645\u0627\u0646 \u0645\u0637\u0645\u0626\u0646 \u0646\u0634\u0648\u06cc\u0645 \u0647\u06cc\u0686 \u062a\u0648\u0627\u0641\u0642\u06cc \u0631\u0627 \u062a\u0627\u06cc\u06cc\u062f \u0646\u0645\u06cc\u200c\u06a9\u0646\u06cc\u0645",
