          "summary": "\u062e\u0628\u0631\u06af\u0632\u0627\u0631\u06cc \u0631\u0648\u06cc\u062a\u0631\u0632 \u0628\u0647 \u0646\u0642\u0644 \u0627\u0632 \u0645\u0646\u0627\u0628\u0639 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646\u06cc \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0647\u06cc\u0626\u062a \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0628\u0631\u0627\u06cc \u0645\u0630\u0627\u06a9\u0631\u0647 \u0628\u0627 \u0645\u0642\u0627\u0645\u200c\u0647\u0627\u06cc \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0648\u0627\u0631\u062f \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f\u060c \u067e\u0627\u06cc\u062a\u062e\u062a \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0627\u0633\u062a. \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u062f\u0631 \u0622\u0633\u062a\u0627\u0646\u0647 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0628\u0647 \u062e\u0628\u0631\u0646\u06af\u0627\u0631\u0627\u0646 \u06af\u0641\u062a \u06a9\u0647 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0628\u0647\u200c\u0632\u0648\u062f\u06cc\u2026",
