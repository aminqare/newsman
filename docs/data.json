        {
          "title": "\u0632\u0648\u062c \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627\u06cc\u06cc \u0632\u0646\u062f\u0627\u0646\u06cc \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646: \u0627\u062d\u062a\u0645\u0627\u0644\u0627 \u0645\u062f\u062a \u0637\u0648\u0644\u0627\u0646\u06cc \u0627\u06cc\u0646\u062c\u0627 \u062e\u0648\u0627\u0647\u06cc\u0645 \u0628\u0648\u062f",
          "link": "https://www.bbc.com/persian/articles/ce8p9n3411wo?at_medium=RSS&at_campaign=rss",
          "summary": "\u06cc\u06a9 \u0632\u0648\u062c \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627\u06cc\u06cc \u06a9\u0647 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0632\u0646\u062f\u0627\u0646\u06cc \u0647\u0633\u062a\u0646\u062f \u06af\u0641\u062a\u0647\u200c\u0627\u0646\u062f \u0628\u0647 \u0627\u06cc\u0646 \u0646\u062a\u06cc\u062c\u0647 \u0631\u0633\u06cc\u062f\u0647\u200c\u0627\u0646\u062f \u06a9\u0647 \u0627\u062d\u062a\u0645\u0627\u0644\u0627\u064b \u0628\u0631\u0627\u06cc \u0645\u062f\u062a \u0637\u0648\u0644\u0627\u0646\u06cc \u062f\u0631 \u0632\u0646\u062f\u0627\u0646 \u0628\u0627\u0642\u06cc \u062e\u0648\u0627\u0647\u0646\u062f \u0645\u0627\u0646\u062f. \u0644\u06cc\u0646\u062f\u0632\u06cc \u0641\u0648\u0631\u0645\u0646\u060c \u06a9\u0647 \u0628\u0647 \u0647\u0645\u0631\u0627\u0647 \u0647\u0645\u0633\u0631\u0634 \u06a9\u0631\u06cc\u06af \u062f\u0631 \u0632\u0646\u062f\u0627\u0646 \u0627\u0648\u06cc\u0646 \u0632\u0646\u062f\u0627\u0646\u06cc \u0647\u0633\u062a\u0646\u062f\u060c \u067e\u0633 \u0627\u0632 \u062d\u062f\u0648\u062f \u06f1\u06f6 \u0645\u0627\u0647 \u062d\u0628\u0633 \u0645\u06cc\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0628\u0633\u062a\u0647 \u0645\u0627\u0646\u062f\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u00ab\u0647\u0641\u062a\u0647\u200c\u0627\u06cc \u06f1\u06f0 \u0645\u06cc\u0644\u06cc\u0627\u0631\u062f \u0648\u0639\u062f\u0647 \u063a\u0630\u0627\u00bb \u062f\u0631 \u062c\u0647\u0627\u0646 \u0631\u0627 \u062a\u0647\u062f\u06cc\u062f \u0645\u06cc\u200c\u06a9\u0646\u062f",
