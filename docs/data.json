        {
          "title": "\u0633\u0627\u0633\u0627\u0646 \u0622\u0632\u0627\u062f\u0648\u0627\u0631 \u062c\u0648\u0646\u0642\u0627\u0646\u06cc\u060c \u06f2\u06f1 \u0633\u0627\u0644\u0647\u060c\u200c \u0627\u0632 \u0628\u0627\u0632\u062f\u0627\u0634\u062a\u06cc\u200c\u0647\u0627\u06cc \u0627\u0639\u062a\u0631\u0627\u0636\u0627\u062a \u062f\u06cc \u0645\u0627\u0647 \u062f\u0631 \u0627\u0635\u0641\u0647\u0627\u0646 \u0627\u0639\u062f\u0627\u0645 \u0634\u062f",
