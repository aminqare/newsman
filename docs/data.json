        {
          "title": "\u0645\u062d\u0627\u0635\u0631\u0647 \u06cc\u0627 \u062a\u0644\u0647\u061b \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0686\u06af\u0648\u0646\u0647 \u062e\u0637\u0631\u0646\u0627\u06a9\u200c\u062a\u0631\u06cc\u0646 \u0646\u0642\u0637\u0647 \u062c\u0647\u0627\u0646 \u0634\u062f\u061f",
