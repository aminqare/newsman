        {
          "title": "\u0627\u0632 \u067e\u0627\u0646\u0627\u0645\u0627 \u062a\u0627 \u0647\u0631\u0645\u0632\u061b \u06a9\u062f\u0627\u0645 \u0622\u0628\u0631\u0627\u0647\u200c\u0647\u0627 \u0639\u0648\u0627\u0631\u0636 \u0645\u06cc\u200c\u06af\u06cc\u0631\u0646\u062f\u061f",
