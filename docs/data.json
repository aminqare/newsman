          "title": "\ud83d\udd34 \u0622\u0698\u0627\u0646\u0633 \u0627\u0646\u0631\u0698\u06cc: \u0627\u062d\u06cc\u0627\u06cc \u062a\u0648\u0644\u06cc\u062f \u0646\u0641\u062a \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u062f\u0648 \u0633\u0627\u0644 \u0637\u0648\u0644 \u0645\u06cc\u200c\u06a9\u0634\u062f\u061b \u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0686\u0647\u0644 \u0648 \u0646\u0647\u0645\u06cc\u0646 \u0631\u0648\u0632 \u0627\u0632 \u0627\u0646\u0632\u0648\u0627\u06cc \u062f\u06cc\u062c\u06cc\u062a\u0627\u0644 \u0631\u0627 \u062a\u062c\u0631\u0628\u0647 \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0645\u062f\u06cc\u0631 \u0627\u062c\u0631\u0627\u06cc\u06cc \u0622\u0698\u0627\u0646\u0633 \u0628\u06cc\u0646\u200c\u0627\u0644\u0645\u0644\u0644\u06cc \u0627\u0646\u0631\u0698\u06cc \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0628\u0627\u0632\u06af\u0634\u062a \u062a\u0648\u0644\u06cc\u062f \u0646\u0641\u062a \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0628\u0647 \u0633\u0637\u062d \u0642\u0628\u0644 \u0627\u0632 \u062d\u0645\u0644\u0627\u062a \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc\u060c \u0627\u062d\u062a\u0645\u0627\u0644\u0627\u064b \u062f\u0648 \u0633\u0627\u0644 \u0637\u0648\u0644 \u0628\u06a9\u0634\u062f. \u0647\u0645\u0632\u0645\u0627\u0646 \u0628\u0647 \u06af\u0632\u0627\u0631\u0634 \u0646\u062a\u200c\u0628\u0644\u0627\u06a9\u0633\u060c \u062e\u0627\u0645\u0648\u0634\u06cc \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0648\u0627\u0631\u062f \u0686\u0647\u0644 \u0648 \u0646\u0647\u0645\u06cc\u0646 \u0631\u0648\u0632 \u062e\u0648\u062f \u0634\u062f\u0647 \u0648\u2026",
