          "title": "\u062a\u0631\u0627\u0645\u067e: \u062d\u0645\u0644\u0647 \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0631\u06cc\u0632\u06cc\u200c\u0634\u062f\u0647 \u0627\u0645\u0634\u0628 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u0644\u063a\u0648 \u06a9\u0631\u062f\u0645\u060c \u0627\u0645\u0627 \u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0627\u062f\u0627\u0645\u0647 \u062f\u0627\u0631\u062f",
