          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633 \u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u0634\u0628 \u06f1\u06f2 \u0641\u0631\u0648\u0631\u062f\u06cc\u0646 \u062f\u0631 \u0646\u0637\u0642\u06cc \u062e\u0637\u0627\u0628 \u0628\u0647 \u0645\u0631\u062f\u0645 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u062a\u0634\u0631\u06cc\u062d \u0627\u0642\u062f\u0627\u0645 \u0646\u0638\u0627\u0645\u06cc \u0639\u0644\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u067e\u0631\u062f\u0627\u062e\u062a \u0648 \u0627\u0632 \u067e\u0627\u06cc\u0627\u0646 \u0633\u0631\u06cc\u0639 \u0627\u06cc\u0646 \u0631\u0698\u06cc\u0645 \u062e\u0628\u0631 \u062f\u0627\u062f.",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
