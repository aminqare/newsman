        {
          "title": "\u062d\u0645\u0644\u0647 \u0628\u0627 \u0686\u0627\u0642\u0648 \u0628\u0647 \u062f\u0648 \u0645\u0631\u062f \u06cc\u0647\u0648\u062f\u06cc \u062f\u0631 \u0644\u0646\u062f\u0646\u061b \u067e\u0644\u06cc\u0633 \u0627\u06cc\u0646 \u062d\u0627\u062f\u062b\u0647 \u0631\u0627 \u00ab\u062a\u0631\u0648\u0631\u06cc\u0633\u062a\u06cc\u00bb \u062e\u0648\u0627\u0646\u062f\u0647 \u0627\u0633\u062a",
