          "title": "\ud83d\udd34 \u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e: \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u062f\u06cc\u06af\u0631 \u0647\u0631\u06af\u0632 \u0628\u0633\u062a\u0647 \u0646\u062e\u0648\u0627\u0647\u062f \u0634\u062f\u061b \u0627\u0639\u0632\u0627\u0645 \u0686\u0646\u062f\u06cc\u0646 \u0647\u0632\u0627\u0631 \u0646\u06cc\u0631\u0648\u06cc \u062f\u06cc\u06af\u0631 \u0628\u0647 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e \u0631\u0648\u0632 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u06f2\u06f6 \u0641\u0631\u0648\u0631\u062f\u06cc\u0646 \u062f\u0631 \u067e\u06cc\u0627\u0645\u06cc \u062f\u0631 \u062a\u0631\u0648\u062a \u0633\u0648\u0634\u0627\u0644 \u0646\u0648\u0634\u062a: \u00ab\u0686\u06cc\u0646 \u0628\u0633\u06cc\u0627\u0631 \u062e\u0648\u0634\u062d\u0627\u0644 \u0627\u0633\u062a \u06a9\u0647 \u0645\u0646 \u0628\u0647 \u0637\u0648\u0631 \u062f\u0627\u0626\u0645\u06cc \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0628\u0627\u0632 \u0645\u06cc\u200c\u06a9\u0646\u0645. \u0645\u0646 \u0627\u06cc\u0646 \u06a9\u0627\u0631 \u0631\u0627 \u0628\u0631\u0627\u06cc \u0622\u0646\u0647\u0627 \u0646\u06cc\u0632 \u0627\u0646\u062c\u0627\u0645 \u0645\u06cc\u200c\u062f\u0647\u0645 - \u0648 \u0628\u0631\u0627\u06cc \u062c\u0647\u0627\u0646.\u00bb \u0647\u0645\u0632\u0645\u0627\u0646 \u0648\u0627\u0634\u0646\u06af\u062a\u0646\u200c\u067e\u0633\u062a \u0627\u0632 \u0642\u0648\u0644 \u0645\u0642\u0627\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
