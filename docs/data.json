          "summary": "\u06a9\u0646\u0633\u0631\u062a \u06a9\u0627\u0646\u06cc\u0647 \u0648\u0633\u062a\u060c \u0631\u067e\u0631 \u0645\u0634\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u062f\u0631 \u0644\u0647\u0633\u062a\u0627\u0646\u060c \u0628\u0647 \u062e\u0627\u0637\u0631 \u0627\u0638\u0647\u0627\u0631\u0627\u062a \u06cc\u0647\u0648\u062f\u0633\u062a\u06cc\u0632\u0627\u0646\u0647\u060c \u0646\u0698\u0627\u062f\u067e\u0631\u0633\u062a\u0627\u0646\u0647 \u0648 \u0637\u0631\u0641\u062f\u0627\u0631\u06cc \u0627\u0632 \u0646\u0627\u0632\u06cc\u200c\u0647\u0627 \u0644\u063a\u0648 \u0634\u062f. \u062e\u0628\u0631\u06af\u0632\u0627\u0631\u06cc \u0641\u0631\u0627\u0646\u0633\u0647 \u06af\u0632\u0627\u0631\u0634 \u06a9\u0631\u062f\u0647 \u06a9\u0647 \u0627\u06cc\u0646 \u06a9\u0646\u0633\u0631\u062a \u0628\u0627 \u0641\u0634\u0627\u0631 \u062f\u0648\u0644\u062a \u0644\u0647\u0633\u062a\u0627\u0646 \u0644\u063a\u0648 \u0634\u062f\u0647 \u0648 \u062f\u0648\u0644\u062a \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u0627\u0638\u0647\u0627\u0631\u0627\u062a \u06a9\u0627\u0646\u06cc\u0647 \u0648\u0633\u062a\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u062c\u0646\u062c\u0627\u0644 \u0627\u0646\u062a\u0635\u0627\u0628 \u0633\u0641\u06cc\u0631 \u0633\u0627\u0628\u0642 \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u062f\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627\u061b \u0627\u0641\u0632\u0627\u06cc\u0634 \u0641\u0634\u0627\u0631\u0647\u0627 \u0628\u0631\u0627\u06cc \u0627\u0633\u062a\u0639\u0641\u0627\u06cc \u06a9\u06cc\u200c\u06cc\u0631 \u0627\u0633\u062a\u0627\u0631\u0645\u0631",
          "link": "https://www.bbc.com/persian/articles/c4gv8nx9184o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0648\u0632\u06cc\u0631\u0627\u0646 \u062f\u0648\u0644\u062a \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u0645\u06cc\u200c\u06af\u0648\u06cc\u0646\u062f \u06a9\u0647 \u06a9\u06cc\u200c\u06cc\u0631 \u0627\u0633\u062a\u0627\u0631\u0645\u0631\u060c \u0646\u062e\u0633\u062a\u200c\u0648\u0632\u06cc\u0631\u060c \u067e\u0627\u0631\u0644\u0645\u0627\u0646 \u0631\u0627 \u062f\u0631 \u0645\u0648\u0631\u062f \u0627\u0646\u062a\u0635\u0627\u0628 \u067e\u06cc\u062a\u0631 \u0645\u0646\u062f\u0644\u0633\u0648\u0646\u060c \u0633\u0641\u06cc\u0631 \u0633\u0627\u0628\u0642 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u062f\u0631 \u0648\u0627\u0634\u0646\u06af\u062a\u0646 \u06af\u0645\u0631\u0627\u0647 \u0646\u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u062c\u0646\u062c\u0627\u0644 \u0628\u0631 \u0633\u0631 \u0627\u0646\u062a\u0635\u0627\u0628 \u0622\u0642\u0627\u06cc \u0645\u0646\u062f\u0644\u0633\u0648\u0646 \u0634\u062f\u062a \u06af\u0631\u0641\u062a\u0647 \u0627\u0633\u062a \u0648 \u0627\u062d\u0632\u0627\u0628 \u0645\u062e\u0627\u0644\u0641 \u062f\u0648\u0644\u062a \u062e\u0648\u0627\u0633\u062a\u0627\u0631\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u067e\u0644\u06cc\u0633 \u0633\u0647 \u0646\u0641\u0631 \u0631\u0627 \u0628\u0647 \u062a\u0644\u0627\u0634 \u0628\u0631\u0627\u06cc \u0622\u062a\u0634\u200c\u0632\u062f\u0646 \u06cc\u06a9\u06cc \u0627\u0632 \u062f\u0641\u0627\u062a\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u06cc\u0646\u062a\u0631\u0646\u0634\u0646\u0627\u0644 \u062f\u0631 \u0634\u0645\u0627\u0644 \u063a\u0631\u0628 \u0644\u0646\u062f\u0646 \u0645\u062a\u0647\u0645 \u06a9\u0631\u062f",
          "link": "https://www.bbc.com/persian/articles/c5yw01ywk0do?at_medium=RSS&at_campaign=rss",
          "summary": "\u067e\u0644\u06cc\u0633 \u0644\u0646\u062f\u0646 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u0633\u0647 \u0646\u0641\u0631 \u0628\u0647 \u062a\u0644\u0627\u0634 \u0628\u0631\u0627\u06cc \u0622\u062a\u0634 \u0632\u062f\u0646 \u06cc\u06a9\u06cc \u0627\u0632 \u062f\u0641\u0627\u062a\u0631 \u0645\u0631\u062a\u0628\u0637 \u0628\u0627 \u0634\u0628\u06a9\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0627\u06cc\u0646\u062a\u0631\u0646\u0634\u0646\u0627\u0644 \u062f\u0631 \u0634\u0645\u0627\u0644\u200c\u063a\u0631\u0628 \u0644\u0646\u062f\u0646 \u0631\u0633\u0645\u0627 \u0645\u062a\u0647\u0645 \u0634\u062f\u0646\u062f \u0648 \u067e\u0633 \u0627\u0632 \u062a\u0641\u0647\u06cc\u0645 \u0627\u062a\u0647\u0627\u0645 \u0642\u0631\u0627\u0631 \u0627\u0633\u062a \u0645\u062d\u0627\u06a9\u0645\u0647 \u0634\u0648\u0646\u062f. \u06cc\u06a9\u06cc \u0627\u0632 \u0627\u06cc\u0646 \u0633\u0647 \u0646\u0641\u0631 \u06a9\u0647 \u062f\u06cc\u0631\u0648\u0632 \u062e\u0628\u0631 \u0628\u0627\u0632\u062f\u0627\u0634\u062a \u0622\u0646\u0647\u0627 \u0645\u0646\u062a\u0634\u0631 \u0634\u062f\u2026",
