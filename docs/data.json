        {
          "title": "\u062a\u0635\u0627\u0648\u06cc\u0631 \u0645\u0627\u0647\u0648\u0627\u0631\u0647\u200c\u0627\u06cc \u0648\u06cc\u0631\u0627\u0646 \u0634\u062f\u0646 \u0634\u0647\u0631\u0647\u0627\u06cc \u062c\u0646\u0648\u0628 \u0644\u0628\u0646\u0627\u0646 \u0628\u0631 \u0627\u062b\u0631 \u062a\u062e\u0631\u06cc\u0628\u200c\u0647\u0627\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0631\u0627 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f",
