          "summary": "\u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e \u06af\u0641\u062a \u06a9\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u062a\u0648\u0627\u0641\u0642 \u0628\u0633\u06cc\u0627\u0631 \u0646\u0632\u062f\u06cc\u06a9 \u0634\u062f\u0647\u200c\u0627\u0646\u062f \u0648 \u0631\u0627\u0628\u0637\u0647 \u062e\u0648\u0628\u06cc \u0628\u0627 \u0627\u0641\u0631\u0627\u062f\u06cc \u06a9\u0647 \u0627\u06a9\u0646\u0648\u0646 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0631 \u0633\u0631 \u06a9\u0627\u0631 \u0647\u0633\u062a\u0646\u062f \u0628\u0631\u0642\u0631\u0627\u0631 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0648\u0632\u06cc\u0631 \u062c\u0646\u06af \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f \u06a9\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0622\u0645\u0627\u062f\u0647 \u0627\u0632 \u0633\u0631 \u06af\u0631\u0641\u062a\u0646 \u0639\u0645\u0644\u06cc\u0627\u062a \u0646\u0638\u0627\u0645\u06cc \u0627\u0633\u2026",
