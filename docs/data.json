          "title": "\u200c\ud83d\udd34 \u0633\u0646\u062a\u06a9\u0627\u0645 \u0627\u0632 \u0622\u063a\u0627\u0632 \u0639\u0645\u0644\u06cc\u0627\u062a \u062f\u0641\u0627\u0639\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0639\u0644\u06cc\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u062e\u0628\u0631 \u062f\u0627\u062f\u061b \u062a\u0631\u0627\u0645\u067e: \u0633\u0631\u0646\u06af\u0648\u0646\u06cc \u0628\u0627\u0644\u06af\u0631\u062f \u0622\u067e\u0627\u0686\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u06a9\u0627\u0631 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0648\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u0633\u062a\u0627\u062f \u0641\u0631\u0645\u0627\u0646\u062f\u0647\u06cc \u0645\u0631\u06a9\u0632\u06cc \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 (\u0633\u0646\u062a\u06a9\u0627\u0645) \u0631\u0648\u0632 \u0633\u0647\u200c\u0634\u0646\u0628\u0647 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f \u06a9\u0647 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u062f\u0631 \u067e\u0627\u0633\u062e \u0628\u0647 \u0633\u0631\u0646\u06af\u0648\u0646\u06cc \u06cc\u06a9 \u0647\u0644\u06cc\u06a9\u0648\u067e\u062a\u0631 \u0622\u067e\u0627\u0686\u06cc \u0627\u0631\u062a\u0634 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u06a9\u0647 \u062f\u06cc\u0631\u0648\u0632 \u0631\u062e \u062f\u0627\u062f\u060c \u0633\u0627\u0639\u062a \u06f5 \u0628\u0639\u062f \u0627\u0632 \u0638\u0647\u0631 \u0628\u0647 \u0648\u0642\u062a \u0634\u0631\u0642 \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0628\u0647 \u062f\u0633\u062a\u0648\u0631 \u0641\u0631\u0645\u0627\u0646\u062f\u0647 \u06a9\u0644 \u0642\u0648\u0627\u060c \u062f\u2026",
