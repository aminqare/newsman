        {
          "title": "\u0622\u06cc\u0627 \u062a\u0635\u0648\u06cc\u0631 \u067e\u0631\u0632\u0631\u0642\u200c\u0648\u0628\u0631\u0642 \u062f\u0648\u0628\u06cc \u062f\u0631 \u0645\u0639\u0631\u0636 \u062a\u0647\u062f\u06cc\u062f \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0647 \u0627\u0633\u062a\u061f",
