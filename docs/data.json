        {
          "title": "\u0641\u06cc\u0632\u06cc\u0648\u062a\u0631\u0627\u067e\u06cc \u06a9\u0647 \u00ab\u0646\u0641\u0631\u06cc\u0646 \u0631\u0628\u0627\u0637 \u0635\u0644\u06cc\u0628\u06cc\u00bb \u0631\u0627 \u0628\u0627\u0637\u0644 \u06a9\u0631\u062f: \u0634\u06a9\u06cc\u0644 \u0627\u0648\u0646\u06cc\u0644 \u062f\u0631 \u06a9\u0644\u06cc\u0646\u06cc\u06a9 \u0645\u0646 \u0628\u06cc\u0645\u0627\u0631 \u067e\u0630\u06cc\u0631\u0634 \u0645\u06cc\u200c\u06a9\u0631\u062f",
