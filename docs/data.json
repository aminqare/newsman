          "summary": "\u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u062a\u0635\u0648\u06cc\u0631 \u062f\u06cc\u0631\u06cc\u0646\u0647 \u0627\u0645\u0646\u06cc\u062a \u0648 \u062b\u0628\u0627\u062a \u062f\u0631 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u0631\u0627 \u0628\u0647\u200c\u0637\u0648\u0631 \u062c\u062f\u06cc \u062e\u062f\u0634\u0647\u200c\u062f\u0627\u0631 \u06a9\u0631\u062f. \u062d\u0645\u0644\u0627\u062a \u0645\u0648\u0634\u06a9\u06cc\u060c \u0627\u062e\u062a\u0644\u0627\u0644 \u0627\u0642\u062a\u0635\u0627\u062f\u06cc \u0648 \u0644\u063a\u0648 \u06af\u0633\u062a\u0631\u062f\u0647 \u0633\u0641\u0631\u0647\u0627 \u0646\u0634\u0627\u0646 \u062f\u0627\u062f \u0627\u06cc\u0646 \u0645\u0646\u0637\u0642\u0647 \u0646\u06cc\u0632 \u0627\u0632 \u062a\u0628\u0639\u0627\u062a \u062f\u0631\u06af\u06cc\u0631\u06cc \u0645\u0635\u0648\u0646 \u0646\u06cc\u0633\u062a. \u0647\u0645\u0632\u0645\u0627\u0646\u060c \u062a\u0631\u062f\u06cc\u062f \u062f\u0631\u0628\u0627\u0631\u0647 \u062a\u0639\u0647\u062f \u0627\u0645\u0646\u06cc\u062a\u06cc \u0622\u0645\u0631\u06cc\u2026",
