        {
          "title": "\u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0686\u06af\u0648\u0646\u0647 \u0648\u0627\u0628\u0633\u062a\u06af\u06cc \u062c\u0647\u0627\u0646 \u0628\u0647 \u0646\u0641\u062a \u0648 \u06af\u0627\u0632 \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u0631\u0627 \u0622\u0634\u06a9\u0627\u0631 \u06a9\u0631\u062f\u061f",
