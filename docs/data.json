          "title": "\u0628\u0646\u06cc\u0627\u0646\u200c\u06af\u0630\u0627\u0631 \u0622\u0646\u062a\u0631\u0648\u067e\u06cc\u06a9: \u062a\u0648\u0633\u0639\u0647 \u0647\u0648\u0634 \u0645\u0635\u0646\u0648\u0639\u06cc \u0628\u062f\u0648\u0646 \u0646\u0638\u0627\u0631\u062a \u0627\u0646\u0633\u0627\u0646 \u0631\u0627 \u0628\u0627\u06cc\u062f \u0645\u062a\u0648\u0642\u0641 \u06a9\u0646\u06cc\u0645",
