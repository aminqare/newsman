          "title": "\u0686\u0631\u0627 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u062a\u0635\u0645\u06cc\u0645 \u06af\u0631\u0641\u062a \u06cc\u06a9 \u062f\u0627\u0644\u0627\u0646 \u062a\u062c\u0627\u0631\u06cc \u0628\u0631\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0628\u0627\u0632 \u06a9\u0646\u062f\u061f",
