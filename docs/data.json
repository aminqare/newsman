        {
          "title": "\u0686\u06cc\u0646 \u0648 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u061b \u0645\u06cc\u0627\u0646\u062c\u06cc \u0635\u0644\u062d \u06cc\u0627 \u0628\u0627\u0632\u06cc\u06af\u0631 \u062e\u0627\u0645\u0648\u0634\u061f",
