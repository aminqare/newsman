          "summary": "\u062c\u06cc\u200c\u062f\u06cc \u0648\u0646\u0633\u060c \u0645\u0639\u0627\u0648\u0646 \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0628\u0631\u0627\u06cc \u0645\u0630\u0627\u06a9\u0631\u0647 \u0628\u0627 \u0647\u06cc\u0626\u062a \u0627\u06cc\u0631\u0627\u0646\u06cc \u0639\u0627\u0632\u0645 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u0634\u062f \u0648 \u067e\u06cc\u0634 \u0627\u0632 \u062d\u0631\u06a9\u062a \u0628\u0647 \u062e\u0628\u0631\u0646\u06af\u0627\u0631\u0627\u0646 \u06af\u0641\u062a \u0628\u0647 \u0627\u06cc\u0646 \u06af\u0641\u062a\u200c\u0648\u06af\u0648\u0647\u0627 \u062e\u0648\u0634\u200c\u0628\u06cc\u0646 \u0648 \u0686\u0634\u0645 \u0627\u0646\u062a\u0638\u0627\u0631 \u0634\u0631\u0648\u0639 \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0627\u0633\u062a. \u062a\u0631\u06a9\u06cc\u0628 \u0647\u06cc\u0626\u062a \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0632\u0645\u0627\u0646 \u0648\u0631\u0648\u062f \u0622\u0646\u0647\u0627 \u0628\u0647 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u0647\u0646\u0648\u0632\u2026",
