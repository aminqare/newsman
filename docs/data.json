          "summary": "\u0628\u0646\u06cc\u0627\u0645\u06cc\u0646 \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648\u060c \u0646\u062e\u0633\u062a \u0648\u0632\u06cc\u0631 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u06af\u0641\u062a \u06a9\u0647 \u062a\u0635\u0631\u0641 \u0642\u0644\u0639\u0647 \u062a\u0627\u0631\u06cc\u062e\u06cc \u0648 \u0627\u0633\u062a\u0631\u0627\u062a\u0698\u06cc\u06a9 \u0634\u0642\u06cc\u0641 (\u0628\u0648\u0641\u0648\u0631) \u062f\u0631 \u062c\u0646\u0648\u0628 \u0644\u0628\u0646\u0627\u0646 \u062a\u0648\u0633\u0637 \u0646\u06cc\u0631\u0648\u0647\u0627\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u06cc\u060c \u00ab\u062a\u063a\u06cc\u06cc\u0631\u06cc \u0686\u0634\u0645\u06af\u06cc\u0631\u00bb \u062f\u0631 \u062c\u0646\u06af \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u0639\u0644\u06cc\u0647 \u062d\u0632\u0628\u200c\u0627\u0644\u0644\u0647 \u0627\u0633\u062a.",
