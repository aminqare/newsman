          "summary": "\u062f\u0631 \u067e\u06cc \u062c\u0646\u06af \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646\u060c \u062a\u0647\u0631\u0627\u0646 \u0637\u0631\u062d\u06cc \u0631\u0627 \u0628\u0631\u0627\u06cc \u062f\u0631\u06cc\u0627\u0641\u062a \u0639\u0648\u0627\u0631\u0636 \u0627\u0632 \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627\u06cc \u0639\u0628\u0648\u0631\u06cc \u0627\u0632 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0645\u0637\u0631\u062d \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a\u061b \u0627\u0642\u062f\u0627\u0645\u06cc \u06a9\u0647 \u0628\u0627 \u0648\u0627\u06a9\u0646\u0634\u200c\u0647\u0627\u06cc \u0628\u06cc\u0646\u200c\u0627\u0644\u0645\u0644\u0644\u06cc \u0631\u0648\u0628\u0647\u200c\u0631\u0648 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0627\u06cc\u0646 \u06af\u0632\u0627\u0631\u0634 \u0628\u0627 \u0646\u06af\u0627\u0647\u06cc \u0628\u0647 \u0646\u0645\u0648\u0646\u0647\u200c\u0647\u0627\u06cc\u06cc \u0645\u0627\u0646\u0646\u062f \u06a9\u0627\u0646\u0627\u0644 \u067e\u0627\u0646\u0627\u0645\u0627 \u0648\u2026",
