        {
          "title": "\u062a\u0631\u0627\u0645\u067e \u0628\u0631 \u0633\u0631 \u062f\u0648\u0631\u0627\u0647\u06cc\u061b \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u062d\u0627\u0644 \u0628\u0631\u0631\u0633\u06cc \u06af\u0632\u06cc\u0646\u0647\u200c\u0647\u0627\u06cc \u0633\u062e\u062a \u062f\u0631 \u0642\u0628\u0627\u0644 \u0627\u06cc\u0631\u0627\u0646",
