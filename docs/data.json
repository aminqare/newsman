          "title": "\u0622\u06cc\u0627 \u062a\u0631\u0627\u0645\u067e \u0645\u0631\u0632\u0647\u0627\u06cc \u0642\u062f\u0631\u062a \u0631\u06cc\u0627\u0633\u062a\u200c\u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0631\u0627 \u062c\u0627\u0628\u0647\u200c\u062c\u0627 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a\u061f",
