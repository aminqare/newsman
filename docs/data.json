        {
          "title": "\u0686\u0631\u0627 \u0627\u06cc\u0646\u200c \u0628\u0627\u0631 \u0627\u0648\u0644 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u062d\u0645\u0644\u0647 \u06a9\u0631\u062f\u061f",
