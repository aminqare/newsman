          "summary": "\u0648\u0627\u06a9\u0646\u0634 \u0645\u062d\u062a\u0627\u0637\u0627\u0646\u0647 \u0648 \u0646\u0633\u0628\u062a\u0627\u064b \u06a9\u0645\u200c\u0633\u0631\u0648\u0635\u062f\u0627\u06cc \u062f\u0648\u0644\u062a \u06a9\u0646\u0648\u0646\u06cc \u0648\u0646\u0632\u0648\u0626\u0644\u0627 \u0628\u0647 \u062d\u0645\u0644\u0627\u062a \u06f2\u06f8 \u0641\u0648\u0631\u06cc\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0639\u0644\u06cc\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u06a9\u0647 \u062f\u0648\u0644\u062a \u062f\u0644\u0633\u06cc \u0631\u0648\u062f\u0631\u06cc\u06af\u0632\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0645\u0648\u0642\u062a \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631\u060c \u062a\u0627 \u0686\u0647 \u0627\u0646\u062f\u0627\u0632\u0647 \u0627\u06cc\u0646 \u062a\u0648\u0644\u06cc\u062f\u06a9\u0646\u0646\u062f\u0647 \u0646\u0641\u062a \u062f\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc \u062c\u0646\u0648\u0628\u06cc \u0631\u0627 \u0627\u0632 \u00ab\u0627\u0626\u062a\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0645\u062f\u0627\u0631\u0633\u060c \u0628\u06cc\u0645\u0627\u0631\u0633\u062a\u0627\u0646\u200c\u200c\u0647\u0627 \u0648 \u0628\u0646\u0627\u0647\u0627\u06cc \u062a\u0627\u0631\u06cc\u062e\u06cc \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631 \u062d\u0645\u0644\u0627\u062a \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0647\u062f\u0641 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/c1kgr99xz31o?at_medium=RSS&at_campaign=rss",
          "summary": "\u062a\u0635\u0627\u0648\u06cc\u0631 \u0645\u0627\u0647\u0648\u0627\u0631\u0647\u200c\u0627\u06cc \u0648 \u0648\u06cc\u062f\u06cc\u0648\u0647\u0627\u06cc \u062a\u0627\u0626\u06cc\u062f\u0634\u062f\u0647 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u06a9\u0647 \u0627\u0632 \u0632\u0645\u0627\u0646 \u0622\u063a\u0627\u0632 \u062d\u0645\u0644\u0627\u062a \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062f\u0631 \u0631\u0648\u0632 \u0634\u0646\u0628\u0647\u060c \u0645\u062f\u0627\u0631\u0633\u060c \u06cc\u06a9 \u0628\u06cc\u0645\u0627\u0631\u0633\u062a\u0627\u0646 \u0648 \u0628\u0646\u0627\u0647\u0627\u06cc \u062a\u0627\u0631\u06cc\u062e\u06cc \u0628\u0647\u200c\u0634\u062f\u062a \u0622\u0633\u06cc\u0628 \u062f\u06cc\u062f\u0647\u200c\u0627\u0646\u062f. \u0627\u06cc\u0646 \u062f\u0631 \u062d\u0627\u0644\u06cc \u0627\u0633\u062a \u06a9\u0647 \u0634\u0645\u0627\u0631 \u062a\u0644\u0641\u0627\u062a \u063a\u06cc\u0631\u0646\u0638\u0627\u0645\u06cc\u0627\u0646 \u06af\u0632\u0627\u0631\u0634\u200c\u0634\u062f\u0647\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u062d\u0645\u0644\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u06a9\u0634\u062a\u06cc \u0627\u06cc\u0631\u0627\u0646\u06cc \u062f\u0631 \u0622\u0628\u200c\u0647\u0627\u06cc \u0646\u0632\u062f\u06cc\u06a9 \u0633\u0631\u06cc\u200c\u0644\u0627\u0646\u06a9\u0627\u061b \u0627\u0646\u062a\u0642\u0627\u062f\u0647\u0627 \u0627\u0632 \u062f\u0648\u0644\u062a \u0647\u0646\u062f \u0627\u0648\u062c \u06af\u0631\u0641\u062a",
          "link": "https://www.bbc.com/persian/articles/c86ydl03e83o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0648\u0632 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u0686\u0647\u0627\u0631\u0645 \u0645\u0627\u0631\u0633\u060c \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0648\u06cc\u062f\u0626\u0648\u06cc\u06cc \u0645\u0646\u062a\u0634\u0631 \u06a9\u0631\u062f \u06a9\u0647 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0627\u062f \u06cc\u06a9\u06cc \u0627\u0632 \u0632\u06cc\u0631\u062f\u0631\u06cc\u0627\u06cc\u06cc\u200c\u0647\u0627\u06cc \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u062f\u0631 \u0627\u0642\u06cc\u0627\u0646\u0648\u0633 \u0647\u0646\u062f \u0628\u0647 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u062c\u0646\u06af\u06cc \u0627\u06cc\u0631\u0627\u0646\u06cc \u062d\u0645\u0644\u0647 \u06a9\u0631\u062f\u0647 \u0648 \u0622\u0646 \u0631\u0627 \u063a\u0631\u0642 \u0645\u06cc\u200c\u06a9\u0646\u062f. \u0627\u06cc\u0646 \u062d\u0645\u0644\u0647 \u062d\u0648\u0627\u0644\u06cc \u0633\u0627\u0639\u062a \u067e\u0646\u062c \u0635\u0628\u062d \u0631\u0648\u0632 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u062f\u0631 \u0646\u0632\u062f\u06cc\u06a9\u06cc\u2026",
