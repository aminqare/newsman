        {
          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e \u067e\u0627\u06cc\u0627\u0646 \u0645\u0647\u0644\u062a \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0631\u0627 \u06f8 \u0634\u0628 \u0633\u0647\u200c\u0634\u0646\u0628\u0647 \u0628\u0647 \u0648\u0642\u062a \u0634\u0631\u0642 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f\u061b \u0645\u0631\u062f\u0645 \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u062f\u0631 \u0645\u06cc\u0627\u0646\u0647 \u062c\u0646\u06af \u0631\u0647\u0627 \u0646\u062e\u0648\u0627\u0647\u06cc\u0645 \u06a9\u0631\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e\u060c \u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0632\u0645\u0627\u0646 \u062f\u0642\u06cc\u0642 \u067e\u0627\u06cc\u0627\u0646 \u0645\u0647\u0644\u062a \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0631\u0627\u06cc \u0628\u0627\u0632\u06af\u0634\u0627\u06cc\u06cc \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632 \u0631\u0627 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f. \u0627\u0648 \u0647\u0645\u0686\u0646\u06cc\u0646 \u06af\u0641\u062a \u06a9\u0647 \u0628\u0647 \u0627\u0641\u0631\u0627\u062f\u06cc \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u00ab\u0645\u0635\u0648\u0646\u06cc\u062a \u0645\u062d\u062f\u0648\u062f\u00bb \u062f\u0627\u062f\u0647 \u0634\u062f\u0647 \u062a\u0627 \u0627\u0645\u06a9\u0627\u0646 \u0645\u0630\u0627\u06a9\u0631\u0647 \u0648 \u062a\u0648\u0627\u0641\u0642 \u0628\u0631\u0642\u0631\u0627\u0631 \u0628\u0627\u0634\u062f. \u0622\u0642\u0627\u06cc \u062a\u0631\u0627\u0645\u067e \u06af\u0641\u062a \u0645\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
