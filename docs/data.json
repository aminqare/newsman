        {
          "title": "\u0648\u0627\u06a9\u0646\u0634 \u06a9\u0627\u0646\u0627\u062f\u0627 \u0628\u0647 \u0628\u0627\u0632\u06af\u0634\u062a \u0645\u0647\u062f\u06cc \u062a\u0627\u062c \u0627\u0632 \u062a\u0648\u0631\u0646\u062a\u0648\u061b \u062a\u0623\u06a9\u06cc\u062f \u0628\u0631 \u0645\u0645\u0646\u0648\u0639\u06cc\u062a \u0648\u0631\u0648\u062f \u00ab\u0627\u0641\u0631\u0627\u062f \u0645\u0631\u062a\u0628\u0637 \u0628\u0627 \u0633\u067e\u0627\u0647 \u067e\u0627\u0633\u062f\u0627\u0631\u0627\u0646\u00bb",
