        {
          "title": "\u0645\u06cc\u0644\u06cc\u0648\u0646\u200c\u0647\u0627 \u062f\u0644\u0627\u0631 \u0634\u0631\u0637\u0628\u0646\u062f\u06cc \u062f\u0642\u0627\u06cc\u0642\u06cc \u067e\u06cc\u0634 \u0627\u0632 \u067e\u0633\u062a \u062a\u0631\u0627\u0645\u067e \u062f\u0631\u0628\u0627\u0631\u0647 \u0645\u0630\u0627\u06a9\u0631\u0647 \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u062a\u0648\u062c\u0647\u200c\u0647\u0627 \u0631\u0627 \u062c\u0644\u0628 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a",
