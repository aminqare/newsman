          "title": "\u06cc\u06a9 \u0631\u0627\u0646\u0646\u062f\u0647 \u06a9\u0627\u0645\u06cc\u0648\u0646 \u0633\u0627\u0628\u0642 \u0628\u0647 \u0639\u0644\u062a \u0647\u0645\u06a9\u0627\u0631\u06cc \u062f\u0631 \u062a\u0648\u0637\u0626\u0647 \u062a\u0631\u0648\u0631 \u0645\u0633\u06cc\u062d \u0639\u0644\u06cc\u200c\u0646\u0698\u0627\u062f \u0628\u0647 \u06f1\u06f0 \u0633\u0627\u0644 \u0632\u0646\u062f\u0627\u0646 \u0645\u062d\u06a9\u0648\u0645 \u0634\u062f",
