        {
          "title": "\u00ab\u0647\u06cc\u0686 \u062c\u0627\u06cc\u06af\u0632\u06cc\u0646\u06cc \u0628\u0631\u0627\u06cc \u0632\u0639\u0641\u0631\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646 \u0648\u062c\u0648\u062f \u0646\u062f\u0627\u0631\u062f\u00bb\u061b \u0686\u06af\u0648\u0646\u0647 \u062c\u0646\u06af \u0642\u06cc\u0645\u062a \u00ab\u0637\u0644\u0627\u06cc \u0633\u0631\u062e\u00bb \u0631\u0627 \u0627\u0641\u0632\u0627\u06cc\u0634 \u062f\u0627\u062f\u061f",
