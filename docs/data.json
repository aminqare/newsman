          "summary": "\u0686\u0631\u062e\u0634 \u0646\u0627\u06af\u0647\u0627\u0646\u06cc \u0641\u06cc\u0641\u0627 \u062f\u0631 \u0622\u062e\u0631\u06cc\u0646 \u0644\u062d\u0638\u0627\u062a \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u06a9\u0647 \u0647\u0648\u0627\u062f\u0627\u0631\u0627\u0646 \u062f\u06cc\u06af\u0631 \u0627\u062c\u0627\u0632\u0647 \u0646\u062f\u0627\u0631\u0646\u062f \u0628\u0637\u0631\u06cc\u200c\u0647\u0627\u06cc \u0622\u0628 \u0686\u0646\u062f\u0628\u0627\u0631\u0645\u0635\u0631\u0641 \u0631\u0627 \u0628\u0627 \u062e\u0648\u062f \u0628\u0647 \u062f\u0627\u062e\u0644 \u0648\u0631\u0632\u0634\u06af\u0627\u0647\u200c\u0647\u0627 \u0628\u0628\u0631\u0646\u062f\u061b \u0627\u0645\u0627 \u0645\u0648\u0627\u062f \u063a\u0630\u0627\u06cc\u06cc \u0648 \u0646\u0648\u0634\u06cc\u062f\u0646\u06cc \u062a\u0646\u0647\u0627 \u0645\u0648\u0627\u0631\u062f \u0645\u0645\u0646\u0648\u0639\u0647 \u062f\u0631 \u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc \u06f2\u06f0\u06f2\u06f6 \u0646\u06cc\u0633\u062a\u0646\u062f.",
