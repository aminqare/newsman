        {
          "title": "\u0645\u062d\u0627\u0633\u0628\u0647\u200c\u06af\u0631 \u062a\u0648\u0631\u0645 \u0645\u0648\u0627\u062f \u063a\u0630\u0627\u06cc\u06cc\u061b \u062d\u0633\u0627\u0628 \u06a9\u0646\u06cc\u062f \u0647\u0632\u06cc\u0646\u0647 \u0633\u0628\u062f \u062e\u0631\u06cc\u062f \u0634\u0645\u0627 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0686\u0642\u062f\u0631 \u0628\u0627\u0644\u0627 \u0631\u0641\u062a\u0647 \u0627\u0633\u062a",
