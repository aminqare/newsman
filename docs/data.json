        {
          "title": "\u06f3\u06f0\u06f0 \u0645\u0647\u0627\u062c\u0631 \u0639\u0627\u0632\u0645 \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u0631\u0628\u0648\u062f\u0647 \u0648 \u0628\u0631\u0627\u06cc \u0628\u0627\u062c\u06af\u06cc\u0631\u06cc \u062a\u0647\u062f\u06cc\u062f \u0628\u0647 \u0628\u0631\u062f\u0627\u0634\u062a\u0646 \u06a9\u0644\u06cc\u0647 \u0634\u062f\u0646\u062f",
