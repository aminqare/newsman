          "summary": "\u062f\u0631 \u067e\u06cc \u0628\u0633\u062a\u0647 \u0634\u062f\u0646 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u060c \u0639\u0631\u0636\u0647 \u0632\u0639\u0641\u0631\u0627\u0646 \u06a9\u0627\u0647\u0634 \u06cc\u0627\u0641\u062a\u0647 \u0648 \u0627\u06cc\u0646 \u0645\u062d\u062f\u0648\u062f\u06cc\u062a \u0634\u0627\u0645\u0644 \u0628\u0631\u062e\u06cc \u0627\u0642\u0644\u0627\u0645 \u0627\u0633\u0627\u0633\u06cc \u062f\u06cc\u06af\u0631 \u0645\u0627\u0646\u0646\u062f \u0646\u062e\u0648\u062f \u0648 \u0632\u0631\u0634\u06a9 \u0646\u06cc\u0632 \u0634\u062f\u0647 \u0627\u0633\u062a\u061b \u0645\u0648\u0627\u062f\u06cc \u06a9\u0647 \u062f\u0631 \u0628\u0633\u06cc\u0627\u0631\u06cc \u0627\u0632 \u063a\u0630\u0627\u0647\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646\u06cc \u0648 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647\u200c\u0627\u06cc \u06a9\u0627\u0631\u0628\u0631\u062f \u06af\u0633\u062a\u0631\u062f\u0647\u200c\u0627\u06cc \u062f\u0627\u0631\u0646\u062f.",
