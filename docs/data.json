        {
          "title": "\u0627\u0632 \u0639\u0627\u0634\u0648\u0631\u0627 \u062a\u0627 \u0627\u0632\u062f\u0648\u0627\u062c \u0645\u0648\u0642\u062a\u061b \u062f\u0627\u0645\u0646\u0647 \u0645\u062d\u062f\u0648\u062f\u06cc\u062a\u200c\u0647\u0627\u06cc \u0637\u0627\u0644\u0628\u0627\u0646 \u0639\u0644\u06cc\u0647 \u0634\u06cc\u0639\u06cc\u0627\u0646 \u06af\u0633\u062a\u0631\u062f\u0647\u200c\u062a\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f",
