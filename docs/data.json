          "title": "\ud83d\udd34 \u0631\u0648\u06cc\u062a\u0631\u0632: \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0637\u0631\u062d\u06cc \u0628\u0631\u0627\u06cc \u0622\u062a\u0634\u200c\u0628\u0633 \u0641\u0648\u0631\u06cc \u062f\u0631\u06cc\u0627\u0641\u062a \u06a9\u0631\u062f\u0647\u200c\u0627\u0646\u062f\u061b \u0639\u0644\u06cc \u0641\u0647\u06cc\u0645\u060c \u0627\u0632 \u0628\u0627\u0632\u062f\u0627\u0634\u062a\u200c\u0634\u062f\u06af\u0627\u0646 \u0627\u0639\u062a\u0631\u0627\u0636\u0627\u062a \u062f\u06cc\u200c \u06f1\u06f4\u06f0\u06f4 \u0627\u0639\u062f\u0627\u0645 \u0634\u062f",
