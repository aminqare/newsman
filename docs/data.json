        {
          "title": "\u0647\u0644\u0645\u0627\u061b \u06a9\u0648\u062f\u06a9 \u0646\u0648\u067e\u0627\u06cc \u0627\u06cc\u0631\u0627\u0646\u06cc \u06a9\u0647 \u0627\u0632 \u062d\u0645\u0644\u0647 \u0647\u0648\u0627\u06cc\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u062c\u0627\u0646 \u0628\u0647 \u062f\u0631 \u0628\u0631\u062f \u0627\u0645\u0627 \u062e\u0627\u0646\u0648\u0627\u062f\u0647\u200c\u0627\u0634 \u0631\u0627 \u0627\u0632 \u062f\u0633\u062a \u062f\u0627\u062f",
          "link": "https://www.bbc.com/persian/articles/cy81v93792yo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0647\u0644\u0645\u0627\u060c \u06a9\u0648\u062f\u06a9 \u06f1\u06f8 \u0645\u0627\u0647\u0647\u060c \u067e\u0633 \u0627\u0632 \u062d\u0645\u0644\u0647 \u0647\u0648\u0627\u06cc\u06cc \u0628\u0647 \u062e\u0627\u0646\u0647\u200c\u0627\u0634 \u062f\u0631 \u062a\u0628\u0631\u06cc\u0632 \u0632\u0646\u062f\u0647 \u0627\u0632 \u0632\u06cc\u0631 \u0622\u0648\u0627\u0631 \u0628\u06cc\u0631\u0648\u0646 \u06a9\u0634\u06cc\u062f\u0647 \u0634\u062f\u060c \u0627\u0645\u0627 \u0647\u0645\u0647 \u0627\u0639\u0636\u0627\u06cc \u062e\u0627\u0646\u0648\u0627\u062f\u0647\u200c\u0627\u0634 \u062c\u0627\u0646 \u0628\u0627\u062e\u062a\u0646\u062f. \u0631\u0648\u0627\u06cc\u062a \u0627\u0648 \u062f\u0631 \u0634\u0631\u0627\u06cc\u0637 \u0645\u062d\u062f\u0648\u062f\u06cc\u062a \u0627\u0637\u0644\u0627\u0639\u0627\u062a\u060c \u062a\u0648\u062c\u0647 \u0632\u06cc\u0627\u062f\u06cc \u062c\u0644\u0628 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0628\u0631 \u0627\u0633\u0627\u0633 \u06af\u0632\u0627\u0631\u0634\u200c\u0647\u0627 \u0647\u062f\u0641 \u062d\u0645\u0644\u0647 \u067e\u062f\u0631 \u0627\u0648\u2026",
