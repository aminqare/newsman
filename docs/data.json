        {
          "title": "\u0646\u0638\u0627\u0645\u06cc \u06a9\u0647 \u062d\u0627\u06a9\u0645\u0627\u0646 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0631\u0627\u06cc \u0645\u0627\u0646\u062f\u06af\u0627\u0631\u06cc \u062f\u0631 \u0642\u062f\u0631\u062a \u0628\u0646\u0627 \u06a9\u0631\u062f\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/cg7em50pml4o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0628\u06cc\u0634 \u0627\u0632 \u0686\u0647\u0627\u0631 \u062f\u0647\u0647 \u067e\u0633 \u0627\u0632 \u0627\u0646\u0642\u0644\u0627\u0628 \u0627\u0633\u0644\u0627\u0645\u06cc \u06a9\u0647 \u062d\u0627\u06a9\u0645\u0627\u0646 \u06a9\u0646\u0648\u0646\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u0628\u0647 \u0642\u062f\u0631\u062a \u0631\u0633\u0627\u0646\u062f\u060c \u0627\u06a9\u0646\u0648\u0646 \u0622\u0646\u200c\u0647\u0627 \u0628\u0627 \u06cc\u06a9\u06cc \u0627\u0632 \u062f\u0634\u0648\u0627\u0631\u062a\u0631\u06cc\u0646 \u0645\u0642\u0627\u0637\u0639 \u062a\u0627\u0631\u06cc\u062e \u062e\u0648\u062f \u0631\u0648\u0628\u0647\u200c\u0631\u0648 \u0647\u0633\u062a\u0646\u062f. \u062d\u0645\u0644\u0627\u062a \u0647\u0648\u0627\u06cc\u06cc \u0645\u0634\u062a\u0631\u06a9 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0627\u0639\u062b \u06a9\u0634\u062a\u0647 \u0634\u062f\u0646 \u0622\u06cc\u062a\u200c\u0627\u0644\u0644\u0647 \u0639\u0644\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc\u060c \u0631\u0647\u0628\u0631 \u062c\u0645\u0647\u2026",
