        {
          "title": "\u06cc\u06a9\u0634\u0646\u0628\u0647\u200c\u0627\u06cc \u062f\u06cc\u06af\u0631 \u062f\u0631 \u062c\u0647\u0646\u0645\u061b \u0631\u0642\u0627\u0628\u062a \u0638\u0627\u0644\u0645\u0627\u0646\u0647\u200c\u0627\u06cc \u06a9\u0647 \u0633\u062a\u0627\u0631\u0647\u200c\u0647\u0627 \u0631\u0627 \u0628\u0647 \u0632\u0627\u0646\u0648 \u062f\u0631 \u0645\u06cc\u200c\u0622\u0648\u0631\u062f",
