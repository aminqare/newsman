          "title": "\u0627\u0646\u062a\u0642\u0627\u062f \u0634\u0627\u0647\u0632\u0627\u062f\u0647 \u0631\u0636\u0627 \u067e\u0647\u0644\u0648\u06cc \u0627\u0632 \u0631\u0698\u0647 \u0628\u0627 \u062a\u06cc\u200c\u0634\u0631\u062a \u0633\u0627\u0648\u0627\u06a9",
