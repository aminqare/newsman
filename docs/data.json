          "title": "\u062a\u0631\u0627\u0645\u067e \u0627\u0632 \u0627\u062d\u062a\u0645\u0627\u0644 \u0627\u0632 \u0633\u0631\u06af\u06cc\u0631\u06cc \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0628\u0627 \u0627\u06cc\u0631\u0627\u0646 \u062e\u0628\u0631 \u062f\u0627\u062f\u060c \u0633\u0647 \u0645\u062c\u0631\u0648\u062d \u062f\u0631 \u067e\u06cc \u0627\u0646\u0641\u062c\u0627\u0631 \u00ab\u0627\u0634\u06cc\u0627\u0621 \u062f\u0633\u062a\u200c\u0633\u0627\u0632\u00bb \u062f\u0631 \u0645\u0631\u06a9\u0632 \u062a\u0647\u0631\u0627\u0646",
