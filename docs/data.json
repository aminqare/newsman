        {
          "title": "\u00ab\u0646\u0628\u0627\u06cc\u062f \u0628\u0647 \u0641\u06cc\u0644\u062a\u0631\u0634\u06a9\u0646 \u0645\u06cc\u0644\u06cc\u0648\u0646\u06cc \u0639\u0627\u062f\u062a \u06a9\u0631\u062f\u00bb\u061b \u0645\u0637\u0627\u0644\u0628\u0627\u062a \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u0622\u0632\u0627\u062f \u067e\u0633 \u0627\u0632 \u0622\u062a\u0634\u200c\u0628\u0633",
