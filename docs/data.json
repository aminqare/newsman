          "title": "\u062d\u0645\u0644\u0647 \u067e\u0647\u067e\u0627\u062f\u06cc \u0628\u0647 \u0633\u0641\u0627\u0631\u062a \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u0628\u063a\u062f\u0627\u062f \u0647\u0645\u0632\u0645\u0627\u0646 \u0628\u0627 \u062d\u0645\u0644\u0627\u062a \u0647\u0648\u0627\u06cc\u06cc \u0628\u0647 \u062a\u0647\u0631\u0627\u0646",
