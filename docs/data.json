        {
          "title": "\u062a\u0646\u0634 \u062f\u0631 \u0645\u0642\u062f\u0633\u200c\u062a\u0631\u06cc\u0646 \u0645\u06a9\u0627\u0646 \u0628\u06cc\u062a\u200c\u0627\u0644\u0645\u0642\u062f\u0633\u061b \u0645\u0644\u06cc\u200c\u06af\u0631\u0627\u06cc\u0627\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u06cc \u0642\u0648\u0627\u0639\u062f \u0631\u0627 \u0646\u0627\u062f\u06cc\u062f\u0647 \u0645\u06cc\u200c\u06af\u06cc\u0631\u0646\u062f",
