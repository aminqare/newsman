          "summary": "\u0628\u06cc\u200c\u0628\u06cc\u200c\u0633\u06cc \u0645\u0637\u0644\u0639 \u0634\u062f\u0647 \u0627\u0633\u062a \u06a9\u0647 \u0628\u06cc\u0634 \u0627\u0632 \u06f3\u06f0\u06f0 \u0645\u0647\u0627\u062c\u0631 \u06a9\u0647 \u062a\u0627\u0628\u0633\u062a\u0627\u0646 \u06af\u0630\u0634\u062a\u0647 \u0628\u0647 \u0633\u0648\u06cc \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u0645\u06cc\u200c\u0631\u0641\u062a\u0646\u062f\u060c \u0631\u0628\u0648\u062f\u0647 \u0634\u062f\u0646\u062f\u061b \u0622\u0646\u0647\u0627 \u0633\u067e\u0633 \u0634\u06a9\u0646\u062c\u0647 \u0648 \u062a\u0647\u062f\u06cc\u062f \u0628\u0647 \u0628\u0631\u062f\u0627\u0634\u062a\u0646 \u0627\u062c\u0628\u0627\u0631\u06cc \u0627\u0639\u0636\u0627\u06cc \u0628\u062f\u0646 \u0634\u062f\u0646\u062f. \u0627\u06cc\u0646 \u0645\u0631\u062f\u0627\u0646 \u062c\u0648\u0627\u0646\u060c \u0647\u0645\u06af\u06cc \u0627\u0647\u0644 \u06a9\u0631\u062f\u0633\u062a\u0627\u0646 \u0639\u0631\u0627\u0642\u060c \u0627\u0632 \u0633\u0648\u06cc \u06cc\u06a9 \u06af\u0631\u0648\u0647 \u0634\u0628\u0647\u200c\u0646\u0638\u0627\u0645\u06cc \u062f\u2026",
