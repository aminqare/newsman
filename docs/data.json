        {
          "title": "\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u0639\u0631\u0628\u0633\u062a\u0627\u0646 \u062f\u0631 \u0645\u0648\u0631\u062f \u0628\u0646\u200c\u0628\u0633\u062a \u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0648 \u067e\u06cc\u0627\u0645\u062f\u0647\u0627\u06cc \u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0686\u0647 \u0645\u06cc\u200c\u06af\u0648\u06cc\u0646\u062f\u061f",
