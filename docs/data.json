        {
          "title": "\u0686\u06af\u0648\u0646\u0647 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u062a\u0635\u0648\u0631 \u0627\u0645\u0646\u06cc\u062a \u0631\u0627 \u062f\u0631 \u06a9\u0634\u0648\u0631\u200c\u0647\u0627\u06cc \u0645\u0646\u0637\u0642\u0647 \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633 \u062f\u0631\u200c\u0647\u0645\u200c \u0634\u06a9\u0633\u062a\u061f",
