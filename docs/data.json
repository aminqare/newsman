        {
          "title": "\u062a\u0631\u0627\u0645\u067e: \u0628\u0647 \u0646\u062a\u0627\u0646\u06cc\u0627\u0647\u0648 \u06af\u0641\u062a\u0645 \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u0628\u0631\u0627\u0628\u0631 \u0627\u06cc\u0631\u0627\u0646 \u062a\u0646\u0647\u0627 \u0628\u0645\u0627\u0646\u06cc",
          "link": "https://www.bbc.co.uk/persian/live/cy8d9p3mje1t?at_medium=RSS&at_campaign=rss",
          "summary": "\u06cc\u06a9 \u0631\u0648\u0632 \u0628\u0639\u062f \u0627\u0632 \u062d\u0645\u0644\u0627\u062a \u0646\u0638\u0627\u0645\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0647\u0645\u062f\u06cc\u06af\u0631\u060c \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u062f\u0631 \u06af\u0641\u062a\u06af\u0648 \u0628\u0627 \u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627 \u0627\u0632 \u062c\u0632\u06cc\u06cc\u0627\u062a \u062a\u0644\u0627\u0634 \u062e\u0648\u062f \u0628\u0631\u0627\u06cc \u062a\u0648\u0642\u0641 \u0627\u06cc\u0646 \u062f\u0631\u06af\u06cc\u0631\u06cc \u06af\u0641\u062a\u0647 \u0648 \u062a\u0635\u0631\u06cc\u062d \u06a9\u0631\u062f\u0647 \u06a9\u0647 \u062f\u0631 \u062a\u0645\u0627\u0633 \u062a\u0644\u0641\u0646\u06cc \u0631\u0648\u0632 \u06cc\u06a9\u0634\u0646\u0628\u0647 \u0628\u0627 \u0646\u062e\u0633\u062a\u200c\u0648\u0632\u06cc\u0631 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0627\u0648 \u0647\u0634\u062f\u0627\u0631 \u062f\u0627\u062f\u0647 \u06a9\u0647 \u00ab\u0645\u0645\u06a9\u0646\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0628\u0627 \u0645\u0645\u0627\u0646\u0639\u062a \u0627\u0632 \u0648\u0631\u0648\u062f \u0628\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627\u060c \u0628\u0647\u062a\u0631\u06cc\u0646 \u062f\u0627\u0648\u0631 \u0622\u0641\u0631\u06cc\u0642\u0627 \u0627\u0632 \u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc \u0628\u0627\u0632\u0645\u0627\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/c14y82zg4keo?at_medium=RSS&at_campaign=rss",
          "summary": "\u062f\u0631 \u067e\u06cc \u0645\u0645\u0627\u0646\u0639\u062a \u0627\u0632 \u0648\u0631\u0648\u062f \u0639\u0645\u0631 \u0639\u0628\u062f\u0627\u0644\u0642\u0627\u062f\u0631 \u0639\u0631\u062a\u0646\u060c \u062f\u0627\u0648\u0631 \u0633\u0648\u0645\u0627\u0644\u06cc\u0627\u06cc\u06cc \u0628\u0647 \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647\u060c \u0641\u06cc\u0641\u0627 \u0646\u0627\u0645 \u0627\u0648 \u0631\u0627 \u0627\u0632 \u0641\u0647\u0631\u0633\u062a \u062f\u0627\u0648\u0631\u0627\u0646 \u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc \u062d\u0630\u0641 \u06a9\u0631\u062f. \u0622\u0642\u0627\u06cc \u0639\u0631\u062a\u0646 \u06a9\u0647 \u06cc\u06a9\u06cc \u0627\u0632 \u0628\u0631\u062c\u0633\u062a\u0647\u200c\u062a\u0631\u06cc\u0646 \u062f\u0627\u0648\u0631\u0627\u0646 \u0622\u0641\u0631\u06cc\u0642\u0627 \u0648 \u0628\u0631\u0646\u062f\u0647 \u062c\u0648\u0627\u06cc\u0632 \u0645\u062a\u0639\u062f\u062f\u06cc \u0627\u0633\u062a\u060c\u200c \u0628\u0627 \u0648\u062c\u0648\u062f \u062f\u0627\u0634\u062a\u0646 \u0645\u062f\u0627\u0631\u06a9 \u0645\u0639\u062a\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0631\u06a9\u0648\u0631\u062f\u0634\u06a9\u0646\u06cc \u06cc\u0627 \u0622\u0644\u0627\u06cc\u0646\u062f\u06af\u06cc\u061b \u00ab\u0632\u0645\u06cc\u0646 \u062a\u062d\u0645\u0644 \u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc \u0631\u0627 \u0646\u062f\u0627\u0631\u062f\u00bb",
          "link": "https://www.bbc.com/persian/articles/crm0wgxgjmzo?at_medium=RSS&at_campaign=rss",
          "summary": "\u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc \u06f2\u06f0\u06f2\u06f6 \u06a9\u0647 \u0628\u0647 \u0645\u06cc\u0632\u0628\u0627\u0646\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc \u0634\u0645\u0627\u0644\u06cc \u0648 \u0628\u0627 \u062d\u0636\u0648\u0631 \u06f4\u06f8 \u062a\u06cc\u0645 \u0628\u0631\u06af\u0632\u0627\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f\u060c \u0645\u0633\u0627\u0641\u062a\u200c\u0647\u0627\u06cc \u0633\u0641\u0631 \u0648 \u062d\u062c\u0645 \u0627\u0646\u062a\u0634\u0627\u0631 \u06af\u0627\u0632\u0647\u0627\u06cc \u06af\u0644\u062e\u0627\u0646\u0647\u200c\u0627\u06cc \u0628\u06cc\u200c\u0633\u0627\u0628\u0642\u0647\u200c\u0627\u06cc \u0628\u0647 \u0647\u0645\u0631\u0627\u0647 \u062e\u0648\u0627\u0647\u062f \u062f\u0627\u0634\u062a. \u0628\u0631\u062e\u06cc \u0627\u0632 \u0647\u0648\u0627\u062f\u0627\u0631\u0627\u0646 \u062a\u0646\u0647\u0627 \u0628\u0631\u0627\u06cc \u062f\u0646\u0628\u0627\u0644 \u06a9\u0631\u062f\u0646 \u0628\u0627\u0632\u06cc\u200c\u0647\u0627\u06cc \u062a\u06cc\u0645 \u062e\u0648\u062f\u060c \u0686\u0646\u062f\u06cc\u0646 \u062a\u0646 \u062f\u06cc\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u06cc \u0627\u0632 \u062a\u0631\u0627\u0645\u067e \u0628\u0647\u200c\u062e\u0627\u0637\u0631 \u062f\u0631\u062e\u0648\u0627\u0633\u062a \u062e\u0648\u06cc\u0634\u062a\u0646\u062f\u0627\u0631\u06cc \u0627\u0646\u062a\u0642\u0627\u062f \u06a9\u0631\u062f\u0646\u062f",
          "link": "https://www.bbc.com/persian/articles/cy9r4np43ddo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0633\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u06cc \u0627\u0632 \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u067e \u0628\u0647\u200c\u062f\u0644\u06cc\u0644 \u062f\u0631\u062e\u0648\u0627\u0633\u062a \u0628\u0631\u0627\u06cc \u062e\u0648\u06cc\u0634\u062a\u0646\u062f\u0627\u0631\u06cc \u062f\u0631 \u0628\u0631\u0627\u0628\u0631 \u062d\u0645\u0644\u0627\u062a \u0627\u06cc\u0631\u0627\u0646 \u0627\u0646\u062a\u0642\u0627\u062f \u06a9\u0631\u062f\u0647\u200c\u0627\u0646\u062f\u061b \u062f\u0631 \u062d\u0627\u0644\u06cc \u06a9\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0627 \u0648\u062c\u0648\u062f \u0627\u06cc\u0646 \u062f\u0631\u062e\u0648\u0627\u0633\u062a\u200c\u0647\u0627 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u062d\u0645\u0644\u0647 \u06a9\u0631\u062f\u0647 \u0648 \u0628\u0631\u062e\u06cc \u0646\u0627\u0638\u0631\u0627\u0646\u060c \u0627\u06cc\u0646 \u0627\u062e\u062a\u0644\u0627\u0641\u0627\u062a \u0639\u0644\u0646\u06cc \u0631\u0627 \u0628\u062e\u0634\u06cc \u0627\u0632 \u06cc\u06a9 \u0627\u0633\u062a\u0631\u0627\u062a\u2026",
