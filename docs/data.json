        {
          "title": "\u00ab\u0646\u0628\u0627\u06cc\u062f \u0628\u0647 \u0641\u06cc\u0644\u062a\u0631\u0634\u06a9\u0646 \u0645\u06cc\u0644\u06cc\u0648\u0646\u06cc \u0639\u0627\u062f\u062a \u06a9\u0631\u062f\u00bb\u061b \u0645\u0637\u0627\u0644\u0628\u0627\u062a \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u0622\u0632\u0627\u062f \u067e\u0633 \u0627\u0632 \u0622\u062a\u0634\u200c\u0628\u0633",
          "link": "https://www.bbc.com/persian/articles/cz678qqg9x6o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0648\u0627\u06cc\u062a \u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0627\u0632 \u062f\u0627\u062e\u0644 \u0627\u06cc\u0631\u0627\u0646 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u062f \u0645\u062d\u062f\u0648\u062f\u06cc\u062a \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u0628\u0647 \u06a9\u0633\u0628\u200c\u0648\u06a9\u0627\u0631\u0647\u0627\u060c \u0645\u0639\u06cc\u0634\u062a \u0648 \u0633\u0644\u0627\u0645\u062a \u0631\u0648\u0627\u0646 \u0622\u0633\u06cc\u0628 \u0632\u062f\u0647 \u0648 \u0647\u0645\u200c\u0632\u0645\u0627\u0646 \u0646\u06af\u0631\u0627\u0646\u06cc \u0627\u0632 \u0622\u06cc\u0646\u062f\u0647 \u0648 \u0634\u06a9\u0627\u0641 \u0637\u0628\u0642\u0627\u062a\u06cc \u0631\u0627 \u062a\u0634\u062f\u06cc\u062f \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u062f\u0631 \u0627\u06cc\u0646 \u0645\u06cc\u0627\u0646\u060c \u0628\u0633\u06cc\u0627\u0631\u06cc \u0628\u0631 \u062f\u0633\u062a\u0631\u0633\u06cc \u0622\u0632\u0627\u062f \u0628\u0647 \u0627\u06cc\u0646\u062a\u0631\u0646\u062a \u0628\u0647 \u0639\u0646\u0648\u0627\u0646 \u06cc\u06a9 \u00ab\u062d\u0642\u2026",
