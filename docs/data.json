        {
          "title": "\u0627\u0632 \u0645\u062d\u0631\u0645 \u062a\u0627 \u0686\u0647\u0627\u0631\u0645 \u0698\u0648\u0626\u06cc\u0647\u061b \u0686\u0631\u0627 \u0628\u0631\u0646\u0627\u0645\u0647 \u062e\u0627\u06a9\u0633\u067e\u0627\u0631\u06cc \u0639\u0644\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc \u0627\u06a9\u0646\u0648\u0646 \u0627\u0639\u0644\u0627\u0645 \u0645\u06cc\u200c\u0634\u0648\u062f\u061f",
