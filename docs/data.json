          "summary": "\u067e\u0631\u0632\u06cc\u062f\u0646\u062a \u062a\u0631\u0627\u0645\u067e \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u0627\u06af\u0631 \u062a\u0648\u0627\u0641\u0642 \u062d\u0627\u0635\u0644 \u0634\u0648\u062f\u060c \u0627\u06cc\u0627\u0644\u0627\u062a \u0645\u062a\u062d\u062f\u0647 \u0628\u0647 \u0647\u0645\u0631\u0627\u0647 \u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u0628\u0631\u0627\u06cc \u0628\u0627\u0632\u06cc\u0627\u0628\u06cc \u0648 \u0627\u0632 \u0628\u06cc\u0646 \u0628\u0631\u062f\u0646 \u0627\u0648\u0631\u0627\u0646\u06cc\u0648\u0645 \u063a\u0646\u06cc\u200c\u0634\u062f\u0647 \u0647\u0645\u06a9\u0627\u0631\u06cc \u062e\u0648\u0627\u0647\u062f \u06a9\u0631\u062f. \u0627\u0648 \u062f\u0631 \u0639\u06cc\u0646 \u062d\u0627\u0644 \u06af\u0641\u062a \u06a9\u0647 \u062f\u0631 \u0635\u0648\u0631\u062a \u0639\u062f\u0645 \u062a\u0648\u0627\u0641\u0642\u060c \u062a\u0648\u0627\u0646 \u0646\u0638\u0627\u0645\u06cc \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u0628\u0647 \u0642\u062f\u0631\u06cc \u062a\u0636\u0639\u06cc\u0641 \u062e\u0648\u0627\u0647\u062f \u06a9\u2026",
