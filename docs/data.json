        {
          "title": "\u0698\u0627\u067e\u0646 \u062f\u0631 \u0622\u0633\u062a\u0627\u0646\u0647 \u0686\u0631\u062e\u0634 \u062a\u0627\u0631\u06cc\u062e\u06cc\u061b \u0635\u0644\u062d\u200c\u0637\u0644\u0628\u06cc \u06cc\u0627 \u0642\u062f\u0631\u062a \u0646\u0638\u0627\u0645\u06cc",
