        {
          "title": "\u0633\u0646\u062a\u06a9\u0627\u0645: \u0628\u0645\u0628\u200c\u0627\u0641\u06a9\u0646\u200c\u0647\u0627\u06cc \u0628\u06cc\u200c\u06f2 \u0628\u0631\u0627\u06cc \u0627\u0646\u062c\u0627\u0645 \u0639\u0645\u0644\u06cc\u0627\u062a \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u067e\u0631\u0648\u0627\u0632 \u062f\u0631\u0622\u0645\u062f\u0646\u062f",
          "link": "https://www.bbc.co.uk/persian/live/cly0lwzk2ryt?at_medium=RSS&at_campaign=rss",
          "summary": "\u0641\u0631\u0645\u0627\u0646\u062f\u0647\u06cc \u0645\u0631\u06a9\u0632\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u0645\u0646\u0637\u0642\u0647 (\u0633\u0646\u062a\u06a9\u0627\u0645) \u0633\u0627\u0639\u062a\u06cc \u067e\u06cc\u0634 \u062f\u0631 \u0634\u0628\u06a9\u0647 \u0627\u06cc\u06a9\u0633 \u06af\u0641\u062a \u06a9\u0647 \u0628\u0645\u0628\u200c\u0627\u0641\u06a9\u0646\u200c\u0647\u0627\u06cc \u0631\u0627\u062f\u0627\u0631\u06af\u0631\u06cc\u0632 \u0628\u06cc\u200c\u06f2 \u0628\u0631\u0627\u06cc \u0627\u0646\u062c\u0627\u0645 \u0645\u0627\u0645\u0648\u0631\u06cc\u062a\u06cc \u062f\u0631 \u062c\u0631\u06cc\u0627\u0646 \u0639\u0645\u0644\u06cc\u0627\u062a \u00ab\u062e\u0634\u0645 \u062d\u0645\u0627\u0633\u06cc\u00bb \u0628\u0647 \u067e\u0631\u0648\u0627\u0632 \u062f\u0631\u0622\u0645\u062f\u0646\u062f. \u062f\u0631 \u0627\u06cc\u0646 \u067e\u06cc\u0627\u0645 \u06af\u0641\u062a\u0647 \u0634\u062f\u0647 \u06a9\u0647 \u0627\u06cc\u0646 \u0628\u0645\u0628\u200c\u0627\u0641\u06a9\u0646\u200c\u0647\u0627 \u00ab\u0628\u0627 \u0622\u062a\u0634 \u062f\u0648\u0631\u0628\u0631\u062f\u060c\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u062f\u0631\u0628\u0627\u0631\u0647 \u062d\u0645\u0644\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u067e\u0627\u06cc\u06af\u0627\u0647\u200c\u0647\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u062e\u0627\u0648\u0631\u0645\u06cc\u0627\u0646\u0647 \u0686\u0647 \u0645\u06cc\u200c\u062f\u0627\u0646\u06cc\u0645\u061f",
