        {
          "title": "\u062d\u06a9\u0648\u0645\u062a \u0627\u06cc\u0631\u0627\u0646 \u0647\u0645\u0686\u0646\u0627\u0646 \u067e\u0627\u0628\u0631\u062c\u0627\u0633\u062a\u061b \u0631\u0648\u0632\u0647\u0627\u06cc \u0622\u06cc\u0646\u062f\u0647 \u0646\u0634\u0627\u0646 \u062e\u0648\u0627\u0647\u062f \u062f\u0627\u062f \u0622\u06cc\u0627 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u062f\u0648\u0627\u0645 \u0628\u06cc\u0627\u0648\u0631\u062f",
