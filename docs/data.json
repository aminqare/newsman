          "title": "\ud83d\udd34 \u062a\u0631\u0627\u0645\u067e: \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u0645\u0627\u0645\u0648\u0631\u06cc\u062a \u062e\u0634\u0645 \u062d\u0645\u0627\u0633\u06cc \u0646\u0632\u062f\u06cc\u06a9\u06cc\u0645\u061b \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0631\u0627 \u0628\u0647 \u0639\u0635\u0631 \u062d\u062c\u0631 \u0628\u0627\u0632 \u0645\u06cc\u200c\u06af\u0631\u062f\u0627\u0646\u06cc\u0645 \u06a9\u0647 \u0628\u0647 \u0622\u0646 \u062a\u0639\u0644\u0642 \u062f\u0627\u0631\u062f\u061b \u0627\u06cc\u0646 \u0631\u0698\u06cc\u0645 \u06f4\u06f5 \u0647\u0632\u0627\u0631 \u0645\u0639\u062a\u0631\u0636 \u0631\u0627 \u06a9\u0634\u062a",
