          "summary": "\u062f\u0631 \u06cc\u06a9 \u0633\u0627\u0644 \u06af\u0630\u0634\u062a\u0647\u060c \u0634\u0645\u0627\u0631 \u0646\u0641\u062a\u06a9\u0634\u200c\u0647\u0627 \u0648 \u062f\u06cc\u06af\u0631 \u06a9\u0634\u062a\u06cc\u200c\u0647\u0627\u06cc \u062a\u062c\u0627\u0631\u06cc\u200c \u06a9\u0647 \u0645\u0627\u0644\u06a9\u0627\u0646\u0634\u0627\u0646 \u0622\u0646\u200c\u0647\u0627 \u0631\u0627 \u062f\u0631 \u0646\u0642\u0627\u0637 \u0645\u062e\u062a\u0644\u0641 \u062c\u0647\u0627\u0646 \u0631\u0647\u0627 \u0645\u06cc\u200c\u06a9\u0646\u0646\u062f\u060c \u0628\u0647\u200c\u0637\u0648\u0631 \u0686\u0634\u0645\u06af\u06cc\u0631\u06cc \u0627\u0641\u0632\u0627\u06cc\u0634 \u06cc\u0627\u0641\u062a\u0647 \u0627\u0633\u062a. \u0686\u0647 \u0686\u06cc\u0632\u06cc \u0628\u0627\u0639\u062b \u0627\u06cc\u0646 \u0627\u0641\u0632\u0627\u06cc\u0634 \u0634\u062f\u0647 \u0627\u0633\u062a \u0648 \u067e\u06cc\u0627\u0645\u062f \u0627\u0646\u0633\u0627\u0646\u06cc \u0627\u06cc\u0646 \u0648\u0636\u0639\u06cc\u062a \u0628\u0631\u0627\u06cc \u0645\u0644\u0648\u0627\u0646\u0627\u0646\u0650 \u0627\u06cc\u0646 \u06a9\u0634\u062a\u2026",
