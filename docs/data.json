        {
          "title": "\u062f\u0648\u0644\u062a \u062a\u0631\u0627\u0645\u067e \u0628\u0631\u062e\u06cc \u0645\u0647\u0627\u062c\u0631\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0648 \u0627\u0641\u063a\u0627\u0646 \u0631\u0627 \u0627\u0632 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u0622\u0641\u0631\u06cc\u0642\u0627\u06cc \u0645\u0631\u06a9\u0632\u06cc \u0627\u062e\u0631\u0627\u062c \u0645\u06cc\u200c\u06a9\u0646\u062f",
