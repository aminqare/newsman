        {
          "title": "\u0639\u0627\u0645\u0644 \u062d\u0645\u0644\u0647 \u0645\u0631\u06af\u0628\u0627\u0631 \u0628\u0647 \u0628\u0627\u0632\u0627\u0631\u0686\u0647 \u06a9\u0631\u06cc\u0633\u0645\u0633 \u062f\u0631 \u0622\u0644\u0645\u0627\u0646 \u0628\u0647 \u062d\u0628\u0633 \u0627\u0628\u062f \u0645\u062d\u06a9\u0648\u0645 \u0634\u062f",
          "link": "https://www.bbc.com/persian/articles/ced467ny2z6o?at_medium=RSS&at_campaign=rss",
          "summary": "\u062f\u0627\u062f\u06af\u0627\u0647\u06cc \u062f\u0631 \u0622\u0644\u0645\u0627\u0646 \u0639\u0627\u0645\u0644 \u062d\u0645\u0644\u0647 \u062f\u0648 \u0633\u0627\u0644 \u067e\u06cc\u0634 \u0628\u0647 \u0628\u0627\u0632\u0627\u0631\u0686\u0647 \u06a9\u0631\u06cc\u0633\u0645\u0633 \u0634\u0647\u0631 \u0645\u0627\u06af\u062f\u0628\u0648\u0631\u06af \u0631\u0627 \u0628\u0647 \u062d\u0628\u0633 \u0627\u0628\u062f \u0645\u062d\u06a9\u0648\u0645 \u06a9\u0631\u062f. \u062f\u0631 \u0627\u06cc\u0646 \u062d\u0645\u0644\u0647 \u0634\u0634 \u0646\u0641\u0631 \u06a9\u0634\u062a\u0647 \u0648 \u0628\u06cc\u0634 \u0627\u0632 \u0633\u06cc\u0635\u062f \u0646\u0641\u0631 \u0632\u062e\u0645\u06cc \u0634\u062f\u0647 \u0628\u0648\u062f\u0646\u062f. \u062f\u0627\u062f\u06af\u0627\u0647 \u0628\u0627 \u062f\u0631 \u0646\u0638\u0631 \u06af\u0631\u0641\u062a\u0646 \u0627\u0634\u062f \u0645\u062c\u0627\u0632\u0627\u062a \u0628\u0631\u0627\u06cc \u0637\u0627\u0644\u0628 \u0639\u0628\u062f\u0627\u0644\u0645\u062d\u0633\u0646\u060c \u0627\u0647\u0644 \u0639\u0631\u0628\u0633\u062a\u0627\u0646\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0645\u062d\u0631\u0645 \u0645\u062a\u0641\u0627\u0648\u062a \u0627\u0645\u0633\u0627\u0644 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646\u061b \u0627\u0632 \u06cc\u0627\u062f\u0628\u0648\u062f \u06a9\u0634\u062a\u0647\u200c\u0634\u062f\u06af\u0627\u0646 \u062f\u06cc \u062a\u0627 \u0634\u0627\u0645 \u063a\u0631\u06cc\u0628\u0627\u0646 \u06a9\u0647\u0631\u06cc\u0632\u06a9",
          "link": "https://www.bbc.com/persian/articles/cwyk5de211no?at_medium=RSS&at_campaign=rss",
          "summary": "\u0647\u06cc\u0626\u062a\u200c\u0647\u0627\u06cc \u0639\u0632\u0627\u062f\u0627\u0631\u06cc \u062f\u0631 \u06a9\u0648\u0686\u0647\u200c\u062e\u06cc\u0627\u0628\u0627\u0646\u200c\u0647\u0627\u06cc \u0634\u0647\u0631\u0647\u0627\u06cc \u0645\u062e\u062a\u0644\u0641 \u062f\u06cc\u062f\u0647 \u0645\u06cc\u200c\u0634\u062f \u0648 \u062f\u0633\u062a\u0647\u200c\u0647\u0627\u06cc \u0633\u06cc\u0646\u0647\u200c\u0632\u0646\u06cc \u0645\u0627\u0646\u0646\u062f \u0633\u0627\u0644\u200c\u0647\u0627\u06cc \u06af\u0630\u0634\u062a\u0647 \u0627\u0632 \u0627\u06cc\u0646 \u0633\u0648 \u0628\u0647 \u0622\u0646\u200c\u0633\u0648 \u0645\u06cc\u200c\u0631\u0641\u062a\u0646\u062f. \u0627\u0645\u0627 \u0628\u0633\u06cc\u0627\u0631\u06cc \u0627\u0632 \u0645\u0631\u0627\u0633\u0645\u06cc \u06a9\u0647 \u0628\u0631\u06af\u0632\u0627\u0631 \u0634\u062f \u0645\u062a\u0627\u062b\u0631 \u0627\u0632 \u0648\u0642\u0627\u06cc\u0639\u06cc \u0628\u0648\u062f\u0647\u200c\u0627\u0646\u062f \u06a9\u0647 \u0627\u06cc\u0631\u0627\u0646\u06cc\u0627\u0646 \u062f\u0631 \u0645\u0627\u0647\u200c\u0647\u0627\u06cc \u0627\u062e\u06cc\u0631 \u0627\u0632\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0627\u0641\u0632\u0627\u06cc\u0634 \u0622\u0645\u0627\u0631 \u0631\u0633\u0645\u06cc \u06a9\u0634\u062a\u0647\u200c\u0634\u062f\u06af\u0627\u0646 \u0632\u0645\u06cc\u0646\u200c\u0644\u0631\u0632\u0647\u200c\u0647\u0627\u06cc \u0648\u0646\u0632\u0648\u0626\u0644\u0627 \u0628\u0647 \u0628\u06cc\u0634 \u0627\u0632 \u062f\u0648 \u0628\u0631\u0627\u0628\u0631 \u0628\u0631\u0622\u0648\u0631\u062f \u0627\u0648\u0644\u06cc\u0647",
          "link": "https://www.bbc.com/persian/articles/cwyk5d0lje4o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0631\u0626\u06cc\u0633\u200c\u062c\u0645\u0647\u0648\u0631 \u0645\u0648\u0642\u062a \u0648\u0646\u0632\u0648\u0626\u0644\u0627 \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u062a\u0627\u06a9\u0646\u0648\u0646 \u0645\u0631\u06af \u06f5\u06f8\u06f9 \u0646\u0641\u0631 \u062f\u0631 \u062f\u0648 \u0632\u0644\u0632\u0644\u0647 \u0645\u0647\u06cc\u0628 \u0631\u0648\u0632 \u0686\u0647\u0627\u0631\u0634\u0646\u0628\u0647 \u062f\u0631 \u0627\u06cc\u0646 \u06a9\u0634\u0648\u0631 \u062a\u0627\u06cc\u06cc\u062f \u0634\u062f\u0647 \u0627\u0633\u062a\u061b \u06cc\u0639\u0646\u06cc \u0628\u06cc\u0634 \u0627\u0632 \u062f\u0648 \u0628\u0631\u0627\u0628\u0631 \u0628\u0631\u0622\u0648\u0631\u062f\u0647\u0627\u06cc \u0627\u0648\u0644\u06cc\u0647. \u062f\u0644\u0633\u06cc \u0631\u0648\u062f\u0631\u06cc\u06af\u0632 \u0647\u0645\u0686\u0646\u06cc\u0646 \u0622\u0645\u0627\u0631 \u0645\u062c\u0631\u0648\u062d\u0627\u0646 \u0631\u0627 \u06f2\u06f9\u06f8\u06f0 \u0646\u0641\u0631 \u0627\u0639\u0644\u0627\u0645 \u06a9\u0631\u062f. \u062f\u0631 \u0647\u0645\u06cc\u0646 \u062d\u0627\u0644 \u0639\u0645\u2026",
