        {
          "title": "\u0641\u0648\u062a\u0628\u0627\u0644 \u062f\u0631 \u0633\u0627\u06cc\u0647 \u0633\u06cc\u0627\u0633\u062a \u0648 \u0647\u0632\u06cc\u0646\u0647\u200c\u0647\u0627\u06cc \u0647\u0646\u06af\u0641\u062a\u061b \u0627\u0648\u0644\u06cc\u0646 \u062c\u0627\u0645 \u062c\u0647\u0627\u0646\u06cc \u06a9\u0647 \u0645\u06cc\u0632\u0628\u0627\u0646 \u0628\u0627 \u0645\u0647\u0645\u0627\u0646 \u062f\u0631 \u062c\u0646\u06af \u0627\u0633\u062a",
