          "summary": "\u00ab\u0628\u0639\u062f \u0627\u0632 \u062f\u06cc\u200c\u0645\u0627\u0647 \u0628\u0647\u200c\u0646\u062f\u0631\u062a \u067e\u06cc\u0634 \u0645\u06cc\u200c\u0622\u0645\u062f \u0628\u0627 \u06a9\u0633\u06cc \u062d\u0631\u0641 \u0628\u0632\u0646\u0645 \u0648 \u0646\u0634\u0646\u0648\u0645 \u06cc\u06a9\u06cc \u0627\u0632 \u0627\u0642\u0648\u0627\u0645 \u0648 \u0622\u0634\u0646\u0627\u06cc\u0627\u0646\u0634 \u06a9\u0634\u062a\u0647 \u0634\u062f\u0647. \u062f\u0631 \u062c\u0627\u06cc\u06cc \u06a9\u0647 \u0645\u0646 \u0632\u0646\u062f\u06af\u06cc \u0645\u06cc\u200c\u06a9\u0646\u0645 \u0622\u062f\u0645\u200c\u0647\u0627 \u0648\u0627\u0642\u0639\u0627 \u062f\u0631 \u0628\u06cc\u0627\u0646 \u0645\u0633\u0627\u0626\u0644 \u0627\u06cc\u0646\u200c\u0686\u0646\u06cc\u0646\u06cc \u0645\u062d\u0627\u0641\u0638\u0647\u200c\u06a9\u0627\u0631\u0646\u062f \u0648 \u0627\u06cc\u0646 \u0628\u0631\u0627\u06cc\u0645 \u0645\u0639\u0646\u0627\u062f\u0627\u0631 \u0627\u0633\u062a. \u0645\u0646 \u062f\u0631 \u062f\u0627\u0631\u0648\u062e\u0627\u0646\u0647 \u0634\u0628\u0627\u0646\u0647\u200c\u0631\u0648\u0632\u06cc\u2026",
