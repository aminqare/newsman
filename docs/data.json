          "title": "\u067e\u0627\u0644\u0627\u06cc\u0634\u06af\u0627\u0647 \u0646\u0641\u062a \u06a9\u0648\u06cc\u062a \u062f\u0631 \u062d\u0645\u0644\u0647 \u067e\u0647\u067e\u0627\u062f\u06cc \u0622\u0633\u06cc\u0628 \u062f\u06cc\u062f",
