        {
          "title": "\u06cc\u06a9 \u062a\u062c\u0627\u0648\u0632 \u06af\u0631\u0648\u0647\u06cc \u062f\u06cc\u06af\u0631 \u062f\u0631 \u0647\u0646\u062f\u061b \u0686\u0631\u0627 \u0632\u0646\u0627\u0646 \u0647\u0646\u0648\u0632 \u062f\u0631 \u0627\u0645\u0627\u0646 \u0646\u06cc\u0633\u062a\u0646\u062f\u061f",
