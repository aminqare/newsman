          "title": "\ud83d\udd34 \u062f\u06cc\u062f\u0627\u0631 \u062a\u0627\u0631\u06cc\u062e\u06cc \u0646\u0645\u0627\u06cc\u0646\u062f\u06af\u0627\u0646 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0648 \u0644\u0628\u0646\u0627\u0646 \u062f\u0631 \u0648\u0627\u0634\u0646\u06af\u062a\u0646\u061b \u0631\u0626\u06cc\u0633 \u0645\u0648\u0633\u0627\u062f: \u0647\u062f\u0641 \u0645\u0627 \u00ab\u062a\u063a\u06cc\u06cc\u0631 \u0631\u0698\u06cc\u0645\u00bb \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0633\u062a",
