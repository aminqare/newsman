          "summary": "\u0645\u0630\u0627\u06a9\u0631\u0627\u062a \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u062f\u0631 \u0627\u0633\u0644\u0627\u0645\u200c\u0622\u0628\u0627\u062f \u062f\u0631 \u0641\u0636\u0627\u06cc\u06cc \u0627\u0632 \u062a\u0646\u0634 \u0648 \u0628\u06cc\u200c\u0627\u0639\u062a\u0645\u0627\u062f\u06cc \u0622\u063a\u0627\u0632 \u0645\u06cc\u200c\u0634\u0648\u062f \u0648 \u0645\u062c\u0645\u0648\u0639\u0647\u200c\u0627\u06cc \u0627\u0632 \u0628\u0627\u0632\u06cc\u06af\u0631\u0627\u0646 \u0633\u06cc\u0627\u0633\u06cc \u0648 \u062f\u06cc\u067e\u0644\u0645\u0627\u062a\u06cc\u06a9 \u062f\u0631 \u0634\u06a9\u0644\u200c\u062f\u0647\u06cc \u0628\u0647 \u0622\u0646 \u0646\u0642\u0634 \u062f\u0627\u0631\u0646\u062f. \u0627\u0632 \u062c\u0645\u0644\u0647 \u0627\u06cc\u0646 \u0686\u0647\u0631\u0647\u200c\u0647\u0627 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646 \u0628\u0647 \u062c\u06cc\u200c\u062f\u06cc \u0648\u0646\u0633\u060c \u0645\u062d\u0645\u062f\u0628\u0627\u0642\u0631 \u0642\u0627\u0644\u06cc\u0628\u0627\u0641\u060c \u0639\u0628\u0627\u0633 \u0639\u0631\u0627\u0642\u0686\u06cc\u2026",
