        {
          "title": "\u0627\u0633\u062a\u0627\u0631\u0645\u0631: \u0646\u0628\u0627\u06cc\u062f \u0633\u0631\u0646\u0648\u0634\u062a \u0628\u0631\u06cc\u062a\u0627\u0646\u06cc\u0627 \u062f\u0631 \u06af\u0631\u0648 \u062a\u062d\u0648\u0644\u0627\u062a \u062f\u0631 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u062f\u06cc\u06af\u0631 \u0628\u0627\u0634\u062f",
