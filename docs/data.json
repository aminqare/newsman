        {
          "title": "\u0645\u0631\u06cc\u0645 \u0627\u06a9\u0628\u0631\u06cc \u0645\u0646\u0641\u0631\u062f \u067e\u0633 \u0627\u0632 \u06f1\u06f7 \u0633\u0627\u0644 \u0632\u0646\u062f\u0627\u0646 \u0628\u062f\u0648\u0646 \u0645\u0631\u062e\u0635\u06cc\u060c \u0622\u0632\u0627\u062f \u0634\u062f",
