          "title": "\u062e\u0634\u0646 \u0648 \u062e\u0648\u0646\u06cc\u0646 \u0627\u0645\u0627 \u0645\u062d\u0628\u0648\u0628 \u062c\u0648\u0627\u0646\u0627\u0646\u061b \u0627\u0632 \u0628\u0648\u06a9\u0633 \u0628\u062f\u0648\u0646 \u062f\u0633\u062a\u06a9\u0634 \u0686\u0647 \u0645\u06cc\u200c\u062f\u0627\u0646\u06cc\u0645\u061f",
