        {
          "title": "\u00ab\u062a\u0631\u0633\u200c\u0647\u0627\u06cc \u0628\u06cc\u200c\u067e\u0627\u06cc\u0627\u0646\u00bb\u061b \u062d\u062a\u06cc \u0627\u06af\u0631 \u062c\u0646\u06af \u067e\u0627\u06cc\u0627\u0646 \u06cc\u0627\u0628\u062f\u060c \u0622\u0633\u06cc\u0628 \u0628\u0647 \u06a9\u0648\u062f\u06a9\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646 \u0627\u062f\u0627\u0645\u0647 \u062e\u0648\u0627\u0647\u062f \u062f\u0627\u0634\u062a",
          "link": "https://www.bbc.com/persian/articles/cwywgz719n9o?at_medium=RSS&at_campaign=rss",
          "summary": "\u062d\u062a\u06cc \u0628\u0627 \u0648\u062c\u0648\u062f \u0622\u062a\u0634\u200c\u0628\u0633 \u062c\u0646\u06af \u062f\u0631 \u0630\u0647\u0646 \u06a9\u0648\u062f\u06a9\u0627\u0646 \u0627\u06cc\u0631\u0627\u0646\u06cc \u0627\u062f\u0627\u0645\u0647 \u062f\u0627\u0631\u062f. \u062a\u0631\u0633 \u0627\u0632 \u0635\u062f\u0627\u0647\u0627\u06cc \u0639\u0627\u062f\u06cc\u060c \u0646\u0634\u0627\u0646\u0647\u200c\u0647\u0627\u06cc \u0627\u0633\u062a\u0631\u0633 \u067e\u0633 \u0627\u0632 \u0633\u0627\u0646\u062d\u0647 \u0648 \u0627\u0636\u0637\u0631\u0627\u0628 \u06af\u0633\u062a\u0631\u062f\u0647 \u062f\u0631 \u0628\u0633\u06cc\u0627\u0631\u06cc \u0627\u0632 \u06a9\u0648\u062f\u06a9\u0627\u0646 \u062f\u06cc\u062f\u0647 \u0645\u06cc\u200c\u0634\u0648\u062f. \u0628\u0633\u062a\u0647 \u0634\u062f\u0646 \u0645\u062f\u0627\u0631\u0633\u060c \u0646\u0627\u0627\u0645\u0646\u06cc \u0648 \u0641\u0634\u0627\u0631 \u062e\u0627\u0646\u0648\u0627\u062f\u0647\u200c\u0647\u0627 \u062f\u0646\u06cc\u0627\u06cc \u0622\u0646\u200c\u0647\u0627 \u0631\u0627 \u0645\u062d\u062f\u0648\u062f \u06a9\u0631\u062f\u0647\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0648\u06cc\u06a9\u062a\u0648\u0631 \u0627\u0648\u0631\u0628\u0627\u0646 \u0646\u062e\u0633\u062a\u200c\u0648\u0632\u06cc\u0631 \u0645\u062c\u0627\u0631\u0633\u062a\u0627\u0646 \u06a9\u0647 \u067e\u0633 \u0627\u0632 \u06f1\u06f6 \u0633\u0627\u0644 \u0628\u0631\u0627\u06cc \u0645\u0627\u0646\u062f\u0646 \u062f\u0631 \u0642\u062f\u0631\u062a \u0645\u06cc\u200c\u062c\u0646\u06af\u062f",
          "link": "https://www.bbc.com/persian/articles/cly01ddk03ko?at_medium=RSS&at_campaign=rss",
          "summary": "\u0647\u06cc\u0686 \u0631\u0647\u0628\u0631 \u062f\u0631 \u0642\u062f\u0631\u062a \u062f\u0631 \u0627\u062a\u062d\u0627\u062f\u06cc\u0647 \u0627\u0631\u0648\u067e\u0627 \u0628\u0647 \u0627\u0646\u062f\u0627\u0632\u0647 \u0648\u06cc\u06a9\u062a\u0648\u0631 \u0627\u0648\u0631\u0628\u0627\u0646 \u06a9\u0634\u0648\u0631\u0634 \u0631\u0627 \u0631\u0647\u0628\u0631\u06cc \u0646\u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0627\u0645\u0627 \u067e\u0633 \u0627\u0632 \u06f1\u06f6 \u0633\u0627\u0644\u060c \u0627\u0648 \u062f\u0631 \u0627\u0646\u062a\u062e\u0627\u0628\u0627\u062a \u06f1\u06f2 \u0622\u0648\u0631\u06cc\u0644 \u0628\u0627 \u062c\u062f\u06cc\u200c\u062a\u0631\u06cc\u0646 \u0686\u0627\u0644\u0634 \u062e\u0648\u062f \u0631\u0648\u0628\u0647\u200c\u0631\u0648 \u0627\u0633\u062a\u061b \u062c\u0627\u06cc\u06cc \u06a9\u0647 \u0628\u06cc\u0634\u062a\u0631 \u0646\u0638\u0631\u0633\u0646\u062c\u06cc\u200c\u0647\u0627 \u0646\u0634\u0627\u0646 \u0645\u06cc\u200c\u062f\u0647\u0646\u062f \u0627\u0648 \u062f\u0631 \u0645\u0633\u06cc\u0631 \u0634\u06a9\u0633\u062a \u0627\u0632 \u0633\u0648\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u06a9\u0634\u0648\u0631 \u0646\u0641\u062a\u200c\u062e\u06cc\u0632\u06cc \u06a9\u0647 \u0627\u0632 \u0628\u062d\u0631\u0627\u0646 \u0627\u0646\u0631\u0698\u06cc \u0646\u0627\u0634\u06cc \u0627\u0632 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0633\u0648\u062f \u0646\u0645\u06cc\u200c\u0628\u0631\u062f",
          "link": "https://www.bbc.com/persian/articles/cdrmz5k8ex5o?at_medium=RSS&at_campaign=rss",
          "summary": "\u0628\u0627 \u0648\u062c\u0648\u062f \u0627\u0641\u0632\u0627\u06cc\u0634 \u0642\u06cc\u0645\u062a \u0646\u0641\u062a \u0628\u0647\u200c \u062f\u0644\u06cc\u0644 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0627\u062e\u062a\u0644\u0627\u0644 \u062f\u0631 \u062a\u0646\u06af\u0647 \u0647\u0631\u0645\u0632\u060c \u0644\u06cc\u0628\u06cc \u0646\u062a\u0648\u0627\u0646\u0633\u062a\u0647 \u0627\u0632 \u0627\u06cc\u0646 \u0641\u0631\u0635\u062a \u0628\u0647\u0631\u0647 \u0628\u0628\u0631\u062f. \u0686\u0646\u062f\u062f\u0633\u062a\u06af\u06cc \u0633\u06cc\u0627\u0633\u06cc\u060c \u0641\u0633\u0627\u062f\u060c \u0646\u0627\u0627\u0645\u0646\u06cc \u0648 \u0632\u06cc\u0631\u0633\u0627\u062e\u062a\u200c\u0647\u0627\u06cc \u0641\u0631\u0633\u0648\u062f\u0647\u060c \u0638\u0631\u0641\u06cc\u062a \u062a\u0648\u0644\u06cc\u062f \u0648 \u0635\u0627\u062f\u0631\u0627\u062a \u0631\u0627 \u0645\u062d\u062f\u0648\u062f \u06a9\u0631\u062f\u0647\u200c\u0627\u0646\u062f. \u062f\u0631\u06af\u06cc\u0631\u06cc \u0628\u0631 \u0633\u0631 \u06a9\u0646\u062a\u0631\u0644 \u0646\u0647\u0627\u062f\u0647\u0627\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u0622\u06cc\u0627 \u0646\u0641\u062a \u0648\u0646\u0632\u0648\u0626\u0644\u0627 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u062f \u067e\u06cc\u0627\u0645\u062f\u0647\u0627\u06cc \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646 \u0631\u0627 \u062f\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0645\u0647\u0627\u0631 \u06a9\u0646\u062f\u061f",
