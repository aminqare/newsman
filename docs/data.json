          "title": "\ud83d\udd34 \u0648\u0627\u06a9\u0646\u0634 \u00ab\u0642\u062f\u0631\u062a\u0645\u0646\u062f\u00bb \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0628\u0647 \u062d\u0645\u0644\u0647 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0628\u0647 \u06cc\u06a9 \u06a9\u0634\u062a\u06cc \u062a\u062c\u0627\u0631\u06cc\u061b \u062a\u0627\u0633\u06cc\u0633\u0627\u062a \u0646\u0638\u0627\u0645\u06cc \u062f\u0631 \u0633\u0648\u0627\u062d\u0644 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0645\u0628\u0627\u0631\u0627\u0646 \u0634\u062f",
