        {
          "title": "\u062a\u0627\u062b\u06cc\u0631 \u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0628\u0631 \u062a\u062c\u0627\u0631\u062a \u0648 \u0627\u0642\u062a\u0635\u0627\u062f \u0627\u06cc\u0631\u0627\u0646 \u0686\u06cc\u0633\u062a\u061f",
