        {
          "title": "\u0647\u0634\u062f\u0627\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0628\u0647 \u0627\u062f\u0627\u0645\u0647 \u0645\u062d\u0627\u0635\u0631\u0647 \u062f\u0631\u06cc\u0627\u06cc\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627: \u0627\u062c\u0627\u0632\u0647 \u0646\u0645\u06cc\u200c\u062f\u0647\u06cc\u0645 \u0635\u0627\u062f\u0631\u0627\u062a \u0648 \u0648\u0627\u0631\u062f\u0627\u062a \u062f\u0631 \u062e\u0644\u06cc\u062c \u0641\u0627\u0631\u0633\u060c \u062f\u0631\u06cc\u0627\u06cc \u0639\u0645\u0627\u0646 \u0648 \u062f\u0631\u06cc\u0627\u06cc \u0633\u0631\u062e \u0627\u0646\u062c\u0627\u0645 \u0634\u0648\u062f",
