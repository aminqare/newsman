          "title": "\ud83d\udd34 \u062d\u0645\u0644\u0647 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0645\u0631\u0627\u06a9\u0632 \u062a\u0648\u0644\u06cc\u062f \u0645\u0648\u0634\u06a9\u200c\u0647\u0627\u06cc \u0628\u0627\u0644\u0633\u062a\u06cc\u06a9 \u0633\u067e\u0627\u0647 \u062f\u0631 \u062a\u0647\u0631\u0627\u0646\u061b \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u0632 \u062d\u0645\u0644\u0647 \u062f\u0648\u0628\u0627\u0631\u0647 \u0628\u0647 \u062a\u0623\u0633\u06cc\u0633\u0627\u062a \u0646\u0637\u0646\u0632 \u062e\u0628\u0631 \u062f\u0627\u062f",
          "link": "https://ir.voanews.com/a/8118506.html",
          "summary": "\u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc \u0645\u06cc\u200c\u06af\u0648\u06cc\u062f \u06a9\u0647 \u062f\u0631 \u0627\u06cc\u0646 \u0631\u0648\u0632 \u062a\u0623\u0633\u06cc\u0633\u0627\u062a \u063a\u0646\u06cc\u200c\u0633\u0627\u0632\u06cc \u0646\u0637\u0646\u0632 \u0628\u0627\u0631 \u062f\u06cc\u06af\u0631 \u0647\u062f\u0641 \u062d\u0645\u0644\u0647 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a\u0647 \u0627\u0633\u062a. \u0645\u0648\u0636\u0648\u0639\u06cc \u06a9\u0647 \u0647\u0646\u0648\u0632 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0628\u0647 \u0622\u0646 \u0648\u0627\u06a9\u0646\u0634 \u0646\u0634\u0627\u0646 \u0646\u062f\u0627\u062f\u0647\u200c\u0627\u0646\u062f. \u0627\u0632 \u062f\u06cc\u06af\u0631 \u0633\u0648 \u0628\u0627 \u06af\u0630\u0634\u062a \u0628\u06cc\u0634 \u0627\u0632 \u06f5\u06f0\u06f0 \u0633\u0627\u0639\u062a \u0627\u0632 \u0642\u0637\u0639 \u0633\u0631\u0627\u0633\u0631\u06cc \u0627\u06cc\u0646\u062a\u0631\u0646\u062a\u060c \u062e\u0627\u0645\u0648\u0634\u06cc \u062f\u06cc\u2026",
          "source": "\u062e\u0628\u0631 \u0627\u0648\u0644 - \u0635\u062f\u0627\u06cc \u0622\u0645\u0631\u06cc\u06a9\u0627",
