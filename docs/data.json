          "title": "\u0627\u0646\u062a\u0642\u0627\u0644 \u0642\u062f\u0631\u062a \u0628\u0647 \u0645\u062c\u062a\u0628\u06cc \u062e\u0627\u0645\u0646\u0647\u200c\u0627\u06cc\u061b \u062a\u062f\u0627\u0648\u0645 \u06cc\u0627 \u062a\u063a\u06cc\u06cc\u0631 \u062f\u0631 \u062c\u0645\u0647\u0648\u0631\u06cc \u0627\u0633\u0644\u0627\u0645\u06cc\u061f",
