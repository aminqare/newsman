        {
          "title": "\u0646\u0631\u06af\u0633 \u0631\u0634\u06cc\u062f\u06cc \u0628\u0627\u0632\u06cc\u06af\u0631 \u0646\u0642\u0634 \u0646\u0627\u0632\u0646\u06cc\u0646 \u0632\u0627\u063a\u0631\u06cc-\u0631\u062a\u06a9\u0644\u06cc\u0641\u060c \u0628\u0641\u062a\u0627 \u0646\u0642\u0634 \u0627\u0648\u0644 \u0628\u0647\u062a\u0631\u06cc\u0646 \u0628\u0627\u0632\u06cc\u06af\u0631 \u0632\u0646 \u0631\u0627 \u0627\u0632 \u0622\u0646 \u062e\u0648\u062f \u06a9\u0631\u062f",
