        {
          "title": "\u0639\u0631\u0641\u0627\u0646 \u06a9\u06cc\u0627\u0646\u06cc\u060c \u0627\u0632 \u0628\u0627\u0632\u062f\u0627\u0634\u062a\u200c\u0634\u062f\u06af\u0627\u0646 \u0627\u0639\u062a\u0631\u0627\u0636\u0627\u062a \u062f\u06cc \u0645\u0627\u0647 \u062f\u0631 \u0627\u06cc\u0631\u0627\u0646 \u0627\u0639\u062f\u0627\u0645 \u0634\u062f",
          "link": "https://www.bbc.com/persian/articles/c4gjn49q4nlo?at_medium=RSS&at_campaign=rss",
          "summary": "\u0642\u0648\u0647 \u0642\u0636\u0627\u0626\u06cc\u0647 \u0627\u0632 \u0627\u0639\u062f\u0627\u0645 \u0639\u0631\u0641\u0627\u0646 \u06a9\u06cc\u0627\u0646\u06cc\u060c \u0627\u0632 \u0628\u0627\u0632\u062f\u0627\u0634\u062a \u0634\u062f\u06af\u0627\u0646 \u0627\u0639\u062a\u0631\u0627\u0636\u0627\u062a \u062f\u06cc \u0645\u0627\u0647 \u062f\u0631 \u0627\u0635\u0641\u0647\u0627\u0646 \u062e\u0628\u0631 \u062f\u0627\u062f\u0647 \u0627\u0633\u062a. \u0642\u0648\u0647 \u0642\u0636\u0627\u0626\u06cc\u0647 \u0627\u062a\u0647\u0627\u0645\u0627\u062a \u0639\u0631\u0641\u0627\u0646 \u06a9\u06cc\u0627\u0646\u06cc \u0631\u0627 \u00ab\u062a\u062e\u0631\u06cc\u0628 \u0648 \u062a\u062d\u0631\u06cc\u0642 \u0627\u0645\u0648\u0627\u0644 \u0639\u0645\u0648\u0645\u06cc \u0648 \u062e\u0635\u0648\u0635\u06cc\u060c \u0627\u06cc\u062c\u0627\u062f \u0631\u0639\u0628 \u0648 \u0648\u062d\u0634\u062a \u062f\u0631 \u0633\u0637\u062d \u0634\u0647\u0631\u060c \u062d\u0645\u0644 \u0633\u0644\u0627\u062d \u0633\u0631\u062f \u0648 \u062d\u0645\u0644\u0647 \u0628\u0647 \u0645\u0627\u0645\u0648\u0631\u0627\u0646\u2026",
          "source": "BBC &#8238;\u0641\u0627\u0631\u0633\u06cc",
          "source_url": "https://feeds.bbci.co.uk/persian/rss.xml"
        },
        {
          "title": "\u067e\u0634\u062a\u200c\u067e\u0631\u062f\u0647 \u0628\u0627\u0632\u067e\u0631\u062f\u0627\u062e\u062a \u0648\u0627\u0645 \u062f\u0631 \u0633\u0627\u06cc\u0647 \u062c\u0646\u06af \u0627\u06cc\u0631\u0627\u0646\u061b \u0622\u06cc\u0627 \u0631\u0648\u0627\u0628\u0637 \u0627\u0645\u0627\u0631\u0627\u062a \u0628\u0627 \u067e\u0627\u06a9\u0633\u062a\u0627\u0646 \u062f\u0686\u0627\u0631 \u062a\u0646\u0634 \u0634\u062f\u0647 \u0627\u0633\u062a\u061f",
